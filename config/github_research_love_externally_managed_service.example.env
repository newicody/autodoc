# Fabrique de bundle consommée par le CLI OpenRC r16-r57.
AUTODOC_GITHUB_RESEARCH_OPENRC_SERVICE_FACTORY="context.github_research_love_externally_managed_installed_composition_0287:build_github_research_love_openrc_service_bundle"

# Doit être fournie par l'unité de liaison installée suivante.
# Aucun fallback, fake ou backend en mémoire n'est accepté.
AUTODOC_GITHUB_RESEARCH_EXTERNALLY_MANAGED_COMPONENT_FACTORY=""

AUTODOC_GITHUB_RESEARCH_SERVICE_REF="service:autodoc-github-research-scheduler"
AUTODOC_GITHUB_RESEARCH_SERVICE_ACTOR_REF="actor:openrc-autodoc-scheduler"
AUTODOC_GITHUB_RESEARCH_SERVICE_CAUSE_REF="cause:openrc-service-tick"
AUTODOC_GITHUB_RESEARCH_POLL_INTERVAL_SECONDS="1.0"
AUTODOC_GITHUB_RESEARCH_MAX_TASK_STEPS="16"
AUTODOC_GITHUB_RESEARCH_STARTUP_YIELD_LIMIT="128"
