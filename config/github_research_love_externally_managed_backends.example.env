# Portes explicites du processus OpenRC. Elles autorisent les adaptateurs réels,
# mais chaque commande reste soumise aux politiques typées du Scheduler.
AUTODOC_QDRANT_POINT_WRITE_ALLOWED="true"
AUTODOC_QDRANT_SEARCH_ALLOWED="true"
AUTODOC_GITHUB_RESEARCH_SERVICE_POLICY_DECISION_ID="policy:openrc-github-research-scheduler"

# Le mot de passe PostgreSQL et l'éventuelle clé Qdrant restent dans
# /etc/autodoc/autodoc.env, mode 0600, jamais dans le dépôt.
