digraph specialist_capability_growth_durable_history_0285 {
  rankdir=LR;
  node [shape=box];

  proposal [label="r2 proposal + evidence"];
  revision [label="r3 candidate revision"];
  gate [label="r4 operator gate"];
  decision [label="approved decision"];
  command [label="r5 append command"];
  port [label="history port\nSQL authority contract"];
  test_adapter [label="deterministic test adapter\ndurable=false"];
  sql [label="future real SQL adapter\nappend-only authority", style=dashed];
  snapshot [label="history snapshot\ncomplete revisions + digests"];
  qdrant [label="Qdrant projection only", style=dashed];
  scheduler [label="existing Scheduler\nselection remains external", style=dashed];

  proposal -> gate;
  revision -> gate;
  gate -> decision;
  decision -> command;
  revision -> command;
  command -> port;
  port -> test_adapter [label="tests"];
  port -> sql [label="later adapter"];
  test_adapter -> snapshot;
  sql -> snapshot;
  snapshot -> qdrant [label="later sql_ref projection"];
  snapshot -> scheduler [label="r6 explicit selection"];
}
