digraph native_love_laboratory_r10 {
  rankdir=LR;
  node [shape=box];

  scheduler [label="Existing Scheduler"];
  dispatcher [label="Existing Dispatcher"];
  handler [label="Native love visit handler"];
  provider [label="NativeLoveLaboratoryProvider"];
  resolver [label="Injected input resolver"];
  specialist [label="Love concept/affect specialist\nstdlib_lexical_v1"];
  result [label="LaboratoryVisitResult"];

  scheduler -> dispatcher;
  dispatcher -> handler;
  handler -> provider;
  resolver -> provider;
  provider -> specialist;
  specialist -> result;
  result -> scheduler [label="reply"];
}
