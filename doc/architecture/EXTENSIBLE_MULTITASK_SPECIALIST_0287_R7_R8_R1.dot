digraph extensible_multitask_specialist_0287_r7_r8_r1 {
    rankdir=LR;
    node [shape=box];

    descriptor [label="PortableSpecialistDescriptor\nidentity + capabilities"];
    types [label="SpecialistTaskType[]\nversioned extensions"];
    definition [label="ExtensibleMultitaskSpecialistDefinition"];
    scheduler [label="existing Scheduler\nauthority"];
    plan [label="SpecialistTaskPlan\nacyclic dependency graph"];
    task_a [label="Task A\ncapability X"];
    task_b [label="Task B\ncapability Y"];
    laboratory [label="concrete laboratory\nfuture handler runtime"];
    backend [label="existing backend ref\nOpenVINO or deterministic"];
    results [label="SpecialistTaskResult[]"];
    liaison [label="existing liaison synthesis\nlater phase"];

    descriptor -> definition;
    types -> definition;
    definition -> scheduler [label="declared to"];
    scheduler -> plan [label="authorizes"];
    plan -> task_a;
    plan -> task_b;
    task_a -> task_b [label="optional dependency"];
    scheduler -> laboratory [label="submits ready task"];
    laboratory -> backend [label="uses binding"];
    laboratory -> results;
    results -> scheduler [label="returns"];
    results -> liaison [label="after evidence acceptance"];
}
