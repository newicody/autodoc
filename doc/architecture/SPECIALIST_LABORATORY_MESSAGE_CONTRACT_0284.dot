digraph specialist_laboratory_message_contract_0284 {
    rankdir=LR;
    node [shape=box];

    descriptor [label="PortableSpecialistDescriptor\nstable specialist_ref"];
    visit_request [label="LaboratoryVisitRequest"];
    demand_frame [label="SpecialistDemandFrame\nexisting /dev/shm frame"];
    demand_message [label="SpecialistLaboratoryMessage\nkind=demand"];
    opinion_message [label="SpecialistLaboratoryMessage\nkind=opinion"];
