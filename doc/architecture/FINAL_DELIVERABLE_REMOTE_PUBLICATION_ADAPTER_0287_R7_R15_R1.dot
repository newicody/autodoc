digraph final_deliverable_remote_publication_0287_r7_r15_r1 {
    rankdir=LR;
    graph [label="0287-r7-r15-r1 final deliverable remote publication", labelloc=t];
    node [shape=box];

    plan [label="r13 immutable\npublication plan"];
    parser [label="plan parser\nsrc/context"];
    issue_read [label="Issue comments\nread"];
    project_read [label="ProjectV2 field\nread"];
    preflight [label="create / update / replay\ncollision guard"];
    preview [label="preview\n(default)"];
    gates [label="operator approval\n3 locks\nexact plan_digest"];
    issue_write [label="Issue comment\ncreate if required"];
    project_write [label="ProjectV2 field\nupdate if required"];
    readback [label="Issue + ProjectV2\nremote readback"];
    verifier [label="r13 exact\nreadback verifier"];
    result [label="confirmed / replay /\nblocked / collision / partial"];
    gh [label="gh api\nREST + GraphQL", shape=component];

    plan -> parser -> preflight;
    issue_read -> preflight;
    project_read -> preflight;
    preflight -> preview [label="no execute"];
    preflight -> gates [label="execute"];
    gates -> issue_write -> project_write -> readback -> verifier -> result;
    preview -> result;

    gh -> issue_read;
    gh -> project_read;
    issue_write -> gh;
    project_write -> gh;
    gh -> readback;
}
