digraph missing_runtime_configuration_test_isolation {
  rankdir=LR;
  operator_var [label="operator .var config", shape=folder];
  production [label="production default lookup", shape=box];
  temp_empty [label="explicit empty temp INI", shape=note];
  negative_test [label="missing-runtime negative test", shape=box];
  expected_error [label="operator-facing error", shape=box];
  operator_var -> production;
  temp_empty -> negative_test -> expected_error;
}
