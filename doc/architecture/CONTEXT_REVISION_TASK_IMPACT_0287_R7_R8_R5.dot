digraph context_revision_task_impact_0287_r7_r8_r5 {
  rankdir=LR;
  sql_old [label="SQL context revision rN\nauthority"];
  sql_new [label="SQL accepted revision rN+1\nauthority"];
  change [label="ContextRevisionChangeSet\nreference-only"];
  binding [label="TaskContextBinding\npolicy + watched refs"];
  assess [label="TaskContextImpactAssessment\nno decision"];
  decision [label="SchedulerContextImpactDecision\nnot executed"];
  later [label="r8-r6 execution adapter\nScheduler + EventBus + authorized transport"];
  sql_old -> change;
  sql_new -> change;
  change -> assess;
  binding -> assess;
  assess -> decision;
  decision -> later [style=dashed];
}
