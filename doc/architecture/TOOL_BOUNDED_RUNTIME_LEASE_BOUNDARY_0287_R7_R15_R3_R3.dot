digraph tool_bounded_runtime_lease_0287_r7_r15_r3_r3 {
  rankdir=LR;
  node [shape=box];

  factory [label="Runtime factory\n(same CLI process)"];
  lease [label="ImportedActionsRuntimeLease\nprocess-local owner"];
  ports [label="Validated runtime ports\nScheduler / SQL / E5 / Qdrant"];
  r14 [label="r14 execution"];
  scheduler [label="Canonical Scheduler\ntool-bounded lifecycle"];
  hooks [label="Close hooks\nreverse order / exact once"];
  receipt [label="Lease receipt\nclosed or replay"];
  preview [label="Preview JSON\n_r15_runtime_lease"];
  external [label="Externally managed runtime\nno CLI close", shape=note];

  factory -> lease;
  lease -> ports;
  ports -> r14;
  scheduler -> r14;
  r14 -> scheduler [label="shutdown"];
  scheduler -> hooks;
  hooks -> receipt;
  receipt -> preview;
  ports -> external [style=dashed, label="external lifecycle"];
}
