digraph native_love_r11 {
  rankdir=LR;
  node [shape=box];

  scheduler [label="Existing Scheduler"];
  dispatcher [label="Existing Dispatcher"];
  provider [label="Collaborative native provider"];
  first [label="Concept/affect analyst"];
  first_artifact [label="Digest-backed first artifact"];
  preparation [label="Second visit preparation\n(no execution)"];
  second [label="Relational-dynamics analyst"];
  conversation [label="Closed v2 conversation\n2 visits / 4 messages"];
  liaison [label="Liaison synthesis\nr12", style=dashed];

  scheduler -> dispatcher -> provider -> first;
  first -> first_artifact -> preparation;
  preparation -> scheduler [label="new authorized submission"];
  provider -> second;
  second -> conversation;
  conversation -> liaison [style=dashed];
}
