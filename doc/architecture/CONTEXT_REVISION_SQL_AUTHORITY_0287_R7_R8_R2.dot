digraph context_revision_sql_authority_0287_r7_r8_r2 {
    rankdir=LR;
    node [shape=box];

    legacy [label="SqlContextRecord v1\nunchanged"];
    bridge [label="explicit bridge"];
    sql [label="SQL authority\nobjects + revisions + relations"];
    zfs [label="ZFS/content store\nheavy bytes"];
    projection [label="projection metadata\ndigest + model + point ref"];
    qdrant [label="Qdrant\nvectors + recall"];
    scheduler [label="Scheduler\nimpact decisions"];
    proxy [label="ControlProxy\ntransport routes only"];

    legacy -> bridge -> sql;
    zfs -> sql [label="storage_ref + digest"];
    sql -> projection;
    projection -> qdrant [label="reconstructible"];
    sql -> scheduler [label="context revision refs"];
    scheduler -> proxy [label="authorized route action"];
    proxy -> sql [style=dashed, label="no semantic authority"];
}
