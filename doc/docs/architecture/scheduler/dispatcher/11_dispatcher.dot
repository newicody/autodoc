digraph Dispatcher {
    // ROADMAP_ID: scheduler.dispatcher
    // ROADMAP_PARENT: scheduler/10_scheduler.dot

    rankdir=TB;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // ROADMAP_NOTE[phase2_4]:
    // Sous-graphe ajouté pour fermer la navigation descendante depuis Scheduler.
    // Dispatcher reste un routeur kernel : il publie une copie observable vers
    // EventBus, appelle le handler enregistré et résout explicitement les
    // événements sans handler pour éviter tout blocage de ComponentProxy.

    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    Queue [label="PriorityQueue", fillcolor="#ede7f6", color="#512da8", URL="../priority_queue/13_priority_queue.svg"];
    Dispatcher [label="Dispatcher", fillcolor="#ede7f6", color="#512da8"];
    HandlerTable [label="handlers: EventType -> callable", fillcolor="#eceff1", color="#455a64"];
    Handler [label="registered handler", fillcolor="#e8f5e9", color="#388e3c"];
    NoHandler [label="no handler\nexplicit no-op result", fillcolor="#ffebee", color="#c62828"];
    RequestReply [label="Request.reply", fillcolor="#fff3e0", color="#ef6c00"];
    EventBus [label="EventBus\nobservation only", fillcolor="#f5f5f5", color="#666666", URL="../event_bus/12_event_bus.svg"];
    Telemetry [label="KernelTelemetry\ndispatch timing", fillcolor="#f5f5f5", color="#666666", URL="../../observability/70_observability.svg"];

    Scheduler -> Queue [label="get next event"];
    Queue -> Dispatcher [label="dispatch(event)"];
    Dispatcher -> EventBus [style=dashed, label="publish copy"];
    Dispatcher -> HandlerTable [label="lookup"];
    HandlerTable -> Handler [label="found"];
    HandlerTable -> NoHandler [label="missing"];
    Handler -> RequestReply [style=dashed, label="set result"];
    NoHandler -> RequestReply [style=dashed, label="set explicit result"];
    Dispatcher -> Telemetry [style=dashed, label="record duration"];

    Nav_Global [label="Global", shape=plaintext, URL="../../00_global.svg"];
    Nav_Up [label="Up: Scheduler", shape=plaintext, URL="../10_scheduler.svg"];
    Nav_EventBus [label="EventBus", shape=plaintext, URL="../event_bus/12_event_bus.svg"];

    { rank=sink; Nav_Global; Nav_Up; Nav_EventBus; }
}
