digraph EventBus {
    // ROADMAP_ID: scheduler.event_bus
    // ROADMAP_PARENT: scheduler/10_scheduler.dot

    rankdir=LR;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // ROADMAP_NOTE[phase2_4]:
    // Sous-graphe ajouté pour distinguer clairement observation et commande.
    // EventBus ne commande aucun composant : il diffuse seulement des copies
    // vers logger, telemetry, recorder, tracer, dashboard et futurs watchers.

    Dispatcher [fillcolor="#ede7f6", color="#512da8", URL="../dispatcher/11_dispatcher.svg"];
    PolicyEngine [label="PolicyEngine\nPOLICY_DENIED", fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    InferenceHandler [label="InferenceRequestHandler\nINFERENCE_RESULT", fillcolor="#fffde7", color="#f9a825", URL="../../inference/40_inference.svg"];
    ContextHandler [label="ContextRequestHandler\nCONTEXT_REPLY", fillcolor="#fff3e0", color="#ef6c00", URL="../../context/20_context.svg"];
    EventBus [label="EventBus\nobservation only", fillcolor="#f5f5f5", color="#666666"];
    Logger [fillcolor="#f5f5f5", color="#666666", URL="../../observability/70_observability.svg"];
    Metrics [fillcolor="#f5f5f5", color="#666666", URL="../../observability/70_observability.svg"];
    EventRecorder [fillcolor="#f5f5f5", color="#666666", URL="../../observability/70_observability.svg"];
    Tracer [fillcolor="#f5f5f5", color="#666666", URL="../../observability/70_observability.svg"];
    Dashboard [fillcolor="#f5f5f5", color="#666666", URL="../../observability/70_observability.svg"];

    Dispatcher -> EventBus [style=dashed, label="event copy"];
    PolicyEngine -> EventBus [style=dashed, label="denied copy"];
    InferenceHandler -> EventBus [style=dashed, label="result copy"];
    ContextHandler -> EventBus [style=dashed, label="context copy"];
    EventBus -> Logger;
    EventBus -> Metrics;
    EventBus -> EventRecorder;
    EventBus -> Tracer;
    EventBus -> Dashboard;

    Nav_Global [label="Global", shape=plaintext, URL="../../00_global.svg"];
    Nav_Up [label="Up: Scheduler", shape=plaintext, URL="../10_scheduler.svg"];
    Nav_Dispatcher [label="Dispatcher", shape=plaintext, URL="../dispatcher/11_dispatcher.svg"];
    Nav_Observability [label="Observability", shape=plaintext, URL="../../observability/70_observability.svg"];

    { rank=sink; Nav_Global; Nav_Up; Nav_Dispatcher; Nav_Observability; }
}
