digraph EventBusLegacy {
    // ROADMAP_ID: scheduler.event_bus.legacy
    // ROADMAP_NOTE[phase2_4c]:
    // Ancienne entrée plate conservée comme redirection lisible. Le détail réel
    // de l'EventBus vit dans scheduler/event_bus/12_event_bus.dot.

    rankdir=LR;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="10_scheduler.svg"];
    EventBusDetail [label="EventBus\nview detail", fillcolor="#ede7f6", color="#512da8", URL="event_bus/12_event_bus.svg"];

    Scheduler -> EventBusDetail [label="descend"];

    Nav_Scheduler [label="Up: Scheduler", shape=plaintext, URL="10_scheduler.svg"];
    Nav_Detail [label="Detail: EventBus", shape=plaintext, URL="event_bus/12_event_bus.svg"];

    { rank=sink; Nav_Scheduler; Nav_Detail; }
}
