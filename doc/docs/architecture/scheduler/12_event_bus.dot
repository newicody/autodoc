digraph EventBus {
    rankdir=LR;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    EventBus [fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    Dispatcher [fillcolor="#ede7f6", color="#512da8", URL="../dispatcher/11_dispatcher.svg"];

    subgraph cluster_services {
        label="Services";
        node [fillcolor="#e1f5fe", color="#0288d1"];
        SQLiteProd [URL="../../services/30_services.svg"];
        SQLiteMaint[URL="../../services/30_services.svg"];
        Qdrant  [URL="../../services/30_services.svg"];
        Cache   [URL="../../services/30_services.svg"];
        Knowledge[URL="../../services/30_services.svg"];
        Router  [URL="../../services/30_services.svg"];
    }

    subgraph cluster_observability {
        label="Observability";
        node [fillcolor="#f5f5f5", color="#666666"];
        Logger [URL="../../observability/70_observability.svg"];
        Metrics [URL="../../observability/70_observability.svg"];
        Replay [URL="../../observability/70_observability.svg"];
        Dashboard [URL="../../observability/70_observability.svg"];
    }

    // Edges
    Dispatcher -> EventBus [label="publish"]; // Dispatcher publie

    EventBus -> SQLiteProd;   // Distribution
    EventBus -> SQLiteMaint;
    EventBus -> Qdrant;
    EventBus -> Cache;
    EventBus -> Knowledge;
    EventBus -> Router;
    EventBus -> Logger;
    EventBus -> Metrics;
    EventBus -> Replay;

    Metrics -> Dashboard [style=dashed]; // Métriques → Dashboard

    // Navigation
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="../10_scheduler.svg"];
    Nav_Dispatcher [label="Dispatcher", shape=plaintext, URL="../dispatcher/11_dispatcher.svg"];
    { rank=sink; Nav_Scheduler; Nav_Dispatcher; }
}
