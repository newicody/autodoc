digraph ComponentProxy {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    subgraph cluster_proxy {
        label="Component Proxy";
        color="#512da8"; bgcolor="#ede7f6";
        node [fillcolor="#ede7f6", color="#512da8"];
        Registry [URL="../10_scheduler.svg"];
        Proxy [URL="../10_scheduler.svg"];
        Scheduler [URL="../10_scheduler.svg"];
    }

    subgraph cluster_experts {
        label="Experts";
        node [fillcolor="#e8f5e9", color="#388e3c"];
        Meta   [URL="../../experts/40_experts.svg"];
        Python [URL="../../experts/40_experts.svg"];
        C      [URL="../../experts/40_experts.svg"];
        KiCad  [URL="../../experts/40_experts.svg"];
        FreeCAD[URL="../../experts/40_experts.svg"];
        Web    [URL="../../experts/40_experts.svg"];
        SVG    [URL="../../experts/40_experts.svg"];
    }

    subgraph cluster_validation {
        label="Validation";
        node [fillcolor="#f3e5f5", color="#7b1fa2"];
        Compiler [URL="../../validation/50_validation.svg"];
        Tests    [URL="../../validation/50_validation.svg"];
        Validator[URL="../../validation/50_validation.svg"];
        Confidence[URL="../../validation/50_validation.svg"];
        Conflict [URL="../../validation/50_validation.svg"];
        Version  [URL="../../validation/50_validation.svg"];
    }

    GET [fillcolor="#fff3e0", color="#ef6c00", URL="../../context/20_context.svg"];

    // Edges
    Registry -> Proxy [label="wrap"];           // Registry wrap
    Proxy -> Scheduler [label="yield Event"];   // Proxy → Scheduler
    Proxy -> Meta;      // Délégation
    Proxy -> Python;
    Proxy -> C;
    Proxy -> KiCad;
    Proxy -> FreeCAD;
    Proxy -> Web;
    Proxy -> SVG;
    Proxy -> Compiler [label="soumet"];         // Soumission validation
    Compiler -> Tests;
    Tests -> Validator;
    Validator -> Confidence;
    Confidence -> Conflict;
    Conflict -> Version;
    GET -> Proxy [label="context()"];           // Contexte

    // Navigation
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="../10_scheduler.svg"];
    Nav_Context [label="Context", shape=plaintext, URL="../../context/20_context.svg"];
    { rank=sink; Nav_Scheduler; Nav_Context; }
}
