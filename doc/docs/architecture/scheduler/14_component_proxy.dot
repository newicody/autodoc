digraph ComponentProxyLegacy {
    // ROADMAP_ID: scheduler.component_proxy.legacy
    // ROADMAP_NOTE[phase2_4c]:
    // Ancienne entrée plate conservée comme redirection lisible. Le détail réel
    // de ComponentProxy vit dans scheduler/component_proxy/14_component_proxy.dot.

    rankdir=LR;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="10_scheduler.svg"];
    ComponentProxyDetail [label="ComponentProxy\nview detail", fillcolor="#ede7f6", color="#512da8", URL="component_proxy/14_component_proxy.svg"];

    Scheduler -> ComponentProxyDetail [label="descend"];

    Nav_Scheduler [label="Up: Scheduler", shape=plaintext, URL="10_scheduler.svg"];
    Nav_Detail [label="Detail: ComponentProxy", shape=plaintext, URL="component_proxy/14_component_proxy.svg"];

    { rank=sink; Nav_Scheduler; Nav_Detail; }
}
