digraph ComponentProxy {
    // ROADMAP_ID: scheduler.component_proxy
    // ROADMAP_PARENT: scheduler/10_scheduler.dot

    rankdir=TB;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // ROADMAP_NOTE[phase2_4]:
    // Sous-graphe ajouté pour documenter la membrane obligatoire entre kernel
    // et composant réel. Le proxy démarre tick(), intercepte yield Event,
    // attend Request.reply et renvoie le résultat via asend().

    RealComponent [label="Real Component\ntick() + context()", fillcolor="#e8f5e9", color="#388e3c", URL="../../experts/40_experts.svg"];
    ComponentProxy [label="ComponentProxy\nmandatory membrane", fillcolor="#ede7f6", color="#512da8"];
    TickLoop [label="async tick loop", fillcolor="#ede7f6", color="#512da8"];
    YieldEvent [label="yield Event(...)\nintention only", fillcolor="#eceff1", color="#455a64"];
    Scheduler [label="Scheduler.emit()", fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    RequestReply [label="Request.reply Future", fillcolor="#fff3e0", color="#ef6c00"];
    Asend [label="tick().asend(result)", fillcolor="#eceff1", color="#455a64"];
    Context [label="context()\ncalled by ContextRequestHandler", fillcolor="#fff3e0", color="#ef6c00", URL="../../context/20_context.svg"];
    Lifecycle [label="ComponentState\nLOAD/START/STOP/ERROR", fillcolor="#f5f5f5", color="#666666"];

    ComponentProxy -> RealComponent [label="wraps"];
    ComponentProxy -> Lifecycle [style=dashed, label="state"];
    ComponentProxy -> TickLoop [label="start"];
    TickLoop -> RealComponent [label="anext/asend"];
    RealComponent -> YieldEvent [label="cooperative yield"];
    YieldEvent -> Scheduler [label="emit"];
    Scheduler -> RequestReply [style=dashed, label="handler result"];
    RequestReply -> Asend;
    Asend -> TickLoop;
    ComponentProxy -> Context [label="safe context surface"];

    Nav_Global [label="Global", shape=plaintext, URL="../../00_global.svg"];
    Nav_Up [label="Up: Scheduler", shape=plaintext, URL="../10_scheduler.svg"];
    Nav_Context [label="Context", shape=plaintext, URL="../../context/20_context.svg"];
    Nav_Inference [label="Inference", shape=plaintext, URL="../../inference/40_inference.svg"];

    { rank=sink; Nav_Global; Nav_Up; Nav_Context; Nav_Inference; }
}
