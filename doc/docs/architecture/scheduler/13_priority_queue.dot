digraph PriorityQueueLegacy {
    // ROADMAP_ID: scheduler.priority_queue.legacy
    // ROADMAP_NOTE[phase2_4c]:
    // Ancienne entrée plate conservée comme redirection lisible. Le détail réel
    // de PriorityQueue vit dans scheduler/priority_queue/13_priority_queue.dot.

    rankdir=LR;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="10_scheduler.svg"];
    PriorityQueueDetail [label="PriorityQueue\nview detail", fillcolor="#ede7f6", color="#512da8", URL="priority_queue/13_priority_queue.svg"];

    Scheduler -> PriorityQueueDetail [label="descend"];

    Nav_Scheduler [label="Up: Scheduler", shape=plaintext, URL="10_scheduler.svg"];
    Nav_Detail [label="Detail: PriorityQueue", shape=plaintext, URL="priority_queue/13_priority_queue.svg"];

    { rank=sink; Nav_Scheduler; Nav_Detail; }
}
