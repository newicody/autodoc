digraph PriorityQueue {
    rankdir=LR;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    Decision [fillcolor="#fff3e0", color="#ef6c00", URL="../../context/decision_engine/24_decision_engine.svg"];
    Queue [fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    Dispatcher [fillcolor="#ede7f6", color="#512da8", URL="../dispatcher/11_dispatcher.svg"];

    // Edges
    Scheduler -> Queue [label="push event"]; // Scheduler pousse
    Decision -> Queue [style=dashed, label="ajustement"]; // Decision ajuste
    Queue -> Dispatcher [label="pop event"]; // File → Dispatcher

    // Navigation
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="../10_scheduler.svg"];
    Nav_Dispatcher [label="Dispatcher", shape=plaintext, URL="../dispatcher/11_dispatcher.svg"];
    { rank=sink; Nav_Scheduler; Nav_Dispatcher; }
}
