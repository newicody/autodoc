digraph PriorityQueue {
    // ROADMAP_ID: scheduler.priority_queue
    // ROADMAP_PARENT: scheduler/10_scheduler.dot

    rankdir=TB;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    // ROADMAP_NOTE[phase2_4]:
    // Sous-graphe ajouté pour documenter la file comme chemin de commande.
    // Même priorité => ordre FIFO via compteur monotone. EventBus reste hors
    // de ce chemin et ne peut pas modifier l'ordre d'exécution.

    ComponentProxy [label="ComponentProxy", fillcolor="#ede7f6", color="#512da8", URL="../component_proxy/14_component_proxy.svg"];
    SchedulerEmit [label="Scheduler.emit(event)", fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    PolicyEngine [label="PolicyEngine.decide(event)", fillcolor="#ede7f6", color="#512da8", URL="../10_scheduler.svg"];
    PriorityQueue [label="PriorityQueue", fillcolor="#ede7f6", color="#512da8"];
    Entry [label="(priority, counter, event)", fillcolor="#eceff1", color="#455a64"];
    Dispatcher [label="Dispatcher", fillcolor="#ede7f6", color="#512da8", URL="../dispatcher/11_dispatcher.svg"];
    Telemetry [label="KernelTelemetry\nenqueue/dequeue/latency", fillcolor="#f5f5f5", color="#666666", URL="../../observability/70_observability.svg"];

    ComponentProxy -> SchedulerEmit [label="yield Event"];
    SchedulerEmit -> PolicyEngine [label="pre-queue gate"];
    PolicyEngine -> PriorityQueue [label="allowed"];
    PriorityQueue -> Entry [label="stores"];
    Entry -> Dispatcher [label="next event"];
    SchedulerEmit -> Telemetry [style=dashed, label="enqueue"];
    PriorityQueue -> Telemetry [style=dashed, label="dequeue"];

    Nav_Global [label="Global", shape=plaintext, URL="../../00_global.svg"];
    Nav_Up [label="Up: Scheduler", shape=plaintext, URL="../10_scheduler.svg"];
    Nav_Dispatcher [label="Dispatcher", shape=plaintext, URL="../dispatcher/11_dispatcher.svg"];

    { rank=sink; Nav_Global; Nav_Up; Nav_Dispatcher; }
}
