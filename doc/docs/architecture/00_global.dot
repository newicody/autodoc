        InferenceAdapter [label="InferenceAdapter\nexecution membrane", URL="inference/40_inference.svg"];
        BackendRegistry [label="BackendRegistry\ncurrent", URL="inference/40_inference.svg"];
        DummyBackend [label="DummyInferenceBackend\ncurrent", URL="inference/40_inference.svg"];
        InferenceResult [label="INFERENCE_RESULT\nobservable", URL="inference/40_inference.svg"];
