digraph Global {
    // ROADMAP_ID: global

    rankdir=TB;

    // ROADMAP_NOTE[phase2_5]:
    // BackendRegistry est ajouté au layer inference pour préparer
    // l’enregistrement explicite d’OpenVINO sans modifier le Scheduler.

    // ROADMAP_NOTE[phase3_0]:
    // OpenVINOModelProfileRegistry est ajouté pour décrire un ou plusieurs
    // modèles OpenVINO possibles avant de créer les backends exécutables.
    compound=true;
    splines=ortho;
    nodesep=0.5;
    ranksep=0.8;

    graph [fontname="Arial", fontsize=11];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    // ROADMAP_NOTE[phase2_4]:
// ReplayReportBundleWriter ajoute un dossier de replay contrôlé :
// report.txt, report.json et manifest.json avec sha256. La roadmap DOT
// est aussi vérifiée par tests/docs/test_dot_links.py afin que les liens
// descente/remontée pointent vers des sources DOT existantes.
    // Le Layer 9 ajoute ReplayReportFileWriter après ReplayReportExport.
    // Cette étape persiste les exports texte/JSON vers chemins explicites.
    // Aucun répertoire n'est créé ni aucun fichier écrasé sans demande explicite.
    // Le writer reste passif et ne commande jamais le Scheduler vivant.


    // ROADMAP_NOTE[phase4_18_r2]:
    // GitHub Project Orchestrator est visible dans l'architecture globale.
    // Cette couche reste future et documentaire : pas d'API GitHub, pas de token,
    // pas de polling réseau et pas de dépendance Copilot dans le coeur.

    // ROADMAP_NOTE[phase4_19]:
    // La Phase 4 se clôt par un audit du moteur local E5 : corpus, recherche,
    // diagnostics, gates, rapports, contexte, consommation et prompt packet.
    // Le stack E5 reste hors Scheduler, hors Qdrant et hors backend de réponse.

    // ROADMAP_NOTE[phase4_20]:
    // Phase 4 clôturée : le moteur local E5 produit des artefacts déterministes
    // de recherche, contexte consommé et prompt packet. La Phase 5 peut brancher
    // ce socle au serveur local ou au Context Engine sans changer ces frontières.

    // ROADMAP_NOTE[phase5_2]:
    // E5RuntimeArtifactDirectoryLoader ajoute la bordure IO locale pour lire un
    // artifact-dir Phase 4 et réutiliser le pont pur E5RuntimeBridge. Aucun daemon,
    // réseau, Scheduler vivant, Qdrant ou LLM n'est introduit.


    // ROADMAP_NOTE[phase5_4]:
    // E5LocalContextRuntime ajoute une façade runtime locale stable au-dessus
    // du loader 5.2 et du bridge 5.1. Elle retourne un statut typé et un
    // InferenceContext sans CLI, daemon, réseau, Scheduler vivant, Qdrant ou LLM.

    // ROADMAP_NOTE[phase5_5]:
    // E5ContextAttachment fusionne explicitement un résultat runtime E5 local
    // avec un InferenceContext existant. Cette étape prépare l'intake futur du
    // ContextEngine sans lancer Scheduler, daemon, réseau, Qdrant ou LLM.

    // ROADMAP_NOTE[phase5_6]:
    // ContextEngine reçoit une entrée E5 explicite : artifact-dir ou runtime result
    // -> attachement -> last_inference_context. Aucun autoload, aucun Scheduler
    // vivant, aucun daemon, réseau, Qdrant ou LLM n'est introduit.

    // ROADMAP_NOTE[phase5_7]:
    // E5ContextEngineStatus ajoute une projection passive et sérialisable
    // de l'état E5 attaché au ContextEngine. Elle ne lit aucun fichier,
    // ne mute aucun contexte et ne déclenche aucun Scheduler/backend.

    // ROADMAP_NOTE[phase5_8]:
    // E5ContextEngineCLI ajoute une bordure manuelle : artifact-dir ->
    // ContextEngine.attach_e5_artifact_dir() -> E5ContextEngineStatus. Elle
    // ne lance aucun Scheduler vivant, daemon, réseau, Qdrant ou LLM.


    // ROADMAP_NOTE[phase5_10]:
    // Phase 5.10 audite le bloc d'intake manuel local : artifact-dir Phase 4,
    // ContextEngine E5 CLI, report JSON et projection status. Elle ne modifie
    // pas le runtime et prépare seulement la bascule future vers serveur/local loop.

    // ROADMAP_NOTE[phase5_9]:
    // E5ContextEngineCLIReport ajoute --report-file à la bordure CLI 5.8.
    // La commande existante peut persister son payload intake + status en JSON
    // atomique sans nouvelle surface CLI, Scheduler vivant, réseau, Qdrant ou LLM.







    // ROADMAP_NOTE[phase5_17]:
    // LocalServerBoundary formalise une surface serveur local future pour
    // SourceCandidate, reports et ContextEngine intake. Cette étape reste
    // contract-only : pas de serveur, socket, framework, réseau, GitHub API,
    // token, Scheduler autoload, Qdrant, LLM ou appel OpenVINO.




    // ROADMAP_NOTE[phase6_1_r1]:
    // la CLI produit une commande typée qui traverse Scheduler -> Dispatcher
    // -> SourceCandidateIntakeHandler -> store JSON réel -> événement observable.
    // ROADMAP_NOTE[phase6_1]:
    // SourceCandidateIntakeCLI démarre Phase 6 : une entrée opérateur locale
    // crée ou remplace une SourceCandidate dans le store JSON atomique. Aucun
    // serveur, daemon, réseau, API GitHub, token, Qdrant, LLM ou OpenVINO.

    // ROADMAP_NOTE[phase5_18]:
    // Phase 5 se clôt sur l'intégration locale contrôlée : artifact-dir E5,
    // runtime bridge/facade, ContextEngine intake explicite, status/report,
    // SourceCandidate local, projection GitHub documentaire et frontière
    // adapter serveur futur non choisie. Aucun daemon, réseau, GitHub API,
    // token, Qdrant, LLM ou appel OpenVINO caché n'est introduit.

    // ROADMAP_NOTE[phase5_17_r1]:
    // LocalServerBoundaryClarification précise que la frontière serveur est
    // un contrat d'adapter futur non choisi : adapter_kind=undecided et
    // framework_choice=undecided. FastAPI/Flask ne sont pas recommandés ici.

    // ROADMAP_NOTE[phase5_16]:
    // GitHubProjectionDesign formalise la projection future entre le store
    // local SourceCandidate et newicody/autodoc. Cette étape reste documentaire :
    // aucun token, réseau, polling, GitHub API, serveur, Qdrant ou LLM.

    // ROADMAP_NOTE[phase5_15]:
    // SourceCandidateStorageReport ajoute un store JSON local explicite pour
    // SourceCandidate : load, upsert atomique, snapshot et rapport optionnel.
    // La valeur newicody/autodoc reste une projection future sans API GitHub,
    // réseau, token, daemon, Qdrant, LLM ou base de données.

    // ROADMAP_NOTE[phase5_14]:
    // SourceCandidateContract ajoute le contrat local d'une entrée candidate :
    // origin/input/policy/status/decision/transition immuable. La valeur
    // newicody/autodoc prépare la projection GitHub future sans API, réseau ou token.

    // ROADMAP_NOTE[phase5_13]:
    // LocalContextLoopCLI ajoute une orchestration manuelle mince : artifact-dir
    // Phase 4 -> ContextEngine intake -> status -> report + next_action opérateur.
    // Elle ne relance pas E5/OpenVINO, ne mute aucune décision et n'ajoute aucun
    // daemon, serveur, réseau, Qdrant, LLM ou stockage persistant.

    // ROADMAP_NOTE[phase5_12]:
    // LocalContextLoopDesign formalise la boucle locale manuelle : artifact-dir
    // Phase 4 -> runtime local -> intake explicite ContextEngine -> status/report
    // -> décision humaine. Aucun serveur, daemon, réseau, stockage persistant,
    // Qdrant, LLM ou appel OpenVINO caché n'est introduit.

    // ROADMAP_NOTE[phase5_3]:
    // E5 artifact context CLI ajoute une bordure de vérification locale pour
    // afficher l'InferenceContext construit depuis un artifact-dir, sans daemon,
    // réseau, Scheduler vivant, Qdrant ou LLM.

    subgraph cluster_L0 {
        label="Layer 0 — Hardware target";
        color="#c62828";
        bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#c62828"];
        CPU [label="Intel i5-11400\nCPU"];
        RAM [label="128GB DDR4"];
        Storage [label="ZFS\nNVMe + RAIDZ2 SATA"];
        GPU [label="Intel iGPU\nOpenVINO future"];
    }

    subgraph cluster_L1 {
        label="Layer 1 — MissiPy Micro-Kernel Phase 2.3";
        color="#512da8";
        bgcolor="#ede7f6";
        node [fillcolor="#ede7f6", color="#512da8"];
        Launcher [URL="scheduler/10_scheduler.svg", tooltip="Zoom Scheduler"];
        Registry [URL="scheduler/10_scheduler.svg", tooltip="Registry"];
        Proxy [label="ComponentProxy\nstateful", URL="scheduler/component_proxy/14_component_proxy.svg", tooltip="Runtime proxy"];
        Scheduler [URL="scheduler/10_scheduler.svg", tooltip="Zoom Scheduler"];
        Policy [label="PolicyEngine\npre-queue gate", URL="scheduler/10_scheduler.svg"];
        Queue [label="PriorityQueue\nFIFO same priority", URL="scheduler/priority_queue/13_priority_queue.svg"];
        Dispatcher [label="Dispatcher\nno handler = no block", URL="scheduler/dispatcher/11_dispatcher.svg"];
        EventBus [label="EventBus\nobservation only", URL="scheduler/event_bus/12_event_bus.svg"];
        Lifecycle [label="LifecycleManager\nComponentState", URL="scheduler/10_scheduler.svg"];
    }

    subgraph cluster_L2 {
        label="Layer 2 — Contracts";
        color="#455a64";
        bgcolor="#eceff1";
        node [fillcolor="#eceff1", color="#455a64"];
        EventContract [label="Event + Request\nuuid id"];
        LifecycleContract [label="ComponentState"];
        ComponentContract [label="Component"];
        ContextContract [label="ContextSnapshot"];
        InferenceContract [label="InferenceRequest\nInferenceResult"];
        PolicyContract [label="Decision\nallowed / denied"];
        TelemetryContract [label="TelemetrySnapshot\nimmutable"];
    }

    subgraph cluster_L3 {
        label="Layer 3 — Context Fabric active";
        color="#ef6c00";
        bgcolor="#fff3e0";
        node [fillcolor="#fff3e0", color="#ef6c00"];
        ContextEngine [label="ContextEngine", URL="context/20_context.svg"];
        Collector [label="ContextCollector", URL="context/20_context.svg"];
        Reducer [label="ContextReducer", URL="context/20_context.svg"];
        Snapshot [label="GlobalContextSnapshot", URL="context/20_context.svg"];
        InferenceCtx [label="InferenceContext", URL="context/20_context.svg"];
        E5RuntimeBridge [label="E5RuntimeBridge\nPhase 5.1", URL="context/25_e5_runtime_bridge.svg"];
        E5ArtifactLoader [label="E5RuntimeArtifactDirectoryLoader\nPhase 5.2", URL="context/26_e5_artifact_directory_loader.svg"];
        E5ArtifactContextCLI [label="E5 artifact context CLI\nPhase 5.3", URL="context/27_e5_artifact_context_cli.svg"];
        E5LocalRuntime [label="E5LocalContextRuntime\nPhase 5.4", URL="context/28_e5_local_context_runtime.svg"];
        E5ContextAttachment [label="E5ContextAttachment\nPhase 5.5", URL="context/29_e5_context_attachment.svg"];
        E5ContextEngineIntake [label="ContextEngine E5 intake\nPhase 5.6", URL="context/30_e5_context_engine_intake.svg"];
        E5ContextEngineStatus [label="ContextEngine E5 status\nPhase 5.7", URL="context/31_e5_context_engine_status.svg"];
        E5ContextEngineCLI [label="ContextEngine E5 CLI\nPhase 5.8", URL="context/32_e5_context_engine_cli.svg"];
        E5ContextEngineCLIReport [label="ContextEngine E5 CLI report\nPhase 5.9", URL="context/33_e5_context_engine_cli_report.svg"];
        E5ContextEngineIntakeAudit [label="ContextEngine local intake audit\nPhase 5.10", URL="context/34_e5_context_engine_intake_audit.svg"];
        ContextEngineContractLock [label="ContextEngine contract lock\nPhase 5.11", URL="context/35_context_engine_contract_lock.svg"];
        LocalContextLoopDesign [label="Local context loop design\nPhase 5.12", URL="context/36_local_context_loop_design.svg"];
        LocalContextLoopCLI [label="Local context loop CLI\nPhase 5.13", URL="context/37_local_context_loop_cli.svg"];
        SourceCandidateContract [label="SourceCandidate contract\nPhase 5.14", URL="context/38_source_candidate_contract.svg"];
        SourceCandidateStore [label="SourceCandidate local store/report\nPhase 5.15", URL="context/39_source_candidate_storage_report.svg"];
        GitHubProjectionDesign [label="GitHub projection design\nnewicody/autodoc\nPhase 5.16", URL="context/40_github_projection_design.svg"];
        LocalServerBoundary [label="Local server boundary\ncontract-only\nPhase 5.17", URL="context/41_local_server_boundary.svg"];
        Decision [label="DecisionEngine\nfuture", URL="context/20_context.svg"];
        SourceCandidateIntakeLivePath [label="SourceCandidate intake live path\nPhase 6.1-r1", URL="context/44_source_candidate_intake_live_path.svg"];
    }

    E5ContextEngineIntake -> E5ContextEngineStatus [label="status projection"];
    E5ContextEngineCLI -> E5ContextEngineIntake [label="manual artifact-dir intake"];
    E5ContextEngineCLI -> E5ContextEngineStatus [label="renders status"];
    E5ContextEngineCLI -> E5ContextEngineCLIReport [label="optional --report-file"];
    E5ContextEngineCLIReport -> E5ContextEngineStatus [label="persists status payload"];
    E5ContextEngineCLIReport -> E5ContextEngineIntakeAudit [style=dashed, label="audited boundary"];
    E5ContextEngineIntakeAudit -> ContextEngineContractLock [style=dashed, label="contracts locked"];
    ContextEngineContractLock -> ContextEngine [style=dashed, label="legacy constructor + tick contract"];
    E5ContextEngineIntakeAudit -> ContextEngine [style=dashed, label="manual local intake only"];
    ContextEngineContractLock -> LocalContextLoopDesign [style=dashed, label="enables local loop design"];
    LocalContextLoopDesign -> E5ContextEngineCLIReport [style=dashed, label="uses existing report boundary"];
    LocalContextLoopDesign -> LocalContextLoopCLI [style=dashed, label="manual loop boundary"];
    LocalContextLoopCLI -> E5ContextEngineCLIReport [style=dashed, label="uses existing artifact/status chain"];
    LocalContextLoopCLI -> SourceCandidateContract [style=dashed, label="next_action vocabulary"];
    SourceCandidateContract -> SourceCandidateStore [style=dashed, label="explicit local JSON store"];
    SourceCandidateStore -> Decision [style=dashed, label="stored candidate decisions"];
    SourceCandidateIntakeLivePath -> SourceCandidateStore [style=dashed, label="Scheduler handler writes JSON store"];
    SourceCandidateStore -> GitHubProjectionDesign [style=dashed, label="future projection payload"];
    SourceCandidateContract -> Decision [style=dashed, label="operator decision contract"];
    LocalContextLoopDesign -> Decision [style=dashed, label="human decision future"];

    subgraph cluster_L4 {
        label="Layer 4 — Independent Services future";
        color="#0288d1";
        bgcolor="#e1f5fe";
        node [fillcolor="#e1f5fe", color="#0288d1"];
        Router [URL="services/30_services.svg"];
        SQLiteProd [label="SQLite Production", URL="services/30_services.svg"];
        SQLiteMaint [label="SQLite Maintenance", URL="services/30_services.svg"];
        Qdrant [URL="services/30_services.svg"];
        Cache [URL="services/30_services.svg"];
        Knowledge [label="Knowledge Manager", URL="services/30_services.svg"];
    }

    subgraph cluster_L5 {
