digraph Global {
    // ROADMAP_ID: global

    rankdir=TB;

    // ROADMAP_NOTE[phase2_5]:
    // BackendRegistry est ajouté au layer inference pour préparer
    // l’enregistrement explicite d’OpenVINO sans modifier le Scheduler.

    // ROADMAP_NOTE[phase3_0]:
    // OpenVINOModelProfileRegistry est ajouté pour décrire un ou plusieurs
    // modèles OpenVINO possibles avant de créer les backends exécutables.
    compound=true;
    splines=ortho;
    nodesep=0.5;
    ranksep=0.8;

    graph [fontname="Arial", fontsize=11];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    // ROADMAP_NOTE[phase2_4]:
// ReplayReportBundleWriter ajoute un dossier de replay contrôlé :
// report.txt, report.json et manifest.json avec sha256. La roadmap DOT
// est aussi vérifiée par tests/docs/test_dot_links.py afin que les liens
// descente/remontée pointent vers des sources DOT existantes.
    // Le Layer 9 ajoute ReplayReportFileWriter après ReplayReportExport.
    // Cette étape persiste les exports texte/JSON vers chemins explicites.
    // Aucun répertoire n'est créé ni aucun fichier écrasé sans demande explicite.
    // Le writer reste passif et ne commande jamais le Scheduler vivant.


    // ROADMAP_NOTE[phase4_18_r2]:
    // GitHub Project Orchestrator est visible dans l'architecture globale.
    // Cette couche reste future et documentaire : pas d'API GitHub, pas de token,
    // pas de polling réseau et pas de dépendance Copilot dans le coeur.

    // ROADMAP_NOTE[phase4_19]:
    // La Phase 4 se clôt par un audit du moteur local E5 : corpus, recherche,
    // diagnostics, gates, rapports, contexte, consommation et prompt packet.
    // Le stack E5 reste hors Scheduler, hors Qdrant et hors backend de réponse.

    // ROADMAP_NOTE[phase4_20]:
    // Phase 4 clôturée : le moteur local E5 produit des artefacts déterministes
    // de recherche, contexte consommé et prompt packet. La Phase 5 peut brancher
    // ce socle au serveur local ou au Context Engine sans changer ces frontières.

    // ROADMAP_NOTE[phase5_2]:
    // E5RuntimeArtifactDirectoryLoader ajoute la bordure IO locale pour lire un
    // artifact-dir Phase 4 et réutiliser le pont pur E5RuntimeBridge. Aucun daemon,
    // réseau, Scheduler vivant, Qdrant ou LLM n'est introduit.


    // ROADMAP_NOTE[phase5_4]:
    // E5LocalContextRuntime ajoute une façade runtime locale stable au-dessus
    // du loader 5.2 et du bridge 5.1. Elle retourne un statut typé et un
    // InferenceContext sans CLI, daemon, réseau, Scheduler vivant, Qdrant ou LLM.

    // ROADMAP_NOTE[phase5_3]:
    // E5 artifact context CLI ajoute une bordure de vérification locale pour
    // afficher l'InferenceContext construit depuis un artifact-dir, sans daemon,
    // réseau, Scheduler vivant, Qdrant ou LLM.

    subgraph cluster_L0 {
        label="Layer 0 — Hardware target";
        color="#c62828";
        bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#c62828"];
        CPU [label="Intel i5-11400\nCPU"];
        RAM [label="128GB DDR4"];
        Storage [label="ZFS\nNVMe + RAIDZ2 SATA"];
        GPU [label="Intel iGPU\nOpenVINO future"];
    }

    subgraph cluster_L1 {
        label="Layer 1 — MissiPy Micro-Kernel Phase 2.3";
        color="#512da8";
        bgcolor="#ede7f6";
        node [fillcolor="#ede7f6", color="#512da8"];
        Launcher [URL="scheduler/10_scheduler.svg", tooltip="Zoom Scheduler"];
        Registry [URL="scheduler/10_scheduler.svg", tooltip="Registry"];
        Proxy [label="ComponentProxy\nstateful", URL="scheduler/component_proxy/14_component_proxy.svg", tooltip="Runtime proxy"];
        Scheduler [URL="scheduler/10_scheduler.svg", tooltip="Zoom Scheduler"];
        Policy [label="PolicyEngine\npre-queue gate", URL="scheduler/10_scheduler.svg"];
        Queue [label="PriorityQueue\nFIFO same priority", URL="scheduler/priority_queue/13_priority_queue.svg"];
        Dispatcher [label="Dispatcher\nno handler = no block", URL="scheduler/dispatcher/11_dispatcher.svg"];
        EventBus [label="EventBus\nobservation only", URL="scheduler/event_bus/12_event_bus.svg"];
        Lifecycle [label="LifecycleManager\nComponentState", URL="scheduler/10_scheduler.svg"];
    }

    subgraph cluster_L2 {
        label="Layer 2 — Contracts";
        color="#455a64";
        bgcolor="#eceff1";
        node [fillcolor="#eceff1", color="#455a64"];
        EventContract [label="Event + Request\nuuid id"];
        LifecycleContract [label="ComponentState"];
        ComponentContract [label="Component"];
        ContextContract [label="ContextSnapshot"];
        InferenceContract [label="InferenceRequest\nInferenceResult"];
        PolicyContract [label="Decision\nallowed / denied"];
        TelemetryContract [label="TelemetrySnapshot\nimmutable"];
    }

    subgraph cluster_L3 {
        label="Layer 3 — Context Fabric active";
        color="#ef6c00";
        bgcolor="#fff3e0";
        node [fillcolor="#fff3e0", color="#ef6c00"];
        ContextEngine [label="ContextEngine", URL="context/20_context.svg"];
        Collector [label="ContextCollector", URL="context/20_context.svg"];
        Reducer [label="ContextReducer", URL="context/20_context.svg"];
        Snapshot [label="GlobalContextSnapshot", URL="context/20_context.svg"];
        InferenceCtx [label="InferenceContext", URL="context/20_context.svg"];
        E5RuntimeBridge [label="E5RuntimeBridge\nPhase 5.1", URL="context/25_e5_runtime_bridge.svg"];
        E5ArtifactLoader [label="E5RuntimeArtifactDirectoryLoader\nPhase 5.2", URL="context/26_e5_artifact_directory_loader.svg"];
        E5ArtifactContextCLI [label="E5 artifact context CLI\nPhase 5.3", URL="context/27_e5_artifact_context_cli.svg"];
        Decision [label="DecisionEngine\nfuture", URL="context/20_context.svg"];
    }

    subgraph cluster_L4 {
        label="Layer 4 — Independent Services future";
        color="#0288d1";
        bgcolor="#e1f5fe";
        node [fillcolor="#e1f5fe", color="#0288d1"];
        Router [URL="services/30_services.svg"];
        SQLiteProd [label="SQLite Production", URL="services/30_services.svg"];
        SQLiteMaint [label="SQLite Maintenance", URL="services/30_services.svg"];
        Qdrant [URL="services/30_services.svg"];
        Cache [URL="services/30_services.svg"];
        Knowledge [label="Knowledge Manager", URL="services/30_services.svg"];
    }

    subgraph cluster_L5 {
        label="Layer 5 — Inference Phase 3.0";
        color="#f9a825";
        bgcolor="#fffde7";
        node [fillcolor="#fffde7", color="#f9a825"];
        InferenceHandler [label="InferenceRequestHandler", URL="inference/40_inference.svg"];
        InferenceAdapter [label="InferenceAdapter\nexecution membrane", URL="inference/40_inference.svg"];
        BackendRegistry [label="BackendRegistry\ncurrent", URL="inference/40_inference.svg"];
        DummyBackend [label="DummyInferenceBackend\ncurrent", URL="inference/40_inference.svg"];
        InferenceResult [label="INFERENCE_RESULT\nobservable", URL="inference/40_inference.svg"];
        OpenVINO [label="OpenVINOBackend\nfuture", URL="inference/40_inference.svg"];
        MCTS [label="MCTS proposer\nfuture"];
    }

    subgraph cluster_L6 {
        label="Layer 6 — Experts";
        color="#388e3c";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#388e3c"];
        Dummy [label="DummyExpert\ncurrent", URL="experts/40_experts.svg"];
        ExpertsFuture [label="Python / C / KiCad / Web\nfuture", URL="experts/40_experts.svg"];
    }

    subgraph cluster_L7 {
        label="Layer 7 — Validation future";
        color="#7b1fa2";
        bgcolor="#f3e5f5";
        node [fillcolor="#f3e5f5", color="#7b1fa2"];
        Validation [label="Compiler -> Tests -> Validator", URL="validation/50_validation.svg"];
    }

    subgraph cluster_L8 {
        label="Layer 8 — Learning future";
        color="#6d4c41";
        bgcolor="#efebe9";
        node [fillcolor="#efebe9", color="#6d4c41"];
        Learning [label="Metrics / Ranking / Patterns", URL="learning/60_learning.svg"];
    }

    subgraph cluster_L9 {
        label="Layer 9 — Observability Phase 2.4";
        color="#666666";
        bgcolor="#f5f5f5";
        node [fillcolor="#f5f5f5", color="#666666"];
        Logger [URL="observability/70_observability.svg"];
        KernelTelemetry [label="KernelTelemetry
current", URL="observability/70_observability.svg"];
        TelemetrySnapshot [label="TelemetrySnapshot", URL="observability/70_observability.svg"];
        EventRecorder [label="EventRecorder
current", URL="observability/70_observability.svg"];
        EventLogSnapshot [label="EventLogSnapshot", URL="observability/70_observability.svg"];
        ReplayReader [label="ReplayReader
current", URL="observability/70_observability.svg"];
        ReplayPlan [label="ReplayPlan
controlled", URL="observability/70_observability.svg"];
        ReplaySandbox [label="ReplaySandbox
isolated", URL="observability/70_observability.svg"];
        ReplaySandboxResult [label="ReplaySandboxResult
immutable", URL="observability/70_observability.svg"];
        ReplayScenario [label="ReplayScenario
controlled", URL="observability/70_observability.svg"];
        ReplayScenarioRunner [label="ReplayScenarioRunner
passive", URL="observability/70_observability.svg"];
        ReplayReport [label="ReplayReport
deterministic", URL="observability/70_observability.svg"];
        ReplayReportExporter [label="ReplayReportExporter
text/json", URL="observability/70_observability.svg"];
        ReplayReportExport [label="ReplayReportExport
immutable", URL="observability/70_observability.svg"];
        ReplayReportFileWriter [label="ReplayReportFileWriter
controlled files", URL="observability/70_observability.svg"];
        ReplayReportWriteResult [label="ReplayReportWriteResult
sha256", URL="observability/70_observability.svg"];
        ReplayReportBundleWriter [label="ReplayReportBundleWriter
controlled bundle", URL="observability/70_observability.svg"];
        ReplayBundleWriteResult [label="ReplayBundleWriteResult
manifest + sha256", URL="observability/70_observability.svg"];
        Metrics [URL="observability/70_observability.svg"];
        Replay [URL="observability/70_observability.svg"];
        Dashboard [URL="observability/70_observability.svg"];
        Watchdog [URL="observability/70_observability.svg"];
    }

    subgraph cluster_L10 {
        label="Layer 10 — Test Harness Phase 2.4";
        color="#1565c0";
        bgcolor="#e3f2fd";
        node [fillcolor="#e3f2fd", color="#1565c0"];
        Pytest [label="pytest suite\n22 tests", URL="tests/80_tests.svg"];
        CompileAll [label="compileall"];
        DotRender [label="Graphviz render"];
    }



    subgraph cluster_L11 {
        label="Layer 11 — Remote Work Intake future";
        color="#00897b";
        bgcolor="#e0f2f1";
        node [fillcolor="#e0f2f1", color="#00897b"];
        GitHubProject [label="GitHub Project
kanban / issues", URL="integrations/90_github_project_orchestrator.svg"];
        GitHubAction [label="GitHub Action
triage artifact", URL="integrations/90_github_project_orchestrator.svg"];
        CopilotMetadata [label="Copilot metadata
optionnel", URL="integrations/90_github_project_orchestrator.svg"];
        SourceCandidate [label="SourceCandidate
cycle de vie", URL="integrations/91_source_candidate_lifecycle.svg"];
        LocalAuthority [label="source autoritative
serveur local", URL="integrations/91_source_candidate_lifecycle.svg"];
        GitHubFeedback [label="retour GitHub
status / commentaire / PR", URL="integrations/90_github_project_orchestrator.svg"];
    }

    subgraph cluster_L12 {
        label="Layer 12 — E5 local context stack — Phase 4 closed";
        color="#3949ab";
        bgcolor="#e8eaf6";
        node [fillcolor="#e8eaf6", color="#3949ab"];
        E5LocalStack [label="E5 local context stack
Phase 4 closed", URL="inference/74_e5_phase4_closure.svg"];
        E5Corpus [label="corpus JSON
missipy.e5.corpus.v1", URL="inference/73_e5_phase4_final_audit.svg"];
        E5Reports [label="report/context/consumed/prompt
JSON artifacts", URL="inference/74_e5_phase4_closure.svg"];
    }

    Launcher -> Registry;
    Registry -> Proxy;
    Proxy -> Scheduler [label="emit(Event)"];
    Scheduler -> Policy [label="decide(Event)"];
    Policy -> Queue [label="allowed -> put(priority, event)"];
    Policy -> EventBus [label="denied -> POLICY_DENIED", style=dashed];
    Policy -> Proxy [label="denied -> Decision", style=dashed];
    Queue -> Dispatcher [label="get(), FIFO if same priority"];
    Dispatcher -> Lifecycle [label="handler"];
    Dispatcher -> EventBus [label="publish copy"];
    Dispatcher -> Proxy [label="Request.reply", style=dashed];

    Lifecycle -> LifecycleContract [style=dotted];
    Proxy -> LifecycleContract [style=dotted];

    Scheduler -> ContextEngine [label="clock tick"];
    ContextEngine -> Collector;
    Collector -> Scheduler [label="CONTEXT_REQUEST"];
    Dispatcher -> Collector [label="Request.reply", style=dashed];
    Collector -> Reducer;
    Reducer -> Snapshot;
    Snapshot -> InferenceCtx;
    InferenceCtx -> Decision [style=dashed, label="future"];

    Scheduler -> EventContract [style=dotted];
    Policy -> PolicyContract [style=dotted];
    KernelTelemetry -> TelemetryContract [style=dotted];
    Proxy -> ComponentContract [style=dotted];
    ContextEngine -> ContextContract [style=dotted];
    InferenceHandler -> InferenceContract [style=dotted];
    ReplayReader -> ReplayContract [style=dotted];
    InferenceAdapter -> InferenceContract [style=dotted];
    BackendRegistry -> InferenceContract [style=dotted];

    Proxy -> Dummy [label="tick/asend"];

    Dispatcher -> InferenceHandler [label="INFERENCE_REQUEST"];
    InferenceHandler -> InferenceAdapter [label="infer(request)"];
    InferenceAdapter -> BackendRegistry [label="select_backend"];
    BackendRegistry -> DummyBackend [label="model=dummy"];
    DummyBackend -> InferenceAdapter [label="InferenceResult"];
    InferenceAdapter -> InferenceHandler [label="InferenceResult"];
    InferenceHandler -> InferenceResult [label="publish copy"];
    InferenceHandler -> Proxy [label="Request.reply", style=dashed];
    InferenceResult -> EventBus [style=dashed];
    OpenVINOProfiles -> OpenVINO [style=dashed, label="to_backend_config"];
    OpenVINO -> GPU [style=dashed, label="future"];
    E5Corpus -> E5LocalStack [style=dashed, label="feeds"];
    E5LocalStack -> E5Reports [style=dashed, label="produces"];
    E5Reports -> E5ArtifactLoader [style=dashed, label="Phase 5.2 artifact-dir"];
    E5ArtifactLoader -> E5RuntimeBridge [style=dashed, label="loaded bundle"];
    E5ArtifactLoader -> E5ArtifactContextCLI [style=dashed, label="local check"];
    E5ArtifactContextCLI -> E5RuntimeBridge [style=dashed, label="uses bridge"];
    E5RuntimeBridge -> InferenceCtx [style=dashed, label="features / priorities"];
    E5RuntimeBridge -> ContextEngine [style=dashed, label="future intake"];
    E5RuntimeBridge -> Knowledge [style=dashed, label="future enriched context"];
    E5LocalStack -> Knowledge [style=dashed, label="future enriched context"];

    Scheduler -> KernelTelemetry [style=dashed, label="measure enqueue/dequeue/latency"];
    Policy -> KernelTelemetry [style=dashed, label="denied count"];
    ContextEngine -> KernelTelemetry [style=dashed, label="context ticks"];
    KernelTelemetry -> TelemetrySnapshot [label="snapshot()"];
    TelemetrySnapshot -> Metrics [style=dashed];

    EventBus -> Logger [style=dashed];
    EventBus -> Metrics [style=dashed];
    EventBus -> EventRecorder [style=dashed, label="record copy"];
    EventRecorder -> EventLogSnapshot [label="snapshot()"];
    EventLogSnapshot -> ReplayReader [label="read/filter"];
    ReplayReader -> ReplayPlan [label="to_replay_plan()"];
    ReplayPlan -> ReplaySandbox [label="replay(plan)"];
    ReplaySandbox -> ReplaySandboxResult [label="result"];
    ReplayPlan -> ReplayScenario [label="scenario(plan)"];
    ReplayScenario -> ReplayScenarioRunner [label="run/report"];
    ReplayScenarioRunner -> ReplaySandbox [label="uses isolated sandbox"];
    ReplaySandboxResult -> ReplayScenarioRunner [label="collect result"];
    ReplayScenarioRunner -> ReplayReport [label="deterministic report"];
    ReplayReport -> ReplayReportExporter [label="export"];
    ReplayReportExporter -> ReplayReportExport [label="text/json"];
    ReplayReportExport -> ReplayReportFileWriter [label="write explicit path"];
    ReplayReportFileWriter -> ReplayReportWriteResult [label="bytes + sha256"];
    ReplayReportFileWriter -> ReplayReportBundleWriter [style=dashed, label="used by bundle"];
    ReplayReportBundleWriter -> ReplayBundleWriteResult [label="manifest + files"];
    ReplayReportWriteResult -> Replay [style=dashed];
    Metrics -> Dashboard [style=dashed];
    Watchdog -> Scheduler [style=dashed];

    Pytest -> EventContract [style=dotted];
    Pytest -> Dispatcher [style=dotted];
    Pytest -> Proxy [style=dotted];
    Pytest -> ContextEngine [style=dotted];
    Pytest -> InferenceHandler [style=dotted];
    Pytest -> BackendRegistry [style=dotted];
    Pytest -> OpenVINOProfiles [style=dotted];
