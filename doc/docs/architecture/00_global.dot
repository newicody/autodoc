    EventRecorder -> EventLogSnapshot [label="snapshot()"];
    EventLogSnapshot -> ReplayReader [label="read/filter"];
    ReplayReader -> ReplayPlan [label="to_replay_plan()"];
    ReplayPlan -> ReplaySandbox [label="replay(plan)"];
