digraph Global {
    rankdir=TB; compound=true;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    // --- Styles Hardware ---
    subgraph cluster_L0 {
        label="Hardware Layer";
        color="#c62828"; bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#c62828"];
        CPU [label="Intel i5-11400\nCPU Affinity"];
        RAM [label="128GB DDR4"];
        Storage [label="ZFS\nNVMe stripe overlay\nRAIDZ2 SATA"];
        GPU [label="Intel iGPU\nOpenVINO Backend"];
    }

    // --- Micro Kernel ---
    subgraph cluster_L1 {
        label="MissiPy Micro Kernel";
        color="#512da8"; bgcolor="#ede7f6";
        node [fillcolor="#ede7f6", color="#512da8"];
        Launcher [URL="scheduler/10_scheduler.svg"];   // clic → scheduler
        Registry [URL="scheduler/10_scheduler.svg"];
        Proxy    [URL="scheduler/component_proxy/14_component_proxy.svg"];
        Scheduler[URL="scheduler/10_scheduler.svg"];
        Dispatcher[URL="scheduler/dispatcher/11_dispatcher.svg"];
        Queue    [URL="scheduler/priority_queue/13_priority_queue.svg"];
        EventBus [URL="scheduler/event_bus/12_event_bus.svg"];
        Policy   [URL="scheduler/10_scheduler.svg"];
        Lifecycle[URL="scheduler/10_scheduler.svg"];
    }

    // --- Context Fabric ---
    subgraph cluster_L2 {
        label="Global Context Fabric";
        color="#ef6c00"; bgcolor="#fff3e0";
        node [fillcolor="#fff3e0", color="#ef6c00"];
        GET      [URL="context/20_context.svg"];
        Collector[URL="context/collector/21_collector.svg"];
        Reducer  [URL="context/reducer/22_reducer.svg"];
        Snapshot [URL="context/snapshot/23_snapshot.svg"];
        Inference[URL="context/20_context.svg"];
        Adapter  [URL="context/decision_engine/24_decision_engine.svg"];
        Decision [URL="context/decision_engine/24_decision_engine.svg"];
    }

    // --- Services ---
    subgraph cluster_L3 {
        label="Independent Services";
        color="#0288d1"; bgcolor="#e1f5fe";
        node [fillcolor="#e1f5fe", color="#0288d1"];
        SQLiteProd[URL="services/30_services.svg"];
        SQLiteMaint[URL="services/30_services.svg"];
        Qdrant  [URL="services/30_services.svg"];
        Cache   [URL="services/30_services.svg"];
        Knowledge[URL="services/30_services.svg"];
        Router  [URL="services/30_services.svg"];
    }

    // --- AI Backends ---
    subgraph cluster_L4 {
        label="AI Backends";
        color="#fbc02d"; bgcolor="#fffde7";
        node [fillcolor="#fffde7", color="#fbc02d"];
        OpenVINO [URL="learning/60_learning.svg"];
        Embedding[URL="learning/60_learning.svg"];
        MCTS     [URL="learning/60_learning.svg"];
    }

    // --- Experts ---
    subgraph cluster_L5 {
        label="Expert Components";
        color="#388e3c"; bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#388e3c"];
        Meta   [URL="experts/40_experts.svg"];
        Python [URL="experts/40_experts.svg"];
        C      [URL="experts/40_experts.svg"];
        KiCad  [URL="experts/40_experts.svg"];
        FreeCAD[URL="experts/40_experts.svg"];
        Web    [URL="experts/40_experts.svg"];
        SVG    [URL="experts/40_experts.svg"];
    }

    // --- Validation ---
    subgraph cluster_L6 {
        label="Validation Pipeline";
        color="#7b1fa2"; bgcolor="#f3e5f5";
        node [fillcolor="#f3e5f5", color="#7b1fa2"];
        Compiler [URL="validation/50_validation.svg"];
        Tests    [URL="validation/50_validation.svg"];
        Validator[URL="validation/50_validation.svg"];
        Confidence[URL="validation/50_validation.svg"];
        Conflict [URL="validation/50_validation.svg"];
        Version  [URL="validation/50_validation.svg"];
    }

    // --- Observability ---
    subgraph cluster_L7 {
        label="Observability";
        color="#666666"; bgcolor="#f5f5f5";
        node [fillcolor="#f5f5f5", color="#666666"];
        Logger   [URL="observability/70_observability.svg"];
        Metrics  [URL="observability/70_observability.svg"];
        Replay   [URL="observability/70_observability.svg"];
        Dashboard[URL="observability/70_observability.svg"];
        Watchdog [URL="observability/70_observability.svg"];
    }

    // ================================
    // Edges (commentaires invisibles)
    // ================================
    // Initialisation
    Launcher -> Registry;   // Launcher amorce le registre
    Registry -> Proxy;      // Le registre alimente le Proxy
    Proxy -> Scheduler;     // Le Proxy transmet les événements au Scheduler
    Scheduler -> Queue;     // Le Scheduler pousse dans la file prioritaire
    Queue -> Dispatcher;    // La file donne au Dispatcher
    Dispatcher -> EventBus; // Le Dispatcher publie sur l'Event Bus

    // Boucle de contexte
    Scheduler -> GET [label="Clock Tick"]; // Le Scheduler déclenche le tick de contexte
    GET -> Proxy [label="context()"];      // GET_CONTEXT_ALL interroge le Proxy
    Proxy -> Collector;   // Le Proxy envoie les données brutes au Collector
    Collector -> Reducer; // Le Collector transmet au Reducer
    Reducer -> Snapshot;  // Le Reducer produit un Snapshot immuable
    Snapshot -> Inference;// Le Snapshot est transformé en InferenceContext
    Inference -> Adapter; // L'InferenceContext est adapté pour la décision
    Adapter -> Decision;  // L'Adapter envoie le contexte interprété au Decision Engine

    // Décisions
    Decision -> Policy;          // Le Decision Engine influence la Policy
    Policy -> Scheduler;         // La Policy ajuste le Scheduler
    Decision -> Queue [style=dashed]; // Le Decision Engine peut injecter dans la file
    Decision -> MCTS [style=dashed];  // Le Decision Engine peut lancer MCTS

    // Services
    EventBus -> SQLiteProd;   // Alimente SQLite Production
    EventBus -> SQLiteMaint;  // Alimente SQLite Maintenance
    EventBus -> Qdrant;       // Alimente Qdrant
    EventBus -> Cache;        // Alimente le Cache
    EventBus -> Knowledge;    // Alimente le Knowledge Manager
    EventBus -> Router;       // Alimente le Router

    // Backends IA
    Adapter -> OpenVINO;      // L'Adapter pilote OpenVINO
    Adapter -> Embedding;     // L'Adapter pilote le moteur d'embeddings
    Qdrant -> Embedding;      // Qdrant fournit des vecteurs à l'embedding

    // Experts
    Proxy -> Meta;      // Délégation à l'expert Meta
    Proxy -> Python;    // Délégation à l'expert Python
    Proxy -> C;         // Délégation à l'expert C/ASM
    Proxy -> KiCad;     // Délégation à l'expert KiCad
    Proxy -> FreeCAD;   // Délégation à l'expert FreeCAD
    Proxy -> Web;       // Délégation à l'expert Web
    Proxy -> SVG;       // Délégation à l'expert SVG/MIDI

    // Validation
    Proxy -> Compiler;      // Soumission au pipeline
    Compiler -> Tests;      // Compilation → tests
    Tests -> Validator;     // Tests → validation sémantique
    Validator -> Confidence;// Validation → confiance
    Confidence -> Conflict; // Confiance → détection de conflits
    Conflict -> Version;    // Conflits → gestion de version

    // Observabilité
    EventBus -> Logger;     // Envoi au Logger
    EventBus -> Metrics;    // Envoi aux Métriques
    EventBus -> Replay;     // Envoi au Replay
    Metrics -> Dashboard;   // Les Métriques nourrissent le Dashboard
    Watchdog -> Scheduler;  // Le Watchdog surveille le Scheduler

    // Lien physique
    OpenVINO -> GPU [style=dashed]; // OpenVINO s'exécute sur le GPU

    // ================================
    // Navigation explicite (doublon, mais plus visible)
    // ================================
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="scheduler/10_scheduler.svg"];
    Nav_Context [label="Context", shape=plaintext, URL="context/20_context.svg"];
    Nav_Services [label="Services", shape=plaintext, URL="services/30_services.svg"];
    Nav_Experts [label="Experts", shape=plaintext, URL="experts/40_experts.svg"];
    Nav_Validation [label="Validation", shape=plaintext, URL="validation/50_validation.svg"];
    Nav_Learning [label="Learning", shape=plaintext, URL="learning/60_learning.svg"];
    Nav_Observability [label="Observability", shape=plaintext, URL="observability/70_observability.svg"];
    { rank=sink; Nav_Scheduler; Nav_Context; Nav_Services; Nav_Experts; Nav_Validation; Nav_Learning; Nav_Observability; }
}
