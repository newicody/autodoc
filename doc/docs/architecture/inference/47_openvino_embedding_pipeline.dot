digraph OpenVINOEmbeddingPipeline {
    // ROADMAP_ID: inference.openvino_embedding_pipeline
    // ROADMAP_PARENT: inference/46_tokenizer_contract.dot
    // ROADMAP_NOTE[phase3_5]:
    // Cette page assemble tokenizer injectable, raw inputs, backend sélectionné
    // par InferenceAdapter et output adapter. Elle ne choisit aucun tokenizer
    // concret et ne branche pas Qdrant.

    // ROADMAP_NOTE[phase3_6]:
    // Le pipeline peut maintenant être validé avec DeterministicTokenizer,
    // tokenizer de test pure stdlib non compatible production.

    // ROADMAP_NOTE[phase3_10]:
    // Le pipeline reçoit maintenant des textes E5 préfixés par E5Text avant
    // tokenization. Le ranking local reste une couche au-dessus du pipeline.

    rankdir=TB;
    splines=ortho;

    graph [fontname="Arial", fontsize=11];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    subgraph cluster_text {
        label="Texte et tokenization";
        color="#1565c0";
        bgcolor="#e3f2fd";
        node [fillcolor="#e3f2fd", color="#1565c0"];

        Text [label="texte unique\nPhase 3.5 mono-vector"];
        E5Text [label="E5Text\nquery: / passage:", URL="49_e5_query_passage.svg"];
        TokenizationRequest [label="TokenizationRequest", URL="46_tokenizer_contract.svg"];
        TokenizerRegistry [label="TokenizerRegistry\nselect(tokenizer_name)", URL="46_tokenizer_contract.svg"];
        TextTokenizer [label="TextTokenizer Protocol\ninjectable", URL="46_tokenizer_contract.svg"];
        TokenizationResult [label="TokenizationResult\ninput_ids / attention_mask", URL="46_tokenizer_contract.svg"];
    }

    subgraph cluster_raw {
        label="Projection raw OpenVINO";
        color="#2e7d32";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#2e7d32"];

        RawInputs [label="OpenVINOEmbeddingRawInputs", URL="45_openvino_embedding_raw.svg"];
        InferenceRequest [label="InferenceRequest\ncontext['inputs']", URL="40_inference.svg"];
    }

    subgraph cluster_execution {
        label="Exécution backend";
        color="#6d4c41";
        bgcolor="#efebe9";
        node [fillcolor="#efebe9", color="#6d4c41"];

        InferenceAdapter [label="InferenceAdapter", URL="40_inference.svg"];
        BackendRegistry [label="BackendRegistry", URL="40_inference.svg"];
        OpenVINOBackend [label="OpenVINOBackend", URL="41_openvino_backend.svg"];
        Runtime [label="RealOpenVINORuntime", URL="42_openvino_runtime.svg"];
        InferenceResult [label="InferenceResult\nmetadata['raw_outputs']", URL="40_inference.svg"];
    }

    subgraph cluster_vector {
        label="Post-traitement embedding";
        color="#00838f";
        bgcolor="#e0f7fa";
        node [fillcolor="#e0f7fa", color="#00838f"];

        OutputAdapter [label="OpenVINOEmbeddingOutputAdapter", URL="45_openvino_embedding_raw.svg"];
        Vector [label="OpenVINOEmbeddingVector", URL="45_openvino_embedding_raw.svg"];
        PipelineResult [label="OpenVINOEmbeddingPipelineResult\ntext/model/backend/vector"];
    }

    subgraph cluster_not_here {
        label="Hors phase";
        color="#b71c1c";
        bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#b71c1c"];

        NoConcreteTokenizer [label="pas de tokenizer concret"];
        NoQdrant [label="pas de Qdrant"];
        NoBatch [label="pas de batch vectoriel"];
        NoScheduler [label="pas de responsabilité Scheduler", URL="../scheduler/10_scheduler.svg"];
    }

    Text -> E5Text [style=dashed, label="Phase 3.10"];
    E5Text -> TokenizationRequest;
    TokenizationRequest -> TokenizerRegistry;
    TokenizerRegistry -> TextTokenizer;
    TextTokenizer -> TokenizationResult;
    TokenizationResult -> RawInputs;
    RawInputs -> InferenceRequest;
    InferenceRequest -> InferenceAdapter;
    InferenceAdapter -> BackendRegistry;
    BackendRegistry -> OpenVINOBackend;
    OpenVINOBackend -> Runtime;
    Runtime -> InferenceResult;
    InferenceResult -> OutputAdapter [label="raw_outputs"];
    RawInputs -> OutputAdapter [style=dashed, label="attention_mask"];
    OutputAdapter -> Vector;
    Vector -> PipelineResult;

    PipelineResult -> NoConcreteTokenizer [style=dotted];
    PipelineResult -> NoQdrant [style=dotted];
    PipelineResult -> NoBatch [style=dotted];
    PipelineResult -> NoScheduler [style=dotted];

    Nav_Inference [label="Inference", shape=plaintext, URL="40_inference.svg"];
    Nav_Raw [label="Embedding raw", shape=plaintext, URL="45_openvino_embedding_raw.svg"];
    Nav_Tokenizer [label="Tokenizer contract", shape=plaintext, URL="46_tokenizer_contract.svg"];
    Nav_TestTokenizer [label="Deterministic tokenizer", shape=plaintext, URL="48_deterministic_tokenizer.svg"];
    Nav_E5QueryPassage [label="E5 query/passage", shape=plaintext, URL="49_e5_query_passage.svg"];
    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];

    { rank=sink; Nav_Inference; Nav_Raw; Nav_Tokenizer; Nav_TestTokenizer; Nav_E5QueryPassage; Nav_Global; }
}
