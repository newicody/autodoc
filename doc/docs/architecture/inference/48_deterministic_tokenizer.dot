digraph DeterministicTokenizer {
    // ROADMAP_ID: inference.deterministic_tokenizer
    // ROADMAP_PARENT: inference/46_tokenizer_contract.dot
    // ROADMAP_NOTE[phase3_6]:
    // Tokenizer concret minimal, pure stdlib, ajouté pour tester le pipeline
    // embedding sans dépendance externe et sans vocabulaire réel. Ce n'est pas
    // le tokenizer de production d'un modèle OpenVINO.

    rankdir=TB;
    splines=ortho;

    graph [fontname="Arial", fontsize=11];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    subgraph cluster_input {
        label="Entrée contractuelle";
        color="#1565c0";
        bgcolor="#e3f2fd";
        node [fillcolor="#e3f2fd", color="#1565c0"];

        Request [label="TokenizationRequest\ntexts / text_pairs", URL="46_tokenizer_contract.svg"];
        Config [label="TokenizerConfig\npadding / truncation / max_length", URL="46_tokenizer_contract.svg"];
        Registry [label="TokenizerRegistry\nexplicit registration", URL="46_tokenizer_contract.svg"];
    }

    subgraph cluster_tokenizer {
        label="Tokenizer déterministe";
        color="#2e7d32";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#2e7d32"];

        Tokenizer [label="DeterministicTokenizer\npure stdlib"];
        Split [label="whitespace split\noptional lowercase"];
        HashIds [label="SHA-256 ids\nstable, no hash()"];
        Specials [label="CLS / SEP optionnels"];
        Padding [label="padding\nnone / longest / max_length"];
    }

    subgraph cluster_output {
        label="Sortie compatible pipeline";
        color="#00838f";
        bgcolor="#e0f7fa";
        node [fillcolor="#e0f7fa", color="#00838f"];

        Result [label="TokenizationResult\ninput_ids / attention_mask / token_type_ids", URL="46_tokenizer_contract.svg"];
        RawInputs [label="OpenVINOEmbeddingRawInputs", URL="45_openvino_embedding_raw.svg"];
        Pipeline [label="OpenVINOEmbeddingPipeline", URL="47_openvino_embedding_pipeline.svg"];
    }

    subgraph cluster_not_production {
        label="Limites volontaires";
        color="#b71c1c";
        bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#b71c1c"];

        NoVocab [label="pas de vocabulaire réel"];
        NoHF [label="pas de transformers/tokenizers"];
        NoModelCompat [label="pas compatible modèle réel"];
        NoDownload [label="pas de téléchargement"];
    }

    Registry -> Tokenizer [label="register"];
    Request -> Tokenizer;
    Config -> Tokenizer;
    Tokenizer -> Split;
    Split -> HashIds;
    HashIds -> Specials;
    Specials -> Padding;
    Padding -> Result;
    Result -> RawInputs;
    RawInputs -> Pipeline;

    Tokenizer -> NoVocab [style=dotted];
    Tokenizer -> NoHF [style=dotted];
    Tokenizer -> NoModelCompat [style=dotted];
    Tokenizer -> NoDownload [style=dotted];

    Nav_Tokenizer [label="Tokenizer contract", shape=plaintext, URL="46_tokenizer_contract.svg"];
    Nav_Pipeline [label="Embedding pipeline", shape=plaintext, URL="47_openvino_embedding_pipeline.svg"];
    Nav_Inference [label="Inference", shape=plaintext, URL="40_inference.svg"];
    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];

    { rank=sink; Nav_Tokenizer; Nav_Pipeline; Nav_Inference; Nav_Global; }
}
