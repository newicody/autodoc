digraph Inference {
    // ROADMAP_ID: inference
    // ROADMAP_PARENT: 00_global.dot

    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    // ROADMAP_NOTE[phase2_9]:
    // OpenVINOBackend possède maintenant un runtime réel optionnel isolé dans
    // inference/openvino_runtime.py. Le Scheduler, le Dispatcher et
    // ComponentProxy ne changent pas. Aucun modèle n'est imposé : le runtime
    // exécute uniquement des entrées OpenVINO brutes.

    // ROADMAP_NOTE[phase3_0]:
    // Les profils OpenVINO séparent le choix déclaratif des modèles de
    // BackendRegistry. On peut préparer embedding/generation/raw sans imposer
    // de tokenizer ni instancier OpenVINO.

    // ROADMAP_NOTE[phase3_1]:
    // OpenVINOBackendFactory devient le pont explicite entre profils déclarés
    // et backends enregistrés. Aucun fallback modèle n'est ajouté.

    // ROADMAP_NOTE[phase3_2]:
    // OpenVINOEmbeddingProfileConfig fournit une configuration de profil
    // embedding sans modèle local imposé et sans tokenizer intégré.

    // ROADMAP_NOTE[phase3_3]:
    // La couche embedding raw sépare tokens déjà préparés, inputs OpenVINO
    // bruts, pooling/normalisation et vecteur final. Aucun tokenizer ni
    // modèle précis n'est imposé.

    // ROADMAP_NOTE[phase3_4]:
    // Le contrat tokenizer ajoute la membrane texte -> TokenizationResult ->
    // OpenVINOEmbeddingRawInputs sans imposer Hugging Face, SentencePiece ou
    // un modèle local.

    // ROADMAP_NOTE[phase3_5]:
    // OpenVINOEmbeddingPipeline assemble tokenizer injectable, raw inputs,
    // InferenceAdapter et output adapter en chemin direct mono-texte. Le
    // Scheduler ne reçoit aucune nouvelle responsabilité.

    // ROADMAP_NOTE[phase3_6]:
    // DeterministicTokenizer fournit un tokenizer concret minimal de test,
    // pure stdlib, pour valider le pipeline sans choisir de vrai tokenizer
    // modèle. Il ne revendique aucune compatibilité BGE/E5/MiniLM.

    // ROADMAP_NOTE[phase3_10]:
    // Le contrat E5 query/passage rend explicite le rôle du texte avant
    // tokenization et ajoute un mini-ranker local query -> passages -> scores
    // avant Qdrant.

    // ROADMAP_NOTE[phase3_12]:
    // E5CorpusIndex persiste les embeddings de passages localement. La query
    // reste calculée à la demande, mais les passages ne sont plus recalculés
    // à chaque recherche. Qdrant reste une étape ultérieure.

    // ROADMAP_NOTE[phase3_13]:
    // E5SourceDocument et E5TextChunk ajoutent l'ingestion locale de fichiers
    // TXT/Markdown. Le découpage source -> chunks -> E5CorpusDocument reste
    // déterministe, hors Scheduler et avant Qdrant.
    // ROADMAP_NOTE[phase3_14]:
    // E5SearchReport enrichit les hits du corpus avec contexte source, lignes
    // et extrait stable pour rendre la recherche locale exploitable.

    // ROADMAP_NOTE[phase3_15]:
    // E5IncrementalCorpusBuilder évite de recalculer les embeddings des chunks
    // inchangés en comparant une empreinte stable document.id + texte préfixé.

    subgraph cluster_contracts {
        label="Contracts";
        color="#455a64";
        bgcolor="#eceff1";
        node [fillcolor="#eceff1", color="#455a64"];
        InferenceRequest [label="InferenceRequest\nprompt/context/model/metadata"];
        InferenceResult [label="InferenceResult\ntext/confidence/backend/metadata"];
        InferenceBackend [label="InferenceBackend Protocol"];
        RegistrySnapshot [label="BackendRegistrySnapshot\ndefault/name list"];
    }

    subgraph cluster_runtime {
        label="Runtime Phase 2.5";
        color="#f9a825";
        bgcolor="#fffde7";
        node [fillcolor="#fffde7", color="#f9a825"];
        EventRequest [label="EventType.INFERENCE_REQUEST\nRequest.reply"];
        Handler [label="InferenceRequestHandler"];
        Adapter [label="InferenceAdapter\nexecution membrane"];
        Registry [label="BackendRegistry\nexplicit backend list"];
        Dummy [label="DummyInferenceBackend\ndeterministic"];
        EventResult [label="EventType.INFERENCE_RESULT\nobservable"];
    }

    subgraph cluster_openvino_contract {
        label="OpenVINO Phase 2.9";
        color="#6d4c41";
        bgcolor="#efebe9";
        node [fillcolor="#efebe9", color="#6d4c41"];
        OpenVINO [label="OpenVINOBackend\nbackend membrane", URL="41_openvino_backend.svg"];
        OpenVINOConfig [label="OpenVINOBackendConfig"];
        OpenVINOState [label="OpenVINOBackendState"];
        OpenVINORuntime [label="OpenVINORuntime Protocol\ninjected fake/real"];
        RealRuntime [label="RealOpenVINORuntime\noptional real runtime", URL="42_openvino_runtime.svg"];
        ModelProfile [label="OpenVINOModelProfile\ndeclarative model", URL="43_openvino_profiles.svg"];
        ProfileRegistry [label="OpenVINOModelProfileRegistry\nprofiles only", URL="43_openvino_profiles.svg"];
        BackendFactory [label="OpenVINOBackendFactory\nprofile -> backend", URL="43_openvino_profiles.svg"];
        EmbeddingConfig [label="OpenVINOEmbeddingProfileConfig\nembedding config", URL="44_openvino_embedding_profile.svg"];
        EmbeddingRaw [label="OpenVINOEmbeddingRawInputs\nraw token tensors", URL="45_openvino_embedding_raw.svg"];
        EmbeddingVector [label="OpenVINOEmbeddingVector\npost-processed vector", URL="45_openvino_embedding_raw.svg"];
        TokenizerContract [label="Tokenizer contract\ntext -> tokens", URL="46_tokenizer_contract.svg"];
        TokenizationResult [label="TokenizationResult\ninput_ids / attention_mask", URL="46_tokenizer_contract.svg"];
        EmbeddingPipeline [label="OpenVINOEmbeddingPipeline\ntext -> vector", URL="47_openvino_embedding_pipeline.svg"];
        E5Text [label="E5Text\nquery/passage role", URL="49_e5_query_passage.svg"];
        E5Ranker [label="E5LocalRanker\nquery -> passages", URL="49_e5_query_passage.svg"];
        E5Sources [label="E5 source loader\nTXT/Markdown -> chunks", URL="51_e5_sources.svg"];
        E5SearchReport [label="E5SearchReport\nsource + lines + excerpt", URL="52_e5_search_report.svg"];
    }

    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/10_scheduler.svg"];
    Dispatcher [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/dispatcher/11_dispatcher.svg"];
    ComponentProxy [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/component_proxy/14_component_proxy.svg"];
    EventBus [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/event_bus/12_event_bus.svg"];

    ComponentProxy -> EventRequest [label="yield Event"];
    EventRequest -> Scheduler [label="emit"];
    Scheduler -> Dispatcher [label="Queue"];
    Dispatcher -> Handler;
    Handler -> InferenceRequest [style=dotted, label="validate payload"];
    Handler -> Adapter [label="infer(request)"];
    Adapter -> Registry [label="select_backend"];
    Registry -> RegistrySnapshot [style=dotted, label="snapshot"];
    Registry -> InferenceBackend [style=dotted, label="protocol"];
    Registry -> Dummy [label="model=dummy"];
    Dummy -> InferenceResult;
    InferenceResult -> Adapter;
    Adapter -> Handler;
    Handler -> ComponentProxy [label="Request.reply", style=dashed];
    Handler -> EventResult [label="publish"];
    EventResult -> EventBus [style=dashed];

    Registry -> OpenVINO [style=dashed, label="future registered backend"];
    OpenVINO -> OpenVINOConfig [style=dotted, label="immutable config"];
    OpenVINO -> OpenVINOState [style=dotted, label="observable state"];
    OpenVINO -> OpenVINORuntime [style=dashed, label="infer via injection"];
    OpenVINORuntime -> RealRuntime [style=dotted, label="implementation"];
    EmbeddingConfig -> ModelProfile [label="to_model_profile"];
    E5Text -> TokenizerContract [style=dashed, label="prefixed text"];
    TokenizerContract -> TokenizationResult [label="tokenize"];
    TokenizationResult -> EmbeddingRaw [label="to_embedding_raw_inputs"];
    TokenizationResult -> EmbeddingPipeline [style=dashed, label="Phase 3.5"];
    EmbeddingPipeline -> EmbeddingRaw [label="raw inputs"];
    EmbeddingRaw -> InferenceRequest [style=dashed, label="context inputs"];
    EmbeddingPipeline -> Adapter [style=dashed, label="infer raw request"];
    RealRuntime -> EmbeddingVector [style=dashed, label="raw output adapter"];
    EmbeddingVector -> EmbeddingPipeline [style=dotted, label="result vector"];
    EmbeddingPipeline -> E5Ranker [style=dashed, label="Phase 3.10"];
    E5Sources -> E5CorpusBuilder [style=dashed, label="source chunks"];
    EmbeddingPipeline -> E5CorpusBuilder [style=dashed, label="embed passages once"];
    E5Corpus -> E5Incremental [style=dashed, label="previous index"];
    E5Sources -> E5Incremental [style=dashed, label="new chunks"];
    E5Incremental -> E5Corpus [style=dashed, label="new index"];
    EmbeddingPipeline -> E5CorpusSearcher [style=dashed, label="embed query only"];
    E5CorpusBuilder -> E5Corpus [label="write index"];
    E5Corpus -> E5CorpusSearcher [label="read persisted vectors"];
    E5CorpusSearcher -> E5SearchReport [style=dashed, label="report hits"];
    ModelProfile -> ProfileRegistry [label="register profile"];
    ProfileRegistry -> BackendFactory [label="select(profile_name)"];
    BackendFactory -> OpenVINOConfig [style=dashed, label="to_backend_config"];
    BackendFactory -> OpenVINO [style=dashed, label="build backend"];
    BackendFactory -> Registry [style=dashed, label="register backend"];

    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="../scheduler/10_scheduler.svg"];
    Nav_Services [label="Services", shape=plaintext, URL="../services/30_services.svg"];
    Nav_Profiles [label="OpenVINO profiles", shape=plaintext, URL="43_openvino_profiles.svg"];
    Nav_Embedding [label="Embedding profile", shape=plaintext, URL="44_openvino_embedding_profile.svg"];
    Nav_EmbeddingRaw [label="Embedding raw IO", shape=plaintext, URL="45_openvino_embedding_raw.svg"];
    Nav_Tokenizer [label="Tokenizer contract", shape=plaintext, URL="46_tokenizer_contract.svg"];
    Nav_Pipeline [label="Embedding pipeline", shape=plaintext, URL="47_openvino_embedding_pipeline.svg"];
    Nav_TestTokenizer [label="Deterministic tokenizer", shape=plaintext, URL="48_deterministic_tokenizer.svg"];
    Nav_E5QueryPassage [label="E5 query/passage", shape=plaintext, URL="49_e5_query_passage.svg"];
    Nav_E5Corpus [label="E5 corpus", shape=plaintext, URL="50_e5_corpus.svg"];
    Nav_E5Sources [label="E5 sources", shape=plaintext, URL="51_e5_sources.svg"];
    Nav_E5SearchReport [label="E5 search report", shape=plaintext, URL="52_e5_search_report.svg"];
    Nav_E5Incremental [label="E5 incremental", shape=plaintext, URL="53_e5_incremental.svg"];

    { rank=sink; Nav_Global; Nav_Scheduler; Nav_Services; Nav_Profiles; Nav_Embedding; Nav_EmbeddingRaw; Nav_Tokenizer; Nav_Pipeline; Nav_TestTokenizer; Nav_E5QueryPassage; Nav_E5Corpus; Nav_E5Sources; Nav_E5SearchReport; Nav_E5Incremental; }
}
