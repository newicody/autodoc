digraph OpenVINORuntime {
    // ROADMAP_ID: inference.openvino_runtime
    // ROADMAP_PARENT: inference/41_openvino_backend.dot
    // ROADMAP_NOTE[phase2_9]:
    // RealOpenVINORuntime est le seul module autorisé à importer openvino. Il
    // ne choisit aucun modèle et ne fait aucun traitement spécifique embedding
    // ou génération. Les entrées brutes arrivent via InferenceRequest.context.

    // ROADMAP_NOTE[phase3_0]:
    // Le choix du modèle est maintenant représenté par OpenVINOModelProfile,
    // mais le runtime reste raw-input only et ne tokenise toujours pas.

    rankdir=TB;
    splines=ortho;

    graph [fontname="Arial", fontsize=11];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    subgraph cluster_contract {
        label="Contrat stable";
        color="#455a64";
        bgcolor="#eceff1";
        node [fillcolor="#eceff1", color="#455a64"];

        Request [label="InferenceRequest\ncontext['inputs'] ou metadata['inputs']"];
        Config [label="OpenVINOBackendConfig\nmodel_path/device/backend_name"];
        Result [label="InferenceResult\nbackend/config metadata"];
        State [label="RealOpenVINORuntimeState\navailable/cache/infer_count"];
    }

    subgraph cluster_runtime {
        label="Runtime réel optionnel";
        color="#6d4c41";
        bgcolor="#efebe9";
        node [fillcolor="#efebe9", color="#6d4c41"];

        Runtime [label="RealOpenVINORuntime\nseul import openvino"];
        Import [label="import openvino as ov\nonly here"];
        Core [label="ov.Core()"];
        ReadModel [label="core.read_model(model_path)"];
        Compile [label="core.compile_model(model, device)"];
        Cache [label="compiled model cache\n(model_path, device)"];
        Infer [label="compiled_model(inputs)\nor infer_request.infer(inputs)"];
    }

    subgraph cluster_limits {
        label="Limites volontairement gardées";
        color="#b71c1c";
        bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#b71c1c"];

        NoTokenizer [label="pas de tokenizer"];
        ModelChoiceElsewhere [label="choix modèle
via profiles", URL="43_openvino_profiles.svg"];
        NoScheduler [label="aucun lien Scheduler"];
    }

    Request -> Runtime;
    Config -> Runtime;
    Runtime -> Import [style=dashed];
    Import -> Core;
    Core -> ReadModel;
    ReadModel -> Compile;
    Compile -> Cache;
    Cache -> Infer;
    Infer -> Result;
    Runtime -> State [label="state()", style=dotted];

    Runtime -> NoTokenizer [style=dotted];
    Runtime -> ModelChoiceElsewhere [style=dotted];
    Runtime -> NoScheduler [style=dotted];

    Nav_Backend [label="OpenVINOBackend", shape=plaintext, URL="41_openvino_backend.svg"];
    Nav_Inference [label="Inference", shape=plaintext, URL="40_inference.svg"];
    Nav_Profiles [label="Profils modèles", shape=plaintext, URL="43_openvino_profiles.svg"];
    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];

    { rank=sink; Nav_Backend; Nav_Inference; Nav_Profiles; Nav_Global; }
}
