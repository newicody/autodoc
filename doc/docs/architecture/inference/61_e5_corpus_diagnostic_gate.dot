digraph E5CorpusDiagnosticGate {
  // ROADMAP_ID: inference.e5_corpus_diagnostic_gate
  // ROADMAP_PARENT: inference/60_e5_corpus_diagnostics.dot
  // ROADMAP_NOTE[phase4_7]:
  // Transforme les diagnostics locaux E5 en garde-fous actionnables par code retour.

  rankdir=LR;
  graph [
    fontname="Arial",
    fontsize=10,
    labelloc="t",
    label="Phase 4.7 — E5 corpus diagnostic gate",
    bgcolor="white",
    pad=0.25,
    nodesep=0.45,
    ranksep=0.75
  ];
  node [shape=box, style="filled,rounded", fontname="Arial", fontsize=10, margin="0.09,0.06"];
  edge [fontname="Arial", fontsize=9, color="#455a64", arrowsize=0.8];

  subgraph cluster_input {
    label="Entrée lecture seule";
    color="#1565c0";
    bgcolor="#e3f2fd";
    penwidth=1.5;
    node [fillcolor="#e3f2fd", color="#1565c0"];
    CorpusJson [label="corpus.json\nmissipy.e5.corpus.v1", URL="50_e5_corpus.svg"];
    InspectCli [label="inspect_e5_corpus.py\n--index corpus.json", URL="60_e5_corpus_diagnostics.svg"];
    Diagnostics [label="E5CorpusDiagnostics\nagrégats + santé"];
  }

  subgraph cluster_gate {
    label="Gate optionnel";
    color="#6a1b9a";
    bgcolor="#f3e5f5";
    penwidth=1.7;
    node [fillcolor="#f3e5f5", color="#6a1b9a"];
    Config [label="E5CorpusDiagnosticGateConfig\nseuils immuables"];
    MinChunks [label="--min-chunks N"];
    MaxMissing [label="--max-missing-source-metadata N"];
    MaxEmpty [label="--max-empty-texts N"];
    MaxDim [label="--max-dimension-mismatches N"];
    FailWarnings [label="--fail-on-warning"];
    Evaluate [label="evaluate_e5_corpus_diagnostic_gate()\nfonction pure locale"];
  }

  subgraph cluster_result {
    label="Résultat actionnable";
    color="#2e7d32";
    bgcolor="#e8f5e9";
    penwidth=1.5;
    node [fillcolor="#e8f5e9", color="#2e7d32"];
    GateResult [label="E5CorpusDiagnosticGateResult\npassed + violations"];
    TextGate [label="sortie text\nsection gate:"];
    JsonGate [label="sortie json\nclé gate"];
    ExitOk [shape=diamond, label="passed ?"];
    Code0 [label="exit 0\ncorpus accepté"];
    Code2 [label="exit 2\nseuil violé"];
  }

  subgraph cluster_scope {
    label="Limites d'architecture";
    color="#78909c";
    bgcolor="#fafafa";
    penwidth=1.0;
    node [shape=note, style="filled", fillcolor="#fafafa", color="#78909c"];
    NoWrite [label="lecture seule\npas de promotion"];
    NoScheduler [label="pas de Scheduler"];
    NoQdrant [label="pas de Qdrant"];
    NoFormatChange [label="format corpus v1\ninchangé"];
    NoSvg [label="pas de SVG versionné"];
  }

  subgraph cluster_navigation {
    label="Navigation roadmap";
    color="#ef6c00";
    bgcolor="#fff3e0";
    penwidth=1.4;
    node [fillcolor="#fff3e0", color="#ef6c00"];
    DiagnosticsPhase [label="Phase 4.6\ncorpus diagnostics", URL="60_e5_corpus_diagnostics.svg"];
    HygieneCli [label="Phase 4.5\nhygiène CLI", URL="59_e5_source_hygiene_cli.svg"];
    ScoreGuard [label="Phase 4.3\nsearch score guard", URL="57_e5_score_guard.svg"];
  }

  CorpusJson -> InspectCli;
  InspectCli -> Diagnostics;
  MinChunks -> Config;
  MaxMissing -> Config;
  MaxEmpty -> Config;
  MaxDim -> Config;
  FailWarnings -> Config;
  Diagnostics -> Evaluate;
  Config -> Evaluate;
  Evaluate -> GateResult;
  GateResult -> TextGate;
  GateResult -> JsonGate;
  GateResult -> ExitOk;
  ExitOk -> Code0 [label="oui"];
  ExitOk -> Code2 [label="non"];

  Evaluate -> NoWrite [style=dotted];
  Evaluate -> NoScheduler [style=dotted];
  Evaluate -> NoQdrant [style=dotted];
  Evaluate -> NoFormatChange [style=dotted];
  Evaluate -> NoSvg [style=dotted];

  DiagnosticsPhase -> Diagnostics [label="produit"];
  HygieneCli -> CorpusJson [label="réduit les anomalies"];
  ScoreGuard -> Code0 [style=dotted, label="utiliser après validation"];

  subgraph cluster_legend {
    label="Légende";
    color="#cfd8dc";
    bgcolor="#ffffff";
    penwidth=1.0;
    node [shape=plaintext, fillcolor="#ffffff", color="#ffffff"];
    Legend [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#e3f2fd">Bleu</TD><TD>lecture corpus</TD></TR>
        <TR><TD BGCOLOR="#f3e5f5">Violet</TD><TD>seuils gate</TD></TR>
        <TR><TD BGCOLOR="#e8f5e9">Vert</TD><TD>résultat actionnable</TD></TR>
        <TR><TD BGCOLOR="#fff3e0">Orange</TD><TD>navigation roadmap</TD></TR>
      </TABLE>
    >];
  }

  // HTML_DETAIL[phase4_7]:
  // title: Diagnostic gate
  // summary: Transforme un diagnostic E5 local en verdict utilisable par CI/dev.
  // technical: Les seuils sont optionnels, évalués après lecture du corpus, et ne modifient jamais le format v1.
  // ui_hint: Afficher passed/violations dans une bannière HTML, avec liens vers les agrégats responsables.
}
