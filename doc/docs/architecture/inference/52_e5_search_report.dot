digraph E5SearchReport {
    // ROADMAP_ID: inference.e5_search_report
    // ROADMAP_PARENT: inference/50_e5_corpus.dot
    // ROADMAP_NOTE[phase3_14]:
    // Le rapport enrichit les résultats E5 locaux avec source_path, lignes,
    // chunk_index et extrait. Il rend le corpus local exploitable avant Qdrant.

    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    subgraph cluster_input {
        label="Entrée recherche";
        color="#1565c0";
        bgcolor="#e3f2fd";
        node [fillcolor="#e3f2fd", color="#1565c0"];
        Results [label="E5CorpusSearchResults\nhits ranked", URL="50_e5_corpus.svg"];
        Hit [label="E5CorpusSearchHit\nscore + metadata", URL="50_e5_corpus.svg"];
    }

    subgraph cluster_report {
        label="Rapport Phase 3.14";
        color="#2e7d32";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#2e7d32"];
        Config [label="E5SearchReportConfig\nexcerpt/full text"];
        SourceContext [label="E5SearchSourceContext\nsource_path + lines"];
        Excerpt [label="make_excerpt\nstable one-line excerpt"];
        ReportHit [label="E5SearchReportHit\nrank + source + excerpt"];
        Report [label="E5SearchReport\ntext/json output"];
    }

    subgraph cluster_cli {
        label="CLI";
        color="#6d4c41";
        bgcolor="#efebe9";
        node [fillcolor="#efebe9", color="#6d4c41"];
        SearchCli [label="search_e5_corpus.py\n--excerpt-chars / --full-text"];
        TextOut [label="text output\nhuman readable"];
        JsonOut [label="json output\nprogram readable"];
    }

    Results -> Hit;
    Config -> Report;
    Hit -> SourceContext [label="metadata"];
    Hit -> Excerpt [label="text"];
    SourceContext -> ReportHit;
    Excerpt -> ReportHit;
    ReportHit -> Report;
    Report -> SearchCli;
    SearchCli -> TextOut;
    SearchCli -> JsonOut;

    Nav_Inference [label="Inference", shape=plaintext, URL="40_inference.svg"];
    Nav_E5Corpus [label="E5 corpus", shape=plaintext, URL="50_e5_corpus.svg"];
    Nav_E5Sources [label="E5 sources", shape=plaintext, URL="51_e5_sources.svg"];

    { rank=sink; Nav_Inference; Nav_E5Corpus; Nav_E5Sources; }
}
