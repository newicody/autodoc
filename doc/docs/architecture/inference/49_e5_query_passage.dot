digraph E5QueryPassage {
    // ROADMAP_ID: inference.e5_query_passage
    // ROADMAP_PARENT: inference/47_openvino_embedding_pipeline.dot
    // ROADMAP_NOTE[phase3_10]:
    // Cette page clarifie le contrat E5 query/passage avant Qdrant. Elle rend
    // explicite le rôle du texte avant tokenization et ajoute un mini-ranker
    // local pour valider query -> passages -> scores en mémoire.

    rankdir=TB;
    splines=ortho;

    graph [fontname="Arial", fontsize=11];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    subgraph cluster_roles {
        label="Rôles E5";
        color="#1565c0";
        bgcolor="#e3f2fd";
        node [fillcolor="#e3f2fd", color="#1565c0"];

        RawQuery [label="texte utilisateur brut"];
        RawPassage [label="document / chunk brut"];
        E5Query [label="E5Text.query\nquery: ..."];
        E5Passage [label="E5Text.passage\npassage: ..."];
    }

    subgraph cluster_embedding {
        label="Embeddings";
        color="#2e7d32";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#2e7d32"];

        Pipeline [label="OpenVINOEmbeddingPipeline", URL="47_openvino_embedding_pipeline.svg"];
        QueryVector [label="query vector\nnormalisé"];
        PassageVector [label="passage vector\nnormalisé"];
    }

    subgraph cluster_ranker {
        label="Ranking local avant Qdrant";
        color="#6d4c41";
        bgcolor="#efebe9";
        node [fillcolor="#efebe9", color="#6d4c41"];

        DotProduct [label="dot_product\n= cosine si normalisé"];
        Ranker [label="E5LocalRanker"];
        Results [label="E5RankedResults\nscore décroissant"];
    }

    subgraph cluster_not_here {
        label="Hors phase";
        color="#b71c1c";
        bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#b71c1c"];

        NoQdrant [label="pas de Qdrant"];
        NoBatch [label="pas de batch optimisé"];
        NoScheduler [label="pas de Scheduler", URL="../scheduler/10_scheduler.svg"];
    }

    RawQuery -> E5Query [label="default role query"];
    RawPassage -> E5Passage [label="default role passage"];
    E5Query -> Pipeline;
    E5Passage -> Pipeline;
    Pipeline -> QueryVector;
    Pipeline -> PassageVector;
    QueryVector -> DotProduct;
    PassageVector -> DotProduct;
    DotProduct -> Ranker;
    Ranker -> Results;

    Results -> NoQdrant [style=dotted];
    Results -> NoBatch [style=dotted];
    Results -> NoScheduler [style=dotted];

    Nav_Inference [label="Inference", shape=plaintext, URL="40_inference.svg"];
    Nav_Pipeline [label="Embedding pipeline", shape=plaintext, URL="47_openvino_embedding_pipeline.svg"];
    Nav_CLI [label="E5 CLI", shape=plaintext, URL="40_inference.svg"];
    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];

    { rank=sink; Nav_Inference; Nav_Pipeline; Nav_CLI; Nav_Global; }
}
