digraph E5SourceHygieneCli {
  // ROADMAP_ID: inference.e5_source_hygiene_cli
  // ROADMAP_PARENT: inference/58_e5_source_hygiene.dot
  // ROADMAP_NEXT: inference/60_e5_corpus_diagnostics.dot
  // ROADMAP_NOTE[phase4_5]:
  // Exposition contrôlée des exclusions source depuis build_e5_corpus.py et
  // rebuild_e5_corpus.py, sans duplication du filtrage.

  rankdir=LR;
  graph [
    fontname="Arial",
    fontsize=10,
    labelloc="t",
    label="Phase 4.5 — E5 source hygiene CLI controls",
    bgcolor="white",
    pad=0.25,
    nodesep=0.45,
    ranksep=0.7
  ];
  node [shape=box, style="filled,rounded", fontname="Arial", fontsize=10, margin="0.09,0.06"];
  edge [fontname="Arial", fontsize=9, color="#455a64", arrowsize=0.8];

  subgraph cluster_commands {
    label="Commandes exposées";
    color="#1565c0";
    bgcolor="#e3f2fd";
    penwidth=1.5;
    node [fillcolor="#e3f2fd", color="#1565c0"];
    BuildCli [label="build_e5_corpus.py\nindex local", URL="50_e5_corpus.svg"];
    RebuildCli [label="rebuild_e5_corpus.py\nstaging -> validation -> promotion", URL="56_e5_safe_rebuild.svg"];
  }

  subgraph cluster_args {
    label="Options utilisateur";
    color="#ef6c00";
    bgcolor="#fff3e0";
    penwidth=1.7;
    node [fillcolor="#fff3e0", color="#ef6c00"];
    SourceDir [label="--source-dir PATH\nrépétable"];
    ExcludeDir [label="--exclude-dir NAME\nex: vendor"];
    ExcludeSuffix [label="--exclude-file-suffix SUFFIX\nex: .draft.md"];
    NoRecursive [label="--no-recursive\nscan plat"];
  }

  subgraph cluster_shared {
    label="Chemin partagé";
    color="#6a1b9a";
    bgcolor="#f3e5f5";
    penwidth=1.5;
    node [fillcolor="#f3e5f5", color="#6a1b9a"];
    CollectBuild [label="e5_corpus_cli._collect_passages()"];
    CollectRebuild [label="e5_rebuild_cli._collect_passages()"];
    Merge [label="_merge_cli_values()\ndefaults + extras"];
    Sources [label="e5_sources.py\nsource discovery", URL="58_e5_source_hygiene.svg"];
  }

  subgraph cluster_guards {
    label="Garanties";
    color="#2e7d32";
    bgcolor="#e8f5e9";
    penwidth=1.5;
    node [fillcolor="#e8f5e9", color="#2e7d32"];
    DefaultsKept [label="defaults conservés\n.git, caches, venv, build, dist"];
    ExtraOnly [label="extras ajoutés\npas de remplacement"];
    BeforeRead [label="filtrage avant read_text\naucun hash parasite"];
    CorpusFormat [label="format corpus v1\ninchangé"];
    Diagnostics [label="inspect_e5_corpus.py\ndiagnostic lecture seule", URL="60_e5_corpus_diagnostics.svg"];
  }

  subgraph cluster_scope {
    label="Hors périmètre";
    color="#78909c";
    bgcolor="#fafafa";
    penwidth=1.0;
    node [shape=note, style="filled", fillcolor="#fafafa", color="#78909c"];
    NoScheduler [label="pas de Scheduler"];
    NoQdrant [label="pas de Qdrant"];
    NoSvg [label="pas de SVG versionné"];
  }

  BuildCli -> CollectBuild;
  RebuildCli -> CollectRebuild;
  SourceDir -> CollectBuild;
  SourceDir -> CollectRebuild;
  ExcludeDir -> Merge;
  ExcludeSuffix -> Merge;
  NoRecursive -> Sources;
  CollectBuild -> Merge;
  CollectRebuild -> Merge;
  Merge -> Sources;
  Sources -> DefaultsKept;
  Sources -> ExtraOnly;
  Sources -> BeforeRead;
  BeforeRead -> CorpusFormat;
  NoScheduler -> NoQdrant [style=invis];
  NoQdrant -> NoSvg [style=invis];

  Nav_Inference [label="Inference", shape=plaintext, URL="40_inference.svg"];
  Nav_Sources [label="E5 sources", shape=plaintext, URL="51_e5_sources.svg"];
  Nav_Hygiene [label="Source hygiene", shape=plaintext, URL="58_e5_source_hygiene.svg"];
  Nav_Corpus [label="E5 corpus", shape=plaintext, URL="50_e5_corpus.svg"];
  Nav_Rebuild [label="Safe rebuild", shape=plaintext, URL="56_e5_safe_rebuild.svg"];
  { rank=sink; Nav_Inference; Nav_Sources; Nav_Hygiene; Nav_Corpus; Nav_Rebuild; }

  CorpusFormat -> Diagnostics [label="inspectable"];
  Diagnostics -> NoQdrant [style=dotted, label="confirme"];

  // HTML_DETAIL[phase4_5]:
  // title: CLI source hygiene controls
  // summary: Les CLI build/rebuild exposent des exclusions supplémentaires répétables.
  // technical: Les options sont fusionnées avec les defaults avant discover_e5_source_files().
  // data: cli_options=--exclude-dir,--exclude-file-suffix
  // data: consumers=build_e5_corpus.py,rebuild_e5_corpus.py
  // ui_hint: Afficher les exclusions effectives en bas du panneau de graphe HTML.
}

  // HTML_DETAIL[phase4_6]:
  // title: Corpus diagnostics handoff
  // summary: Les contrôles CLI d'hygiène préparent un corpus inspectable en lecture seule.
  // technical: inspect_e5_corpus.py lit le corpus v1 et agrège sources, extensions, reuse et santé.
  // ui_hint: Afficher un bouton Diagnostic sur les graphes d'ingestion et de recherche locale.
