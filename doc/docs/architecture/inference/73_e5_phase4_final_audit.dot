digraph E5Phase4FinalAudit {
  graph [
    label="Phase 4.19 — E5 Phase 4 final audit",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: integrations/91_source_candidate_lifecycle.dot

  subgraph cluster_engine {
    label="Moteur local E5 clôturé";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Corpus [label="corpus JSON\nmissipy.e5.corpus.v1"];
    Build [label="build / rebuild\nsafe promotion"];
    Inspect [label="diagnostics\ngates / validation"];
    Search [label="search local\nscore + source"];
    Report [label="E5SearchReport\nreport.json"];
  }

  subgraph cluster_context {
    label="Chaîne contexte -> prompt";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff8e1";

    Bundle [label="E5ContextBundle", URL="68_e5_context_bundle.svg"];
    Consumed [label="E5ConsumedContext", URL="69_e5_context_consumer.svg"];
    Prompt [label="E5AnswerPromptPacket", URL="70_e5_answer_prompt_packet.svg"];
    ArtifactDir [label="--artifact-dir\ndry-run complet", URL="72_e5_dry_run_artifact_dir.svg"];
  }

  subgraph cluster_boundaries {
    label="Frontières préservées";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    NoScheduler [label="pas de Scheduler\nmodifié ou requis"];
    NoQdrant [label="pas de Qdrant\nservice futur"];
    NoLLM [label="pas de génération\nprompt seulement"];
    NoGitHubApi [label="pas d'API GitHub\narchitecture future"];
    Stdlib [label="aucune dépendance\nhors stdlib"];
    BoundaryIO [label="IO en bordure\nCLI + report_io.py"];
  }

  subgraph cluster_future {
    label="Passage vers phases futures";
    style="rounded,dashed";
    color="#b0bec5";

    Phase5 [label="Phase 5\nserveur local / runtime"];
    Phase6 [label="Phase 6\nGitHub Project Orchestrator", URL="../integrations/90_github_project_orchestrator.svg"];
    SourceCandidate [label="SourceCandidate\nfuture intake", URL="../integrations/91_source_candidate_lifecycle.svg"];
  }

  Corpus -> Build;
  Build -> Inspect;
  Inspect -> Search;
  Search -> Report;
  Report -> Bundle;
  Bundle -> Consumed;
  Consumed -> Prompt;
  Prompt -> ArtifactDir;

  NoScheduler -> Search [style=dashed];
  NoQdrant -> Corpus [style=dashed];
  NoLLM -> Prompt [style=dashed];
  NoGitHubApi -> SourceCandidate [style=dashed];
  Stdlib -> Bundle [style=dashed];
  BoundaryIO -> ArtifactDir [style=dashed];

  ArtifactDir -> Phase5 [style=dashed, label="runtime handoff"];
  SourceCandidate -> Phase5 [style=dashed, label="context intake"];
  Phase6 -> SourceCandidate [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← Source Candidate lifecycle", shape=plaintext, URL="../integrations/91_source_candidate_lifecycle.svg"];
    DryRun [label="← E5 dry-run artifact dir", shape=plaintext, URL="72_e5_dry_run_artifact_dir.svg"];
    Next [label="next: phase 4 closure", shape=plaintext, URL="74_e5_phase4_closure.svg"];
  }

  // HTML_DETAIL[phase4_19]: Audit final de Phase 4 ; le moteur E5 local est prêt pour un handoff serveur sans Scheduler/Qdrant/LLM.
}
