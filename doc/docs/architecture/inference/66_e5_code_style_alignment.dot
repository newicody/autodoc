digraph e5_code_style_alignment {
  graph [
    rankdir=LR,
    labelloc=t,
    label="E5 code style alignment",
    fontsize=18
  ];

  node [
    shape=box,
    style="rounded",
    fontsize=11
  ];

  edge [
    fontsize=10
  ];

  source [
    label="E5 implementation sources"
  ];

  tests [
    label="E5 tests"
  ];

  style_rules [
    label="Style constraints"
  ];

  architecture_docs [
    label="Architecture documentation"
  ];

  reports [
    label="Phase reports"
  ];

  validation [
    label="Validation gate"
  ];

  source -> validation;
  tests -> validation;
  style_rules -> validation;
  architecture_docs -> validation;
  reports -> validation;

  validation -> source [
    label="keep aligned"
  ];

  validation -> tests [
    label="verify"
  ];

  validation -> architecture_docs [
    label="document"
  ];

  validation -> reports [
    label="record"
  ];
}
