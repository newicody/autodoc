digraph TokenizerContract {
    // ROADMAP_ID: inference.tokenizer_contract
    // ROADMAP_PARENT: inference/45_openvino_embedding_raw.dot
    // ROADMAP_NOTE[phase3_4]:
    // Cette page décrit le contrat tokenizer injectable. Elle définit texte ->
    // TokenizationResult -> OpenVINOEmbeddingRawInputs sans imposer Hugging
    // Face, SentencePiece, vocabulaire local ou modèle précis.

    // ROADMAP_NOTE[phase3_5]:
    // OpenVINOEmbeddingPipeline consomme TokenizerRegistry et TextTokenizer
    // sans en faire une dépendance du Scheduler ou du backend.

    // ROADMAP_NOTE[phase3_6]:
    // DeterministicTokenizer devient une implémentation de test explicite du
    // protocole TextTokenizer. Il sert au pipeline mais pas à un modèle réel.

    rankdir=TB;
    splines=ortho;

    graph [fontname="Arial", fontsize=11];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    subgraph cluster_request {
        label="Entrée texte";
        color="#1565c0";
        bgcolor="#e3f2fd";
        node [fillcolor="#e3f2fd", color="#1565c0"];

        Config [label="TokenizerConfig\nname / max_length / padding / truncation"];
        Request [label="TokenizationRequest\ntexts / text_pairs? / metadata"];
        Protocol [label="TextTokenizer Protocol\ntokenize(request, config)"];
    }

    subgraph cluster_result {
        label="Sortie tokenisée";
        color="#2e7d32";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#2e7d32"];

        Result [label="TokenizationResult\ninput_ids / attention_mask / token_type_ids?"];
        Pipeline [label="OpenVINOEmbeddingPipeline\nconsumes tokenizer", URL="47_openvino_embedding_pipeline.svg"];
        ShapeChecks [label="shape checks\n2D rectangular + same shape"];
        RawInputs [label="OpenVINOEmbeddingRawInputs", URL="45_openvino_embedding_raw.svg"];
    }

    subgraph cluster_registry {
        label="Registre explicite";
        color="#6d4c41";
        bgcolor="#efebe9";
        node [fillcolor="#efebe9", color="#6d4c41"];

        Registry [label="TokenizerRegistry\nexplicit tokenizers only"];
        Snapshot [label="TokenizerRegistrySnapshot\nnames/default/count"];
    }

    subgraph cluster_not_here {
        label="Non imposé ici";
        color="#b71c1c";
        bgcolor="#ffebee";
        node [fillcolor="#ffebee", color="#b71c1c"];

        NoHF [label="pas d'import transformers"];
        NoTokenizers [label="pas d'import tokenizers"];
        NoSentencePiece [label="pas de SentencePiece imposé"];
        NoDownload [label="pas de téléchargement"];
        NoModel [label="pas de modèle imposé"];
    }

    Config -> Protocol;
    Request -> Protocol;
    Protocol -> Result [label="tokenize"];
    Result -> ShapeChecks;
    Result -> RawInputs [label="to_embedding_raw_inputs"];
    Result -> Pipeline [style=dashed, label="Phase 3.5"];

    Protocol -> Registry [style=dashed, label="register"];
    Registry -> Protocol [style=dashed, label="select"];
    Registry -> Snapshot [label="snapshot"];

    Protocol -> NoHF [style=dotted];
    Protocol -> NoTokenizers [style=dotted];
    Protocol -> NoSentencePiece [style=dotted];
    Protocol -> NoDownload [style=dotted];
    Protocol -> NoModel [style=dotted];

    Nav_RawIO [label="Embedding raw IO", shape=plaintext, URL="45_openvino_embedding_raw.svg"];
    Nav_EmbeddingProfile [label="Embedding profile", shape=plaintext, URL="44_openvino_embedding_profile.svg"];
    Nav_Profiles [label="OpenVINO profiles", shape=plaintext, URL="43_openvino_profiles.svg"];
    Nav_Inference [label="Inference", shape=plaintext, URL="40_inference.svg"];
    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];
    Nav_Pipeline [label="Embedding pipeline", shape=plaintext, URL="47_openvino_embedding_pipeline.svg"];
    Nav_TestTokenizer [label="Deterministic tokenizer", shape=plaintext, URL="48_deterministic_tokenizer.svg"];

    { rank=sink; Nav_RawIO; Nav_EmbeddingProfile; Nav_Profiles; Nav_Inference; Nav_Pipeline; Nav_TestTokenizer; Nav_Global; }
}
