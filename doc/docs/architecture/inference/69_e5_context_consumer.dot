digraph E5ContextConsumer {
  graph [
    label="Phase 4.15 — E5 context consumer",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: inference/68_e5_context_bundle.dot
  // ROADMAP_NEXT: inference/70_e5_answer_prompt_packet.dot

  subgraph cluster_input {
    label="Entrée";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Bundle [label="E5ContextBundle\nquery + items", URL="68_e5_context_bundle.svg"];
    Policy [label="E5ContextConsumptionPolicy\nmax_chars + max_items + scores"];
  }

  subgraph cluster_domain {
    label="Domaine pur";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Consumer [label="consume_e5_context_bundle()\naucun IO"];
    Item [label="E5ConsumedContextItem\nrank/source/text"];
    Consumed [label="E5ConsumedContext\ncontext_text + budget"];
  }

  subgraph cluster_output {
    label="Sortie";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff8e1";

    Json [label="to_json_dict()\nstable"];
    Text [label="to_text()\nhumain"];
    Prompt [label="Phase 4.16\nE5AnswerPromptPacket", URL="70_e5_answer_prompt_packet.svg"];
  }

  subgraph cluster_rules {
    label="Règles";
    style="rounded,dashed";
    color="#b0bec5";

    NoDeps [label="aucune dépendance hors stdlib"];
    NoLLM [label="pas de LLM\npas de Scheduler\npas de Qdrant"];
    CodeRule [label="code_rule_review: done"];
  }

  Bundle -> Consumer;
  Policy -> Consumer;
  Consumer -> Item;
  Item -> Consumed;
  Consumed -> Json;
  Consumed -> Text;
  Consumed -> Prompt;
  NoDeps -> Consumer [style=dashed];
  NoLLM -> Consumer [style=dashed];
  CodeRule -> Consumer [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Parent [label="← context bundle", shape=plaintext, URL="68_e5_context_bundle.svg"];
    Next [label="answer prompt packet →", shape=plaintext, URL="70_e5_answer_prompt_packet.svg"];
  }

  // HTML_DETAIL[phase4_15]: contexte consommé, budget déterministe, aucune génération.
}
