digraph E5ContextConsumer {
  // ROADMAP_ID: inference.e5_context_consumer
  // ROADMAP_PARENT: inference/68_e5_context_bundle.dot
  // ROADMAP_NOTE[phase4_15]:
  // Prépare un contexte déterministe borné depuis E5ContextBundle, sans IO, sans Scheduler et sans LLM.

  rankdir=LR;
  graph [
    fontname="Arial",
    fontsize=10,
    labelloc="t",
    label="Phase 4.15 — E5 context consumer contract",
    bgcolor="white",
    pad=0.25,
    nodesep=0.5,
    ranksep=0.8
  ];
  node [shape=box, style="filled,rounded", fontname="Arial", fontsize=10, margin="0.09,0.06"];
  edge [fontname="Arial", fontsize=9, color="#455a64", arrowsize=0.8];

  subgraph cluster_rule {
    label="Code rule";
    color="#5e35b1";
    bgcolor="#ede7f6";
    penwidth=1.5;
    node [fillcolor="#ede7f6", color="#5e35b1"];
    Parent [label="← context bundle", URL="68_e5_context_bundle.svg"];
    NoDeps [label="aucune dépendance hors stdlib"];
    NoCli [label="pas de nouvelle CLI\ndomaine pur"];
    NoIo [label="aucun effet IO\nlecture/écriture en bordure"];
  }

  subgraph cluster_input {
    label="Entrée";
    color="#1565c0";
    bgcolor="#e3f2fd";
    penwidth=1.5;
    node [fillcolor="#e3f2fd", color="#1565c0"];
    Bundle [label="E5ContextBundle\nquery + ranked items", URL="68_e5_context_bundle.svg"];
    Item [label="E5ContextBundleItem\nsource/lines/excerpt"];
  }

  subgraph cluster_contract {
    label="Contrat consommateur";
    color="#2e7d32";
    bgcolor="#e8f5e9";
    penwidth=1.5;
    node [fillcolor="#e8f5e9", color="#2e7d32"];
    Policy [label="E5ContextConsumptionPolicy\nmax_chars + max_items"];
    UseCase [label="consume_e5_context_bundle()\nfonction pure"];
    Result [label="E5ConsumedContext\ntexte borné + JSON"];
    ResultItem [label="E5ConsumedContextItem\ntexte prêt consommation"];
  }

  subgraph cluster_future {
    label="Préparation future";
    color="#ef6c00";
    bgcolor="#fff3e0";
    penwidth=1.5;
    node [fillcolor="#fff3e0", color="#ef6c00"];
    FutureInference [label="futur InferenceContext\nnon modifié en 4.15"];
    FutureAnswer [label="futur composant réponse\nnon branché"];
  }

  subgraph cluster_tests {
    label="Tests";
    color="#c62828";
    bgcolor="#ffebee";
    penwidth=1.5;
    node [fillcolor="#ffebee", color="#c62828"];
    UnitTests [label="test_e5_context_consumer.py\nbudget + JSON + invariants"];
    Rule [label="code_rule_review: done\nno external dependency"];
  }

  Parent -> Bundle;
  NoDeps -> Policy [style=dotted];
  NoCli -> UseCase [style=dotted];
  NoIo -> Result [style=dotted];
  Bundle -> Item;
  Bundle -> UseCase;
  Policy -> UseCase;
  UseCase -> Result;
  Result -> ResultItem;
  Result -> FutureInference [style=dashed, label="prépare"];
  Result -> FutureAnswer [style=dashed, label="prépare"];
  UnitTests -> UseCase;
  Rule -> NoDeps;

  subgraph cluster_scope {
    label="Hors périmètre 4.15";
    color="#b0bec5";
    bgcolor="#fafafa";
    node [fillcolor="#fafafa", color="#78909c"];
    NoQdrant [label="pas de Qdrant"];
    NoScheduler [label="pas de Scheduler"];
    NoLlm [label="pas de LLM"];
    NoCorpusSchema [label="pas de changement\nmissipy.e5.corpus.v1"];
  }

  Result -> NoQdrant [style=dotted];
  Result -> NoScheduler [style=dotted];
  Result -> NoLlm [style=dotted];
  Result -> NoCorpusSchema [style=dotted];

  subgraph cluster_legend {
    label="Légende";
    color="#cfd8dc";
    bgcolor="#ffffff";
    penwidth=1.0;
    node [shape=plaintext, fillcolor="#ffffff", color="#ffffff"];
    Legend [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#ede7f6">Violet</TD><TD>règles code_rule</TD></TR>
        <TR><TD BGCOLOR="#e3f2fd">Bleu</TD><TD>bundle source</TD></TR>
        <TR><TD BGCOLOR="#e8f5e9">Vert</TD><TD>contrat pur de consommation</TD></TR>
        <TR><TD BGCOLOR="#fff3e0">Orange</TD><TD>préparation future</TD></TR>
        <TR><TD BGCOLOR="#ffebee">Rouge</TD><TD>tests</TD></TR>
      </TABLE>
    >];
  }

  // HTML_DETAIL[phase4_15]:
  // title: E5 context consumer contract
  // summary: Transforme un E5ContextBundle en contexte texte déterministe borné pour un futur consommateur de raisonnement.
  // technical: consume_e5_context_bundle est pur ; budget max_chars/max_items explicite ; aucun IO ni backend supplémentaire.
  // ui_hint: Afficher used_chars/max_chars, selected_item_count et skipped_item_count dans une future vue HTML.
}
