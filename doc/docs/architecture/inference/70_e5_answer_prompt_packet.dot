digraph E5AnswerPromptPacket {
  graph [
    label="Phase 4.16 — E5 answer prompt packet",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: inference/69_e5_context_consumer.dot
  // ROADMAP_NEXT: inference/71_e5_prompt_file_cli.dot

  subgraph cluster_input {
    label="Entrée";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Consumed [label="E5ConsumedContext\ncontext_text + budget", URL="69_e5_context_consumer.svg"];
    Policy [label="E5AnswerPromptPolicy\nsystem + instruction + empty notice"];
  }

  subgraph cluster_domain {
    label="Domaine pur";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Builder [label="build_e5_answer_prompt()\naucun IO"];
    Packet [label="E5AnswerPromptPacket\nprompt_text + JSON stable"];
  }

  subgraph cluster_prompt {
    label="Prompt déterministe";
    style="rounded,filled";
    color="#d1c4e9";
    fillcolor="#f3e5f5";

    System [label="[SYSTEM]\ninstruction stable"];
    Question [label="[QUESTION]\nquery utilisateur"];
    Context [label="[CONTEXT]\ncontexte E5 consommé"];
    Instructions [label="[INSTRUCTIONS]\ncontrat de réponse"];
  }

  subgraph cluster_rules {
    label="Règles";
    style="rounded,dashed";
    color="#b0bec5";

    NoDeps [label="aucune dépendance hors stdlib"];
    NoRuntime [label="pas d'appel modèle\npas de LLM"];
    Border [label="fichier futur en bordure\npas dans le domaine"];
  }

  Consumed -> Builder;
  Policy -> Builder;
  Builder -> Packet;
  Packet -> System;
  Packet -> Question;
  Packet -> Context;
  Packet -> Instructions;
  NoDeps -> Builder [style=dashed];
  NoRuntime -> Builder [style=dashed];
  Border -> Packet [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Parent [label="← context consumer", shape=plaintext, URL="69_e5_context_consumer.svg"];
    Next [label="prompt file CLI →", shape=plaintext, URL="71_e5_prompt_file_cli.svg"];
  }

  // HTML_DETAIL[phase4_16]: paquet prompt déterministe, sans LLM ni IO.
}
