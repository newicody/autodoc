digraph E5DryRunArtifactDir {
  graph [
    label="Phase 4.18 — E5 dry-run artifact directory",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: inference/71_e5_prompt_file_cli.dot

  subgraph cluster_cli {
    label="CLI search";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Search [label="tools/e5.py search\nfaçade existante", URL="67_e5_unified_command_surface.svg"];
    ArtifactDir [label="--artifact-dir DIR\ndry-run local"];
    Explicit [label="chemins explicites\nprioritaires"];
    Command [label="E5SearchCommand\nartifacts policy"];
  }

  subgraph cluster_outputs {
    label="Artefacts par défaut";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff8e1";

    Report [label="report.json\nE5SearchReport"];
    Context [label="context.json\nE5ContextBundle", URL="68_e5_context_bundle.svg"];
    Consumed [label="consumed_context.json\nE5ConsumedContext", URL="69_e5_context_consumer.svg"];
    Prompt [label="prompt.json\nE5AnswerPromptPacket", URL="70_e5_answer_prompt_packet.svg"];
    ReportIO [label="report_io.py\nwrite_json_report_atomic()"];
  }

  subgraph cluster_rules {
    label="Règles";
    style="rounded,dashed";
    color="#b0bec5";

    NoDeps [label="aucune dépendance hors stdlib"];
    NoLLM [label="pas de LLM\npas de Scheduler\npas de Qdrant"];
    Boundary [label="création dossier + écriture\nuniquement bordure CLI"];
    Stable [label="noms stables\nJSON stable"];
  }

  Search -> ArtifactDir;
  Search -> Explicit;
  ArtifactDir -> Command;
  Explicit -> Command [label="override"];
  Command -> Report;
  Command -> Context;
  Command -> Consumed;
  Command -> Prompt;
  Report -> ReportIO;
  Context -> ReportIO;
  Consumed -> ReportIO;
  Prompt -> ReportIO;

  NoDeps -> Command [style=dashed];
  NoLLM -> Command [style=dashed];
  Boundary -> ReportIO [style=dashed];
  Stable -> Report [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Parent [label="← prompt file CLI", shape=plaintext, URL="71_e5_prompt_file_cli.svg"];
    Next [label="next: GitHub Project Orchestrator", shape=plaintext, URL="../integrations/90_github_project_orchestrator.svg"];
  }

  // HTML_DETAIL[phase4_18]: --artifact-dir produit un dry-run complet report/context/consumed_context/prompt sans backend de réponse.
}
