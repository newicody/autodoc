digraph e5_unified_command_surface {
  graph [
    rankdir=LR,
    labelloc=t,
    label="E5 unified command surface",
    fontsize=18
  ];

  node [
    shape=box,
    style="rounded",
    fontsize=11
  ];

  edge [
    fontsize=10
  ];

  operator [
    label="Operator / CLI"
  ];

  command_surface [
    label="Unified E5 command surface"
  ];

  profile [
    label="OpenVINO embedding profile"
  ];

  pipeline [
    label="Embedding pipeline"
  ];

  incremental [
    label="Incremental embedding"
  ];

  search_report [
    label="Search report"
  ];

  search_report_file [
    label="Search report file"
  ];

  validation_set [
    label="Search validation set"
  ];

  rebuild_report_file [
    label="Rebuild report file"
  ];

  context_bundle [
    label="Context bundle"
  ];

  prompt_file_cli [
    label="Prompt file CLI"
  ];

  phase4_closure [
    label="Phase 4 closure"
  ];

  artifacts [
    label="Local artifacts"
  ];

  operator -> command_surface;

  command_surface -> profile;
  command_surface -> pipeline;
  command_surface -> incremental;
  command_surface -> search_report;
  command_surface -> search_report_file;
  command_surface -> validation_set;
  command_surface -> rebuild_report_file;
  command_surface -> context_bundle;
  command_surface -> prompt_file_cli;
  command_surface -> phase4_closure;

  profile -> artifacts;
  pipeline -> artifacts;
  incremental -> artifacts;
  search_report -> artifacts;
  search_report_file -> artifacts;
  validation_set -> artifacts;
  rebuild_report_file -> artifacts;
  context_bundle -> artifacts;
  prompt_file_cli -> artifacts;
  phase4_closure -> artifacts;
}
