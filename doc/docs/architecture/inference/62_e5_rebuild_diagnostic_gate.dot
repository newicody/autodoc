digraph E5RebuildDiagnosticGate {
  // ROADMAP_ID: inference.e5_rebuild_diagnostic_gate
  // ROADMAP_PARENT: inference/56_e5_safe_rebuild.dot
  // ROADMAP_NOTE[phase4_8]:
  // Applique le diagnostic gate sur le candidat staging avant promotion finale.

  rankdir=LR;
  graph [
    fontname="Arial",
    fontsize=10,
    labelloc="t",
    label="Phase 4.8 — E5 rebuild diagnostic gate",
    bgcolor="white",
    pad=0.25,
    nodesep=0.5,
    ranksep=0.8
  ];
  node [shape=box, style="filled,rounded", fontname="Arial", fontsize=10, margin="0.09,0.06"];
  edge [fontname="Arial", fontsize=9, color="#455a64", arrowsize=0.8];

  subgraph cluster_build {
    label="Rebuild sûr existant";
    color="#1565c0";
    bgcolor="#e3f2fd";
    penwidth=1.5;
    node [fillcolor="#e3f2fd", color="#1565c0"];
    Inputs [label="passages / source-dir\nTXT Markdown", URL="51_e5_sources.svg"];
    RebuildCli [label="rebuild_e5_corpus.py\nstaging + lock", URL="56_e5_safe_rebuild.svg"];
    Builder [label="E5CorpusBuilder\nE5IncrementalCorpusBuilder", URL="50_e5_corpus.svg"];
    Staging [label=".corpus.json.rebuild.json\ncandidat relu"];
  }

  subgraph cluster_gate {
    label="Gate diagnostic avant promotion";
    color="#6a1b9a";
    bgcolor="#f3e5f5";
    penwidth=1.7;
    node [fillcolor="#f3e5f5", color="#6a1b9a"];
    Inspect [label="inspect_e5_corpus(candidate)\nlecture locale", URL="60_e5_corpus_diagnostics.svg"];
    Config [label="seuils CLI\nmin/max + fail-on-warning", URL="61_e5_corpus_diagnostic_gate.svg"];
    Evaluate [label="evaluate_e5_corpus_diagnostic_gate()\nfonction pure"];
    Gate [label="E5CorpusDiagnosticGateResult\npassed + violations"];
  }

  subgraph cluster_decision {
    label="Décision de promotion";
    color="#2e7d32";
    bgcolor="#e8f5e9";
    penwidth=1.5;
    node [fillcolor="#e8f5e9", color="#2e7d32"];
    Passed [shape=diamond, label="gate actif ?\npassed ?"];
    Validation [label="validation-query\noptionnelle"];
    Promote [label="replace(staging -> index)\npromotion finale"];
    Final [label="corpus.json\nindex final"];
  }

  subgraph cluster_failure {
    label="Échec contrôlé";
    color="#c62828";
    bgcolor="#ffebee";
    penwidth=1.5;
    node [fillcolor="#ffebee", color="#c62828"];
    Block [label="pas de promotion\nexit 2"];
    Cleanup [label="cleanup staging\npar défaut"];
    Keep [label="--keep-staging\nconserver candidat"];
  }

  subgraph cluster_scope {
    label="Limites d'architecture";
    color="#78909c";
    bgcolor="#fafafa";
    penwidth=1.0;
    node [shape=note, style="filled", fillcolor="#fafafa", color="#78909c"];
    NoScheduler [label="pas de Scheduler"];
    NoQdrant [label="pas de Qdrant"];
    NoFormatChange [label="format corpus v1\ninchangé"];
    NoSvg [label="pas de SVG versionné"];
  }

  subgraph cluster_navigation {
    label="Navigation roadmap";
    color="#ef6c00";
    bgcolor="#fff3e0";
    penwidth=1.4;
    node [fillcolor="#fff3e0", color="#ef6c00"];
    SafeRebuild [label="Phase 3.18\nsafe rebuild", URL="56_e5_safe_rebuild.svg"];
    Diagnostics [label="Phase 4.6\ncorpus diagnostics", URL="60_e5_corpus_diagnostics.svg"];
    DiagnosticGate [label="Phase 4.7\ndiagnostic gate", URL="61_e5_corpus_diagnostic_gate.svg"];
    HygieneCli [label="Phase 4.5\nsource hygiene CLI", URL="59_e5_source_hygiene_cli.svg"];
  }

  Inputs -> RebuildCli;
  RebuildCli -> Builder;
  Builder -> Staging;
  Staging -> Inspect;
  Config -> Evaluate;
  Inspect -> Evaluate;
  Evaluate -> Gate;
  Gate -> Passed;
  Passed -> Validation [label="oui / non actif"];
  Validation -> Promote;
  Promote -> Final;
  Passed -> Block [label="non"];
  Block -> Cleanup [label="défaut"];
  Block -> Keep [label="si demandé"];

  Evaluate -> NoScheduler [style=dotted];
  Evaluate -> NoQdrant [style=dotted];
  Evaluate -> NoFormatChange [style=dotted];
  Evaluate -> NoSvg [style=dotted];

  SafeRebuild -> RebuildCli [label="étend"];
  HygieneCli -> Inputs [label="nettoie"];
  Diagnostics -> Inspect [label="réutilise"];
  DiagnosticGate -> Config [label="mêmes seuils"];
  RebuildCli -> SearchValidation [label="étape suivante"];

  subgraph cluster_legend {
    label="Légende";
    color="#cfd8dc";
    bgcolor="#ffffff";
    penwidth=1.0;
    node [shape=plaintext, fillcolor="#ffffff", color="#ffffff"];
    Legend [label=<
      <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
        <TR><TD BGCOLOR="#e3f2fd">Bleu</TD><TD>rebuild existant</TD></TR>
        <TR><TD BGCOLOR="#f3e5f5">Violet</TD><TD>diagnostic gate</TD></TR>
        <TR><TD BGCOLOR="#e8f5e9">Vert</TD><TD>promotion autorisée</TD></TR>
        <TR><TD BGCOLOR="#ffebee">Rouge</TD><TD>promotion bloquée</TD></TR>
        <TR><TD BGCOLOR="#fff3e0">Orange</TD><TD>navigation roadmap</TD></TR>
      </TABLE>
    >];
  }

  // HTML_DETAIL[phase4_8]:
  // title: Rebuild diagnostic gate
  // summary: Le candidat staging est diagnostiqué avant validation-query et avant promotion finale.
  // technical: Le gate réutilise E5CorpusDiagnosticGateConfig et evaluate_e5_corpus_diagnostic_gate() sans changer le format corpus v1.
  // ui_hint: Afficher le point de blocage entre staging et promotion avec les violations détaillées.
}
