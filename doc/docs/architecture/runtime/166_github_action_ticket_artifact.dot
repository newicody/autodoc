digraph GitHubActionTicketArtifact0166 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0166 — GitHub Action ticket artifact", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    issue [label="external repo issue/ticket
column + options", fillcolor="#e3f2fd", color="#1565c0"];
    action [label="GitHub Action
immediate producer", fillcolor="#e3f2fd", color="#1565c0"];
    ticket [label="ticket_artifact.json
ticket + column + options", fillcolor="#e8f5e9", color="#2e7d32"];
    copilot [label="copilot_preliminary_opinion.json
advisory only", fillcolor="#fff8e1", color="#f9a825"];
    bundle [label="artifact_bundle.json
same origin_frame_id", fillcolor="#e8f5e9", color="#2e7d32"];
    local [label="local fcron scan later
0167+", fillcolor="#ede7f6", color="#512da8"];

    issue -> action;
    action -> ticket;
    action -> copilot [label="optional"];
    ticket -> bundle;
    copilot -> bundle [label="hint only"];
    bundle -> local [label="download later"];
}
