digraph P1ClosedLoopOperatorComposition0158 {
    rankdir=LR;
    compound=true;

    graph [
        fontname="Arial",
        fontsize=11,
        label="0158 — P1 closed-loop operator composition",
        labelloc=t
    ];

    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    artifact [
        label="local artifact",
        fillcolor="#e3f2fd",
        color="#1565c0"
    ];

    runner0145 [
        label="0145 existing artifact runner\ntools/run_local_artifact_vector_indexing_runner.py",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    handoff0148 [
        label="0148 SQL handoff\ntools/run_sql_persistence_handoff_smoke.py",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    record0149 [
        label="0149 persistence record\ntools/run_sql_context_store_persistence_smoke.py",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    audit0150 [
        label="0150 write surface audit\ntools/run_sql_context_store_write_surface_audit.py",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    write0151 [
        label="0151/0152 controlled SQL write\nDbApiSqlContextStore.upsert_record + readback",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    result0158 [
        label="0158 closed-loop result\nwrite_status=persisted\nreadback_ok=true",
        fillcolor="#fff8e1",
        color="#f9a825"
    ];

    forbidden [
        label="forbidden parallel surfaces\nSQL worker / orchestrator / new adapters",
        fillcolor="#ffebee",
        color="#c62828"
    ];

    artifact -> runner0145;
    runner0145 -> handoff0148 [label="artifact_json + contract + result frame"];
    handoff0148 -> record0149 [label="sql_persistence_handoff.json"];
    record0149 -> audit0150 [label="persistence record"];
    audit0150 -> write0151 [label="selected method: upsert_record"];
    write0151 -> result0158 [label="persisted + readback"];

    forbidden -> runner0145 [style=dashed, label="do not replace"];
    forbidden -> write0151 [style=dashed, label="do not bypass"];
}
