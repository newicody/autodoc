digraph QdrantRecallSqlRehydrate0159 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0159 — Qdrant recall -> SQL rehydrate", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];
    recall [label="Qdrant recall payload\nprojection metadata", fillcolor="#e3f2fd", color="#1565c0"];
    extract [label="extract sql_ref\nunique_sql_context_refs_from_recall\n+ read-only fallback", fillcolor="#e8f5e9", color="#2e7d32"];
    sql [label="DbApiSqlContextStore.get_record\nSQL durable authority", fillcolor="#fff8e1", color="#f9a825"];
    report [label="rehydrated report\nJSON + Markdown", fillcolor="#ede7f6", color="#512da8"];
    forbidden [label="forbidden parallel surfaces\nnew Qdrant adapter / SQL worker / orchestrator", fillcolor="#ffebee", color="#c62828"];
    recall -> extract [label="payload.sql_ref"];
    extract -> sql [label="sql_ref"];
    sql -> report [label="hydrated record"];
    forbidden -> extract [style=dashed, label="do not replace"];
    forbidden -> sql [style=dashed, label="do not bypass"];
}
