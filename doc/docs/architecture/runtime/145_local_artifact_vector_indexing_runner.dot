digraph local_artifact_vector_indexing_runner_0145 {
  rankdir=LR;
  node [shape=box];

  artifact [label="local artifact text"];
  input [label="artifact_input.md"];
  scheduler_smoke [label="tools/run_scheduler_vector_indexing_smoke.py\nexisting smoke surface"];
  handler [label="scheduler_route_handler_minimal.py\nexisting handler"];
  routeproxy [label="route_proxy_runtime_minimal.py\nrequest/result frames"];
  vector_smoke [label="run_local_vector_indexing_live_smoke.py"];
  e5 [label="embed_e5.py --format json --full-vector"];
  qdrant [label="run_qdrant_projection_live_smoke.py --vector-json"];
  report [label="artifact_vector_indexing_report.md/json"];
  sql [label="SQLContextStore\ndurable authority by sql_ref"];

  artifact -> input;
  input -> scheduler_smoke;
  scheduler_smoke -> handler;
  handler -> routeproxy [label="vector_embedding_request"];
  routeproxy -> vector_smoke;
  vector_smoke -> e5;
  e5 -> qdrant;
  qdrant -> routeproxy [label="vector_indexing_result"];
  routeproxy -> report;
  report -> sql [label="sql_ref"];
}
