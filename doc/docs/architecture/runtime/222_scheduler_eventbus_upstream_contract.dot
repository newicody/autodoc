digraph scheduler_eventbus_upstream_contract_0222 {
  rankdir=LR;
  node [shape=box];

  scheduler [label="Scheduler\nupstream authority"];
  eventbus [label="EventBus\ncanonical transport"];
  sink [label="PassiveSupervisorSink\ndownstream observer"];
  cellular [label="CellularState\nin memory"];
  snapshot [label="snapshot\noptional"];
  audit [label="audit/replay\noptional"];

  scheduler -> eventbus [label="emits/exposes events"];
  eventbus -> sink [label="consume"];
  sink -> cellular [label="project"];
  cellular -> snapshot [style=dashed, label="optional write"];
  sink -> audit [style=dashed, label="optional audit"];

  forbidden_run [shape=octagon, label="forbidden:\nSupervisor -> Scheduler.run"];
  forbidden_dispatch [shape=octagon, label="forbidden:\nSupervisor dispatch/policy/proxy"];

  sink -> forbidden_run [style=dotted, label="must not"];
  sink -> forbidden_dispatch [style=dotted, label="must not"];
}
