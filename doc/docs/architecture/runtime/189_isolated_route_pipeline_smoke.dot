digraph isolated_route_pipeline_smoke_0189 {
  rankdir=LR;
  label="0189 Isolated route pipeline smoke";
  labelloc=t;

  context_bus [label="context.bus.jsonl"];
  queue [label="0179 scheduler.route_requests.jsonl"];
  plan [label="0184 request-to-command plan"];
