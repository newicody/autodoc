digraph qdrant_projection_adapter_0119 {
    rankdir=LR;
    node [shape=box];

    SourceCandidate [label="SourceCandidate / GitHub artifact"];
    SQLStore [label="SQLContextStore\nSQL authority on fast_pool"];
    Hydrator [label="SQLContextHydrator"];
    OpenVINO [label="OpenVINOEmbeddingAdapter"];
    Vectors [label="Embedding vectors"];
    Adapter [label="QdrantProjectionAdapter\nbounded points + injected executor"];
    Points [label="Qdrant-ready points\npayload has sql_context_ref"];
    Runtime [label="external Qdrant client adapter later\nno import in 0119"];
    Hits [label="Qdrant recall hits\nrefs only"];
    Rehydrate [label="SQLContextHydrator re-hydrates refs"];
    Draft [label="InferenceContextDraft"];
    Scheduler [label="Scheduler orchestrates jobs\ndoes not build variants"];

    SourceCandidate -> SQLStore;
    SQLStore -> Hydrator;
    Hydrator -> OpenVINO;
    OpenVINO -> Vectors;
    Vectors -> Adapter;
    Adapter -> Points;
    Adapter -> Runtime [style=dashed, label="executor membrane"];
    Runtime -> Hits [style=dashed];
    Hits -> Rehydrate [label="sql_context_ref"];
    Rehydrate -> SQLStore;
    Rehydrate -> Draft;
    Scheduler -> Adapter [style=dashed, label="job carries refs only"];
}
