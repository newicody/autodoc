digraph runtime_surface_eventbus_upstream_contract_0223 {
  rankdir=LR;

  scheduler [label="Scheduler
upstream authority", shape=box];
  route_proxy [label="RouteProxy
observed surface", shape=box];
  control_proxy [label="ControlProxy
observed surface", shape=box];
  shm [label="SHM ring/status
observed surface", shape=box];
  policy [label="Policy gate
decision authority", shape=box];
  eventbus [label="EventBus
canonical observation transport", shape=ellipse];
  sink [label="PassiveSupervisorSink
downstream-only", shape=box];
  cellular [label="CellularState
in-memory projection", shape=box];
  snapshot [label="snapshot
optional", shape=note];
  audit [label="events.jsonl
optional audit/replay", shape=note];

  scheduler -> eventbus [label="emits/exposes events"];
  route_proxy -> eventbus [label="route events"];
  control_proxy -> eventbus [label="control events"];
  shm -> eventbus [label="safe status events"];
  policy -> eventbus [label="decision events"];
  eventbus -> sink [label="consume"];
  sink -> cellular [label="project"];
  cellular -> snapshot [label="write on demand"];
  sink -> audit [label="optional audit"];

  sink -> scheduler [label="forbidden", style=dashed, color=red];
  sink -> route_proxy [label="forbidden control", style=dashed, color=red];
  sink -> control_proxy [label="forbidden control", style=dashed, color=red];
  sink -> shm [label="forbidden write/mmap authority", style=dashed, color=red];
  sink -> policy [label="forbidden decision", style=dashed, color=red];
