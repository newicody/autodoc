digraph data_surface_eventbus_upstream_contract_0224 {
  rankdir=LR;

  scheduler [label="Scheduler\nupstream authority"];
  github [label="GitHub artifact flow\nobserved source"];
  source_candidate [label="SourceCandidate flow\nobserved source"];
  sql [label="SQL\ndurable authority"];
  qdrant [label="Qdrant\nprojection/recall"];
  rehydrate [label="Rehydrate\ncontext load"];
  pushback [label="Pushback\nstatus/result"];
  bus [label="EventBus\ncanonical transport"];
  supervisor [label="PassiveSupervisorSink\ndownstream-only"];
  cellular [label="CellularState\nin-memory projection"];
  snapshot [label="snapshot\noptional"];
  audit [label="events.jsonl\noptional audit/replay"];

  scheduler -> bus;
  github -> bus;
  source_candidate -> bus;
  sql -> bus;
  qdrant -> bus;
  rehydrate -> bus;
  pushback -> bus;
  bus -> supervisor;
  supervisor -> cellular;
  cellular -> snapshot [style=dashed];
  supervisor -> audit [style=dashed];

  supervisor -> github [label="forbidden mutation", color=red, style=dotted];
  supervisor -> sql [label="forbidden write/read", color=red, style=dotted];
  supervisor -> qdrant [label="forbidden write/query", color=red, style=dotted];
  supervisor -> scheduler [label="forbidden Scheduler.run", color=red, style=dotted];
}
