digraph GitHubProjectV2SourceCandidateGate0272 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0272-r7 — Project-native SourceCandidate operator gate", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#e8f5e9", color="#2e7d32"];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    Project [label="GitHub ProjectV2 newicody/2\nquery-only source"];
    Snapshot [label="r3 immutable snapshot"];
    ChangeSet [label="r4 local change set"];
    Handoff [label="r6 SourceCandidate\nhandoff batch"];
    Gate [label="r7 explicit operator decision\nreuses SourceCandidateDecision"];
    Record [label="immutable gate record\ncontent-addressed"];
    Durable [label="r8 future\nSQL authority -> Qdrant sql_ref", style="rounded,dashed"];
    Actions [label="optional repository-Issue\nActions artifact bridge", fillcolor="#fff8e1", color="#f9a825"];

    Project -> Snapshot [label="GraphQL query only"];
    Snapshot -> ChangeSet [label="local compare"];
    ChangeSet -> Handoff [label="bounded conversion"];
    Handoff -> Gate [label="candidate_id + decision_id"];
    Gate -> Record [label="inspect / reject / promote / merge"];
    Record -> Durable [style=dashed, label="promote or merge only"];
    Actions -> Handoff [style=dotted, label="separate optional path"];

    Gate -> Project [style=dashed, dir=none, label="no network / mutation"];
    Gate -> Durable [style=dashed, dir=none, label="no SQL/Qdrant write in r7"];
}
