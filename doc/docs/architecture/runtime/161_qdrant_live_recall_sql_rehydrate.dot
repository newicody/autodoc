digraph QdrantLiveRecallSqlRehydrate0161 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0161 — Qdrant live recall -> SQL rehydrate", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    query [label="query embedding JSON\nE5/OpenVINO existing CLI", fillcolor="#e3f2fd", color="#1565c0"];
    qdrant [label="Qdrant REST /points/search\nlive recall", fillcolor="#e8f5e9", color="#2e7d32"];
    payload [label="recall payload\nsql_ref pointers", fillcolor="#e8f5e9", color="#2e7d32"];
    rehydrate [label="0159 existing SQL rehydrate\nDbApiSqlContextStore.get_record", fillcolor="#fff8e1", color="#f9a825"];
    result [label="hydrated context\nJSON + Markdown", fillcolor="#ede7f6", color="#512da8"];
    forbidden [label="forbidden parallel surfaces\nnew adapters / worker / orchestrator", fillcolor="#ffebee", color="#c62828"];

    query -> qdrant [label="vector"];
    qdrant -> payload [label="hits"];
    payload -> rehydrate [label="sql_ref"];
    rehydrate -> result [label="SQL authority"];

    forbidden -> qdrant [style=dashed, label="do not replace"];
    forbidden -> rehydrate [style=dashed, label="reuse 0159"];
}
