digraph all_surfaces_passive_supervisor_smoke_0234 {
  rankdir=LR;
  node [shape=box];

  scheduler [label="Scheduler\nupstream authority"];
  runtime [label="RouteProxy / ControlProxy / SHM / Policy\nruntime surfaces"];
  data [label="GitHub / SourceCandidate / SQL / Qdrant / Rehydrate / Pushback\ndata surfaces"];
  bus [label="EventBus event contract"];
  sink [label="PassiveSupervisorSink\ndownstream-only"];
  cells [label="CellularState"];
  snapshot [label="snapshot optionnel"];
  audit [label="audit/replay optionnel"];

  scheduler -> bus;
  runtime -> bus;
  data -> bus;
  bus -> sink;
  sink -> cells;
  cells -> snapshot;
  sink -> audit [style=dashed];
}
