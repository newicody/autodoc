digraph GitHubProjectV2ChangeHandoff0272 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0272-r6 — ProjectV2 change set to local SourceCandidate handoffs", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#eceff1", color="#455a64"];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    Project [label="GitHub ProjectV2 newicody/2\nremote workflow surface"];
    Snapshot [label="0272-r3\nquery-only immutable snapshot"];
    ChangeSet [label="0272-r4\nlocal immutable change set"];
    CandidateBuilder [label="0272-r6\nbounded local conversion\nreuses SourceCandidate"];
    HandoffBatch [label="immutable handoff batch\nadded / changed / removed advisory"];
    OperatorGate [label="0272-r7 future\noperator acceptance gate", style="rounded,dashed"];
    Sql [label="0272-r8 future\nSQL durable authority", style="rounded,dashed"];
    Qdrant [label="0272-r8 future\nQdrant payload.sql_ref", style="rounded,dashed"];
    Actions [label="GitHub Actions artifacts\nsecondary issue-event path", fillcolor="#fff8e1", color="#f9a825"];

    Project -> Snapshot [label="GraphQL query only"];
    Snapshot -> ChangeSet [label="local compare"];
    ChangeSet -> CandidateBuilder [label="change_set_ref"];
    CandidateBuilder -> HandoffBatch [label="max_handoffs bounded"];
    HandoffBatch -> OperatorGate [style=dashed, label="requires decision"];
    OperatorGate -> Sql [style=dashed, label="accepted only"];
    Sql -> Qdrant [style=dashed, label="sql_ref"];
    Actions -> HandoffBatch [style=dotted, label="separate future merge"];

    CandidateBuilder -> Project [style=dashed, dir=none, label="no network / no mutation"];
    CandidateBuilder -> Sql [style=dashed, dir=none, label="no write in r6"];
    CandidateBuilder -> Qdrant [style=dashed, dir=none, label="no projection in r6"];
}
