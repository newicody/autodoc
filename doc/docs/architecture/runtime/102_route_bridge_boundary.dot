digraph route_bridge_boundary_0112 {
  graph [
    label="0112 Route bridge boundary — ROOT_GRAPH: doc/docs/architecture/00_global.dot — root-attached runtime overlay",
    labelloc="t",
    fontsize=18
  ];
  rankdir=LR;
  node [shape=box, style="rounded"];

  scheduler_path [label="Scheduler -> PolicyEngine -> PriorityQueue -> Scheduler.run() -> Dispatcher -> Handler"];
  handler [label="Handler -> RouteRuntimeManager"];
  manager [label="RouteRuntimeManager\nControlFS + mmap/eventfd data plane"];
  boundary [label="RouteBridgeBoundary\ndeclaration only\nno active I/O in 0112"];
  network [label="future NetworkBridge\nnot implemented"];
  hardware [label="future HardwareBridge\nnot implemented"];
  eventbus [label="EventBus observation only"];

  scheduler_path -> handler;
  handler -> manager;
  // RouteRuntimeManager -> RouteBridgeBoundary
  manager -> boundary [label="future bridge declaration"];
  boundary -> network [style=dashed, label="later"];
  boundary -> hardware [style=dashed, label="later"];
  manager -> eventbus [style=dotted, label="facts only"];

  guardrails [shape=note, label="No sockets opened\nNo devices opened\nNo ControlProxyBus / RouteBus / VisualizationBus\nNo priority or policy decision\nRoute mmap/eventfd remains data plane, not EventBus"];
  boundary -> guardrails [style=dotted];
}
