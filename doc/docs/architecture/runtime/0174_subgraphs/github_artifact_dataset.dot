digraph github_artifact_dataset_0174 {
  rankdir=LR;
  label="0174 subgraph: github-artifact-dataset";
  labelloc=t;

  project [label="GitHub Project / issue / idea repo\nworkflow surface"];
  action [label="GitHub Action"];
  ticket [label="ticket artifact"];
  opinion [label="Copilot preliminary opinion artifact\nplanned"];
  fetch [label="read-only artifact fetch\npartial"];
  dataset [label="configured server dataset\nlocal/server surface"];
  raw [label="raw"];
  index [label="index/history"];
  queue [label="queue / scheduler-addressable work"];
  bus_fact [label="future bus-compatible observation facts"];

  project -> action;
  action -> ticket;
  action -> opinion;
  ticket -> fetch;
  opinion -> fetch;
  fetch -> dataset;
  dataset -> raw;
  dataset -> index;
  dataset -> queue;
  queue -> bus_fact [label="facts only / future bridge"];

  fetch -> project [label="forbidden mutation in fetch path", style=dashed];
  dataset -> project [label="publication later only", style=dashed];
}
