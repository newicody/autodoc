digraph controlproxy_routeproxy_0174 {
  rankdir=LR;
  label="0174 subgraph: controlproxy-routeproxy";
  labelloc=t;

  scheduler [label="Scheduler-approved route demand"];
  controlproxy [label="ControlProxy\nfast gate / leases / hints"];
  routeproxy [label="RouteProxyRuntime\nframes / permits"];
  shm [label="/dev/shm or explicit runtime root"];
  frames [label="route frames"];
  bus [label="event.bus/context.bus facts"];
  policy [label="policy/zone authority"];

  policy -> scheduler;
  scheduler -> controlproxy;
  controlproxy -> routeproxy;
  routeproxy -> shm;
  shm -> frames;
  controlproxy -> bus [label="facts"];
  routeproxy -> bus [label="facts"];

  controlproxy -> policy [label="forbidden policy decision", style=dashed];
  bus -> scheduler [label="forbidden command path", style=dashed];
}
