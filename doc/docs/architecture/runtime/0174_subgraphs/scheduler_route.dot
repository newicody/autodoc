digraph scheduler_route_0174 {
  rankdir=LR;
  label="0174 subgraph: scheduler-route";
  labelloc=t;

  scheduler [label="Scheduler / policy / zone\nauthority"];
  request [label="SchedulerRouteRequest\nauthorized=True + policy_decision_id"];
  handshake [label="prepare_route_for_scheduler(...)"];
  adapter [label="handle_scheduler_route_request(...)"];
  handler [label="SchedulerRouteHandlerCommand"];
  route_runtime [label="RouteProxyRuntime frame IO"];
  bus [label="event.bus/context.bus facts\nobservation-only"];

  scheduler -> request;
  request -> handshake;
  handshake -> adapter;
  adapter -> handler;
  handler -> route_runtime;
  adapter -> bus [label="adapter facts"];
  handshake -> bus [label="handshake facts"];
  route_runtime -> bus [label="runtime facts"];

  bus -> scheduler [label="forbidden command path", style=dashed];
}
