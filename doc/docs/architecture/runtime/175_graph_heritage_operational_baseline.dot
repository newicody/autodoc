digraph graph_heritage_operational_baseline_0175 {
  rankdir=LR;
  label="0175 graph heritage and operational baseline";
  labelloc=t;

  subgraph cluster_heritage {
    label="Heritage layer";
    old_global [label="old 00_global.dot\nheritage / stale-doc"];
    old_subgraphs [label="old subgraphs\norientation / historical"];
    changelog_holes [label="changelog holes\ndocumentation gap"];
    future_ideas [label="future ideas\ninspiration"];
  }

  subgraph cluster_baseline {
    label="Operational baseline layer";
    rebuilt_0174 [label="0174 rebuilt graph draft\nimmediate baseline"];
    code_surfaces [label="working code surfaces"];
    tests_rules [label="tests / code-rules"];
    chain [label="validated 0162..0174 chain"];
  }

  subgraph cluster_immediate_chain {
    label="Immediate work chain";
    github [label="GitHub artifacts / dataset"];
    scheduler_work [label="scheduler-addressable work"];
    bus_facts [label="event.bus/context.bus facts"];
    bus_adapter [label="bus_visualization_adapter"];
    dot_vispy [label="DOT / VisPy/browser projection"];
  }

  old_global -> future_ideas [label="inspires"];
  old_subgraphs -> future_ideas [label="inspires"];
  changelog_holes -> future_ideas [label="context"];

  code_surfaces -> rebuilt_0174 [label="primary evidence"];
  tests_rules -> rebuilt_0174 [label="guards"];
  chain -> rebuilt_0174 [label="current direction"];

  rebuilt_0174 -> github;
  github -> scheduler_work;
  scheduler_work -> bus_facts [label="facts only"];
  bus_facts -> bus_adapter [label="read"];
  bus_adapter -> dot_vispy [label="projection"];

  old_global -> rebuilt_0174 [label="must not override", style=dashed];
  dot_vispy -> scheduler_work [label="forbidden command path", style=dashed];
  github -> dot_vispy [label="forbidden direct writer", style=dashed];
}
