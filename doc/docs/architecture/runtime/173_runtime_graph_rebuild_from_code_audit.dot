digraph runtime_graph_rebuild_from_code_audit_0173 {
  rankdir=LR;
  label="0173 runtime graph rebuild from code audit";
  labelloc=t;

  subgraph cluster_sources {
    label="Rebuild source priority";
    code [label="working code surfaces"];
    tests [label="passing tests / rules"];
    manifests [label="manifests / patch queue"];
    chain [label="validated 0162..0172 chain"];
    docs [label="docs / changelogs\nsupporting context"];
    stale_dot [label="stale DOT graphs\nhistorical input"];
  }

  subgraph cluster_rebuilt_global {
    label="Rebuilt global and required subgraphs";
    global [label="global"];
    runtime_bus [label="runtime-bus"];
    scheduler_route [label="scheduler-route"];
    github_dataset [label="github-artifact-dataset"];
    vector_sql_qdrant [label="vector-sql-qdrant"];
    controlproxy_routeproxy [label="controlproxy-routeproxy"];
    activity_vispy [label="activity-graph-vispy"];
    docs_provenance [label="docs-provenance"];
  }

  subgraph cluster_canonical_chain {
    label="Canonical activity chain";
    github [label="GitHub Project / issue / idea repo"];
    actions [label="GitHub Actions artifacts"];
    dataset [label="configured server dataset"];
    scheduler [label="Scheduler / policy / zone"];
    route [label="scheduler route / ControlProxy / RouteProxy"];
    openvino [label="OpenVINO/E5 / specialists"];
    qdrant [label="Qdrant projection"];
    sql [label="SQL durable store / rehydrate"];
    review [label="review/publication artifact"];
  }

  subgraph cluster_observation {
    label="Observation and visualization";
    event_bus [label="event.bus facts"];
    context_bus [label="context.bus facts"];
    bus_adapter [label="bus_visualization_adapter"];
    dot_support [label="DOT support representation"];
    vispy [label="VisPy/browser view"];
  }

  code -> global [label="primary"];
  tests -> global [label="validation"];
  manifests -> global [label="changed files"];
  chain -> global [label="planned/current chain"];
  docs -> global [label="context"];
  stale_dot -> global [label="audit only", style=dashed];

  global -> runtime_bus;
  global -> scheduler_route;
  global -> github_dataset;
  global -> vector_sql_qdrant;
  global -> controlproxy_routeproxy;
  global -> activity_vispy;
  global -> docs_provenance;

  github -> actions;
  actions -> dataset;
  dataset -> scheduler [label="scheduler-addressable work"];
  scheduler -> route;
  route -> openvino [label="when scheduled"];
  openvino -> qdrant [label="projection"];
  qdrant -> sql [label="sql_ref rehydrate"];
  sql -> review;

  route -> event_bus [label="facts only"];
  route -> context_bus [label="facts only"];
  dataset -> event_bus [label="future facts only"];
  event_bus -> bus_adapter [label="read"];
  context_bus -> bus_adapter [label="snapshot"];
  bus_adapter -> dot_support [label="projection"];
  dot_support -> vispy [label="navigation / zoom / modes"];

  dot_support -> scheduler [label="forbidden command path", style=dashed];
  dataset -> vispy [label="forbidden direct writer", style=dashed];
}
