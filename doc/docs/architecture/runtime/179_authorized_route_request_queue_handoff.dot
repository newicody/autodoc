digraph authorized_route_request_queue_handoff_0179 {
  rankdir=LR;
  label="0179 Authorized route request queue handoff";
  labelloc=t;

  context_bus [label="context.bus.jsonl"];
  reader0178 [label="0178 context bus scheduler intake reader"];
