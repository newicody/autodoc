digraph sql_context_hydrator_0117 {
  rankdir=LR;
  node [shape=box];

  Artifact [label="artifact / objective / sql:* refs"];
  SQLContextStore [label="SQLContextStore\ndurable authority"];
  SQLContextHydrator [label="SQLContextHydrator\nbounded read side"];
  Fragments [label="Hydrated fragments\nref + title + bounded body"];
  Reducer [label="ContextReducer\nfuture reduction"];
  Draft [label="InferenceContextDraft"];
  OpenVINO [label="OpenVINO adapter\nembeddings only"];
  Qdrant [label="Qdrant projection\nvector search by sql_id"];
  Specialist [label="specialist / LLM boundary"];
  Scheduler [label="Scheduler orchestrates jobs\ndoes not hydrate itself"];

  Artifact -> SQLContextStore;
  SQLContextStore -> SQLContextHydrator [label="read sql:* refs"];
  SQLContextHydrator -> Fragments;
  Fragments -> Reducer;
  Reducer -> Draft;
  Fragments -> OpenVINO [style=dashed, label="later adapter"];
  OpenVINO -> Qdrant [style=dashed, label="vectors + sql_id"];
  Qdrant -> SQLContextHydrator [style=dashed, label="recalled sql:* refs"];
  Draft -> Specialist;
  Scheduler -> SQLContextHydrator [style=dashed, label="job carries refs only"];
}
