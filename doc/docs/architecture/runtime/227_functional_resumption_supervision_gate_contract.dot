digraph functional_resumption_supervision_gate_contract_0227 {
  rankdir=LR;
  node [shape=box];

  Scheduler [label="Scheduler\nupstream authority"];
  RuntimeSurfaces [label="RouteProxy / ControlProxy / SHM / Policy"];
  DataSurfaces [label="GitHub / SourceCandidate / SQL / Qdrant / Rehydrate / Pushback"];
  EventBus [label="EventBus\ncanonical live transport"];
  Gate [label="0227 functional resumption gate\naudit + reuse required"];
  Sink [label="PassiveSupervisorSink\ndownstream-only"];
  State [label="CellularState\nin-memory projection"];
  Snapshot [label="snapshot\noptional output"];
  Audit [label="events.jsonl\noptional audit/replay"];
  VisPy [label="VisPy later\nview only"];

  Scheduler -> EventBus;
  RuntimeSurfaces -> EventBus;
  DataSurfaces -> EventBus;
  EventBus -> Gate;
  Gate -> Sink;
  Sink -> State;
  State -> Snapshot [style=dashed];
  Sink -> Audit [style=dashed];
  Snapshot -> VisPy [style=dashed];
  State -> VisPy [style=dashed];

  ForbiddenBus [label="new/parallel EventBus", shape=octagon];
  ForbiddenRun [label="Scheduler.run / wrapper", shape=octagon];
  ForbiddenFiles [label="mandatory status/events/snapshot path", shape=octagon];
  ForbiddenControl [label="proxy / SHM / policy control", shape=octagon];
  ForbiddenData [label="SQL/Qdrant/GitHub mutation", shape=octagon];

  Gate -> ForbiddenBus [style=dotted, label="reject"];
  Gate -> ForbiddenRun [style=dotted, label="reject"];
  Gate -> ForbiddenFiles [style=dotted, label="reject"];
  Gate -> ForbiddenControl [style=dotted, label="reject"];
  Gate -> ForbiddenData [style=dotted, label="reject"];
}
