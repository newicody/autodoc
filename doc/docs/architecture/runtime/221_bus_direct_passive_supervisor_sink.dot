digraph bus_direct_passive_supervisor_sink_0221 {
  rankdir=LR;

  scheduler [label="Scheduler\nupstream orchestration authority"];
  routeproxy [label="RouteProxy / ControlProxy\nupstream event emitters"];
  shm [label="SHM status/ring surfaces\nupstream observed state"];
  policy [label="Policy decisions\nupstream gate events"];
  eventbus [label="EventBus\ncanonical runtime event transport"];
  sink [label="PassiveSupervisorSink\ndownstream-only accept(event)"];
  state [label="CellularState\nin-memory projection"];
  snapshot [label="snapshot.json\noptional human surface"];
  audit [label="events.jsonl\noptional audit/replay"];
  vispy [label="VisPy later\nview adapter only", style=dashed];

  scheduler -> eventbus;
  routeproxy -> eventbus;
  shm -> eventbus;
  policy -> eventbus;
  eventbus -> sink;
  sink -> state;
  state -> snapshot [style=dashed];
  sink -> audit [style=dashed];
  snapshot -> vispy [style=dashed];

  sink -> scheduler [label="forbidden: Scheduler.run/control", color=red, style=dotted];
  sink -> routeproxy [label="forbidden: proxy control", color=red, style=dotted];
  sink -> policy [label="forbidden: policy decision", color=red, style=dotted];
}
