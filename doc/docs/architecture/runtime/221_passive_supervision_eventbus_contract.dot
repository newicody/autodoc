digraph passive_supervision_eventbus_contract_0221 {
  rankdir=LR;

  scheduler [label="Scheduler\nupstream authority"];
  routeproxy [label="RouteProxy\nupstream emitter"];
  controlproxy [label="ControlProxy\nupstream emitter"];
  shm [label="SHM ring/status\nupstream emitter"];
  policy [label="Policy gate\nupstream authority"];
  github [label="GitHub artifacts\nobserved surface"];
  sql [label="SQL/Qdrant/Rehydrate\nobserved surfaces"];

  eventbus [label="EventBus\ncanonical event transport", shape=box];
  supervisor [label="PassiveSupervisorSink\ndownstream-only", shape=box];
  cellular [label="CellularState\nin memory", shape=box];
  snapshot [label="snapshot.json\noptional output", style=dashed];
  audit [label="events.jsonl\noptional audit/replay", style=dashed];
  vispy [label="VisPy view\nfuture optional view", style=dashed];

  scheduler -> eventbus;
  routeproxy -> eventbus;
  controlproxy -> eventbus;
  shm -> eventbus;
  policy -> eventbus;
  github -> eventbus;
  sql -> eventbus;

  eventbus -> supervisor;
  supervisor -> cellular;
  cellular -> snapshot [style=dashed];
  supervisor -> audit [style=dashed];
  snapshot -> vispy [style=dashed];

  supervisor -> scheduler [label="forbidden", color=red, style=dotted];
  supervisor -> routeproxy [label="forbidden", color=red, style=dotted];
  supervisor -> policy [label="forbidden", color=red, style=dotted];
}
