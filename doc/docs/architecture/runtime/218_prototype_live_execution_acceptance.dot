digraph prototype_live_execution_acceptance_0218 {
  rankdir=LR;
  label="0218 Prototype live execution acceptance";
  labelloc=t;

  plan [label="prototype_live_execution_plan.json"];
  sqlwrite [label="SQL sqlite write"];
  qcreate [label="Qdrant collection create/recreate"];
  upsert [label="Qdrant upsert"];
  query [label="Qdrant query"];
  sqlread [label="SQL read by sql_ref"];
  rehydrate [label="rehydrate"];
  response [label="prototype_live_response.json"];
  acceptance [label="prototype_live_execution_acceptance.json"];

  plan -> sqlwrite;
  sqlwrite -> qcreate;
  qcreate -> upsert;
  upsert -> query;
  query -> sqlread [label="payload.sql_ref"];
  sqlread -> rehydrate;
  rehydrate -> response;
  response -> acceptance [label="prototype_success"];
}
