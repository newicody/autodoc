digraph openvino_embedding_adapter_0118 {
    rankdir=LR;
    node [shape=box];

    SourceCandidate [label="SourceCandidate / GitHub artifact"];
    SQLStore [label="SQLContextStore\nSQL authority on fast_pool"];
    Hydrator [label="SQLContextHydrator"];
    Fragments [label="Hydrated SQL fragments"];
    Adapter [label="OpenVINOEmbeddingAdapter\nbounded texts + injected executor"];
    Runtime [label="src/inference/openvino_runtime.py\nexplicit OpenVINO runtime boundary"];
    Vectors [label="Embedding vectors"];
    QdrantLater [label="Qdrant projection adapter later\nnot authority"];
