digraph context_variability_relock_0113 {
  graph [
    label="0113 Context variability relock — ROOT_GRAPH: doc/docs/architecture/00_global.dot — root-attached context/runtime overlay, not an isolated graph",
    labelloc=t,
    fontsize=18
  ];
  rankdir=LR;
  node [shape=box, fontsize=11];
  edge [fontsize=10];

  objective [label="Objective\nproduce solutions quickly\nby varying context"];
  request [label="ContextRequest"];
  collector [label="ContextCollector"];
  variants [label="ContextVariant[]\nbounded alternatives"];
  reducer [label="ContextReducer"];
  snapshot [label="GlobalContextSnapshot"];
  inference [label="InferenceContext"];
  specialist [label="specialist / LLM / MVTC"];
  solution [label="solution candidate / feedback"];

  objective -> request;
  request -> collector;
  collector -> variants;
  variants -> reducer;
  reducer -> snapshot;
  snapshot -> inference;
  inference -> specialist;
  specialist -> solution;

  sql [label="SQLContextStore\ndurable context authority"];
  gate [label="ContextGate / TaskContext\ncontext selection authority"];
  qdrant [label="Qdrant\nvector projection and retrieval\nnot context authority"];
  openvino [label="OpenVINO\nlocal embedding/inference worker"];
  llm [label="LLM adapter\nspecialist/enricher consumes InferenceContext"];

  sql -> collector [label="hydrate facts/docs/artifacts"];
  sql -> gate [label="stable IDs and structured context"];
  gate -> reducer [label="selection constraints"];
  variants -> openvino [label="embed context material"];
  openvino -> qdrant [label="vectors + SQL refs"];
  qdrant -> collector [label="retrieval returns refs"];
  inference -> llm [label="bounded prompt context"];
  llm -> solution [label="candidate artifact"];

  scheduler [label="Scheduler\norchestrates context variation jobs"];
  policy [label="PolicyEngine\nminimal admission guardrail"];
  queue [label="PriorityQueue\ndeterministic order"];
  dispatcher [label="Dispatcher\nEventType -> Handler only"];
  handler [label="Handler\nthin adapter"];

  scheduler -> policy -> queue -> dispatcher -> handler;
  handler -> collector [label="context jobs"];
  handler -> reducer [label="reduce jobs"];
  handler -> specialist [label="specialist jobs"];

  eventbus [label="EventBus\nobservation only"];
  dataplane [label="Route mmap/eventfd\ndata plane, not EventBus"];
  route [label="ControlProxy / RouteRuntimeManager\nsecondary data plane"];

  route -> dataplane;
  dataplane -> sql [label="runtime facts may be ingested"];
  route -> eventbus [label="facts only"];

  guardrails [shape=note, label="Policy/security/zone are guardrails, not the objective\nNo CapabilityRequest security-first direction\nNo second bus\nNo route-journal-first AI pipeline"];
  objective -> guardrails [style=dotted];
}
