digraph cellular_topology_eventbus_supervision_contract_0225 {
  rankdir=LR;
  node [shape=box];

  scheduler [label="Scheduler\nupstream authority"];
  route_proxy [label="RouteProxy\nupstream events"];
  control_proxy [label="ControlProxy\nupstream events"];
  shm [label="SHM ring/status\nupstream events"];
  policy [label="Policy gate\nupstream decisions"];
  data [label="GitHub / SourceCandidate / SQL / Qdrant\nrehydrate / pushback events"];

  bus [label="EventBus\ncanonical transport"];
  sink [label="PassiveSupervisorSink\ndownstream-only"];
  state [label="CellularState\nin memory"];
  topology [label="CellularTopology\nlocality + observed movement"];
  snapshot [label="optional snapshot"];
  audit [label="optional audit/replay"];
  vispy [label="future VisPy view\nread-only"];

  scheduler -> bus;
  route_proxy -> bus;
  control_proxy -> bus;
  shm -> bus;
  policy -> bus;
  data -> bus;

  bus -> sink;
  sink -> state;
  state -> topology;
  topology -> snapshot [style=dashed];
  topology -> audit [style=dashed];
  topology -> vispy [style=dashed];

  sink -> scheduler [label="no control", style=dotted];
  sink -> route_proxy [label="no control", style=dotted];
  sink -> shm [label="no write", style=dotted];
  sink -> policy [label="no decision", style=dotted];
  sink -> data [label="no mutation", style=dotted];
}
