digraph GithubExternalArtifactSmoke0162 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0162 — GitHub external artifact smoke", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    dev_repo [label="Autodoc dev repo\ninfrastructure only", fillcolor="#ffebee", color="#c62828"];
    github_project [label="external GitHub Project\nideas / Kanban", fillcolor="#e3f2fd", color="#1565c0"];
    action [label="GitHub Action / Copilot\nartifact producer", fillcolor="#e3f2fd", color="#1565c0"];
    smoke [label="0162 local boundary smoke\nno network / no SQL / no Qdrant", fillcolor="#fff8e1", color="#f9a825"];
    review [label="publication review packet\nlocal only", fillcolor="#e8f5e9", color="#2e7d32"];
    future [label="future reviewed GitHub adapter\npublish after review", fillcolor="#ede7f6", color="#512da8"];

    github_project -> action [label="new idea"];
    action -> smoke [label="artifact fixture"];
    smoke -> review [label="response packet"];
    review -> future [label="after review"];

    dev_repo -> smoke [style=dashed, color="#c62828", label="must not be ingested"];
}
