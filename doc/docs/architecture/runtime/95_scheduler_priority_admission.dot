digraph scheduler_priority_admission_0105 {
  graph [label="0105 Scheduler priority/admission lock", labelloc="t", fontsize=20];
  rankdir=LR;
  node [shape=box, style="rounded"];

  component [label="Component / Specialist\nproduces typed command or event"];
  emit [label="Scheduler.emit()\nentry to kernel path"];
  policy [label="PolicyEngine\nminimal admission before queue"];
  queue [label="PriorityQueue\nonly deterministic execution ordering"];
  run [label="Scheduler.run()\nloop + time + dequeue"];
  dispatcher [label="Dispatcher\nEventType -> Handler only"];
  handler [label="Handler\nthin adapter"];
  specialist [label="Specialist branch\nbusiness reasoning / strategy"];
  route_manager [label="RouteRuntimeManager\nControlFS + mmap/eventfd runtime"];
  eventbus [label="EventBus\nobservation only"];
  dataplane [label="mmap/eventfd\ndata plane, not EventBus"];

  component -> emit;
  emit -> policy;
  policy -> queue;
  queue -> run;
  run -> dispatcher;
  dispatcher -> handler;
  handler -> specialist [label="business capability"];
  handler -> route_manager [label="route runtime capability"];
  route_manager -> dataplane;
  dispatcher -> eventbus [style=dashed, label="observable fact copy"];
  route_manager -> eventbus [style=dashed, label="future observable facts only"];

  policy -> specialist [style=dotted, label="does not choose strategy"];
  dispatcher -> route_manager [style=dotted, label="no direct runtime logic"];
}
