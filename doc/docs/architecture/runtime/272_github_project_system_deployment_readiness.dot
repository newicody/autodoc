digraph github_project_system_deployment_readiness_0272 {
  rankdir=LR;
  node [shape=box];

  config [label="existing .ini configuration"];
  local [label="local files + workflow policy checks"];
  project [label="ProjectV2 identity query\nGraphQL query only"];
  workflow [label="workflow metadata + content\nREST GET only"];
  builder [label="builder content\nREST GET only"];
  result [label="typed readiness report"];

  config -> local;
  config -> project;
  config -> workflow;
  config -> builder;
  local -> result;
  project -> result;
  workflow -> result;
  builder -> result;

  forbidden [label="no install / deploy / dispatch / mutation", style=dashed];
  forbidden -> result [style=dashed, arrowhead=none];
}
