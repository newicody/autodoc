digraph scheduler_owned_runtime_component_lifecycle_0254 {
  rankdir=LR;

  openrc [label="OpenRC\nprocess supervisor"];
  launcher [label="launcher\nbootstrap only"];
  scheduler [label="Scheduler\nruntime owner"];

  registry [label="ComponentRegistry"];
  eventbus [label="EventBus\nobservation only"];
  sql [label="SQLContextStore"];
  openvino [label="OpenVINOEmbeddingService"];
  qdrant [label="QdrantProjectionStore"];
  github [label="GitHubArtifactExchange"];
  supervisor [label="PassiveSupervisorSink"];

  openrc -> launcher;
  launcher -> scheduler;
  scheduler -> registry;
  registry -> eventbus;
  registry -> sql;
  registry -> openvino;
  registry -> qdrant;
  registry -> github;
  registry -> supervisor;
  eventbus -> supervisor [label="facts only"];
  sql -> openvino -> qdrant [label="projection path"];
}
