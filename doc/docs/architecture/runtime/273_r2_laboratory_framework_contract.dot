digraph LaboratoryFrameworkContract0273R2 {
  rankdir=LR;
  node [shape=box];

  DurableCandidate [label="durable SourceCandidate"];
  Orientation [label="ServerOrientation"];
  ContractsR2 [label="missipy.laboratory.v1 contracts"];
  ExistingRegistry [label="existing Scheduler-owned registry 0257"];
  ProviderR3 [label="0273-r3 fake provider (inactive now)"];
  Scheduler [label="Scheduler.emit / Policy / Queue"];
  Handler [label="Dispatcher / Handler"];
  Result [label="immutable LaboratoryVisitResult"];
  EventBus [label="EventBus observation-only"];
  Supervisor [label="PassiveSupervisor / Cell Lens / VisPy"];

  DurableCandidate -> Orientation;
  Orientation -> ContractsR2;
  ContractsR2 -> Scheduler;
  ContractsR2 -> ExistingRegistry [label="inactive binding plan"];
  ExistingRegistry -> ProviderR3 [style=dashed, label="future r3"];
  Scheduler -> Handler;
  Handler -> ProviderR3 [style=dashed, label="future bounded call"];
  ProviderR3 -> Result [style=dashed];
  Result -> EventBus [style=dashed, label="facts only"];
  EventBus -> Supervisor;

  Forbidden [shape=note, label="No LaboratoryManager / no parallel registry / no Scheduler.run change"];
  ContractsR2 -> Forbidden [style=dotted, arrowhead=none];
}
