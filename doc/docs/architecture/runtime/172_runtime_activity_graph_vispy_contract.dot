digraph runtime_activity_graph_vispy_contract_0172 {
  rankdir=LR;
  label="0172 runtime activity graph / VisPy contract";
  labelloc=t;

  subgraph cluster_sources {
    label="Sources";
    github [label="GitHub Actions artifacts"];
    dataset [label="Configured server dataset"];
    scheduler [label="Scheduler / policy / zone"];
  }

  subgraph cluster_existing_bus {
    label="Existing observation bus";
    event_bus [label="event.bus facts"];
    context_bus [label="context.bus facts"];
    shm_schema [label="runtime.shm_runtime_schema"];
  }

  subgraph cluster_projection {
    label="Projection support";
    bus_adapter [label="bus_visualization_adapter"];
    dot_contract [label="DOT activity graph contract"];
    vispy [label="VisPy/browser view"];
  }

  subgraph cluster_modes {
    label="View modes";
    architecture [label="architecture"];
    runtime [label="runtime"];
    artifact [label="artifact"];
    scheduler_mode [label="scheduler"];
    bus_mode [label="bus"];
    score [label="score"];
    population [label="population"];
    debug [label="debug"];
  }

  github -> dataset [label="fetch/read-only"];
  dataset -> event_bus [label="future facts only"];
  dataset -> context_bus [label="future context facts only"];
  scheduler -> event_bus [label="facts only"];
  scheduler -> context_bus [label="context facts only"];

  shm_schema -> event_bus [label="schema"];
  shm_schema -> context_bus [label="schema"];

  event_bus -> bus_adapter [label="read tap"];
  context_bus -> bus_adapter [label="snapshot source"];
  bus_adapter -> dot_contract [label="projection"];
  dot_contract -> vispy [label="render/navigation/zoom"];

  dot_contract -> architecture;
  dot_contract -> runtime;
  dot_contract -> artifact;
  dot_contract -> scheduler_mode;
  dot_contract -> bus_mode;
  dot_contract -> score;
  dot_contract -> population;
  dot_contract -> debug;

  dataset -> vispy [label="forbidden direct write", style=dashed];
  github -> vispy [label="forbidden direct write", style=dashed];
  dot_contract -> scheduler [label="forbidden command path", style=dashed];
}
