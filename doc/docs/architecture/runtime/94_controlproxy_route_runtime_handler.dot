digraph ControlProxyRouteRuntimeHandler0104 {
  graph [
    label="0104 ControlProxy route runtime handler binding\nROOT_GRAPH: doc/docs/architecture/00_global.dot",
    labelloc="t",
    fontsize=20
  ];
  node [shape=box, style="rounded"];
  edge [fontsize=10];

  SchedulerRun [label="Scheduler.run()\nqueue + priority loop"];
  Dispatcher [label="Dispatcher\nEventType -> Handler only"];
  ThinHandler [label="ControlProxySchedulerRouteRequestHandler\nthin Handler adapter"];
  RuntimeBinding [label="controlproxy_route_runtime_handler\nvalidate envelope + extract decision"];
  RouteRuntimeManager [label="RouteRuntimeManager\nroute runtime work"];
  ControlFS [label="ControlFS\ngeneration state + lifecycle"];
  DataPlane [label="mmap/eventfd data plane\nnot EventBus"];
  EventBusObservation [label="existing EventBus\nobservation only"];
  SpecialistBranch [label="specialist branch\nbusiness logic"];

  SchedulerRun -> Dispatcher;
  Dispatcher -> ThinHandler;
  ThinHandler -> RuntimeBinding;
  RuntimeBinding -> RouteRuntimeManager;
  RouteRuntimeManager -> ControlFS;
  RouteRuntimeManager -> DataPlane;

  Dispatcher -> EventBusObservation [style=dashed, label="observable copy"];
  SpecialistBranch -> SchedulerRun [style=dashed, label="commands/events through kernel path"];
}
