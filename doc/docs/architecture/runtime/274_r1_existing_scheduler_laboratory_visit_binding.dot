digraph ExistingSchedulerLaboratoryVisitBinding0274R1 {
  rankdir=LR;
  node [shape=box];

  VisitRequest [label="LaboratoryVisitRequest"];
  ExistingScheduler [label="existing Scheduler.emit()"];
  Policy [label="existing PolicyEngine"];
  ExistingQueue [label="existing PriorityQueue"];
  UnchangedRun [label="existing Scheduler.run() unchanged"];
  Dispatcher [label="existing Dispatcher"];
  EventBus [label="existing EventBus observation copy"];
  LaboratoryHandler [label="LaboratoryVisitRequestHandler"];
  FakeProvider [label="r3 deterministic fake provider"];
  Receipt [label="immutable Scheduler visit receipt"];
  Reply [label="existing Request.reply"];

  VisitRequest -> ExistingScheduler;
  ExistingScheduler -> Policy;
  Policy -> ExistingQueue;
  ExistingQueue -> UnchangedRun;
  UnchangedRun -> Dispatcher;
  Dispatcher -> EventBus [style=dashed, label="observation only"];
  Dispatcher -> LaboratoryHandler;
  LaboratoryHandler -> FakeProvider;
  FakeProvider -> Receipt;
  Receipt -> Reply;

  Rejected [shape=note, label="No LaboratoryScheduler / no parallel queue / no parallel bus / no parallel registry"];
  ExistingScheduler -> Rejected [style=dotted, arrowhead=none];
}
