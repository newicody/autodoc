digraph snapshot_audit_replay_supervision_contract_0226 {
  rankdir=LR;
  node [shape=box];

  scheduler [label="Scheduler\nupstream authority"];
  runtime [label="Proxy / SHM / Policy / Data surfaces\nupstream emitters"];
  bus [label="EventBus\ncanonical transport"];
  sink [label="PassiveSupervisorSink\ndownstream observer"];
  state [label="CellularState\nlive projection"];
  snapshot [label="snapshot()/snapshot.json\noptional output"];
  audit [label="events.jsonl\noptional audit/replay"];
  replay [label="replay harness\ntest/debug only"];
  vispy [label="VisPy later\nhuman view only"];

  scheduler -> bus;
  runtime -> bus;
  bus -> sink;
  sink -> state;
  state -> snapshot [style=dashed, label="optional"];
  sink -> audit [style=dashed, label="optional"];
  replay -> sink [style=dashed, label="test/debug only"];
  snapshot -> vispy [style=dashed, label="view"];
  state -> vispy [style=dashed, label="snapshot()"];

  snapshot -> sink [style=dotted, label="forbidden as normal input"];
  audit -> sink [style=dotted, label="replay only, not live path"];
  vispy -> scheduler [style=dotted, label="forbidden"];
}
