digraph route_proxy_flow_control_0129 {
  rankdir=LR;
  node [shape=box];

  scheduler [label="Scheduler\norchestrator"];
  policy [label="PolicyEngine\nadmission/rules"];
  proxy [label="RouteProxy\nfast data-plane control"];
  lease [label="RouteLease\nWriterPermit\nGenerationFence"];
  shm [label="/dev/shm route zones\nmultitask interface\nfuture grid seam"];
  worker [label="specialist / worker\nreads/writes frames"];
  bus [label="EventBus\nobservation facts\nstatistics/paths"];
  sql [label="SQLContextStore\ndurable authority"];
  qdrant [label="Qdrant\nprojection/recall only"];
  e5 [label="E5/OpenVINO\nembedding only"];

  scheduler -> policy;
  policy -> proxy [label="priority/context generation"];
  proxy -> lease;
  lease -> shm;
  worker -> proxy [label="request permit"];
  proxy -> worker [label="grant/block/stale"];
  worker -> shm [label="frame IO"];
  proxy -> bus [label="observation facts"];
  worker -> bus [label="paths/stats"];
  shm -> sql [label="validated refs persist"];
  e5 -> qdrant [label="vectors later"];
  qdrant -> sql [label="sql_ref rehydrate"];
}
