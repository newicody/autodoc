digraph context_bus_scheduler_intake_reader_0178 {
  rankdir=LR;
  label="0178 Context bus scheduler intake reader";
  labelloc=t;

  dataset [label="GitHub artifact dataset outcome"];
  bridge0176 [label="0176 dataset bus observation bridge"];
  context_bus [label="context.bus.jsonl"];
  message [label="ContextBusMessage.from_mapping"];
  filter [label="topic + payload_schema filter"];
  intake [label="0177 scheduler intake builder"];
  route_request [label="SchedulerRouteRequest\nonly with policy_decision_id"];
  scheduler [label="Scheduler / policy / zone\nauthority"];

  dataset -> bridge0176;
  bridge0176 -> context_bus;
  context_bus -> message;
  message -> filter;
  filter -> intake;
  intake -> route_request [label="authorized only"];
  route_request -> scheduler [label="future authorized handoff"];

  context_bus -> scheduler [label="forbidden direct execution", style=dashed];
  intake -> scheduler [label="forbidden Scheduler.run modification", style=dashed];
}
