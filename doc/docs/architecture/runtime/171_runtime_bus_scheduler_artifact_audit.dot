digraph runtime_bus_scheduler_artifact_audit_0171 {
  rankdir=LR;

  github [label="GitHub Actions artifacts\nsource system"];
  fetch [label="artifact fetch / dataset sync\nread-only tools"];
  dataset [label="configured server dataset\nraw/index/history/queue"];
  bus [label="existing event.bus/context.bus\ncanonical observation surface"];
  vispy [label="bus_visualization_adapter\nVisPy/browser read projection"];
  scheduler [label="Scheduler / policy / zone\nauthority"];
  route [label="scheduler route adapter/handler/handshake\nexisting surfaces"];

  github -> fetch [label="read/download only"];
  fetch -> dataset [label="store raw first"];
  dataset -> bus [label="future bridge: facts only"];
  bus -> vispy [label="existing read adapter"];
  scheduler -> route [label="authorized commands"];
  route -> bus [label="observable facts"];

  fetch -> vispy [label="forbidden: direct write", style=dashed];
  fetch -> scheduler [label="forbidden: bypass authority", style=dashed];
}
