digraph scheduler_deliberation_route_contract_0125_r2 {
  rankdir=LR;
  github [label="GitHub artifact exchange\nartifact in / final out"];
  scheduler [label="Scheduler\norchestrator"];
  handler [label="Handler\nthin executor"];
  route [label="/dev/shm route frames\nmultitask data-plane"];
  specialists [label="Specialists\nworkers/adapters"];
  bus [label="EventBus\nobservation/statistics"];
  sql [label="SQLContextStore\ndurable authority"];
  e5 [label="E5/OpenVINO\nembedding only"];
  qdrant [label="Qdrant\nprojection/retrieval"];

  github -> scheduler [label="artifact ref"];
  scheduler -> handler [label="commands"];
  handler -> route [label="demand refs"];
  route -> specialists [label="frames"];
  specialists -> route [label="opinion frames"];
  specialists -> bus [label="facts only"];
  specialists -> e5 [label="query/passages"];
  e5 -> qdrant [label="vectors"];
  qdrant -> sql [label="sql refs rehydrate"];
  handler -> sql [label="durable state"];
  sql -> github [label="final artifact later"];
}
