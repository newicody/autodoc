digraph llm_specialist_adapter_0120 {
    rankdir=LR;
    node [shape=box];

    SourceCandidate [label="SourceCandidate / GitHub artifact"];
    SQLStore [label="SQLContextStore\nSQL authority on fast_pool"];
    Hydrator [label="SQLContextHydrator"];
    Hydrated [label="Hydrated SQL fragments"];
    Draft [label="InferenceContextDraft"];
    Adapter [label="LLMSpecialistAdapter\nbounded prompt + validation"];
    Executor [label="Injected LLM executor\nno runtime import in 0120"];
    Candidates [label="Solution candidates\nevidence_refs + action_refs"];
    GitHub [label="GitHub project result later"];
    Scheduler [label="Scheduler orchestrates jobs\ndoes not build variants"];

    SourceCandidate -> SQLStore;
    SQLStore -> Hydrator;
    Hydrator -> Hydrated;
    Hydrated -> Draft;
    Draft -> Adapter;
    Hydrated -> Adapter;
    Adapter -> Executor [style=dashed, label="specialist membrane"];
    Executor -> Candidates [style=dashed];
    Candidates -> GitHub [style=dashed];
    Scheduler -> Adapter [style=dashed, label="job carries refs only"];
}
