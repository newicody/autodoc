digraph LaboratoryFrameworkReuseAudit0273R1 {
  rankdir=LR;
  node [shape=box];

  DurableCandidate [label="0272 durable SourceCandidate"];
  Orientation [label="ServerOrientation"];
  Scheduler [label="existing Scheduler / Policy / Queue"];
  Registry [label="existing Scheduler-owned registry"];
  Handler [label="existing Dispatcher / Handler boundary"];
  Provider [label="future LaboratoryProvider seam"];
  Specialist [label="existing specialist contracts"];
  Deliberation [label="existing deliberation cycle / routes"];
  SQL [label="SQL durable authority"];
  Vector [label="E5 profile + Qdrant sql_ref"];
  EventBus [label="EventBus observation-only"];
  Supervisor [label="PassiveSupervisor"];
  Visual [label="Cell Lens / VisPy / Canvas"];
  GitHub [label="reviewed GitHub artifact return"];

  DurableCandidate -> Orientation;
  Orientation -> Scheduler;
  Scheduler -> Registry;
  Registry -> Handler;
  Handler -> Provider;
  Provider -> Specialist;
  Specialist -> Deliberation;
  Deliberation -> SQL;
  SQL -> Vector;
  Deliberation -> EventBus;
  EventBus -> Supervisor;
  Supervisor -> Visual;
  Deliberation -> GitHub [style=dashed, label="after publication gate"];

  Provider -> SQL [style=dotted, label="forbidden direct ownership"];
  Provider -> EventBus [style=dotted, label="facts via boundary only"];
  Provider -> Visual [style=dotted, label="no renderer import"];

  Rejected [shape=note, label="Rejected: LaboratoryManager / LaboratoryBus / parallel Scheduler / parallel registry"];
  Provider -> Rejected [style=dashed, arrowhead=none];
}
