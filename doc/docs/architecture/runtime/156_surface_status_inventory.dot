digraph SurfaceStatusInventory0156 {
    rankdir=LR;
    compound=true;

    graph [
        fontname="Arial",
        fontsize=11,
        label="0156 — Surface status inventory",
        labelloc=t
    ];

    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    inventory [
        label="SurfaceStatusInventory\nclassification only",
        fillcolor="#eceff1",
        color="#37474f"
    ];

    p1 [
        label="P1 current validated axis\n0138..0152",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    reusable [
        label="Reusable partial surfaces\nControlFS / RouteProxy / SQL / E5 / Qdrant / replay",
        fillcolor="#fff8e1",
        color="#f9a825"
    ];

    planned [
        label="Planned surfaces\nGitHub / specialists / distributed / hardware",
        fillcolor="#e3f2fd",
        color="#1565c0"
    ];

    rules [
        label="Code rules\nreuse before new surface",
        fillcolor="#f3e5f5",
        color="#6a1b9a"
    ];

    no_runtime [
        label="No runtime mutation\nno worker / orchestrator / adapter",
        fillcolor="#ffebee",
        color="#c62828"
    ];

    global_pending [
        label="00_global.dot refresh pending\nrequires exact local graph state",
        fillcolor="#fff3e0",
        color="#ef6c00"
    ];

    inventory -> p1 [label="marks current/validated"];
    inventory -> reusable [label="marks partial/historical"];
    inventory -> planned [label="marks planned"];
    rules -> inventory [label="governs"];
    inventory -> no_runtime [label="locks boundary"];
    inventory -> global_pending [label="next canonical graph pass"];
}
