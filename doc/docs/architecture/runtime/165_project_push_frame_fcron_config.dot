digraph ProjectPushFrameFcronConfig0165 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0165 — Project push frame + fcron ConfigObj", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    ticket [label="ticket push / move\nexternal repo", fillcolor="#e3f2fd", color="#1565c0"];
    action [label="GitHub Action\nimmediate artifact", fillcolor="#e3f2fd", color="#1565c0"];
    copilot [label="Copilot preliminary opinion\nadvisory artifact", fillcolor="#fff8e1", color="#f9a825"];
    frame [label="ProjectPushFrame\nartifact family", fillcolor="#e8f5e9", color="#2e7d32"];
    config [label="ConfigObj config\n10 min fcron intent", fillcolor="#ede7f6", color="#512da8"];
    fcron [label="concerned fcron table\nidempotent block", fillcolor="#ede7f6", color="#512da8"];
    scan [label="scan-once command\nthen exit", fillcolor="#e8f5e9", color="#2e7d32"];
    history [label="append-only history\nlocal server later", fillcolor="#e8f5e9", color="#2e7d32"];

    ticket -> action;
    action -> frame;
    action -> copilot;
    copilot -> frame [label="hint only"];
    config -> fcron [label="render/update no duplicates"];
    fcron -> scan [label="every 10 min"];
    scan -> history;
    frame -> history;
}
