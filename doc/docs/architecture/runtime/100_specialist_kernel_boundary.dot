digraph SpecialistKernelBoundary0110 {
  graph [
    label="0110 Specialist kernel boundary\nROOT_GRAPH: doc/docs/architecture/00_global.dot",
    labelloc="t",
    fontsize=20
  ];
  node [shape=box, style="rounded"];
  edge [fontsize=10];

  Specialist [label="Specialist branch\nowns business logic"];
  Command [label="SpecialistKernelCommand\ntyped intent, no runtime effect"];
  SchedulerEmit [label="Scheduler.emit()\nentry to kernel path"];
  PolicyEngine [label="PolicyEngine.decide()\nminimal admission before queue"];
  PriorityQueue [label="PriorityQueue\ndeterministic execution order"];
  SchedulerRun [label="Scheduler.run()\nloop + time + queue + priority"];
  Dispatcher [label="Dispatcher\nEventType -> Handler only"];
  Handler [label="Handler\nthin adapter"];
  RouteRuntimeManager [label="RouteRuntimeManager\nroute runtime work"];
  ControlFS [label="ControlFS\ngeneration state + lifecycle"];
  DataPlane [label="Route mmap/eventfd data plane\nnot EventBus"];
  EventBus [label="EventBus\nobservation only"];

  Specialist -> Command [label="produces"];
  Command -> SchedulerEmit [label="SpecialistKernelCommand -> Scheduler.emit()"];
  SchedulerEmit -> PolicyEngine;
  PolicyEngine -> PriorityQueue;
  PriorityQueue -> SchedulerRun;
  SchedulerRun -> Dispatcher;
  Dispatcher -> Handler;
  Handler -> RouteRuntimeManager [label="Handler -> RouteRuntimeManager"];
  RouteRuntimeManager -> ControlFS;
  RouteRuntimeManager -> DataPlane;
  Dispatcher -> EventBus [style=dashed, label="observable copy"];

  Specialist -> RouteRuntimeManager [style=dashed, color="red", label="No direct Specialist -> RouteRuntimeManager call"];
  Specialist -> EventBus [style=dashed, color="red", label="no command path"];
}
