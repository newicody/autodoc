digraph GithubExternalArtifactExistingBuilders0163 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0163 — GitHub external artifact existing builders", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    fixture [label="external GitHub artifact fixture", fillcolor="#e3f2fd", color="#1565c0"];
    artifact [label="GitHubProjectArtifact\nexisting contract", fillcolor="#e8f5e9", color="#2e7d32"];
    source [label="build_github_source_candidate\nSQL-ready context ref", fillcolor="#e8f5e9", color="#2e7d32"];
    plan [label="build_context_exploration_plan", fillcolor="#fff8e1", color="#f9a825"];
    scenario [label="build_github_project_scenario_packet", fillcolor="#ede7f6", color="#512da8"];
    graphnode [label="build_github_project_context_graph\nexport_context_graph_dot", fillcolor="#ede7f6", color="#512da8"];
    review [label="build_github_publication_review\nlocal review only", fillcolor="#e8f5e9", color="#2e7d32"];
    forbidden [label="no new adapter / no SQL write\nno Qdrant write / no GitHub API", fillcolor="#ffebee", color="#c62828"];

    fixture -> artifact;
    artifact -> source;
    source -> plan;
    plan -> scenario;
    scenario -> graphnode;
    graphnode -> review;
    forbidden -> review [style=dashed, label="blocked side effects"];
}
