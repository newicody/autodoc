digraph sql_context_store_minimal_0116 {
  rankdir=LR;
  node [shape=box];

  SourceCandidate [label="SourceCandidate / artifact"];
  GitHubArtifact [label="GitHub Project artifact"];
  SQLContextStore [label="SQLContextStore\ndurable authority"];
  FastPool [label="fast_pool active PostgreSQL\n/srv/autodoc/postgres/data"];
  DataPool [label="data_pool ZFS snapshots\nbackups / dumps / archives"];
  OpenVINO [label="OpenVINO adapter\nembeddings only"];
  Qdrant [label="Qdrant projection\nvector search by sql_id"];
  Hydration [label="SQL re-hydrate recalled IDs"];
  InferenceContext [label="InferenceContext / draft"];
  Specialist [label="specialist / LLM boundary"];
  Scheduler [label="Scheduler orchestrates jobs\ndoes not build variants"];

  SourceCandidate -> SQLContextStore;
  GitHubArtifact -> SQLContextStore;
  SQLContextStore -> FastPool;
  FastPool -> DataPool [label="zfs snapshot/send"];
  SQLContextStore -> OpenVINO [label="hydrated text refs"];
  OpenVINO -> Qdrant [label="vectors + sql_id"];
  Qdrant -> Hydration [label="candidate ids"];
  Hydration -> SQLContextStore;
  Hydration -> InferenceContext;
  InferenceContext -> Specialist;
  Scheduler -> SQLContextStore [style=dashed, label="job carries refs only"];
}
