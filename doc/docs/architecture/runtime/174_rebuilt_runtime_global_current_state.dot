digraph rebuilt_runtime_global_current_state_0282 {
  rankdir=LR;
  label="0174 rebuilt runtime global current-state draft\n0282-r4 current operational architecture";
  labelloc=t;
  compound=true;
  splines=ortho;

  subgraph cluster_external {
    label="External workflow / exchange\nGitHub workflow / review / synchronization";
    github_project [label="Issue + ProjectV2 board\nstatus=validated"];
    ticket_artifacts [label="Actions request + advisory + manifest\nstatus=validated"];
    publication_plan [label="controlled publication plan / preview\nstatus=validated-local"];
    remote_mutation [label="operator-authorized mutation\nstatus=planned"];
  }

  subgraph cluster_dataset {
    label="Configured server dataset";
    fetch [label="0168 read-only artifact fetch\nstatus=validated"];
    raw [label="raw artifacts\nstatus=validated"];
    run_index [label="run-group + closed-loop index\nstatus=validated"];
    cycle_history [label="ProjectV2 append-only cycle history\nstatus=current-0282-r4"];
  }

  subgraph cluster_projectv2 {
    label="ProjectV2 cycle-history development";
    snapshot [label="0272 query-only snapshot\nstatus=validated"];
    normalization [label="0282-r3 parent/theme normalization\nstatus=validated"];
    lineage [label="0282-r2 cycle lineage contract\nstatus=validated"];
    mutation_plan [label="0282-r5/r6 mutation plans\nstatus=planned"];
  }

  subgraph cluster_scheduler {
    label="Scheduler authority";
    scheduler [label="Scheduler / policy / priority\nstatus=current"];
    handlers [label="existing handlers / adapters\nstatus=current"];
    routeproxy [label="ControlProxy / RouteProxy / dev-shm\nstatus=current"];
  }

  subgraph cluster_compute {
    label="Local compute / context";
    fake_lab [label="existing-Scheduler fake laboratory\nstatus=validated"];
    specialists [label="portable specialists / lab visits\nstatus=planned"];
    openvino [label="OpenVINO / E5\nstatus=validated"];
    qdrant [label="Qdrant projection / recall\nstatus=validated; real executor next"];
    sql [label="SQL durable authority / rehydrate\nstatus=validated"];
  }

  subgraph cluster_observation {
    label="Observation / visualization\nObservation only";
    event_bus [label="EventBus facts\nstatus=current"];
    supervisor [label="PassiveSupervisor read model\nstatus=validated"];
    vispy [label="DOT / VisPy / Cell Lens\nstatus=partial"];
  }

  github_project -> ticket_artifacts;
  ticket_artifacts -> fetch;
  fetch -> raw;
  raw -> run_index;
  run_index -> scheduler [label="SourceCandidate + operator gate"];

  github_project -> snapshot [label="GraphQL query-only"];
  snapshot -> normalization;
  normalization -> lineage;
  lineage -> cycle_history [label="append / replay / collision"];
  cycle_history -> mutation_plan [style=dashed];
  mutation_plan -> remote_mutation [label="explicit authorization", style=dashed];

  scheduler -> handlers;
  handlers -> routeproxy;
  scheduler -> fake_lab [label="existing Scheduler path"];
  fake_lab -> run_index [label="closed result"];
  fake_lab -> specialists [style=dashed, label="future portability"];
  scheduler -> openvino [label="when scheduled"];
  openvino -> qdrant;
  qdrant -> sql [label="sql_ref"];
  sql -> scheduler [label="rehydrate"];
  run_index -> publication_plan;
  publication_plan -> remote_mutation [style=dashed];

  scheduler -> event_bus [label="facts only"];
  handlers -> event_bus [label="facts only"];
  routeproxy -> event_bus [label="facts only"];
  fake_lab -> event_bus [label="facts only"];
  event_bus -> supervisor;
  supervisor -> vispy;

  vispy -> scheduler [label="forbidden command path", style=dashed];
  github_project -> event_bus [label="forbidden internal bus source", style=dashed];
  fetch -> vispy [label="forbidden direct writer", style=dashed];
  remote_mutation -> sql [label="forbidden authority path", style=dashed];
}
