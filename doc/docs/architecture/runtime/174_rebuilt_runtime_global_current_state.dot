digraph rebuilt_runtime_global_current_state_0174 {
  rankdir=LR;
  label="0174 rebuilt runtime global current-state draft";
  labelloc=t;

  subgraph cluster_external {
    label="External workflow / exchange";
    github_project [label="GitHub Project / issue / idea repo\nstatus=current"];
    ticket_artifact [label="GitHub Action ticket artifact\nstatus=validated"];
    copilot_opinion [label="Copilot preliminary opinion artifact\nstatus=planned"];
    github_review [label="GitHub review / validation surface\nstatus=planned"];
  }

  subgraph cluster_dataset {
    label="Configured server dataset";
    fetch [label="read-only artifact fetch\nstatus=partial"];
    raw [label="raw artifacts / attachments\nstatus=planned"];
    index [label="index / history\nstatus=partial"];
    queue [label="conversion or scheduler queue\nstatus=planned"];
  }

  subgraph cluster_scheduler {
    label="Scheduler authority";
    scheduler [label="Scheduler / policy / zone\nstatus=current"];
    route_adapter [label="scheduler route handshake / adapter / handler\nstatus=current"];
    controlproxy [label="ControlProxy / RouteProxy data plane\nstatus=current"];
  }

  subgraph cluster_compute {
    label="Local compute / context";
    openvino [label="OpenVINO / E5 / specialists\nstatus=partial"];
    qdrant [label="Qdrant projection/search\nstatus=validated"];
    sql [label="SQL durable store / rehydrate\nstatus=validated"];
    result_artifact [label="review/publication artifact\nstatus=planned"];
  }

  subgraph cluster_observation {
    label="Observation / visualization";
    event_bus [label="event.bus facts\nstatus=current"];
    context_bus [label="context.bus facts\nstatus=current"];
    bus_adapter [label="bus_visualization_adapter\nstatus=current"];
    dot_support [label="DOT activity graph support\nstatus=validated"];
    vispy [label="VisPy/browser view\nstatus=partial"];
  }

  github_project -> ticket_artifact;
  ticket_artifact -> copilot_opinion;
  copilot_opinion -> fetch;
  fetch -> raw;
  raw -> index;
  index -> queue;
  queue -> scheduler;
  scheduler -> route_adapter;
  route_adapter -> controlproxy;
  scheduler -> openvino [label="when scheduled"];
  openvino -> qdrant;
  qdrant -> sql [label="sql_ref rehydrate"];
  sql -> result_artifact;
  result_artifact -> github_review;

  route_adapter -> event_bus [label="facts only"];
  route_adapter -> context_bus [label="facts only"];
  controlproxy -> event_bus [label="facts only"];
  controlproxy -> context_bus [label="facts only"];
  fetch -> event_bus [label="future facts only", style=dashed];
  queue -> event_bus [label="future facts only", style=dashed];

  event_bus -> bus_adapter [label="read"];
  context_bus -> bus_adapter [label="snapshot"];
  bus_adapter -> dot_support [label="projection"];
  dot_support -> vispy [label="titles / zoom / modes"];

  dot_support -> scheduler [label="forbidden command path", style=dashed];
  fetch -> vispy [label="forbidden direct writer", style=dashed];
  github_project -> event_bus [label="forbidden internal bus source", style=dashed];
}
