digraph GithubArtifactServerDatasetSync0167 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0167 — GitHub artifact server dataset sync", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    github [label="GitHub Actions artifacts
source system", fillcolor="#e3f2fd", color="#1565c0"];
    fetched [label="server fetch result
local artifact dir", fillcolor="#e3f2fd", color="#1565c0"];
    raw [label="configured server dataset
raw artifacts + attachments", fillcolor="#e8f5e9", color="#2e7d32"];
    index [label="index + history
provenance/hash/status", fillcolor="#e8f5e9", color="#2e7d32"];
    queue [label="conversion queue
after complete sync", fillcolor="#fff8e1", color="#f9a825"];
    vispy [label="VisPy observation event
stats/status", fillcolor="#ede7f6", color="#512da8"];

    github -> fetched [label="future 0168 fetch"];
    fetched -> raw [label="0167 sync"];
    raw -> index;
    raw -> queue [label="only after raw sync"];
    index -> vispy;
}
