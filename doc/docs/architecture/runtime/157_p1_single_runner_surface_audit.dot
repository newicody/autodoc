digraph P1SingleRunnerSurfaceAudit0157 {
    rankdir=LR;
    compound=true;

    graph [
        fontname="Arial",
        fontsize=11,
        label="0157 — P1 single runner surface audit",
        labelloc=t
    ];

    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    artifact [
        label="local artifact",
        fillcolor="#e3f2fd",
        color="#1565c0"
    ];

    runner0145 [
        label="0145 existing operator runner\ntools/run_local_artifact_vector_indexing_runner.py",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    intake0146 [
        label="0146 artifact intake contract\nsrc/context/artifact_intake_contract.py",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    refs0147 [
        label="0147 dynamic route refs\nsrc/context/artifact_route_refs.py",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    scheduler_smoke [
        label="existing Scheduler/RouteProxy/vector smoke\ntools/run_scheduler_vector_indexing_smoke.py",
        fillcolor="#fff8e1",
        color="#f9a825"
    ];

    handoff0148 [
        label="0148 SQL persistence handoff",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    record0149 [
        label="0149 SQLContextStore persistence record",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    write0151 [
        label="0151/0152 DbApiSqlContextStore.upsert_record\ncontrolled write + DB path",
        fillcolor="#e8f5e9",
        color="#2e7d32"
    ];

    missing0158 [
        label="0158 missing closure\ncompose existing tools into one P1 command",
        fillcolor="#fff3e0",
        color="#ef6c00"
    ];

    forbidden [
        label="forbidden parallel surfaces\norchestrator / worker / new adapters",
        fillcolor="#ffebee",
        color="#c62828"
    ];

    artifact -> runner0145;
    runner0145 -> intake0146;
    runner0145 -> refs0147;
    runner0145 -> scheduler_smoke;
    scheduler_smoke -> handoff0148;
    handoff0148 -> record0149;
    record0149 -> write0151;
    write0151 -> missing0158 [style=dashed, label="next"];
    forbidden -> runner0145 [style=dashed, label="do not replace"];
}
