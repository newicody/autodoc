digraph context_variation_core_contract_0114_r2 {
  graph [
    label="0114-r2 Context variation core contract — ROOT_GRAPH: doc/docs/architecture/00_global.dot — root-attached context overlay",
    labelloc="t",
    fontsize=20
  ];
  rankdir=LR;
  node [shape=box, style="rounded"];

  // ContextVariationObjective -> ContextExplorationPlan -> ContextVariantCandidate -> ContextTrajectory -> ContextExplorationResult -> InferenceContextDraft
  objective [label="ContextVariationObjective\nuser/project objective"];
  axes [label="ContextVariationAxis[]\nways to vary context"];
  plan [label="ContextExplorationPlan\nbounded, reference-only"];
  candidate [label="ContextVariantCandidate\nvariant candidate"];
  trajectory [label="ContextTrajectory\ncontext path, not linear pipeline"];
  result [label="ContextExplorationResult\nrefs + observations"];
  draft [label="InferenceContextDraft\npacket for specialist boundary"];

  scheduler [label="Scheduler\norchestrates jobs only\ndoes not build variants"];
  handler [label="Handler / specialist boundary\nexecutes context jobs"];

  sql [label="SQLContextStore\nSQLContextStore is durable context authority"];
  openvino [label="OpenVINO adapter\nOpenVINO produces local embeddings or light inference behind an adapter"];
  qdrant [label="Qdrant projection\nQdrant is vector projection and retrieval, not context authority"];
  llm [label="LLM / specialist\nLLM consumes InferenceContextDraft or InferenceContext through specialist boundary"];
  future [label="MVTC remains future, not runtime in 0114-r2"];

  objective -> axes;
  axes -> plan;
  scheduler -> handler [label="dispatch bounded context job"];
  handler -> plan;
  plan -> candidate;
  candidate -> trajectory;
  trajectory -> sql [label="hydrate refs"];
  trajectory -> openvino [label="embed/score refs"];
  openvino -> qdrant [label="vector projection / recall"];
  qdrant -> sql [label="return IDs, hydrate in SQL"];
  trajectory -> result;
  result -> draft;
  draft -> llm;
  draft -> future [style=dashed];
}
