digraph scheduler_eventbus_supervisor_source_0222 {
  rankdir=LR;

  scheduler [label="Scheduler\nupstream orchestration authority"];
  event [label="canonical Scheduler EventBus event\ncell_kind=SCHEDULER"];
  eventbus [label="EventBus\nexisting transport"];
  sink [label="PassiveSupervisorSink\ndownstream accept_scheduler_event"];
  state [label="CellularState\nin-memory projection"];
  snapshot [label="snapshot\noptional"];
  audit [label="events.jsonl\noptional audit/replay", style=dashed];

  scheduler -> event;
  event -> eventbus;
  eventbus -> sink;
  sink -> state;
  state -> snapshot [style=dashed];
  sink -> audit [style=dashed];

  sink -> scheduler [label="forbidden: Scheduler.run/control", color=red, style=dotted];
  sink -> eventbus [label="forbidden: implement new bus", color=red, style=dotted];
}
