digraph FakeLaboratoryDeliberationComposition0274R2 {
  rankdir=LR;
  node [shape=box];

  Orientation [label="ServerOrientation"];
  ExistingScheduler [label="existing Scheduler path"];
  FakeProvider [label="r3 deterministic fake provider"];
  Opinions [label="SpecialistPreliminaryOpinion[]"];
  Demands [label="RefinedSpecialistDemand[] when needed"];
  Round [label="DeliberationRound"];
  Fragments [label="SpecialistOutputFragment[]"];
  Synthesis [label="SpecialistLiaisonSynthesis"];
  FinalPacket [label="FinalSynthesisPacket"];
  FinalArtifact [label="FinalArtifactEnvelope"];
  Gate [label="existing publication gate"];
  GitHub [label="future GitHub mutation"];

  Orientation -> ExistingScheduler;
  ExistingScheduler -> FakeProvider;
  FakeProvider -> Opinions;
  Opinions -> Demands;
  Opinions -> Round;
  Demands -> Round;
  FakeProvider -> Fragments;
  Round -> Synthesis;
  Fragments -> Synthesis;
  Synthesis -> FinalPacket [label="only when converged"];
  FinalPacket -> FinalArtifact;
  FinalArtifact -> Gate;
  Gate -> GitHub [style=dashed, label="not executed in r2"];

  Rejected [shape=note, label="No new Scheduler / no LaboratoryOrchestrator / no parallel queue"];
  ExistingScheduler -> Rejected [style=dotted, arrowhead=none];
}
