digraph github_artifact_scheduler_intake_contract_0177 {
  rankdir=LR;
  label="0177 GitHub artifact scheduler intake contract";
  labelloc=t;

  observation [label="GitHub artifact dataset observation"];
  candidate [label="scheduler intake candidate\nnot authorized work"];
  policy [label="policy decision\npolicy_decision_id"];
  mapping [label="scheduler_route_request_mapping(...)\nexisting adapter"];
  route_request [label="SchedulerRouteRequest\nauthorized=True"];
  scheduler [label="Scheduler / policy / zone\nauthority"];

  observation -> candidate;
  candidate -> mapping [label="only with explicit policy_decision_id"];
  policy -> mapping;
  mapping -> route_request;
  route_request -> scheduler [label="future authorized path"];

  candidate -> scheduler [label="forbidden direct execution", style=dashed];
  mapping -> scheduler [label="forbidden Scheduler.run modification", style=dashed];
}
