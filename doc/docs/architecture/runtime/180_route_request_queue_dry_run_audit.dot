digraph route_request_queue_dry_run_audit_0180 {
  rankdir=LR;
  label="0180 Route request queue dry-run audit";
  labelloc=t;

  queue [label="scheduler.route_requests.jsonl"];
  reader [label="iter_authorized_route_request_queue"];
  validate [label="SchedulerRouteRequest.from_mapping"];
