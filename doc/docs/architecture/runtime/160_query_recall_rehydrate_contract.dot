digraph QueryRecallRehydrateContract0160 {
    rankdir=LR;
    compound=true;

    graph [fontname="Arial", fontsize=11, label="0160 — Query recall rehydrate contract", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    query [label="user query
E5 role: query:", fillcolor="#e3f2fd", color="#1565c0"];
    embed [label="existing E5/OpenVINO surface
tools/embed_e5.py", fillcolor="#e8f5e9", color="#2e7d32"];
    recall [label="Qdrant recall payload
sql_ref pointers", fillcolor="#e8f5e9", color="#2e7d32"];
    rehydrate [label="0159 existing rehydrate operator
run_qdrant_recall_sql_rehydrate_smoke.py", fillcolor="#fff8e1", color="#f9a825"];
    sql [label="DbApiSqlContextStore.get_record
SQL durable authority", fillcolor="#fff8e1", color="#f9a825"];
    result [label="hydrated query context
JSON + Markdown", fillcolor="#ede7f6", color="#512da8"];
    forbidden [label="forbidden parallel surfaces
new adapters / worker / orchestrator", fillcolor="#ffebee", color="#c62828"];

    query -> embed [label="query text"];
    embed -> recall [label="query vector boundary"];
    recall -> rehydrate [label="sql_ref payload"];
    rehydrate -> sql [label="get_record"];
    sql -> result [label="hydrated context"];
    forbidden -> embed [style=dashed, label="do not replace"];
    forbidden -> recall [style=dashed, label="do not replace"];
    forbidden -> rehydrate [style=dashed, label="reuse 0159"];
}
