digraph GithubReadOnlyArtifactFetch0164 {
    rankdir=LR;
    graph [fontname="Arial", fontsize=11, label="0164 — GitHub read-only artifact fetch smoke", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9, arrowsize=0.7];

    report [label="operator external review report", fillcolor="#e3f2fd", color="#1565c0"];
    request [label="read-only probe request\nexisting builder", fillcolor="#e3f2fd", color="#1565c0"];
    fake [label="FakeSourceCandidateReadOnlyExternalProbeAdapter\nno external call", fillcolor="#fff8e1", color="#f9a825"];
    result [label="read-only probe result", fillcolor="#e8f5e9", color="#2e7d32"];
    bundle [label="SourceCandidateExternalProbeBundle", fillcolor="#e8f5e9", color="#2e7d32"];
    contract [label="SourceCandidateExternalProjectionContract", fillcolor="#ede7f6", color="#512da8"];
    payload [label="SourceCandidateGithubProjectionPayload\ndry-run only", fillcolor="#ede7f6", color="#512da8"];
    gate [label="remote mutation gate\nclosed", fillcolor="#ffebee", color="#c62828"];

    report -> request;
    request -> fake;
    fake -> result;
    result -> bundle;
    bundle -> contract;
    contract -> payload;
    payload -> gate;
}
