digraph GitHubProjectOrchestrator {
  graph [
    label="Phase 4.18-r1 — GitHub Project Orchestrator",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: inference/72_e5_dry_run_artifact_dir.dot

  subgraph cluster_github {
    label="Surface GitHub";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Project [label="GitHub Project
kanban / status"];
    Issue [label="Issue / ticket
intention utilisateur"];
    Push [label="push / branche
source brute"];
    Action [label="GitHub Action
triage + artifact"];
    Copilot [label="Copilot metadata
optionnel"];
  }

  subgraph cluster_artifact {
    label="Artefact de travail";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff8e1";

    Artifact [label="missipy.source_candidate.v1
metadata + raw content"];
    Policy [label="context_policy
validation + cross-context"];
    Transport [label="artifact transport
GitHub Actions"];
  }

  subgraph cluster_local {
    label="Serveur autodoc local";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Polling [label="polling / import
future integration"];
    Intake [label="Work Artifact Intake"];
    Candidate [label="SourceCandidate", URL="91_source_candidate_lifecycle.svg"];
    Engine [label="E5 / context / prompt
enrichissement local", URL="../inference/72_e5_dry_run_artifact_dir.svg"];
    LocalSource [label="source autoritative
serveur local"];
  }

  subgraph cluster_feedback {
    label="Retour contrôlé";
    style="rounded,filled";
    color="#d1c4e9";
    fillcolor="#ede7f6";

    Report [label="rapport enrichi"];
    Status [label="status / label / commentaire"];
    PR [label="PR / commit
si stabilisé"];
    User [label="validation utilisateur"];
  }

  Project -> Issue;
  Push -> Action;
  Issue -> Action;
  Action -> Copilot [label="triage"];
  Copilot -> Artifact;
  Action -> Artifact;
  Artifact -> Policy;
  Policy -> Transport;
  Transport -> Polling;
  Polling -> Intake;
  Intake -> Candidate;
  Candidate -> Engine;
  Engine -> LocalSource;
  LocalSource -> Report;
  Report -> Status;
  Status -> Project;
  Report -> User;
  User -> Project [label="valide / relance"];
  LocalSource -> PR [style=dashed, label="projection stabilisée"];
  PR -> Push [style=dashed, label="nouvelle boucle"];

  subgraph cluster_rules {
    label="Règles";
    style="rounded,dashed";
    color="#b0bec5";

    GitHubNotSource [label="GitHub n'est pas
source autoritative"];
    LocalAuthority [label="autorité locale
serveur"];
    OptionalCopilot [label="Copilot optionnel
pas une dépendance cœur"];
    NoRuntime [label="phase documentaire
pas d'API / pas de réseau"];
  }

  GitHubNotSource -> Project [style=dashed];
  LocalAuthority -> LocalSource [style=dashed];
  OptionalCopilot -> Copilot [style=dashed];
  NoRuntime -> Polling [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← E5 dry-run artifact dir", shape=plaintext, URL="../inference/72_e5_dry_run_artifact_dir.svg"];
    Next [label="next: source candidate lifecycle", shape=plaintext, URL="91_source_candidate_lifecycle.svg"];
  }

  // HTML_DETAIL[phase4_18_r1]: GitHub pilote, le serveur comprend, le dépôt matérialise, l'utilisateur valide.
}
