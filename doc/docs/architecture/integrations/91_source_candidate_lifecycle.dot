digraph SourceCandidateLifecycle {
  graph [
    label="Phase 4.18-r1 — Source Candidate Lifecycle",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: integrations/90_github_project_orchestrator.dot

  subgraph cluster_inputs {
    label="Entrées candidates";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Push [label="push"];
    Issue [label="issue / ticket"];
    Artifact [label="artifact GitHub"];
    Note [label="note projet"];
  }

  subgraph cluster_states {
    label="États";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff8e1";

    Raw [label="raw"];
    Triaged [label="triaged"];
    Enriched [label="enriched"];
    CandidateContext [label="candidate_context"];
    Validated [label="validated_context"];
    Merged [label="merged_context"];
    Rejected [label="rejected"];
    Archived [label="archived"];
  }

  subgraph cluster_decision {
    label="Décision de contexte";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    NewContext [label="nouveau contexte
autonome"];
    MergeContext [label="fusion dans
contexte existant"];
    StableSource [label="source locale
autoritative"];
    GitProjection [label="projection GitHub
status / commentaire / PR"];
  }

  subgraph cluster_validation {
    label="Validation";
    style="rounded,dashed";
    color="#b0bec5";

    UserValidation [label="validation utilisateur"];
    Tests [label="tests réussis"];
    ProjectRule [label="règle projet"];
    MergedPR [label="PR mergée"];
  }

  Push -> Raw;
  Issue -> Raw;
  Artifact -> Raw;
  Note -> Raw;

  Raw -> Triaged;
  Triaged -> Enriched;
  Enriched -> CandidateContext;
  Enriched -> Rejected;
  Enriched -> Archived;

  CandidateContext -> Validated [label="si règle OK"];
  CandidateContext -> Merged [label="si rattachement"];
  CandidateContext -> Rejected;

  Validated -> NewContext;
  Merged -> MergeContext;
  NewContext -> StableSource;
  MergeContext -> StableSource;
  StableSource -> GitProjection;
  GitProjection -> Issue [style=dashed, label="aller-retour"];

  UserValidation -> Validated [style=dashed];
  Tests -> Validated [style=dashed];
  ProjectRule -> Validated [style=dashed];
  MergedPR -> StableSource [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← GitHub Project Orchestrator", shape=plaintext, URL="90_github_project_orchestrator.svg"];
    Next [label="next: phase 4 final audit", shape=plaintext, URL="../inference/73_e5_phase4_final_audit.svg"];
  }

  // HTML_DETAIL[phase4_18_r1_lifecycle]: Une entrée GitHub peut devenir une source candidate, puis un contexte validé ou fusionné.
}
