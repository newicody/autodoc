digraph Observability {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    subgraph cluster_obs {
        label="Observability";
        color="#666666"; bgcolor="#f5f5f5";
        node [fillcolor="#f5f5f5", color="#666666"];
        Logger [URL="70_observability.svg"];
        Metrics [URL="70_observability.svg"];
        Replay [URL="70_observability.svg"];
        Dashboard [URL="70_observability.svg"];
        Watchdog [URL="70_observability.svg"];
    }

    EventBus [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/event_bus/12_event_bus.svg"];
    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/10_scheduler.svg"];

    // Edges
    EventBus -> Logger;       // Événements → Logger
    EventBus -> Metrics;      // Événements → Métriques
    EventBus -> Replay;       // Événements → Replay
    Metrics -> Dashboard;     // Métriques → Dashboard
    Watchdog -> Scheduler;    // Watchdog surveille Scheduler

    // Navigation
    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="../scheduler/10_scheduler.svg"];
    { rank=sink; Nav_Global; Nav_Scheduler; }
}
