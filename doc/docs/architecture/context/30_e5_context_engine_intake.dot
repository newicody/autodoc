digraph E5ContextEngineIntake {
  graph [
    label="Phase 5.6 — ContextEngine E5 intake facade",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/29_e5_context_attachment.dot

  subgraph cluster_inputs {
    label="Entrées explicites";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    ArtifactDir [label="artifact-dir Phase 4\nreport/context/consumed/prompt", URL="26_e5_artifact_directory_loader.svg"];
    RuntimeResult [label="E5LocalContextRuntimeResult", URL="28_e5_local_context_runtime.svg"];
    EngineState [label="ContextEngine.last_inference_context", URL="20_context.svg"];
  }

  subgraph cluster_intake {
    label="Façade ContextEngine 5.6";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Policy [label="E5ContextEngineIntakePolicy\nruntime_policy + attachment_policy"];
    AttachDir [label="ContextEngine.attach_e5_artifact_dir()"];
    AttachRuntime [label="ContextEngine.attach_e5_runtime_context()"];
    Result [label="E5ContextEngineIntakeResult\nready/changed/counts"];
    Json [label="to_json_dict()\naudit stable"];
  }

  subgraph cluster_existing {
    label="Contrats réutilisés";
    style="rounded,filled";
    color="#d1c4e9";
    fillcolor="#ede7f6";

    Runtime [label="E5LocalContextRuntime", URL="28_e5_local_context_runtime.svg"];
    Attachment [label="E5ContextAttachment", URL="29_e5_context_attachment.svg"];
    Merged [label="InferenceContext fusionné", URL="20_context.svg"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    Manual [label="appel manuel explicite"];
    NoAutoload [label="pas d'autoload"];
    NoScheduler [label="pas de Scheduler vivant"];
    NoDaemon [label="pas de daemon"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoQdrant [label="pas de Qdrant"];
    NoLLM [label="pas de génération LLM"];
    Stdlib [label="stdlib uniquement"];
  }

  ArtifactDir -> AttachDir;
  RuntimeResult -> AttachRuntime;
  EngineState -> AttachDir;
  EngineState -> AttachRuntime;
  Policy -> AttachDir;
  Policy -> AttachRuntime;
  AttachDir -> Runtime;
  Runtime -> Attachment;
  AttachRuntime -> Attachment;
  Attachment -> Merged;
  Merged -> Result;
  Result -> Json;
  Result -> EngineState [label="update last_inference_context"];

  Manual -> AttachDir [style=dashed];
  NoAutoload -> EngineState [style=dashed];
  NoScheduler -> AttachRuntime [style=dashed];
  NoDaemon -> AttachDir [style=dashed];
  NoNetwork -> ArtifactDir [style=dashed];
  NoQdrant -> Runtime [style=dashed];
  NoLLM -> Merged [style=dashed];
  Stdlib -> Policy [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← E5 context attachment", shape=plaintext, URL="29_e5_context_attachment.svg"];
    Context [label="← Context Fabric", shape=plaintext, URL="20_context.svg"];
    Next [label="next: ContextEngine E5 status", shape=plaintext, URL="31_e5_context_engine_status.svg"];
  }

  // HTML_DETAIL[phase5_6]: ContextEngine expose une entrée E5 explicite qui charge un artifact-dir ou accepte un runtime result déjà construit, puis applique le contrat d'attachement 5.5. L'état last_inference_context est mis à jour uniquement par appel direct.
}
