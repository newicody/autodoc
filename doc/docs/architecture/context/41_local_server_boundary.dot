digraph LocalServerBoundary {
  graph [
    label="Phase 5.17-r1 — Local adapter boundary contract",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/40_github_projection_design.dot

  subgraph cluster_local_inputs {
    label="Sources locales existantes";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    SourceCandidateStore [label="SourceCandidateStore\nJSON local explicite"];
    ContextEngine [label="ContextEngine\nintake E5 explicite"];
    E5Status [label="E5ContextEngineStatus\nprojection passive"];
    Reports [label="reports JSON\nlocaux"];
  }

  subgraph cluster_boundary_contract {
    label="Contrat adapter local futur";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Policy [label="LocalServerBoundaryPolicy\nrepository=newicody/autodoc\nbind_host=127.0.0.1\ncontract_only"];
    Boundary [label="LocalServerBoundary\nschema missipy.local_server.boundary.v1"];
    Endpoints [label="LocalServerEndpoint[]\nGET/POST planned only"];
  }

  subgraph cluster_planned_endpoints {
    label="Endpoints planifiés, non implémentés";
    style="rounded,filled";
    color="#b2dfdb";
    fillcolor="#e0f2f1";

    Status [label="GET /status"];
    CandidateCreate [label="POST /source-candidates"];
    CandidateDecision [label="POST /source-candidates/{id}/decision"];
    E5Intake [label="POST /context/e5/intake"];
    ReportGet [label="GET /reports/{id}"];
  }

  subgraph cluster_boundaries {
    label="Frontières 5.17";
    style="rounded,dashed";
    color="#b0bec5";

    NoServer [label="pas de serveur implémenté"];
    NoSocket [label="pas de socket ouvert"];
    NoFramework [label="aucun framework choisi
FastAPI/Flask non décidés"];
    NoNetwork [label="pas de réseau"];
    NoToken [label="pas de token"];
    NoGitHubApi [label="pas d'API GitHub"];
    NoSchedulerAutoload [label="pas d'autoload Scheduler"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    NoOpenVINO [label="pas d'appel OpenVINO"];
    Stdlib [label="aucune dépendance hors stdlib"];
  }

  SourceCandidateStore -> CandidateCreate [style=dashed, label="future explicit write"];
  SourceCandidateStore -> CandidateDecision [style=dashed, label="future explicit decision"];
  ContextEngine -> E5Intake [style=dashed, label="future explicit intake"];
  E5Status -> Status [style=dashed, label="future status read"];
  Reports -> ReportGet [style=dashed, label="future report read"];

  Policy -> Boundary;
  Boundary -> Endpoints;
  Endpoints -> Status;
  Endpoints -> CandidateCreate;
  Endpoints -> CandidateDecision;
  Endpoints -> E5Intake;
  Endpoints -> ReportGet;

  NoServer -> Boundary [style=dashed];
  NoSocket -> Boundary [style=dashed];
  NoFramework -> Policy [style=dashed];
  NoNetwork -> Policy [style=dashed];
  NoToken -> Policy [style=dashed];
  NoGitHubApi -> Policy [style=dashed];
  NoSchedulerAutoload -> E5Intake [style=dashed];
  NoQdrant -> Boundary [style=dashed];
  NoLlm -> Boundary [style=dashed];
  NoOpenVINO -> E5Intake [style=dashed];
  Stdlib -> Boundary [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← GitHub projection design", shape=plaintext, URL="40_github_projection_design.svg"];
    Next [label="next: Phase 5 audit / closure", shape=plaintext, URL="42_phase5_closure_audit.svg"];
  }

  // HTML_DETAIL[phase5_17]: La Phase 5.17-r1 clarifie la frontière serveur local comme contrat d'adapter futur non choisi. Aucun framework concret, serveur HTTP, socket, réseau, token, GitHub API, Qdrant, LLM ou appel OpenVINO n'est introduit. Les endpoints restent seulement planifiés pour un futur loopback contrôlé.
}
