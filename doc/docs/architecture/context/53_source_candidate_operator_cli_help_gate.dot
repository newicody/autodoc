digraph source_candidate_operator_cli_help_gate {
  graph [rankdir=LR, label="Phase 6.12 — SourceCandidate Operator CLI Help Gate", labelloc=t];
  node [shape=box];

  operator [label="operator"];
  unified_cli [label="source_candidate_operator_cli
(adapter only)"];
  command_help [label="--help / subcommand --help"];
  existing_cli [label="existing SourceCandidate CLI modules"];
  pure_modules [label="pure context modules / live paths"];
  tests [label="tests + rules"];

  operator -> unified_cli;
  unified_cli -> command_help;
  unified_cli -> existing_cli [label="delegates"];
  existing_cli -> pure_modules;
  tests -> unified_cli [label="guard discoverability"];
  tests -> existing_cli [label="no backend ownership"];
}
