digraph source_candidate_projection_bundle {
  graph [rankdir=LR, label="Phase 6.14 SourceCandidate projection bundle", labelloc=t];
  node [shape=box];

  report [label="operator_report.json\nlocal input"];
  preview [label="projection_preview.json\nlocal preview"];
  manifest [label="manifest.json\nbundle index"];
  bundle [label="projection bundle directory"];
  future [label="future project surface\nnot contacted", style=dashed];

  report -> preview;
  preview -> manifest;
  preview -> bundle;
  manifest -> bundle;
  bundle -> future [label="handoff preview only", style=dashed];
}
