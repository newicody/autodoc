digraph source_candidate_github_export_bundle {
  graph [rankdir=LR, label="Phase 7.5 SourceCandidate GitHub export bundle", labelloc=t];
  node [shape=box];

  contract [label="external_projection_contract.json"];
  payload [label="github_projection_payload.json"];
  gate [label="remote_mutation_gate.json"];
  adapter [label="github_adapter_dry_run.json\nfake-only"];
  manifest [label="manifest.json"];
  bundle [label="github_export_bundle\nlocal inspection artifact"];
  api [label="GitHub API\nnot contacted", style=dashed];

  contract -> bundle;
  payload -> gate;
  payload -> adapter;
  gate -> bundle;
  adapter -> bundle;
  bundle -> manifest;
  bundle -> api [label="no call", style=dashed];
}
