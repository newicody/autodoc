digraph source_candidate_projection_gate_report {
  graph [rankdir=LR, label="Phase 6.16 SourceCandidate projection gate report", labelloc=t];
  node [shape=box];

  bundle [label="projection bundle"];
  gate [label="projection gate\nPASS / FAIL"];
  report [label="projection_gate_report.json\natomic local artifact"];
  closure [label="future handoff dry-run\nnot external", style=dashed];

  bundle -> gate;
  gate -> report;
  report -> closure [style=dashed];
}
