digraph source_candidate_read_only_external_probe {
  graph [rankdir=LR, label="Phase 7.9 SourceCandidate read-only external probe", labelloc=t];
  node [shape=box];

  review [label="operator_external_review_report.json"];
  request [label="read_only_external_probe_request.json"];
  fake [label="fake read-only probe adapter"];
  result [label="read_only_external_probe_result.json"];
  operator [label="operator decision"];
  api [label="external API\nnot contacted in Phase 7.9", style=dashed];

  review -> request;
  request -> fake;
  fake -> result;
  result -> operator;
  fake -> api [label="no call", style=dashed];
}
