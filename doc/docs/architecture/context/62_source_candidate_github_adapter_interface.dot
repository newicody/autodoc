digraph source_candidate_github_adapter_interface {
  graph [rankdir=LR, label="Phase 7.4 SourceCandidate GitHub adapter interface fake-only", labelloc=t];
  node [shape=box];

  payload [label="github_projection_payload.json"];
  adapter [label="GitHub adapter interface\nplan / dry_run / apply"];
  fake [label="Fake adapter\nlocal simulation only"];
  gate [label="remote mutation gate"];
  result [label="adapter dry-run/apply result\nfake_only=true"];
  api [label="GitHub API\nnot contacted", style=dashed];

  payload -> adapter;
  adapter -> fake;
  fake -> gate;
  gate -> result;
  fake -> api [label="no call", style=dashed];
}
