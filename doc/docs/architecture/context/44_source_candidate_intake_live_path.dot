digraph SourceCandidateIntakeLivePath {
  graph [
    label="Phase 6.1-r1 — SourceCandidate intake live path",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/43_source_candidate_intake_cli.dot

  subgraph cluster_cli {
    label="Adaptateur CLI mince";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Args [label="argparse\n--title / --body / --store-file"];
    Command [label="SourceCandidateIntakeCommand\ncommande typée"];
    Render [label="stdout text/json\nrendu CLI uniquement"];
  }

  subgraph cluster_kernel_path {
    label="Chemin noyau vivant";
    style="rounded,filled";
    color="#d1c4e9";
    fillcolor="#ede7f6";

    Scheduler [label="Scheduler.emit()"];
    Policy [label="PolicyEngine.decide()\ndest=source_candidate"];
    Queue [label="PriorityQueue"];
    Dispatcher [label="Dispatcher"];
    Handler [label="SourceCandidateIntakeHandler"];
  }

  subgraph cluster_real_backend {
    label="Backend réel déclaré";
    style="rounded,filled";
    color="#b2dfdb";
    fillcolor="#e0f2f1";

    UseCase [label="run_source_candidate_intake()"];
    Store [label="SourceCandidateStore JSON réel\nsource_candidates.json"];
    Report [label="rapport JSON atomique\noptionnel"];
  }

  subgraph cluster_observable {
    label="Résultat observable";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff3e0";

    Result [label="SourceCandidateIntakeResult\nmissipy.source_candidate.intake_cli.v1"];
    Event [label="SOURCE_CANDIDATE_INTAKE_RESULT\nEventBus observable"];
    RequestReply [label="Request.reply\nrésultat coopératif"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    NoServer [label="pas de serveur"];
    NoNetwork [label="pas de réseau / GitHub API / token"];
    NoQdrant [label="pas de Qdrant"];
    NoLLM [label="pas de LLM / OpenVINO"];
    Stdlib [label="aucune dépendance hors stdlib"];
  }

  Args -> Command;
  Command -> Scheduler;
  Scheduler -> Policy;
  Policy -> Queue;
  Queue -> Dispatcher;
  Dispatcher -> Handler;
  Handler -> UseCase;
  UseCase -> Store;
  UseCase -> Report [style=dashed];
  UseCase -> Result;
  Handler -> Event;
  Handler -> RequestReply;
  Result -> Render;

  NoServer -> Scheduler [style=dashed];
  NoNetwork -> Store [style=dashed];
  NoQdrant -> Store [style=dashed];
  NoLLM -> Handler [style=dashed];
  Stdlib -> UseCase [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← SourceCandidate intake CLI", shape=plaintext, URL="43_source_candidate_intake_cli.svg"];
    Next [label="next: Phase 6.2 SourceCandidate decision live path", shape=plaintext];
  }

  // HTML_DETAIL[phase6_1_r1]: Phase 6.1-r1 aligne l'intake SourceCandidate avec le nouveau code_rule : la CLI produit une commande typée, l'événement traverse Scheduler, PolicyEngine, PriorityQueue, Dispatcher et SourceCandidateIntakeHandler, puis écrit le store JSON réel et publie SOURCE_CANDIDATE_INTAKE_RESULT. Aucun serveur, réseau, GitHub API, token, Qdrant, LLM ou OpenVINO n'est ajouté.
}
