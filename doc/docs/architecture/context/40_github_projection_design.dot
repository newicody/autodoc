digraph GitHubProjectionDesign {
  graph [
    label="Phase 5.16 — GitHub projection design pour newicody/autodoc",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/39_source_candidate_storage_report.dot

  subgraph cluster_local_authority {
    label="Autorité locale";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Store [label="SourceCandidateStoreSnapshot\nschema missipy.source_candidate.store.v1"];
    Candidate [label="SourceCandidate\nnew/analyzed/rejected/archived/promoted/merged"];
    Decision [label="SourceCandidateDecision\ninspect/relaunch/reject/archive/promote/merge"];
    LocalReport [label="rapport local\nsource_candidate.store_report.v1"];
  }

  subgraph cluster_projection_contract {
    label="Contrat de projection future";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    ProjectionPolicy [label="GitHubProjectionPolicy\nrepository=newicody/autodoc\nmode=documented only"];
    ProjectionPayload [label="GitHubProjectionPayload\nstatus/comment/labels/links future"];
    ProjectionResult [label="GitHubProjectionResult\nplanned/not_sent"];
    HumanReview [label="validation humaine\navant publication future"];
  }

  subgraph cluster_github_surface {
    label="Surface GitHub future";
    style="rounded,filled";
    color="#b2dfdb";
    fillcolor="#e0f2f1";

    GitHubProject [label="GitHub Project\nkanban / issue / ticket"];
    GitHubAction [label="GitHub Action\ntriage artifact future"];
    GitHubFeedback [label="projection retour\ncomment/status/PR future"];
  }

  subgraph cluster_boundaries {
    label="Frontières 5.16";
    style="rounded,dashed";
    color="#b0bec5";

    NoApi [label="pas d'API GitHub"];
    NoToken [label="pas de token"];
    NoNetwork [label="pas de réseau"];
    NoPolling [label="pas de polling"];
    NoServer [label="pas de serveur / daemon"];
    NoDb [label="pas de base de données"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    NoOpenVINO [label="pas d'appel OpenVINO"];
    Stdlib [label="aucune dépendance hors stdlib"];
  }

  Store -> Candidate [label="contains"];
  Candidate -> Decision [style=dashed, label="latest decision"];
  Candidate -> ProjectionPayload [label="projected fields"];
  Decision -> ProjectionPayload [label="status mapping"];
  LocalReport -> ProjectionPayload [style=dashed, label="links / audit data"];
  ProjectionPolicy -> ProjectionPayload;
  ProjectionPayload -> ProjectionResult [label="planned only"];
  ProjectionResult -> HumanReview [label="must be reviewed"];

  GitHubProject -> GitHubAction [style=dashed, label="future incoming item"];
  GitHubAction -> Candidate [style=dashed, label="future SourceCandidate"];
  HumanReview -> GitHubFeedback [style=dashed, label="future publish boundary"];
  GitHubFeedback -> GitHubProject [style=dashed, label="future status loop"];

  NoApi -> ProjectionResult [style=dashed];
  NoToken -> ProjectionPolicy [style=dashed];
  NoNetwork -> GitHubFeedback [style=dashed];
  NoPolling -> GitHubAction [style=dashed];
  NoServer -> ProjectionPayload [style=dashed];
  NoDb -> Store [style=dashed];
  NoQdrant -> Store [style=dashed];
  NoLlm -> Decision [style=dashed];
  NoOpenVINO -> Candidate [style=dashed];
  Stdlib -> ProjectionPayload [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← SourceCandidate storage/report", shape=plaintext, URL="39_source_candidate_storage_report.svg"];
    Next [label="next: Local server boundary", shape=plaintext];
  }

  // HTML_DETAIL[phase5_16]: La Phase 5.16 formalise la projection future GitHub pour newicody/autodoc. GitHub reste une surface de pilotage et de synchronisation ; l'autorité locale reste SourceCandidateStore/ContextEngine. Aucun appel réseau ou token n'est introduit.
}
