digraph source_candidate_remote_mutation_gate {
  graph [rankdir=LR, label="Phase 7.3 SourceCandidate remote mutation gate", labelloc=t];
  node [shape=box];

  payload [label="github_projection_payload.json\ndry-run"];
  policy [label="remote mutation policy\nclosed by default"];
  gate [label="remote mutation gate\nlocal PASS / FAIL"];
  result [label="remote_mutation_gate.json"];
  adapter [label="future adapter apply\nblocked unless PASS", style=dashed];
  api [label="remote API\nnot contacted", style=dashed];

  payload -> gate;
  policy -> gate;
  gate -> result;
  result -> adapter [style=dashed];
  gate -> api [label="no call", style=dashed];
}
