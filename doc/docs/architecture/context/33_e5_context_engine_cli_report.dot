digraph E5ContextEngineCliReport {
  graph [
    label="Phase 5.9 — ContextEngine E5 CLI report file",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/32_e5_context_engine_cli.dot

  subgraph cluster_cli {
    label="Bordure CLI 5.8 étendue";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    ArtifactDir [label="artifact-dir Phase 4", URL="26_e5_artifact_directory_loader.svg"];
    Command [label="E5ContextEngineCliCommand
artifact_dir + policies"];
    ReportPolicy [label="E5ContextEngineCliReportPolicy
path optionnel"];
    Parser [label="--report-file FILE"];
  }

  subgraph cluster_payload {
    label="Payload stable";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Engine [label="ContextEngine attach", URL="30_e5_context_engine_intake.svg"];
    Status [label="E5ContextEngineStatus", URL="31_e5_context_engine_status.svg"];
    Payload [label="missipy.e5.context_engine_cli.v1
intake + status"];
    Stdout [label="stdout text/json"];
    ReportFile [label="report JSON atomique"];
  }

  subgraph cluster_boundaries {
    label="Contraintes";
    style="rounded,dashed";
    color="#b0bec5";

    NoNewCli [label="aucune nouvelle commande"];
    NoScheduler [label="pas de Scheduler vivant"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoBackend [label="pas de backend / OpenVINO"];
    Stdlib [label="stdlib uniquement"];
  }

  ArtifactDir -> Parser;
  Parser -> Command;
  Parser -> ReportPolicy;
  Command -> Engine;
  Engine -> Status;
  Status -> Payload;
  Payload -> Stdout;
  ReportPolicy -> ReportFile;
  Payload -> ReportFile;

  NoNewCli -> Parser [style=dashed];
  NoScheduler -> Engine [style=dashed];
  NoNetwork -> ReportFile [style=dashed];
  NoBackend -> ArtifactDir [style=dashed];
  Stdlib -> ReportPolicy [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← ContextEngine E5 CLI", shape=plaintext, URL="32_e5_context_engine_cli.svg"];
    Next [label="next: ContextEngine local intake audit", shape=plaintext];
  }

  // HTML_DETAIL[phase5_9]: La CLI manuelle 5.8 peut maintenant écrire son payload complet dans un rapport JSON atomique. L'effet IO reste dans la bordure CLI et aucune nouvelle surface de commande n'est créée.
}
