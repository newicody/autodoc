digraph source_candidate_review_audit_summary {
  rankdir=LR;
  node [shape=box];

  cli [label="review audit CLI"];
  review_cli [label="review live path\nScheduler/Dispatcher/Handler"];
  store [label="SourceCandidateStore\nJSON réel"];
  review [label="SourceCandidateReviewResult"];
  audit_reader [label="audit summary reader\nlocal JSON only"];
  audit_files [label="decision audit JSON\noptional"];
  output [label="operator projection\ntext/json"];

  cli -> review_cli;
  review_cli -> store;
  store -> review;
  cli -> audit_reader;
  audit_files -> audit_reader;
  review -> audit_reader;
  audit_reader -> output;
}
