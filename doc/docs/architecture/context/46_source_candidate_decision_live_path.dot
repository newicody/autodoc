digraph source_candidate_decision_live_path {
  graph [rankdir=LR, label="Phase 6.5 — SourceCandidate Decision Live Path", labelloc=t];
  node [shape=box];

  cli [label="CLI adapter\nsource_candidate_decision_cli.py"];
  command [label="SourceCandidateDecisionCommand"];
  event [label="EventType.SOURCE_CANDIDATE_DECISION"];
  scheduler [label="Scheduler\nunchanged"];
  policy [label="PolicyEngine\ndest=source_candidate"];
  queue [label="PriorityQueue"];
  dispatcher [label="Dispatcher"];
  handler [label="SourceCandidateDecisionHandler"];
  store [label="SourceCandidateStore JSON\nreal local backend"];
  result [label="SourceCandidateDecisionResult"];
  result_event [label="SOURCE_CANDIDATE_DECISION_RESULT"];
  stdout [label="stdout text/json"];

  cli -> command;
  command -> event;
  event -> scheduler;
  scheduler -> policy;
  scheduler -> queue;
  queue -> dispatcher;
  dispatcher -> handler;
  handler -> store [label="load + atomic upsert"];
  store -> result;
  result -> result_event;
  result -> stdout;
}
