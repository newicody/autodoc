digraph ContextEngineContractLock {
  graph [
    label="Phase 5.11 — ContextEngine contract lock",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/34_e5_context_engine_intake_audit.dot

  subgraph cluster_locked_contracts {
    label="Contrats verrouillés";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Constructor [label="ContextEngine(registry, scheduler, event_bus)
constructeur historique"];
    ExecuteTick [label="execute_tick()
retourne le snapshot historique"];
    CurrentContext [label="current_inference_context
dernier InferenceContext"];
    LastSnapshot [label="last_snapshot
snapshot du dernier tick"];
    ExplicitIntake [label="attach_e5_artifact_dir()
attach_e5_runtime_context()
entrées explicites seulement"];
  }

  subgraph cluster_regression_guards {
    label="Tests anti-régression";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    LegacyDeps [label="registry/scheduler/event_bus
préservés"];
    TickSnapshot [label="snapshot.components
reste inspectable"];
    BuiltContext [label="InferenceContext construit
mémorisé séparément"];
    NoAutoLoad [label="E5 ne s'attache pas
automatiquement"];
    ExplicitMethods [label="méthodes d'intake
présentes et explicites"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    NoSchedulerChange [label="pas de modification Scheduler"];
    NoDaemon [label="pas de daemon"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    Stdlib [label="stdlib uniquement"];
  }

  Constructor -> LegacyDeps;
  ExecuteTick -> TickSnapshot;
  ExecuteTick -> LastSnapshot;
  ExecuteTick -> BuiltContext;
  BuiltContext -> CurrentContext;
  ExplicitIntake -> ExplicitMethods;
  ExplicitIntake -> NoAutoLoad;

  NoSchedulerChange -> Constructor [style=dashed];
  NoDaemon -> ExplicitIntake [style=dashed];
  NoNetwork -> ExplicitIntake [style=dashed];
  NoQdrant -> ExplicitIntake [style=dashed];
  NoLlm -> CurrentContext [style=dashed];
  Stdlib -> TickSnapshot [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← Intake audit", shape=plaintext, URL="34_e5_context_engine_intake_audit.svg"];
    Next [label="next: local context loop design", shape=plaintext, URL="36_local_context_loop_design.svg"];
  }

  // HTML_DETAIL[phase5_11]: La Phase 5.11 verrouille les contrats sensibles révélés par les corrections 5.6-r1/r2 : constructeur historique ContextEngine, execute_tick qui retourne un snapshot, InferenceContext courant séparé, et intake E5 uniquement explicite.
}
