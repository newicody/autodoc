digraph SourceCandidateStorageReport {
  graph [
    label="Phase 5.15 — SourceCandidate local storage/report",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/38_source_candidate_contract.dot

  subgraph cluster_contract {
    label="Contrats SourceCandidate existants";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Candidate [label="SourceCandidate\nschema missipy.source_candidate.v1"];
    Decision [label="SourceCandidateDecision\ninspect/relaunch/reject/archive/promote/merge"];
  }

  subgraph cluster_io {
    label="Bordure IO locale explicite";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    StorePolicy [label="SourceCandidateStorePolicy\npath + repository=newicody/autodoc"];
    Snapshot [label="SourceCandidateStoreSnapshot\nschema missipy.source_candidate.store.v1"];
    Load [label="load_source_candidate_store()\nmissing file -> empty snapshot"];
    Upsert [label="upsert_source_candidate()\ninsert or replace by candidate_id"];
    StoreFile [label="source_candidates.json\natomic write"];
    WriteResult [label="SourceCandidateStoreWriteResult\ninserted/replaced/count"];
    ReportPolicy [label="SourceCandidateReportPolicy\noptional path"];
    Report [label="SourceCandidateStoreReport\nschema missipy.source_candidate.store_report.v1"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    NoDb [label="pas de base de données"];
    NoServer [label="pas de serveur / daemon"];
    NoWatcher [label="pas de watcher / polling"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoToken [label="pas de token"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    NoOpenVINO [label="pas d'appel OpenVINO"];
    Stdlib [label="stdlib uniquement"];
  }

  Candidate -> Upsert;
  Decision -> Candidate [style=dashed, label="candidate may already be decided"];
  StorePolicy -> Load;
  StorePolicy -> Upsert;
  Load -> Snapshot;
  Snapshot -> Upsert;
  Upsert -> Snapshot [label="new immutable snapshot"];
  Upsert -> StoreFile [label="atomic JSON"];
  Upsert -> WriteResult;
  WriteResult -> Report;
  ReportPolicy -> Report;
  Report -> StoreFile [style=dashed, label="separate optional report file"];

  NoDb -> StoreFile [style=dashed];
  NoServer -> Upsert [style=dashed];
  NoWatcher -> Load [style=dashed];
  NoNetwork -> StorePolicy [style=dashed];
  NoToken -> StorePolicy [style=dashed];
  NoQdrant -> Snapshot [style=dashed];
  NoLlm -> Decision [style=dashed];
  NoOpenVINO -> Candidate [style=dashed];
  Stdlib -> StoreFile [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← SourceCandidate contract", shape=plaintext, URL="38_source_candidate_contract.svg"];
    Next [label="next: GitHub projection design", shape=plaintext, URL="40_github_projection_design.svg"];
  }

  // HTML_DETAIL[phase5_15]: La Phase 5.15 ajoute un store JSON local explicite pour SourceCandidate, avec upsert atomique et rapport optionnel. Le repository par défaut reste newicody/autodoc mais aucun réseau, token ou API GitHub n'est utilisé.
}
