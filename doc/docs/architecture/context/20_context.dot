digraph Context {
    rankdir=TB;
    splines=ortho;

    graph [fontname="Arial", fontsize=11];
    node  [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge  [fontname="Arial", fontsize=9, arrowsize=0.7];

    Scheduler [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/10_scheduler.svg"];
    Registry  [fillcolor="#ede7f6", color="#512da8"];
    Proxy     [label="ComponentProxy", fillcolor="#ede7f6", color="#512da8"];

    EventBus  [label="EventBus\nobservation only", fillcolor="#ede7f6", color="#512da8"];

    subgraph cluster_current {
        label="Phase 1 — fast path actuel";
        color="#ef6c00";
        bgcolor="#fff3e0";
        node [fillcolor="#fff3e0", color="#ef6c00"];
        ContextEngine [label="ContextEngine.execute_tick()"];
        DirectCollect [label="Registry.all()\nproxy.context()"];
        Snapshot [label="GlobalContextSnapshot"];
        InferenceContext [label="InferenceContext"];
    }

    subgraph cluster_target {
        label="Cible — event based";
        color="#f9a825";
        bgcolor="#fffde7";
        node [fillcolor="#fffde7", color="#f9a825"];
        ContextRequest [label="CONTEXT_REQUEST"];
        ContextReply   [label="CONTEXT_REPLY"];
        Collector;
        Reducer;
        DecisionEngine;
    }

    Scheduler -> ContextEngine [label="clock tick"];
    ContextEngine -> EventBus [label="publish CONTEXT_REQUEST"];
    ContextEngine -> Registry;
    Registry -> Proxy;
    Proxy -> DirectCollect [label="context()"];
    DirectCollect -> Snapshot;
    Snapshot -> InferenceContext;

    ContextRequest -> Proxy [style=dashed, label="future"];
    Proxy -> ContextReply [style=dashed, label="future"];
    ContextReply -> Collector [style=dashed];
    Collector -> Reducer [style=dashed];
    Reducer -> Snapshot [style=dashed];
    InferenceContext -> DecisionEngine [style=dashed, label="future"];
    DecisionEngine -> Scheduler [style=dashed];

    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="../scheduler/10_scheduler.svg"];
    { rank=sink; Nav_Global; Nav_Scheduler; }
}
