digraph LocalContextLoopCLI {
  graph [
    label="Phase 5.13 — Local context loop CLI",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/36_local_context_loop_design.dot

  subgraph cluster_input {
    label="Entrée manuelle";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Operator [label="opérateur\npython -m context.local_context_loop_cli"];
    ArtifactDir [label="artifact-dir Phase 4\nreport/context/consumed/prompt"];
    NextAction [label="--next-action\ninspect / relaunch / reject / archive / promote / merge\nreporté seulement"];
  }

  subgraph cluster_loop {
    label="Orchestration mince";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Command [label="LocalContextLoopCommand\ncontrat CLI typé"];
    Engine [label="ContextEngine()\ninstance locale sans Scheduler vivant"];
    Intake [label="attach_e5_artifact_dir()\nintake explicite"];
    Status [label="inspect_e5_context_engine()\nprojection passive"];
    Result [label="LocalContextLoopResult\nschema missipy.local_context_loop_cli.v1"];
    Output [label="stdout text/json\n--report-file JSON atomique"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    NoE5Run [label="ne relance pas E5 / OpenVINO"];
    NoDecisionMutation [label="n'applique aucune décision"];
    NoServer [label="pas de serveur / daemon"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoStorage [label="pas de stockage persistant"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    Stdlib [label="stdlib uniquement"];
  }

  Operator -> Command;
  ArtifactDir -> Command;
  NextAction -> Command;
  Command -> Engine;
  Command -> Intake;
  Engine -> Intake;
  Intake -> Status;
  Status -> Result;
  NextAction -> Result;
  Result -> Output;

  NoE5Run -> ArtifactDir [style=dashed];
  NoDecisionMutation -> NextAction [style=dashed];
  NoServer -> Engine [style=dashed];
  NoNetwork -> Result [style=dashed];
  NoStorage -> Output [style=dashed];
  NoQdrant -> Intake [style=dashed];
  NoLlm -> Status [style=dashed];
  Stdlib -> Command [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← Local context loop design", shape=plaintext, URL="36_local_context_loop_design.svg"];
    Next [label="next: SourceCandidate local contract", shape=plaintext];
  }

  // HTML_DETAIL[phase5_13]: La Phase 5.13 ajoute une CLI de boucle locale manuelle qui consomme un artifact-dir Phase 4, attache explicitement E5 au ContextEngine, inspecte le statut et écrit stdout/report. Le champ next_action est reporté seulement : aucune décision n'est appliquée.
}
