digraph Phase5ClosureAudit {
  graph [
    label="Phase 5.18 — Phase 5 closure audit",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/41_local_server_boundary.dot

  subgraph cluster_phase4_input {
    label="Entrée stable Phase 4";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    ArtifactDir [label="artifact-dir Phase 4\nreport/context/consumed/prompt"];
  }

  subgraph cluster_phase5_intake {
    label="Intake local Phase 5";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Loader [label="E5RuntimeArtifactDirectoryLoader"];
    Runtime [label="E5LocalContextRuntime"];
    Attachment [label="E5ContextAttachment"];
    ContextEngine [label="ContextEngine\nintake explicite"];
    Status [label="E5ContextEngineStatus\nprojection passive"];
    CliReport [label="CLI manuelle\ntext/json/report"];
  }

  subgraph cluster_phase5_candidates {
    label="SourceCandidate local";
    style="rounded,filled";
    color="#b2dfdb";
    fillcolor="#e0f2f1";

    Candidate [label="SourceCandidate\nstatuts/décisions"];
    Store [label="SourceCandidateStore\nJSON atomique"];
    GitHubProjection [label="GitHub projection design\nnewicody/autodoc\nfuture only"];
    AdapterBoundary [label="Local adapter boundary\nadapter_kind=undecided\nframework_choice=undecided"];
  }

  subgraph cluster_locked_contracts {
    label="Contrats verrouillés";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff3e0";

    Constructor [label="ContextEngine(registry, scheduler, event_bus)"];
    Tick [label="execute_tick() -> snapshot"];
    CurrentContext [label="current_inference_context\nlatest InferenceContext"];
    ExplicitOnly [label="E5 intake explicite seulement"];
  }

  subgraph cluster_not_done {
    label="Non-objectifs confirmés";
    style="rounded,dashed";
    color="#b0bec5";

    NoDaemon [label="pas de daemon/polling/watcher"];
    NoNetwork [label="pas de réseau/API GitHub/token"];
    NoServer [label="pas de serveur/framework choisi"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    NoOpenVINO [label="pas d'appel OpenVINO caché"];
  }

  ArtifactDir -> Loader -> Runtime -> Attachment -> ContextEngine -> Status -> CliReport;
  Candidate -> Store -> GitHubProjection -> AdapterBoundary;
  ContextEngine -> Candidate [style=dashed, label="future operator decision"];

  Constructor -> ContextEngine [style=dashed];
  Tick -> ContextEngine [style=dashed];
  CurrentContext -> ContextEngine [style=dashed];
  ExplicitOnly -> ContextEngine [style=dashed];

  NoDaemon -> CliReport [style=dashed];
  NoNetwork -> GitHubProjection [style=dashed];
  NoServer -> AdapterBoundary [style=dashed];
  NoQdrant -> Store [style=dashed];
  NoLlm -> Status [style=dashed];
  NoOpenVINO -> Runtime [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← Local adapter boundary", shape=plaintext, URL="41_local_server_boundary.svg"];
    Next [label="next: Phase 6 entry", shape=plaintext];
  }

  // HTML_DETAIL[phase5_18]: La Phase 5.18 clôture l'intégration locale contrôlée : artifact-dir E5, runtime local, intake ContextEngine explicite, status/report, SourceCandidate local, projection GitHub documentaire et frontière adapter serveur futur non choisie. Aucun daemon, réseau, API GitHub, token, Qdrant, LLM, serveur réel ou appel OpenVINO caché n'est introduit.
}
