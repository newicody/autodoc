digraph source_candidate_external_probe_bundle {
  graph [rankdir=LR, label="Phase 7.11 SourceCandidate external probe bundle", labelloc=t];
  node [shape=box];

  review [label="operator external review report"];
  request [label="read-only probe request"];
  result [label="read-only probe result"];
  bundle [label="external probe bundle"];
  manifest [label="manifest.json"];
  operator [label="operator review"];
  api [label="external API not contacted", style=dashed];

  review -> bundle;
  request -> bundle;
  result -> bundle;
  bundle -> manifest;
  manifest -> operator;
  bundle -> api [label="no call", style=dashed];
}
