digraph source_candidate_projection_gate {
  graph [rankdir=LR, label="Phase 6.15 SourceCandidate projection gate", labelloc=t];
  node [shape=box];

  bundle [label="projection bundle directory"];
  manifest [label="manifest.json"];
  preview [label="projection_preview.json"];
  gate [label="SourceCandidateProjectionGate\nlocal validation"];
  result [label="projection_gate_result\nPASS / FAIL"];
  future [label="future external handoff\nblocked until PASS", style=dashed];

  bundle -> manifest;
  bundle -> preview;
  manifest -> gate;
  preview -> gate;
  gate -> result;
  result -> future [style=dashed];
}
