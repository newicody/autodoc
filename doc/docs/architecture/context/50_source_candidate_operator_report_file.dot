digraph source_candidate_operator_report_file {
  rankdir=LR;
  node [shape=box];

  cli [label="operator report file CLI"];
  report_path [label="operator report path\nreview + audit + summary"];
  report [label="SourceCandidateOperatorReportResult"];
  writer [label="local artifact writer\natomic os.replace"];
  file [label="operator report artifact\nJSON or text"];
  stdout [label="write summary\nstdout"];

  cli -> report_path;
  report_path -> report;
  report -> writer;
  writer -> file;
  writer -> stdout;
}
