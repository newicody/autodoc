digraph E5RuntimeBridge {
  graph [
    label="Phase 5.1 — E5 runtime bridge",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: inference/74_e5_phase4_closure.dot

  subgraph cluster_inputs {
    label="Artefacts Phase 4 déjà produits";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Report [label="report.json\nE5SearchReport"];
    Bundle [label="context.json\nE5ContextBundle"];
    Consumed [label="consumed_context.json\nE5ConsumedContext"];
    Prompt [label="prompt.json\nE5AnswerPromptPacket"];
  }

  subgraph cluster_bridge {
    label="Pont local pur";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff8e1";

    ArtifactBundle [label="E5RuntimeArtifactBundle\npayloads déjà chargés"];
    Policy [label="E5RuntimeBridgePolicy\ncomponent + priority + text policy"];
    Bridge [label="E5RuntimeBridge\naucun IO / aucun backend"];
    Result [label="E5RuntimeBridgeResult\nprojection audit"];
  }

  subgraph cluster_output {
    label="Sortie Context Fabric";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Features [label="features\nmissipy.e5.runtime_bridge.v1"];
    Priorities [label="priorities\ncomponent priority"];
    InferenceContext [label="InferenceContext", URL="20_context.svg"];
  }

  subgraph cluster_boundaries {
    label="Frontières 5.1";
    style="rounded,dashed";
    color="#b0bec5";

    NoRead [label="ne lit pas les fichiers"];
    NoScheduler [label="ne lance pas le Scheduler"];
    NoQdrant [label="pas de Qdrant"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoLLM [label="pas de génération LLM"];
    Stdlib [label="aucune dépendance hors stdlib"];
  }

  Report -> ArtifactBundle;
  Bundle -> ArtifactBundle;
  Consumed -> ArtifactBundle;
  Prompt -> ArtifactBundle;

  ArtifactBundle -> Bridge;
  Policy -> Bridge;
  Bridge -> Result;
  Bridge -> Features;
  Bridge -> Priorities;
  Features -> InferenceContext;
  Priorities -> InferenceContext;

  NoRead -> ArtifactBundle [style=dashed];
  NoScheduler -> InferenceContext [style=dashed];
  NoQdrant -> Bridge [style=dashed];
  NoNetwork -> Bridge [style=dashed];
  NoLLM -> Prompt [style=dashed];
  Stdlib -> Bridge [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Context [label="← Context Fabric", shape=plaintext, URL="20_context.svg"];
    Parent [label="← Phase 4 closure", shape=plaintext, URL="../inference/74_e5_phase4_closure.svg"];
    Next [label="next: local artifact intake", shape=plaintext];
  }

  // HTML_DETAIL[phase5_1]: Le pont convertit des artefacts E5 déjà chargés en InferenceContext ; il ne lit pas de fichiers, ne déclenche aucun Scheduler et n'appelle aucun backend.
}
