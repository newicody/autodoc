digraph E5ContextEngineCli {
  graph [
    label="Phase 5.8 — ContextEngine E5 manual CLI intake",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/31_e5_context_engine_status.dot

  subgraph cluster_input {
    label="Entrée manuelle";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    ArtifactDir [label="artifact-dir Phase 4\nreport/context/consumed/prompt", URL="26_e5_artifact_directory_loader.svg"];
    Parser [label="build_e5_context_engine_parser()"];
    Command [label="E5ContextEngineCliCommand\nartifact_dir + policies"];
  }

  subgraph cluster_runtime {
    label="Intake ContextEngine";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Engine [label="ContextEngine()", URL="20_context.svg"];
    Intake [label="attach_e5_artifact_dir()", URL="30_e5_context_engine_intake.svg"];
    Status [label="inspect_e5_context_engine()", URL="31_e5_context_engine_status.svg"];
    Payload [label="missipy.e5.context_engine_cli.v1"];
    Text [label="text summary"];
    Json [label="json payload"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    Manual [label="appel manuel uniquement"];
    NoScheduler [label="pas de Scheduler vivant"];
    NoDaemon [label="pas de daemon"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoQdrant [label="pas de Qdrant"];
    NoLLM [label="pas de LLM"];
    NoOpenVINO [label="pas d'appel OpenVINO"];
    Stdlib [label="stdlib uniquement"];
  }

  ArtifactDir -> Parser;
  Parser -> Command;
  Command -> Engine;
  Command -> Intake;
  Engine -> Intake;
  Intake -> Status;
  Status -> Payload;
  Intake -> Payload;
  Payload -> Text;
  Payload -> Json;

  Manual -> Parser [style=dashed];
  NoScheduler -> Engine [style=dashed];
  NoDaemon -> Parser [style=dashed];
  NoNetwork -> Payload [style=dashed];
  NoQdrant -> Intake [style=dashed];
  NoLLM -> Text [style=dashed];
  NoOpenVINO -> ArtifactDir [style=dashed];
  Stdlib -> Command [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← E5 ContextEngine status", shape=plaintext, URL="31_e5_context_engine_status.svg"];
    IntakeNav [label="← ContextEngine E5 intake", shape=plaintext, URL="30_e5_context_engine_intake.svg"];
    Next [label="next: ContextEngine local intake audit", shape=plaintext];
  }

  // HTML_DETAIL[phase5_8]: CLI manuelle locale pour attacher un artifact-dir E5 Phase 4 à un ContextEngine éphémère puis afficher le statut 5.7 ; aucune API distante, aucun Scheduler vivant et aucun backend ne sont appelés.
}
