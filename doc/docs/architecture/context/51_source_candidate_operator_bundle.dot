digraph source_candidate_operator_bundle {
  rankdir=LR;
  node [shape=box];

  cli [label="operator bundle CLI"];
  report_path [label="operator report path\nreview + audit + summary"];
  report [label="SourceCandidateOperatorReportResult"];
  file_writer [label="operator report file writer\nJSON + text"];
  manifest [label="bundle manifest\nmanifest.json"];
  bundle [label="local bundle directory"];
  stdout [label="bundle summary\nstdout"];

  cli -> report_path;
  report_path -> report;
  report -> file_writer;
  file_writer -> bundle;
  report -> manifest;
  manifest -> bundle;
  bundle -> stdout;
}
