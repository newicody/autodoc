digraph source_candidate_external_projection_contract {
  graph [rankdir=LR, label="Phase 7.1 SourceCandidate external projection contract", labelloc=t];
  node [shape=box];

  handoff [label="handoff dry-run bundle"];
  manifest [label="handoff_manifest.json"];
  preview [label="projection_preview.json"];
  gate [label="projection_gate_report.json"];
  contract [label="external_projection_contract.json\ntarget-neutral"];
  github [label="future GitHub payload\nnot built here", style=dashed];

  handoff -> manifest;
  handoff -> preview;
  handoff -> gate;
  manifest -> contract;
  preview -> contract;
  gate -> contract;
  contract -> github [style=dashed];
}
