digraph LocalContextLoopDesign {
  graph [
    label="Phase 5.12 — Local context loop design",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/35_context_engine_contract_lock.dot

  subgraph cluster_inputs {
    label="Entrées locales possibles";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Question [label="question / demande locale"];
    ExistingArtifacts [label="artifact-dir Phase 4\nexistant"];
    FutureSource [label="source locale future"];
    FutureCandidate [label="SourceCandidate future"];
  }

  subgraph cluster_loop {
    label="Boucle locale manuelle";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    E5Search [label="E5 search / build\nproduit artifact-dir"];
    ArtifactDir [label="artifact-dir\nreport/context/consumed/prompt"];
    Loader [label="E5RuntimeArtifactDirectoryLoader"];
    Runtime [label="E5LocalContextRuntime"];
    Intake [label="ContextEngine.attach_e5_*\nintake explicite"];
    Status [label="E5ContextEngineStatus\nprojection passive"];
    Report [label="CLI status/report JSON\nPhase 5.9"];
    HumanDecision [label="décision humaine\nrelancer / rejeter / archiver / promouvoir / fusionner"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    NoNewCli [label="pas de nouvelle CLI\nen 5.12"];
    NoServer [label="pas de serveur / daemon"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoStorage [label="pas de stockage persistant"];
    NoScheduler [label="pas d'autoload Scheduler"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    NoOpenVino [label="pas d'appel OpenVINO caché"];
  }

  Question -> E5Search [label="requête"];
  ExistingArtifacts -> ArtifactDir [label="réutilisation"];
  FutureSource -> E5Search [style=dashed, label="future"];
  FutureCandidate -> ArtifactDir [style=dashed, label="future"];

  E5Search -> ArtifactDir;
  ArtifactDir -> Loader;
  Loader -> Runtime;
  Runtime -> Intake;
  Intake -> Status;
  Status -> Report;
  Report -> HumanDecision;
  HumanDecision -> Question [style=dashed, label="relance"];
  HumanDecision -> FutureCandidate [style=dashed, label="future promotion"];

  NoNewCli -> Report [style=dashed];
  NoServer -> HumanDecision [style=dashed];
  NoNetwork -> FutureCandidate [style=dashed];
  NoStorage -> ArtifactDir [style=dashed];
  NoScheduler -> Intake [style=dashed];
  NoQdrant -> ArtifactDir [style=dashed];
  NoLlm -> Status [style=dashed];
  NoOpenVino -> Runtime [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← ContextEngine contract lock", shape=plaintext, URL="35_context_engine_contract_lock.svg"];
    Next [label="next: local loop CLI", shape=plaintext, URL="37_local_context_loop_cli.svg"];
  }

  // HTML_DETAIL[phase5_12]: La Phase 5.12 décrit la boucle locale manuelle reliant artefacts E5, runtime local, intake explicite ContextEngine, status/report et décision humaine. Elle prépare une CLI mince future sans ajouter de daemon, serveur, réseau, Qdrant, LLM ou appel OpenVINO caché.
}
