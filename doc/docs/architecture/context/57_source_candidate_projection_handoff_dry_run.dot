digraph source_candidate_projection_handoff_dry_run {
  graph [rankdir=LR, label="Phase 6.17 SourceCandidate projection handoff dry-run", labelloc=t];
  node [shape=box];

  bundle [label="projection bundle"];
  preview [label="projection_preview.json"];
  gate [label="projection gate report"];
  manifest [label="handoff_manifest.json"];
  dryrun [label="handoff dry-run bundle\nlocal only"];
  future [label="future external handoff\nnot contacted", style=dashed];

  bundle -> preview;
  bundle -> gate;
  preview -> dryrun;
  gate -> dryrun;
  dryrun -> manifest;
  dryrun -> future [style=dashed];
}
