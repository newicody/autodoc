digraph source_candidate_github_projection_payload {
  graph [rankdir=LR, label="Phase 7.2 SourceCandidate GitHub projection payload dry-run", labelloc=t];
  node [shape=box];

  contract [label="external_projection_contract.json"];
  builder [label="GitHub projection payload builder\nlocal dry-run only"];
  payload [label="github_projection_payload.json\ndry_run=true\nremote_mutation=false"];
  gate [label="future remote mutation gate\nnot here", style=dashed];
  api [label="GitHub API\nnot contacted", style=dashed];

  contract -> builder;
  builder -> payload;
  payload -> gate [style=dashed];
  payload -> api [label="no call", style=dashed];
}
