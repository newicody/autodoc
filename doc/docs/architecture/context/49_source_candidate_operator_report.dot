digraph source_candidate_operator_report {
  rankdir=LR;
  graph [fontname="sans-serif"];
  node [shape=box, fontname="sans-serif"];
  edge [fontname="sans-serif"];

  cli [label="operator report CLI"];
  review_audit_cli [label="review audit live path"];
  scheduler [label="Scheduler / Dispatcher"];
  store [label="SourceCandidateStore JSON"];
  audits [label="decision audit JSON files"];
  projection [label="operator report projection"];
  output [label="text / JSON report"];

  cli -> review_audit_cli;
  review_audit_cli -> scheduler;
  scheduler -> store;
  review_audit_cli -> audits;
  review_audit_cli -> projection;
  projection -> output;
}
