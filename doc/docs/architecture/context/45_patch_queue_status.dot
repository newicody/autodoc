digraph patch_queue_status {
  rankdir=LR;
  node [shape=box];

  operator [label="operator"];
  cli [label="apply_patch_queue.py --status"];
  git [label="git status / branch / head"];
  patch_root [label="patch/<id>/ inventory"];
  generated [label="generated artifact scan"];
  report [label="PatchQueueStatus\ntext/json"];

  operator -> cli;
  cli -> git;
  cli -> patch_root;
  cli -> generated;
  cli -> report;
}
