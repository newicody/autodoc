digraph SourceCandidateContract {
  graph [
    label="Phase 5.14 — SourceCandidate local contract",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/37_local_context_loop_cli.dot

  subgraph cluster_input {
    label="Matière brute locale";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    LocalLoop [label="LocalContextLoopResult\nPhase 5.13 future source"];
    ManualNote [label="note opérateur / fichier / artifact-dir"];
    FutureGitHub [label="future GitHub item\nnewicody/autodoc\nprojection seulement"];
  }

  subgraph cluster_contract {
    label="Contrat local pur";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Origin [label="SourceCandidateOrigin\nlocal/file/artifact_dir/github/manual"];
    Input [label="SourceCandidateInput\ntitle/body/labels/metadata"];
    Policy [label="SourceCandidatePolicy\ndefault_repository=newicody/autodoc"];
    Candidate [label="SourceCandidate\nschema missipy.source_candidate.v1"];
    Decision [label="SourceCandidateDecision\ninspect/relaunch/reject/archive/promote/merge"];
    Transition [label="apply_source_candidate_decision()\nreturns new immutable candidate"];
  }

  subgraph cluster_status {
    label="Statuts";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff3e0";

    New [label="new"];
    Analyzed [label="analyzed"];
    Rejected [label="rejected terminal"];
    Archived [label="archived terminal"];
    Promoted [label="promoted terminal"];
    Merged [label="merged terminal"];
  }

  subgraph cluster_boundaries {
    label="Frontières conservées";
    style="rounded,dashed";
    color="#b0bec5";

    NoStorage [label="pas de stockage persistant"];
    NoReport [label="pas de rapport SourceCandidate encore"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoToken [label="pas de token"];
    NoScheduler [label="pas de Scheduler vivant"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    NoOpenVINO [label="pas d'appel OpenVINO"];
    Stdlib [label="stdlib uniquement"];
  }

  LocalLoop -> Input [style=dashed, label="future conversion"];
  ManualNote -> Input;
  FutureGitHub -> Origin [style=dashed, label="future projection"];
  Origin -> Input;
  Policy -> Candidate;
  Input -> Candidate [label="build_source_candidate()"];
  Candidate -> Decision [label="operator decision"];
  Decision -> Transition;
  Transition -> Candidate [label="new instance"];

  Candidate -> New;
  Decision -> Analyzed [label="inspect/relaunch"];
  Decision -> Rejected [label="reject"];
  Decision -> Archived [label="archive"];
  Decision -> Promoted [label="promote"];
  Decision -> Merged [label="merge"];

  NoStorage -> Candidate [style=dashed];
  NoReport -> Candidate [style=dashed];
  NoNetwork -> FutureGitHub [style=dashed];
  NoToken -> FutureGitHub [style=dashed];
  NoScheduler -> Transition [style=dashed];
  NoQdrant -> Candidate [style=dashed];
  NoLlm -> Decision [style=dashed];
  NoOpenVINO -> Input [style=dashed];
  Stdlib -> Policy [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← Local context loop CLI", shape=plaintext, URL="37_local_context_loop_cli.svg"];
    Next [label="next: SourceCandidate local storage/report", shape=plaintext, URL="39_source_candidate_storage_report.svg"];
  }

  // HTML_DETAIL[phase5_14]: La Phase 5.14 ajoute le contrat local SourceCandidate : origine, entrée, politique, statut, décision et transition immuable. La valeur newicody/autodoc prépare la projection GitHub future sans réseau, API ou token.
}
