digraph source_candidate_projection_preview {
  graph [rankdir=LR, label="Phase 6.13 SourceCandidate projection preview", labelloc=t];
  node [shape=box];

  report [label="operator_report.json\nlocal artifact"];
  preview [label="SourceCandidateProjectionPreview\npure projection"];
  file [label="projection_preview.json\natomic local write"];
  external [label="future external surface\nnot contacted", style=dashed];

  report -> preview;
  preview -> file;
  preview -> external [label="preview only", style=dashed];
}
