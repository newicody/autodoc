digraph E5ArtifactDirectoryLoader {
  graph [
    label="Phase 5.2 — E5 artifact directory loader",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/25_e5_runtime_bridge.dot

  subgraph cluster_directory {
    label="Artifact directory Phase 4";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Directory [label="artifact-dir\nDIR"];
    ReportFile [label="report.json"];
    ContextFile [label="context.json"];
    ConsumedFile [label="consumed_context.json"];
    PromptFile [label="prompt.json"];
  }

  subgraph cluster_loader {
    label="Bordure IO contrôlée";
    style="rounded,filled";
    color="#ffe0b2";
    fillcolor="#fff8e1";

    Policy [label="E5RuntimeArtifactDirectoryPolicy\nfilenames + encoding"];
    Loader [label="E5RuntimeArtifactDirectoryLoader\nlecture JSON objets"];
    ReadResult [label="E5RuntimeArtifactDirectoryReadResult\npaths + bundle"];
  }

  subgraph cluster_bridge {
    label="Réutilisation Phase 5.1";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Bundle [label="E5RuntimeArtifactBundle\npayloads chargés"];
    DirectoryBridge [label="E5RuntimeArtifactDirectoryBridge\nloader + bridge"];
    RuntimeBridge [label="E5RuntimeBridge", URL="25_e5_runtime_bridge.svg"];
    InferenceContext [label="InferenceContext", URL="20_context.svg"];
  }

  subgraph cluster_boundaries {
    label="Frontières 5.2";
    style="rounded,dashed";
    color="#b0bec5";

    NoDaemon [label="pas de daemon"];
    NoScheduler [label="ne lance pas le Scheduler"];
    NoQdrant [label="pas de Qdrant"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoLLM [label="pas de génération LLM"];
    Stdlib [label="stdlib uniquement"];
  }

  Directory -> ReportFile;
  Directory -> ContextFile;
  Directory -> ConsumedFile;
  Directory -> PromptFile;

  ReportFile -> Loader;
  ContextFile -> Loader;
  ConsumedFile -> Loader;
  PromptFile -> Loader;
  Policy -> Loader;
  Loader -> ReadResult;
  ReadResult -> Bundle;
  Bundle -> DirectoryBridge;
  DirectoryBridge -> RuntimeBridge;
  RuntimeBridge -> InferenceContext;

  NoDaemon -> Loader [style=dashed];
  NoScheduler -> InferenceContext [style=dashed];
  NoQdrant -> RuntimeBridge [style=dashed];
  NoNetwork -> Loader [style=dashed];
  NoLLM -> RuntimeBridge [style=dashed];
  Stdlib -> Loader [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← E5 runtime bridge", shape=plaintext, URL="25_e5_runtime_bridge.svg"];
    Phase4 [label="← Phase 4 closure", shape=plaintext, URL="../inference/74_e5_phase4_closure.svg"];
    Next [label="next: artifact context CLI", shape=plaintext, URL="27_e5_artifact_context_cli.svg"];
  }

  // HTML_DETAIL[phase5_2]: Le loader est la première bordure IO Phase 5 : il lit un artifact-dir Phase 4 et retourne un E5RuntimeArtifactBundle sans daemon, réseau ni Scheduler.
}
