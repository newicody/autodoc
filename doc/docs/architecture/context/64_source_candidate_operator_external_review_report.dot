digraph source_candidate_operator_external_review_report {
  graph [rankdir=LR, label="Phase 7.8 SourceCandidate operator external review report", labelloc=t];
  node [shape=box];

  bundle [label="github_export_bundle/manifest.json"];
  gate [label="remote_mutation_gate.json"];
  adapter [label="github_adapter_dry_run.json\nfake-only"];
  report [label="operator_external_review_report.json"];
  operator [label="operator review decision"];
  api [label="external API\nnot contacted", style=dashed];

  bundle -> report;
  gate -> report;
  adapter -> report;
  report -> operator;
  report -> api [label="no call", style=dashed];
}
