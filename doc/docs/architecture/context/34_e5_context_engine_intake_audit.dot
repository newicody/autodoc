digraph E5ContextEngineIntakeAudit {
  graph [
    label="Phase 5.10 — ContextEngine local intake audit",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/33_e5_context_engine_cli_report.dot

  subgraph cluster_scope {
    label="Périmètre audité";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    ArtifactDir [label="artifact-dir Phase 4
report/context/consumed/prompt", URL="26_e5_artifact_directory_loader.svg"];
    Runtime [label="E5LocalContextRuntime", URL="28_e5_local_context_runtime.svg"];
    Attachment [label="E5ContextAttachment", URL="29_e5_context_attachment.svg"];
    Intake [label="ContextEngine E5 intake", URL="30_e5_context_engine_intake.svg"];
    Status [label="E5ContextEngineStatus", URL="31_e5_context_engine_status.svg"];
    Cli [label="ContextEngine E5 CLI", URL="32_e5_context_engine_cli.svg"];
    CliReport [label="CLI report JSON", URL="33_e5_context_engine_cli_report.svg"];
  }

  subgraph cluster_audit {
    label="Résultat d'audit 5.10";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    ManualOnly [label="intake manuel explicite"];
    Observable [label="status inspectable
text/json/report"];
    StableBoundary [label="frontière stable
avant serveur/local loop"];
    NoMutation [label="pas de mutation cachée"];
    NoAutoload [label="pas d'autoload E5"];
  }

  subgraph cluster_deferred {
    label="Reporté après 5.10";
    style="rounded,dashed";
    color="#b0bec5";

    ServerLoop [label="serveur/local loop
futur"];
    SchedulerPolicy [label="Scheduler integration
futur et explicite"];
    GitHubIntake [label="GitHub Project Orchestrator
futur"];
    Qdrant [label="Qdrant
futur"];
    Llm [label="LLM réponse
futur"];
  }

  ArtifactDir -> Runtime;
  Runtime -> Attachment;
  Attachment -> Intake;
  Intake -> Status;
  Status -> Cli;
  Cli -> CliReport;

  Cli -> ManualOnly;
  Status -> Observable;
  CliReport -> Observable;
  Intake -> StableBoundary;
  ManualOnly -> NoMutation;
  ManualOnly -> NoAutoload;

  StableBoundary -> ServerLoop [style=dashed];
  StableBoundary -> SchedulerPolicy [style=dashed];
  StableBoundary -> GitHubIntake [style=dashed];
  StableBoundary -> Qdrant [style=dashed];
  StableBoundary -> Llm [style=dashed];

  subgraph cluster_constraints {
    label="Contraintes conservées";
    style="rounded,dashed";
    color="#b0bec5";

    NoDaemon [label="pas de daemon"];
    NoNetwork [label="pas de réseau / token"];
    NoScheduler [label="pas de Scheduler vivant"];
    NoBackend [label="pas d'appel OpenVINO"];
    Stdlib [label="stdlib uniquement"];
  }

  NoDaemon -> ManualOnly [style=dashed];
  NoNetwork -> CliReport [style=dashed];
  NoScheduler -> Intake [style=dashed];
  NoBackend -> Runtime [style=dashed];
  Stdlib -> CliReport [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← CLI report", shape=plaintext, URL="33_e5_context_engine_cli_report.svg"];
    Next [label="next: ContextEngine contract lock", shape=plaintext, URL="35_context_engine_contract_lock.svg"];
  }

  // HTML_DETAIL[phase5_10]: La Phase 5.10 fige l'audit de l'intake local manuel : les artefacts Phase 4 peuvent entrer dans ContextEngine, être inspectés, et être exportés en rapport JSON sans daemon, réseau, Scheduler vivant, Qdrant, LLM ni API GitHub.
}
