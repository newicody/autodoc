digraph SourceCandidateIntakeCLI {
  graph [
    label="Phase 6.1 — SourceCandidate intake CLI",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/42_phase5_closure_audit.dot

  subgraph cluster_operator_input {
    label="Entrée opérateur locale";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Args [label="CLI args\n--title / --body / --origin"];
    BodyFile [label="--body-file\nlecture explicite optionnelle"];
    Metadata [label="labels + metadata\nkey=value"];
  }

  subgraph cluster_contracts {
    label="Contrats SourceCandidate existants";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    Input [label="SourceCandidateInput"];
    Policy [label="SourceCandidatePolicy\nrepository=newicody/autodoc"];
    Candidate [label="SourceCandidate\nID déterministe"];
    Decision [label="SourceCandidateDecision\noptionnelle"];
  }

  subgraph cluster_store {
    label="Bordure IO locale";
    style="rounded,filled";
    color="#b2dfdb";
    fillcolor="#e0f2f1";

    StorePolicy [label="SourceCandidateStorePolicy\n--store-file"];
    Upsert [label="upsert_source_candidate()\nJSON atomique"];
    Store [label="source_candidates.json\nmissipy.source_candidate.store.v1"];
    Report [label="--report-file optionnel\nmissipy.source_candidate.store_report.v1"];
    Payload [label="stdout text/json\nmissipy.source_candidate.intake_cli.v1"];
  }

  subgraph cluster_boundaries {
    label="Frontières 6.1";
    style="rounded,dashed";
    color="#b0bec5";

    NoServer [label="pas de serveur"];
    NoDaemon [label="pas de daemon/watcher/polling"];
    NoNetwork [label="pas de réseau"];
    NoGitHub [label="pas d'API GitHub/token"];
    NoQdrant [label="pas de Qdrant"];
    NoLlm [label="pas de LLM"];
    NoOpenVINO [label="pas d'appel OpenVINO"];
    Stdlib [label="aucune dépendance hors stdlib"];
  }

  Args -> Input;
  BodyFile -> Input [label="read_text explicite"];
  Metadata -> Input;
  Policy -> Candidate;
  Input -> Candidate [label="build_source_candidate"];
  Decision -> Candidate [style=dashed, label="apply before write"];
  Candidate -> Upsert;
  StorePolicy -> Upsert;
  Upsert -> Store;
  Upsert -> Report [style=dashed];
  Upsert -> Payload;

  NoServer -> Payload [style=dashed];
  NoDaemon -> Payload [style=dashed];
  NoNetwork -> Store [style=dashed];
  NoGitHub -> Policy [style=dashed];
  NoQdrant -> Store [style=dashed];
  NoLlm -> Candidate [style=dashed];
  NoOpenVINO -> Candidate [style=dashed];
  Stdlib -> Upsert [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← Phase 5 closure audit", shape=plaintext, URL="42_phase5_closure_audit.svg"];
    Next [label="next: Phase 6 local decision CLI", shape=plaintext];
  }

  // HTML_DETAIL[phase6_1]: Phase 6.1 ajoute une CLI locale pour créer ou remplacer une SourceCandidate dans un store JSON atomique. La commande ne contacte pas GitHub, n'ouvre aucun réseau, ne lance aucun serveur, ne déclenche aucun Scheduler et n'appelle ni Qdrant, ni LLM, ni OpenVINO.
}
