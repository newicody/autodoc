digraph source_candidate_decision_audit {
  graph [rankdir=LR, label="Phase 6.6 — SourceCandidate Decision Audit / Report", labelloc=t];
  node [shape=box];

  cli [label="CLI adapter\n--audit-file"];
  command [label="SourceCandidateDecisionCommand\naudit_policy optional"];
  scheduler [label="Scheduler\nunchanged"];
  handler [label="SourceCandidateDecisionHandler"];
  store [label="SourceCandidateStore JSON\nload + atomic upsert"];
  result [label="SourceCandidateDecisionResult\naudit_path optional"];
  audit [label="decision audit JSON\natomic local report"];
  stdout [label="stdout text/json"];

  cli -> command;
  command -> scheduler;
  scheduler -> handler;
  handler -> store;
  store -> result;
  result -> audit [label="optional"];
  result -> stdout;
}
