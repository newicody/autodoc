digraph E5ContextAttachment {
  graph [
    label="Phase 5.5 — E5 context attachment contract",
    labelloc=t,
    fontsize=18,
    fontname="Arial",
    rankdir=LR,
    bgcolor="#ffffff"
  ];

  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10, fillcolor="#f5f5f5", color="#546e7a"];
  edge [fontname="Arial", fontsize=9, color="#455a64"];

  // ROADMAP_PARENT: context/28_e5_local_context_runtime.dot

  subgraph cluster_inputs {
    label="Entrées explicites";
    style="rounded,filled";
    color="#bbdefb";
    fillcolor="#e3f2fd";

    BaseContext [label="InferenceContext existant", URL="20_context.svg"];
    RuntimeResult [label="E5LocalContextRuntimeResult", URL="28_e5_local_context_runtime.svg"];
    ArtifactShortcut [label="artifact-dir shortcut\noptionnel via runtime 5.4", URL="28_e5_local_context_runtime.svg"];
  }

  subgraph cluster_attach {
    label="Contrat d'attachement 5.5";
    style="rounded,filled";
    color="#c8e6c9";
    fillcolor="#e8f5e9";

    Policy [label="E5ContextAttachmentPolicy\nreplace/require_ready/priority floor"];
    Attachment [label="E5ContextAttachment\nmerge immuable"];
    Result [label="E5ContextAttachmentResult\ncomponents + replaced + ready"];
    Json [label="to_json_dict()\naudit stable"];
  }

  subgraph cluster_output {
    label="Sortie Context Fabric";
    style="rounded,filled";
    color="#d1c4e9";
    fillcolor="#ede7f6";

    Merged [label="InferenceContext fusionné\nfeatures + priorities", URL="20_context.svg"];
    EngineFuture [label="ContextEngine future intake\nappel explicite"];
  }

  subgraph cluster_boundaries {
    label="Frontières";
    style="rounded,dashed";
    color="#b0bec5";

    NoMutation [label="pas de mutation du contexte de base"];
    NoScheduler [label="ne lance pas le Scheduler"];
    NoDaemon [label="pas de daemon"];
    NoNetwork [label="pas de réseau / GitHub API"];
    NoQdrant [label="pas de Qdrant"];
    NoLLM [label="pas de génération LLM"];
    Stdlib [label="stdlib uniquement"];
  }

  BaseContext -> Attachment;
  RuntimeResult -> Attachment;
  ArtifactShortcut -> RuntimeResult [style=dashed, label="via runtime"];
  Policy -> Attachment;
  Attachment -> Result;
  Result -> Merged;
  Result -> Json;
  Merged -> EngineFuture [style=dashed, label="future"];

  NoMutation -> Attachment [style=dashed];
  NoScheduler -> EngineFuture [style=dashed];
  NoDaemon -> Attachment [style=dashed];
  NoNetwork -> ArtifactShortcut [style=dashed];
  NoQdrant -> Attachment [style=dashed];
  NoLLM -> Merged [style=dashed];
  Stdlib -> Policy [style=dashed];

  subgraph cluster_navigation {
    label="Navigation";
    style="rounded,dashed";
    color="#90a4ae";

    Global [label="← Global architecture", shape=plaintext, URL="../00_global.svg"];
    Parent [label="← E5 local context runtime", shape=plaintext, URL="28_e5_local_context_runtime.svg"];
    Context [label="← Context Fabric", shape=plaintext, URL="20_context.svg"];
    Next [label="next: ContextEngine E5 intake", shape=plaintext, URL="30_e5_context_engine_intake.svg"];
  }

  // HTML_DETAIL[phase5_5]: L'attachement E5 fusionne explicitement un InferenceContext existant avec le résultat runtime E5 local. Il préserve les features existantes, applique une politique de remplacement contrôlée et prépare l'intégration future au ContextEngine sans lancer de Scheduler.
}
