digraph Experts {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    subgraph cluster_experts {
        label="Expert Components";
        color="#388e3c"; bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#388e3c"];
        Meta   [URL="40_experts.svg"];
        Python [URL="40_experts.svg"];
        C      [URL="40_experts.svg"];
        KiCad  [URL="40_experts.svg"];
        FreeCAD[URL="40_experts.svg"];
        Web    [URL="40_experts.svg"];
        SVG    [URL="40_experts.svg"];
    }

    Proxy [fillcolor="#ede7f6", color="#512da8", URL="../scheduler/component_proxy/14_component_proxy.svg"];
    Compiler [fillcolor="#f3e5f5", color="#7b1fa2", URL="../validation/50_validation.svg"];

    // Edges
    Proxy -> Meta;      // Délégation
    Proxy -> Python;
    Proxy -> C;
    Proxy -> KiCad;
    Proxy -> FreeCAD;
    Proxy -> Web;
    Proxy -> SVG;
    Proxy -> Compiler [label="soumet"];   // Soumission validation

    // Navigation
    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];
    Nav_Scheduler [label="Scheduler", shape=plaintext, URL="../scheduler/10_scheduler.svg"];
    Nav_Validation [label="Validation", shape=plaintext, URL="../validation/50_validation.svg"];
    { rank=sink; Nav_Global; Nav_Scheduler; Nav_Validation; }
}
