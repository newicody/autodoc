digraph Experts {
    rankdir=TB;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=10];
    edge [fontname="Arial", fontsize=9];

    Proxy [label="ComponentProxy", fillcolor="#ede7f6", color="#512da8", URL="../scheduler/10_scheduler.svg"];
    Contract [label="Component contract\ntick() + context()", fillcolor="#eceff1", color="#455a64"];

    subgraph cluster_current {
        label="Current";
        color="#388e3c";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#388e3c"];
        DummyExpert;
    }

    subgraph cluster_future {
        label="Future experts";
        color="#2e7d32";
        bgcolor="#e8f5e9";
        node [fillcolor="#e8f5e9", color="#2e7d32"];
        Python;
        C;
        ASM;
        KiCad;
        FreeCAD;
        Web;
        SVG_MIDI [label="SVG / MIDI"];
        MetaExpert;
    }

    Contract -> DummyExpert;
    Contract -> Python [style=dashed];
    Contract -> C [style=dashed];
    Contract -> ASM [style=dashed];
    Contract -> KiCad [style=dashed];
    Contract -> FreeCAD [style=dashed];
    Contract -> Web [style=dashed];
    Contract -> SVG_MIDI [style=dashed];
    Contract -> MetaExpert [style=dashed];
    Proxy -> DummyExpert [label="current"];

    Nav_Global [label="Global", shape=plaintext, URL="../00_global.svg"];
    { rank=sink; Nav_Global; }
}
