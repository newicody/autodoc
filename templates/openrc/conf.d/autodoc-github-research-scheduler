# Copie opérateur vers /etc/conf.d/autodoc-github-research-scheduler.
# Ne jamais placer de secret dans le dépôt.

AUTODOC_ROOT="/home/eric/projet/git/autodoc"
AUTODOC_PYTHON="/home/eric/python/bin/python"
AUTODOC_RUNTIME_CONFIG="${AUTODOC_ROOT}/.var/config/love_installed_runtime.ini"
AUTODOC_SERVICE_USER="eric"

# L'unité suivante fournira la composition installée concrète.
AUTODOC_GITHUB_RESEARCH_OPENRC_SERVICE_FACTORY=""

AUTODOC_CONTROLFS_ROOT="/dev/shm/autodoc/controlfs"
AUTODOC_QDRANT_POINT_WRITE_ALLOWED="true"
AUTODOC_QDRANT_SEARCH_ALLOWED="true"

# Les secrets restent dans un fichier local root:root mode 0600.
AUTODOC_ENV_FILE="/etc/autodoc/autodoc.env"
if [ -r "${AUTODOC_ENV_FILE}" ]; then
    . "${AUTODOC_ENV_FILE}"
fi

export AUTODOC_ROOT AUTODOC_PYTHON AUTODOC_RUNTIME_CONFIG
export AUTODOC_SERVICE_USER AUTODOC_GITHUB_RESEARCH_OPENRC_SERVICE_FACTORY
export AUTODOC_CONTROLFS_ROOT
export AUTODOC_QDRANT_POINT_WRITE_ALLOWED AUTODOC_QDRANT_SEARCH_ALLOWED
