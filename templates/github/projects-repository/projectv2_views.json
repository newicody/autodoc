{
  "schema": "autodoc.github.projects_repository_configuration.v1",
  "project": {
    "owner_kind": "user",
    "owner": "newicody",
    "number": 3
  },
  "fields": [
    {
      "name": "Thème",
      "data_type": "single_select",
      "options": [
        {"name": "Général", "color": "GRAY", "description": "Contexte transversal"},
        {"name": "Chalouf", "color": "BLUE", "description": "Démonstrateur intégrateur"},
        {"name": "Architecture", "color": "PURPLE", "description": "Architecture Autodoc/MissiPy"},
        {"name": "OpenVINO", "color": "GREEN", "description": "Inférence et embeddings locaux"},
        {"name": "GitHub", "color": "YELLOW", "description": "Issues, Actions et ProjectV2"}
      ]
    },
    {
      "name": "Type",
      "data_type": "single_select",
      "options": [
        {"name": "Recherche", "color": "BLUE", "description": "Nouveau cycle de recherche"},
        {"name": "Actualisation", "color": "YELLOW", "description": "Mise à jour append-only d'un résultat"}
      ]
    },
    {
      "name": "Affichage",
      "data_type": "single_select",
      "options": [
        {"name": "Action", "color": "YELLOW", "description": "Action opérateur en attente ou en cours"},
        {"name": "Résultat courant", "color": "GREEN", "description": "Dernier résultat actif d'une recherche"},
        {"name": "Historique", "color": "GRAY", "description": "Ancien résultat ou cycle terminé"},
        {"name": "Groupe", "color": "PURPLE", "description": "Boîte de thème ou groupe de contexte"},
        {"name": "Connaissance serveur", "color": "BLUE", "description": "Objet intégré à la connaissance locale"}
      ]
    },
    {"name": "Résumé", "data_type": "text"},
    {"name": "Avis Copilot", "data_type": "text"},
    {
      "name": "Serveur",
      "data_type": "single_select",
      "options": [
        {"name": "En attente", "color": "GRAY", "description": "Pas encore pris en charge"},
        {"name": "En cours", "color": "BLUE", "description": "Traitement local en cours"},
        {"name": "Terminé", "color": "GREEN", "description": "Traitement local terminé"},
        {"name": "Partiel", "color": "YELLOW", "description": "Résultat exploitable mais incomplet"},
        {"name": "Erreur", "color": "RED", "description": "Traitement local en erreur"}
      ]
    },
    {
      "name": "Copilot",
      "data_type": "single_select",
      "options": [
        {"name": "Non demandé", "color": "GRAY", "description": "Aucun avis demandé"},
        {"name": "En attente", "color": "BLUE", "description": "Avis en cours de production"},
        {"name": "Terminé", "color": "GREEN", "description": "Avis disponible"},
        {"name": "Indisponible", "color": "YELLOW", "description": "Avis non produit sans bloquer l'autorité locale"},
        {"name": "Erreur", "color": "RED", "description": "Échec explicite de l'avis"}
      ]
    },
    {"name": "Route Copilot", "data_type": "text"},
    {"name": "Confiance Copilot", "data_type": "number"},
    {"name": "Dernière mise à jour", "data_type": "date"},
    {"name": "Artefact", "data_type": "text"},
    {"name": "Cycle", "data_type": "text"},
    {"name": "Spécialiste", "data_type": "text"},
    {"name": "Révision spécialiste", "data_type": "text"},
    {"name": "Capacité proposée", "data_type": "text"},
    {
      "name": "Action capacité",
      "data_type": "single_select",
      "options": [
        {"name": "add", "color": "GREEN", "description": "Ajouter une capacité"},
        {"name": "refine", "color": "BLUE", "description": "Affiner une capacité existante"},
        {"name": "deprecate", "color": "RED", "description": "Déprécier une capacité"},
        {"name": "restore", "color": "PURPLE", "description": "Restaurer une capacité dépréciée"}
      ]
    },
    {
      "name": "Décision capacité",
      "data_type": "single_select",
      "options": [
        {"name": "pending", "color": "GRAY", "description": "Décision opérateur non rendue"},
        {"name": "approve", "color": "GREEN", "description": "Révision autorisée par l'opérateur"},
        {"name": "reject", "color": "RED", "description": "Révision refusée par l'opérateur"},
        {"name": "defer", "color": "YELLOW", "description": "Décision opérateur différée"}
      ]
    },
    {
      "name": "Statut révision",
      "data_type": "single_select",
      "options": [
        {"name": "request_received", "color": "GRAY", "description": "Demande reçue, sans proposition autoritative"},
        {"name": "proposal_ready", "color": "BLUE", "description": "Proposition locale prête pour revue"},
        {"name": "approved_selected_observed", "color": "GREEN", "description": "Révision approuvée, sélectionnée et observée"},
        {"name": "published", "color": "PURPLE", "description": "Projection GitHub publiée sous autorisation"},
        {"name": "readback_verified", "color": "GREEN", "description": "Relecture query-only vérifiée"},
        {"name": "rejected", "color": "RED", "description": "Révision refusée"},
        {"name": "deferred", "color": "YELLOW", "description": "Révision différée"}
      ]
    },
    {"name": "Référence SQL", "data_type": "text"},
    {"name": "Digest décision", "data_type": "text"},
    {"name": "Laboratoire", "data_type": "text"}
  ],
  "copilot_projection": {
    "status_field": "Copilot",
    "status_value": "Terminé",
    "summary_field": "Avis Copilot",
    "route_field": "Route Copilot",
    "confidence_field": "Confiance Copilot",
    "updated_field": "Dernière mise à jour",
    "artifact_field": "Artefact",
    "cycle_field": "Cycle"
  },
  "specialist_capability_growth_projection": {
    "specialist_field": "Spécialiste",
    "revision_field": "Révision spécialiste",
    "capability_field": "Capacité proposée",
    "action_field": "Action capacité",
    "decision_field": "Décision capacité",
    "revision_status_field": "Statut révision",
    "sql_ref_field": "Référence SQL",
    "decision_digest_field": "Digest décision",
    "laboratory_field": "Laboratoire",
    "allowed_actions": ["add", "refine", "deprecate", "restore"],
    "allowed_decisions": ["pending", "approve", "reject", "defer"],
    "review_status_value": "approved_selected_observed"
  },
  "views": [
    {
      "name": "Recherches",
      "layout": "board",
      "filter": "Affichage:Action",
      "visible_fields": ["Title", "Status", "Thème", "Type", "Serveur", "Copilot", "Dernière mise à jour"],
      "manual_layout": {"column_field": "Status", "group_by": "Thème"}
    },
    {
      "name": "Résultats",
      "layout": "board",
      "filter": "Affichage:\"Résultat courant\"",
      "visible_fields": ["Title", "Status", "Thème", "Résumé", "Avis Copilot", "Serveur", "Copilot", "Dernière mise à jour"],
      "manual_layout": {"column_field": "Status", "group_by": "Thème"}
    },
    {
      "name": "Copilot",
      "layout": "table",
      "filter": "Copilot:Terminé,Indisponible,Erreur",
      "visible_fields": ["Title", "Status", "Thème", "Avis Copilot", "Route Copilot", "Confiance Copilot", "Copilot", "Dernière mise à jour", "Artefact"]
    },
    {
      "name": "Connaissances serveur",
      "layout": "table",
      "filter": "Affichage:\"Connaissance serveur\"",
      "visible_fields": ["Title", "Status", "Thème", "Résumé", "Serveur", "Dernière mise à jour", "Artefact", "Cycle"]
    },
    {
      "name": "Boîtes de thèmes",
      "layout": "table",
      "filter": "Affichage:Groupe",
      "visible_fields": ["Title", "Status", "Thème", "Dernière mise à jour"]
    },
    {
      "name": "Historique",
      "layout": "table",
      "filter": "Affichage:Historique",
      "visible_fields": ["Title", "Status", "Thème", "Type", "Résumé", "Copilot", "Dernière mise à jour", "Cycle"]
    },
    {
      "name": "Révisions spécialistes",
      "layout": "table",
      "filter": "Action capacité:add,refine,deprecate,restore",
      "visible_fields": ["Title", "Status", "Spécialiste", "Révision spécialiste", "Capacité proposée", "Action capacité", "Décision capacité", "Statut révision", "Référence SQL", "Digest décision", "Laboratoire", "Dernière mise à jour"]
    },
    {
      "name": "Tous",
      "layout": "table",
      "filter": "is:issue",
      "visible_fields": ["Title", "Status", "Thème", "Type", "Affichage", "Serveur", "Copilot", "Dernière mise à jour"]
    }
  ]
}
