+        artifact_ref=artifact_ref,
+        source_candidate_ref=source_candidate_ref,
+        sql_ref=sql_ref,
+        qdrant_ref=qdrant_ref,
+        error=error,
+        payload=payload,
+    )
+
+
+
 RUNTIME_SURFACE_CELL_KINDS = frozenset(
     {"ROUTEPROXY", "CONTROLPROXY", "SHM_RING", "POLICY_GATE"}
 )
