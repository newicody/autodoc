+    if duplicate_item:
+        items.append(
+            {
+                "id": "PVTI_other",
+                "project": {"id": "PVT_project", "number": 3},
+            }
+        )
+    return {
+        "data": {
+            "repository": {
+                "issue": {"id": "I_issue", "projectItems": {"nodes": items}}
+            },
+            "user": {
+                "projectV2": {
+                    "id": "PVT_project",
+                    "number": 3,
+                    "fields": {
+                        "nodes": [
+                            {"id": "PVTSSF_field", "name": field_name}
+                        ]
+                    },
+                }
+            },
+            "organization": None,
+        }
+    }
+
+
