+        "runtime-close:qdrant-client",
+        "AUTODOC_QDRANT_POINT_WRITE_ALLOWED",
+        "AUTODOC_QDRANT_SEARCH_ALLOWED",
+    ):
+        assert required in text
+
+    for forbidden in (
+        "LaboratoryManager",
+        "LaboratoryScheduler",
+        "asyncio.run(",
+        "create_task(",
+        "Thread(",
+        "Process(",
+        "remote publication",
