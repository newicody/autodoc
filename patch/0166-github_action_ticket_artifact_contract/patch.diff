+name: autodoc-ticket-artifact
+
+on:
+  issues:
+    types:
+      - opened
+      - edited
+      - reopened
+      - labeled
+      - unlabeled
+  workflow_dispatch:
+
+permissions:
+  contents: read
+  issues: read
+  actions: read
+
+jobs:
+  build-autodoc-ticket-artifact:
+    runs-on: ubuntu-latest
+
+    steps:
+      - name: Checkout external idea repository
+        uses: actions/checkout@v4
+
+      - name: Build Autodoc ticket artifact
+        run: |
+          python scripts/build_autodoc_ticket_artifact.py \
+            --event-path "$GITHUB_EVENT_PATH" \
+            --project-url "https://github.com/users/newicody/projects/2" \
+            --workflow-name "autodoc-ticket-artifact.yml" \
+            --output-dir out/autodoc-artifacts
+
+      - name: Upload ticket artifact
+        uses: actions/upload-artifact@v4
+        with:
+          name: autodoc-ticket-artifact-${{ github.run_id }}
+          path: out/autodoc-artifacts/ticket_artifact.json
+
+      - name: Upload artifact bundle
+        uses: actions/upload-artifact@v4
+        with:
+          name: autodoc-ticket-artifact-bundle-${{ github.run_id }}
+          path: out/autodoc-artifacts/artifact_bundle.json
+
+      - name: Upload optional Copilot preliminary opinion
+        if: ${{ hashFiles('out/autodoc-artifacts/copilot_preliminary_opinion.json') != '' }}
+        uses: actions/upload-artifact@v4
+        with:
+          name: autodoc-copilot-preliminary-opinion-${{ github.run_id }}
+          path: out/autodoc-artifacts/copilot_preliminary_opinion.json
