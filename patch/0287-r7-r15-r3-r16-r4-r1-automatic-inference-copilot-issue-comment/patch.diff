+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[2]
+WORKFLOW = ROOT / "templates/github/projects-repository/.github/workflows/autodoc-controlled-research.yml"
+DOC = ROOT / "templates/github/projects-repository/COPILOT_ADVISORY_V2.md"
+PLANNER = ROOT / "src/context/github_copilot_advisory_v2_issue_publication_0287.py"
+ADAPTER = ROOT / "tools/publish_github_copilot_advisory_v2_issue_comment_0287.py"
+
+
+def test_workflow_automatically_publishes_the_existing_v2_issue_comment() -> None:
+    text = WORKFLOW.read_text(encoding="utf-8")
+
+    assert "  issues: write" in text
+    assert "Build Copilot advisory v2 publication preview" in text
+    assert "Plan automatic Copilot advisory Issue comment" in text
+    assert "Publish automatic Copilot advisory below Issue" in text
+    assert "build_copilot_advisory_v2_publication_preview.py" in text
+    assert "publish_github_copilot_advisory_v2_issue_comment_0287.py" in text
+    assert "--confirm-plan-digest \"${{ steps.copilot-comment-plan.outputs.plan_digest }}\"" in text
+    assert 'AUTODOC_ISSUE_PUBLICATION_ALLOWED: "true"' in text
+    assert "out/copilot_issue_comment_execute.json" in text
+
+
+def test_artifacts_survive_a_comment_publication_failure() -> None:
+    text = WORKFLOW.read_text(encoding="utf-8")
+
+    assert "always() && hashFiles('out/authoritative_request.json') != ''" in text
+    assert "always() && hashFiles('out/copilot_advisory.json') != ''" in text
+    assert "always() && hashFiles('out/dual_artifact_manifest.json') != ''" in text
+    assert text.index("Build human-readable artifact identities") < text.index(
+        "Publish automatic Copilot advisory below Issue"
+    )
+    assert text.index("Publish automatic Copilot advisory below Issue") < text.index(
+        "Upload authoritative request"
+    )
+
+
+def test_workflow_keeps_project_qualification_and_does_not_mutate_issue_body() -> None:
+    text = WORKFLOW.read_text(encoding="utf-8")
+
+    assert "workflow_dispatch:" in text
+    assert "\n  issues:\n" not in text
+    assert "/issues/${ISSUE_NUMBER}/comments" not in text
+    assert "sub-issue" not in text.lower()
+    assert "updateProjectV2ItemFieldValue" not in text
+
+
+def test_existing_issue_publication_contract_is_reused() -> None:
+    planner = PLANNER.read_text(encoding="utf-8")
+    adapter = ADAPTER.read_text(encoding="utf-8")
+    documentation = DOC.read_text(encoding="utf-8")
+
+    assert "MARKER_PREFIX = \"autodoc:copilot-advisory-v2\"" in planner
+    assert 'action == "replay"' in planner
+    assert "multiple existing comments carry the same marker" in planner
+    assert "readback_verified" in adapter
+    assert "Le corps de l’Issue n’est jamais modifié" in documentation
+    assert "ProjectV2 demeure une projection" in documentation
