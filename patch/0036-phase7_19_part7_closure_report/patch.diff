+
+def test_phase7_closure_report_cli_writes_report(tmp_path: Path, capsys) -> None:
+    output = tmp_path / "closure.json"
+
+    exit_code = main(["--root", str(ROOT), "--output", str(output)])
+
+    captured = capsys.readouterr()
