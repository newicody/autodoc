+    assert acceptance["next_bloc"] == "C"
+    assert acceptance["accepted_baseline"] == "controlled-dev-routeproxy-write-read-v1"
+    assert acceptance["issues"] == []
+    assert acceptance["existing_surfaces_reused"] is True
