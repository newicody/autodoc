+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[2]
+CURRENT = ROOT / "doc/README_CURRENT.md"
+INSTALLATION = ROOT / "templates/github/projects-repository/INSTALLATION.md"
+SAFE_DEFAULT_RULE = (
+    ROOT / "tests/rules/test_projects_installation_copilot_safe_default_0284_rule.py"
+)
+ARCHITECTURE = (
+    ROOT / "doc/architecture/SPECIALISTS_LABORATORIES_RULE_COMPATIBILITY_FIX_0284.md"
+)
+MANIFEST = (
+    ROOT
+    / "doc/manifests/"
+    / "MANIFEST_0284_R9_R1_SPECIALISTS_LABORATORIES_RULE_COMPATIBILITY_FIX.md"
+)
+REPORT = (
+    ROOT
+    / "PHASE0284_R9_R1_SPECIALISTS_LABORATORIES_RULE_COMPATIBILITY_FIX_REPORT.md"
+)
+
+
+def test_current_roadmap_preserves_stable_historical_markers() -> None:
+    text = CURRENT.read_text(encoding="utf-8")
+
+    for required in (
+        "GLOBAL_ARCHITECTURE_CURRENT_0282.md",
+        "PROJECTV2_CYCLE_HISTORY_DEVELOPMENT_0282.md",
+        "PROJECT_BEGINNING_CURRENT_COMPARISON_0282.md",
+        "autodoc-authoritative-request/authoritative_request.json",
+        "autodoc-copilot-advisory/copilot_advisory.json",
+        "autodoc-dual-artifact-manifest/dual_artifact_manifest.json",
+        "0281-r2 — dual-artifact run assembly contract",
+        "0281-r7 — real closed-loop smoke",
+        "no new Scheduler or parallel",
+        "orchestrator for laboratories",
+        "Chalouf as the final integrator scenario",
+    ):
+        assert required in text
+
+
+def test_safe_default_rule_accepts_a_cumulative_guide_version() -> None:
+    guide = INSTALLATION.read_text(encoding="utf-8")
+    rule = SAFE_DEFAULT_RULE.read_text(encoding="utf-8")
+
+    assert "Version du guide : `0284-r9`." in guide
+    assert "| `0284-r1-r5` |" in guide
+    assert 'assert "| `0284-r1-r5` |" in source' in rule
+    assert 'assert "Version du guide : `0284-r1-r5`." in source' not in rule
+
+
+def test_fix_documents_lock_non_runtime_boundaries() -> None:
+    combined = "\n".join(
+        path.read_text(encoding="utf-8")
+        for path in (ARCHITECTURE, MANIFEST, REPORT)
+    )
+
+    for required in (
+        "code_rule_review: done",
+        "runtime_modified: false",
+        "scheduler_modified: false",
+        "projects_installation_modified: false",
+        "projects_installation_verified: true",
+        "external_dependencies_added: false",
+    ):
+        assert required in combined
