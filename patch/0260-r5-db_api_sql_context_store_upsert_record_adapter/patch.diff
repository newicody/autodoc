+def _public_record_mapping(record: object) -> dict[str, Any]:
+    """Return a serialisable public mapping for a SQL record-like object."""
+
+    if isinstance(record, Mapping):
+        return dict(record)
+    if is_dataclass(record) and not isinstance(record, type):
+        return dict(asdict(record))
+    public: dict[str, Any] = {}
+    for name in (
+        "context_ref",
+        "record_ref",
+        "record_id",
+        "id",
+        "content",
+        "text",
+        "text_kind",
+        "source_ref",
+        "metadata",
+    ):
+        if hasattr(record, name):
+            value = getattr(record, name)
+            if isinstance(value, Mapping):
+                value = dict(value)
+            public[name] = value
+    return public
+
+
+def _store_result_to_mapping(result: object) -> Mapping[str, Any]:
+    """Normalise existing store results into a mapping for sql_ref extraction."""
+
+    if isinstance(result, Mapping):
+        return dict(result)
+    record = _public_record_mapping(result)
+    if record:
+        sql_ref = (
+            record.get("sql_ref")
+            or record.get("record_ref")
+            or record.get("record_id")
+            or record.get("context_ref")
+            or record.get("id")
+            or ""
+        )
+        return {"sql_ref": str(sql_ref) if sql_ref else "", "record": record}
+    return {"result": result}
+
+
+def _record_field_values_from_payload(payload: Mapping[str, Any]) -> dict[str, Any]:
+    """Build common field values for an existing SQLContextStore record object."""
+
+    metadata = dict(payload.get("metadata", {}))
+    context_ref = str(
+        metadata.get("context_ref")
+        or payload.get("context_ref")
+        or payload.get("intent_id")
+        or uuid.uuid4().hex
+    )
+    text = str(payload.get("text", ""))
+    return {
+        "context_ref": context_ref,
+        "record_ref": context_ref,
+        "record_id": context_ref,
+        "id": context_ref,
+        "content": text,
+        "text": text,
+        "body": text,
+        "text_kind": str(payload.get("text_kind", "passage")),
+        "kind": str(payload.get("text_kind", "passage")),
+        "source_ref": str(payload.get("source_ref", "")),
+        "metadata": metadata,
+        "payload": dict(payload),
+    }
+
+
+def _construct_record_class(record_class: type[Any], values: Mapping[str, Any]) -> object:
+    """Construct an existing record class using only accepted constructor fields."""
+
+    signature = inspect.signature(record_class)
+    kwargs: dict[str, Any] = {}
+    for name, parameter in signature.parameters.items():
+        if name == "self":
+            continue
+        if parameter.kind in (parameter.VAR_POSITIONAL, parameter.VAR_KEYWORD):
+            continue
+        if name in values:
+            kwargs[name] = values[name]
+        elif parameter.default is inspect.Signature.empty:
+            if "ref" in name or name.endswith("_id"):
+                kwargs[name] = values["context_ref"]
+            elif "content" in name or name in {"text", "body"}:
+                kwargs[name] = values["content"]
+            elif "kind" in name:
+                kwargs[name] = values["text_kind"]
+            elif "metadata" in name:
+                kwargs[name] = values["metadata"]
+    return record_class(**kwargs)
+
+
+def _build_existing_store_record(store: object, payload: Mapping[str, Any]) -> object:
+    """Build a record object for existing DbApiSqlContextStore.upsert_record."""
+
+    values = _record_field_values_from_payload(payload)
+    store_module = inspect.getmodule(store.__class__)
+    for name in (
+        "SqlContextRecord",
+        "ContextRecord",
+        "DbApiSqlContextRecord",
+        "SQLContextRecord",
+    ):
+        record_class = getattr(store_module, name, None) if store_module is not None else None
+        if inspect.isclass(record_class):
+            try:
+                return _construct_record_class(record_class, values)
+            except TypeError:
+                continue
+    return SimpleNamespace(**values)
+
