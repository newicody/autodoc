+    _write_summary(summary)
+
+    exit_code = main(
+        [
+            "--summary",
+            str(summary),
+            "--audit-log",
+            str(audit_log),
+            "--report",
+            str(report),
+            "--created-at",
+            "2026-07-02T10:00:00+00:00",
+        ]
+    )
+
+    captured = capsys.readouterr()
+    assert exit_code == 0
