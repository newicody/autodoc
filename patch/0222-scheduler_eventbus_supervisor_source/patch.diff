+
+    forbidden = [
+        "from src.scheduler",
+        "import Scheduler",
+        "Scheduler.run(",
+        "run_scheduler(",
+        "dispatch_handler(",
+        "class EventBus",
+        "mmap(",
+        "upsert(",
+        "download_artifact(",
+        "pushback(",
+    ]
+    for token in forbidden:
+        assert token not in combined
