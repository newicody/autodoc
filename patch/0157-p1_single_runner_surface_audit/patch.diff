+- `LocalArtifactOrchestrator`
+- `LocalVectorIndexingOrchestrator`
+- `SchedulerOpenVINORunner`
+- `SQLPersistenceWorker`
+- `SQLOrchestrator`
+- `VectorOpenVINOEmbeddingAdapter`
+- `VectorQdrantProjectionAdapter`
