@@ -0,0 +1,408 @@
+"""Deterministic context exploration planner.
+
+0115 keeps the project centered on context variability.  The planner turns a
+ContextVariationObjective into a bounded ContextExplorationPlan made of
+reference-only trajectories.  It does not call SQL, Qdrant, OpenVINO, LLM, or
+GitHub directly; it only emits capability hints that later handlers can execute
+behind declared adapters.
+
+Scheduler orchestrates context exploration jobs; it does not build variants itself.
+SQL hydrate -> OpenVINO embed -> Qdrant recall -> SQL re-hydrate -> specialist note.
+No MVTC runtime in 0115.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Iterable
+
+from src.context.context_variation_core import (
+    ContextExplorationBudget,
+    ContextExplorationPlan,
+    ContextTrajectory,
+    ContextTrajectoryStep,
+    ContextVariantCandidate,
+    ContextVariationAxis,
+    ContextVariationObjective,
+)
+
+_DEFAULT_COST_HINT = "small"
+_ALLOWED_COST_HINTS = frozenset({"tiny", "small", "medium", "large"})
+
+
+@dataclass(frozen=True, slots=True)
+class ContextAxisTemplate:
+    """Reusable axis template for deterministic context exploration."""
+
+    axis_id: str
+    label: str
+    question: str
+    tags: tuple[str, ...] = ()
+    keywords: tuple[str, ...] = ()
+    specialist_ref: str | None = None
+
+    def __post_init__(self) -> None:
+        _require_non_empty("axis_id", self.axis_id)
+        _require_non_empty("label", self.label)
+        _require_non_empty("question", self.question)
+        object.__setattr__(self, "tags", _normalize_words(self.tags))
+        object.__setattr__(self, "keywords", _normalize_words(self.keywords))
+        if self.specialist_ref is not None and not self.specialist_ref.startswith("specialist:"):
+            raise ValueError("specialist_ref must be a specialist:* reference")
+
+    def to_axis(self) -> ContextVariationAxis:
+        return ContextVariationAxis(
+            axis_id=self.axis_id,
+            label=self.label,
+            question=self.question,
+            tags=self.tags,
+        )
+
+    def matches(self, text: str) -> bool:
+        haystack = text.lower()
+        return any(keyword in haystack for keyword in self.keywords)
+
+    def to_mapping(self) -> dict[str, str | list[str] | None]:
+        return {
+            "axis_id": self.axis_id,
+            "label": self.label,
+            "question": self.question,
+            "tags": list(self.tags),
+            "keywords": list(self.keywords),
+            "specialist_ref": self.specialist_ref,
+        }
+
+
+@dataclass(frozen=True, slots=True)
+class ContextExplorationPlannerPolicy:
+    """Small deterministic policy for choosing context axes and trajectory depth."""
+
+    max_axes: int = 5
+    prefer_keyword_matches: bool = True
+    include_non_matching_axes: bool = True
+    cost_hint: str = _DEFAULT_COST_HINT
+
+    def __post_init__(self) -> None:
+        if self.max_axes <= 0:
+            raise ValueError("max_axes must be > 0")
+        if self.cost_hint not in _ALLOWED_COST_HINTS:
+            raise ValueError("cost_hint must be one of tiny, small, medium, large")
+
+    def to_mapping(self) -> dict[str, int | bool | str]:
+        return {
+            "max_axes": self.max_axes,
+            "prefer_keyword_matches": self.prefer_keyword_matches,
+            "include_non_matching_axes": self.include_non_matching_axes,
+            "cost_hint": self.cost_hint,
+        }
+
+
+@dataclass(frozen=True, slots=True)
+class ContextExplorationPlannerResult:
+    """Stable result of a planner pass."""
+
+    plan: ContextExplorationPlan
+    selected_axis_ids: tuple[str, ...]
+    skipped_axis_ids: tuple[str, ...] = ()
+
+    def to_mapping(self) -> dict[str, object]:
+        return {
+            "plan": self.plan.to_mapping(),
+            "selected_axis_ids": list(self.selected_axis_ids),
+            "skipped_axis_ids": list(self.skipped_axis_ids),
+        }
+
+
+class ContextExplorationPlanner:
+    """Build bounded context trajectory plans from objectives.
+
+    The planner is intentionally deterministic and side-effect free.  It is a
+    leaf capability that can later sit behind a Handler; the Scheduler should
+    only carry the resulting bounded job and must not learn Qdrant, OpenVINO,
+    SQL, LLM, GitHub, or specialist internals.
+    """
+
+    def __init__(
+        self,
+        *,
+        templates: Iterable[ContextAxisTemplate] | None = None,
+        policy: ContextExplorationPlannerPolicy | None = None,
+    ) -> None:
+        selected_templates = tuple(templates) if templates is not None else default_context_axis_templates()
+        if not selected_templates:
+            raise ValueError("templates must not be empty")
+        self._templates = selected_templates
+        self._policy = policy or ContextExplorationPlannerPolicy()
+
+    @property
+    def templates(self) -> tuple[ContextAxisTemplate, ...]:
+        return self._templates
+
+    @property
+    def policy(self) -> ContextExplorationPlannerPolicy:
+        return self._policy
+
+    def build_plan(
+        self,
+        *,
+        plan_id: str,
+        objective: ContextVariationObjective,
+        budget: ContextExplorationBudget,
+        base_context_refs: tuple[str, ...] = (),
+        payload_refs: tuple[str, ...] = (),
+        specialist_refs: tuple[str, ...] = (),
+    ) -> ContextExplorationPlannerResult:
+        """Build a bounded ContextExplorationPlan from objective and templates."""
+
+        _require_non_empty("plan_id", plan_id)
+        selected_templates, skipped_templates = self._select_templates(objective, budget)
+        axes = tuple(template.to_axis() for template in selected_templates)
+        candidates = tuple(
+            self._candidate_for_template(
+                plan_id=plan_id,
+                objective=objective,
+                template=template,
+                ordinal=index,
+                budget=budget,
+                base_context_refs=base_context_refs,
+                payload_refs=payload_refs,
+                specialist_refs=specialist_refs,
+            )
+            for index, template in enumerate(selected_templates, start=1)
+        )
+        plan = ContextExplorationPlan(
+            plan_id=plan_id,
+            objective=objective,
+            axes=axes,
+            candidates=candidates,
+            budget=budget,
+        )
+        return ContextExplorationPlannerResult(
+            plan=plan,
+            selected_axis_ids=tuple(template.axis_id for template in selected_templates),
+            skipped_axis_ids=tuple(template.axis_id for template in skipped_templates),
+        )
+
+    def _select_templates(
+        self,
+        objective: ContextVariationObjective,
+        budget: ContextExplorationBudget,
+    ) -> tuple[tuple[ContextAxisTemplate, ...], tuple[ContextAxisTemplate, ...]]:
+        limit = min(self._policy.max_axes, budget.max_variants)
+        text = f"{objective.title}\n{objective.statement}\n{objective.source_ref or ''}".lower()
+        matches = tuple(template for template in self._templates if template.matches(text))
+        non_matches = tuple(template for template in self._templates if template not in matches)
+        if self._policy.prefer_keyword_matches:
+            ordered = matches + (non_matches if self._policy.include_non_matching_axes else ())
+        else:
+            ordered = self._templates
+        if not ordered:
+            ordered = self._templates
+        selected = ordered[:limit]
+        skipped = tuple(template for template in self._templates if template not in selected)
+        return selected, skipped
+
+    def _candidate_for_template(
+        self,
+        *,
+        plan_id: str,
+        objective: ContextVariationObjective,
+        template: ContextAxisTemplate,
+        ordinal: int,
+        budget: ContextExplorationBudget,
+        base_context_refs: tuple[str, ...],
+        payload_refs: tuple[str, ...],
+        specialist_refs: tuple[str, ...],
+    ) -> ContextVariantCandidate:
+        slug = _slug(template.axis_id)
+        axis = template.to_axis()
+        merged_specialist_refs = _merge_refs(
+            specialist_refs,
+            (template.specialist_ref,) if template.specialist_ref is not None else (),
+        )
+        steps = _trajectory_steps_for_axis(
+            ordinal=ordinal,
+            axis=axis,
+            objective=objective,
+            max_depth=budget.max_depth,
+            base_context_refs=base_context_refs,
+            payload_refs=payload_refs,
+            specialist_refs=merged_specialist_refs,
+        )
+        trajectory = ContextTrajectory(
+            trajectory_id=f"traj-{ordinal:02d}-{slug}",
+            axis_ids=(axis.axis_id,),
+            steps=steps,
+            rationale=f"Explore context trajectory for axis {axis.label} with refs only.",
+        )
+        return ContextVariantCandidate(
+            variant_id=f"{plan_id}:variant:{ordinal:02d}:{slug}",
+            objective_id=objective.objective_id,
+            trajectory=trajectory,
+            context_refs=base_context_refs,
+            payload_refs=payload_refs,
+            specialist_refs=merged_specialist_refs,
+            cost_hint=self._policy.cost_hint,
+            metadata=(
+                ("axis", axis.axis_id),
+                ("planner", "0115-context-exploration-planner"),
+            ),
+        )
+
+
+def default_context_axis_templates() -> tuple[ContextAxisTemplate, ...]:
+    """Return default axes for product/project context exploration."""
+
+    return (
+        ContextAxisTemplate(
+            axis_id="safety",
+            label="Safety",
+            question="Which constraints, risks, and norms must shape this solution?",
+            tags=("risk", "constraints", "norms"),
+            keywords=("safe", "safety", "baby", "child", "risk", "norm", "danger"),
+            specialist_ref="specialist:safety",
+        ),
+        ContextAxisTemplate(
+            axis_id="material",
+            label="Material",
+            question="Which material and durability context should be recalled?",
+            tags=("material", "durability", "food-contact"),
+            keywords=("material", "silicone", "inox", "steel", "plastic", "food", "fork"),
+            specialist_ref="specialist:material",
+        ),
+        ContextAxisTemplate(
+            axis_id="fabrication",
+            label="Fabrication",
+            question="Which fabrication, cost, and tooling context should be explored?",
+            tags=("fabrication", "process", "cost"),
+            keywords=("fabrication", "manufacture", "print", "mold", "tool", "cost"),
+            specialist_ref="specialist:fabrication",
+        ),
+        ContextAxisTemplate(
+            axis_id="ergonomics",
+            label="Ergonomics",
+            question="Which usage, handling, and human factors context matters?",
+            tags=("usage", "ergonomics", "product"),
+            keywords=("ergonomic", "use", "handle", "baby", "parent", "clean"),
+            specialist_ref="specialist:ergonomics",
+        ),
+        ContextAxisTemplate(
+            axis_id="history",
+            label="Project history",
+            question="Which prior artifacts, decisions, and feedback should be recalled?",
+            tags=("history", "github", "feedback"),
+            keywords=("github", "artifact", "kanban", "project", "feedback", "decision"),
+            specialist_ref="specialist:project-history",
+        ),
+    )
+
+
+def build_minimal_context_exploration_plan(
+    *,
+    plan_id: str,
+    objective: ContextVariationObjective,
+    budget: ContextExplorationBudget,
+    base_context_refs: tuple[str, ...] = (),
+    payload_refs: tuple[str, ...] = (),
+    specialist_refs: tuple[str, ...] = (),
+    templates: Iterable[ContextAxisTemplate] | None = None,
+    policy: ContextExplorationPlannerPolicy | None = None,
+) -> ContextExplorationPlannerResult:
+    """Convenience wrapper for a pure, deterministic planner pass."""
+
+    planner = ContextExplorationPlanner(templates=templates, policy=policy)
+    return planner.build_plan(
+        plan_id=plan_id,
+        objective=objective,
+        budget=budget,
+        base_context_refs=base_context_refs,
+        payload_refs=payload_refs,
+        specialist_refs=specialist_refs,
+    )
+
+
+def _trajectory_steps_for_axis(
+    *,
+    ordinal: int,
+    axis: ContextVariationAxis,
+    objective: ContextVariationObjective,
+    max_depth: int,
+    base_context_refs: tuple[str, ...],
+    payload_refs: tuple[str, ...],
+    specialist_refs: tuple[str, ...],
+) -> tuple[ContextTrajectoryStep, ...]:
+    if max_depth <= 0:
+        raise ValueError("max_depth must be > 0")
+    slug = _slug(axis.axis_id)
+    initial_refs = _merge_refs(
+        tuple(ref for ref in (objective.source_ref, objective.parent_context_ref) if ref is not None),
+        base_context_refs,
+        payload_refs,
+    )
+    specialist_inputs = _merge_refs(initial_refs, specialist_refs)
+    all_steps = (
+        ContextTrajectoryStep(
+            step_id=f"step-{ordinal:02d}-{slug}-sql-base",
+            capability_hint="context.sql.hydrate_base",
+            input_refs=initial_refs,
+            expected_output_ref_kind="ctx",
+            note="SQL hydrate base facts/docs/artifacts by stable refs.",
+        ),
+        ContextTrajectoryStep(
+            step_id=f"step-{ordinal:02d}-{slug}-openvino-embed",
+            capability_hint="embedding.openvino.embed_axis_query",
+            input_refs=initial_refs,
+            expected_output_ref_kind="ctx",
+            note="OpenVINO embed query or refs behind adapter; no Scheduler import.",
+        ),
+        ContextTrajectoryStep(
+            step_id=f"step-{ordinal:02d}-{slug}-qdrant-recall",
+            capability_hint="qdrant.recall_axis_candidates",
+            input_refs=initial_refs,
+            expected_output_ref_kind="ctx",
+            note="Qdrant recall returns candidate IDs, not authority content.",
+        ),
+        ContextTrajectoryStep(
+            step_id=f"step-{ordinal:02d}-{slug}-sql-rehydrate",
+            capability_hint="context.sql.rehydrate_recalled_ids",
+            input_refs=initial_refs,
+            expected_output_ref_kind="ctx",
+            note="SQL re-hydrate recalled IDs before reducer/specialist use.",
+        ),
+        ContextTrajectoryStep(
+            step_id=f"step-{ordinal:02d}-{slug}-specialist-note",
+            capability_hint="specialist.axis.note",
+            input_refs=specialist_inputs,
+            expected_output_ref_kind="ctx",
+            note="Specialist annotates the axis after hydrated context is available.",
+        ),
+    )
+    return all_steps[:max_depth]
+
+
+def _merge_refs(*groups: tuple[str | None, ...]) -> tuple[str, ...]:
+    merged: list[str] = []
+    for group in groups:
+        for ref in group:
+            if ref is not None and ref not in merged:
+                merged.append(ref)
+    return tuple(merged)
+
+
+def _normalize_words(values: tuple[str, ...]) -> tuple[str, ...]:
+    normalized: list[str] = []
+    for value in values:
+        _require_non_empty("word", value)
+        word = value.strip().lower()
+        if word not in normalized:
+            normalized.append(word)
+    return tuple(normalized)
+
+
+def _require_non_empty(name: str, value: str) -> None:
+    if not value or not value.strip():
+        raise ValueError(f"{name} must not be empty")
+
+
+def _slug(value: str) -> str:
+    return "-".join(part for part in value.lower().replace("_", "-").split("-") if part) or "axis"
