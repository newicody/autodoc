+from __future__ import annotations
+
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[2]
+MODULE = ROOT / "src" / "context" / "context_exploration_planner.py"
+DOC = ROOT / "doc" / "architecture" / "CONTEXT_EXPLORATION_PLANNER_0115.md"
+DOT = ROOT / "doc" / "docs" / "architecture" / "runtime" / "108_context_exploration_planner.dot"
+MANIFEST = ROOT / "doc" / "manifests" / "MANIFEST_0115_CHANGED_FILES.md"
+
+
+def _read(path: Path) -> str:
+    return path.read_text(encoding="utf-8")
+
+
+def test_0115_relocks_context_variation_intent() -> None:
+    text = _read(MODULE) + "\n" + _read(DOC)
+    required = [
+        "context variability is the project center",
+        "ContextExplorationPlanner",
+        "ContextVariationObjective into a bounded ContextExplorationPlan",
+        "SQL hydrate -> OpenVINO embed -> Qdrant recall -> SQL re-hydrate -> specialist note",
+        "Scheduler orchestrates context exploration jobs; it does not build variants itself.",
+        "No MVTC runtime in 0115",
+    ]
+    for phrase in required:
+        assert phrase in text
+
+
+def test_0115_planner_keeps_backends_behind_hints() -> None:
+    text = _read(MODULE)
+    forbidden_imports = [
+        "import sqlite3",
+        "import qdrant",
+        "from qdrant",
+        "import openvino",
+        "from openvino",
+        "import torch",
+        "import requests",
+        "import httpx",
+        "import socket",
+    ]
+    for phrase in forbidden_imports:
+        assert phrase not in text
+    assert "capability_hint" in text
+    assert "context.sql.hydrate_base" in text
+    assert "embedding.openvino.embed_axis_query" in text
+    assert "qdrant.recall_axis_candidates" in text
+
+
+def test_0115_graph_is_root_attached_context_overlay() -> None:
+    dot = _read(DOT)
+    required = [
+        "ROOT_GRAPH: doc/docs/architecture/00_global.dot",
+        "root-attached context overlay",
+        "Scheduler -> Handler -> ContextExplorationPlanner",
+        "ContextVariationObjective -> ContextExplorationPlan",
+        "SQL hydrate -> OpenVINO embed -> Qdrant recall -> SQL re-hydrate -> specialist note",
+        "EventBus observation only",
+        "Route mmap/eventfd remains data plane, not EventBus",
+    ]
+    for phrase in required:
+        assert phrase in dot
+
+
+def test_0115_manifest_keeps_kernel_unchanged() -> None:
+    manifest = _read(MANIFEST)
+    assert "src/context/context_exploration_planner.py" in manifest
+    assert "tests/runtime/test_context_exploration_planner.py" in manifest
+    forbidden = [
+        "src/kernel/scheduler.py",
+        "src/kernel/dispatcher.py",
+        "src/kernel/queue.py",
+        "src/policy/engine.py",
+        "src/kernel/event_bus.py",
+    ]
+    for phrase in forbidden:
+        assert phrase not in manifest
diff --git a/tests/runtime/test_context_exploration_planner.py b/tests/runtime/test_context_exploration_planner.py
new file mode 100644
index 0000000..6de28ab
--- /dev/null
+++ b/tests/runtime/test_context_exploration_planner.py
@@ -0,0 +1,126 @@
+from __future__ import annotations
+
+import pytest
+
+from src.context.context_exploration_planner import (
+    ContextAxisTemplate,
+    ContextExplorationPlanner,
+    ContextExplorationPlannerPolicy,
+    build_minimal_context_exploration_plan,
+)
+from src.context.context_variation_core import (
+    ContextExplorationBudget,
+    ContextVariationObjective,
+)
+
+
+def _objective() -> ContextVariationObjective:
+    return ContextVariationObjective(
+        objective_id="obj-baby-fork",
+        title="Baby fork GitHub project item",
+        statement="Explore a safer baby fork with material, fabrication, ergonomics, and project feedback.",
+        source_ref="github:artifact:copilot-first-pass",
+        parent_context_ref="ctx:project:baby-fork",
+    )
+
+
+def _budget(*, max_variants: int = 3, max_depth: int = 5) -> ContextExplorationBudget:
+    return ContextExplorationBudget(
+        max_variants=max_variants,
+        max_depth=max_depth,
+        max_specialist_calls=8,
+        max_retrievals=12,
+        max_wall_time_s=30.0,
+    )
+
+
+def test_planner_builds_bounded_keyword_ordered_plan() -> None:
+    result = build_minimal_context_exploration_plan(
+        plan_id="plan-baby-fork",
+        objective=_objective(),
+        budget=_budget(max_variants=3),
+        base_context_refs=("sql:project:baby-fork",),
+        payload_refs=("artifact:github:baby-fork-card",),
+    )
+
+    assert result.selected_axis_ids == ("safety", "material", "fabrication")
+    assert len(result.plan.candidates) == 3
+    first = result.plan.candidates[0]
+    assert first.variant_id == "plan-baby-fork:variant:01:safety"
+    assert first.context_refs == ("sql:project:baby-fork",)
+    assert first.payload_refs == ("artifact:github:baby-fork-card",)
+    assert "specialist:safety" in first.specialist_refs
+
+
+def test_planner_trajectory_declares_sql_openvino_qdrant_sql_specialist_steps() -> None:
+    result = build_minimal_context_exploration_plan(
+        plan_id="plan-baby-fork",
+        objective=_objective(),
+        budget=_budget(max_variants=1, max_depth=5),
+        base_context_refs=("sql:project:baby-fork",),
+        payload_refs=("artifact:github:baby-fork-card",),
+    )
+
+    hints = tuple(step.capability_hint for step in result.plan.candidates[0].trajectory.steps)
+    assert hints == (
+        "context.sql.hydrate_base",
+        "embedding.openvino.embed_axis_query",
+        "qdrant.recall_axis_candidates",
+        "context.sql.rehydrate_recalled_ids",
+        "specialist.axis.note",
+    )
+    assert all("github:artifact:copilot-first-pass" in step.input_refs for step in result.plan.candidates[0].trajectory.steps[:4])
+
+
+def test_planner_respects_depth_budget_without_scheduler_backend_calls() -> None:
+    result = build_minimal_context_exploration_plan(
+        plan_id="plan-shallow",
+        objective=_objective(),
+        budget=_budget(max_variants=2, max_depth=2),
+    )
+
+    assert len(result.plan.candidates) == 2
+    assert all(len(candidate.trajectory.steps) == 2 for candidate in result.plan.candidates)
+    assert result.plan.budget.max_depth == 2
+
+
+def test_planner_can_use_custom_templates() -> None:
+    template = ContextAxisTemplate(
+        axis_id="cleaning",
+        label="Cleaning",
+        question="Which context helps evaluate cleaning constraints?",
+        tags=("cleaning",),
+        keywords=("wash", "clean"),
+        specialist_ref="specialist:cleaning",
+    )
+    objective = ContextVariationObjective(
+        objective_id="obj-clean",
+        title="Washable baby fork",
+        statement="Find cleaning and dishwasher constraints.",
+        source_ref="github:item:clean",
+    )
+
+    result = build_minimal_context_exploration_plan(
+        plan_id="plan-clean",
+        objective=objective,
+        budget=_budget(max_variants=1),
+        templates=(template,),
+    )
+
+    assert result.selected_axis_ids == ("cleaning",)
+    assert result.plan.axes[0].tags == ("cleaning",)
+    assert result.plan.candidates[0].specialist_refs == ("specialist:cleaning",)
+
+
+def test_planner_rejects_invalid_policy_and_templates() -> None:
+    with pytest.raises(ValueError, match="max_axes must be > 0"):
+        ContextExplorationPlannerPolicy(max_axes=0)
+    with pytest.raises(ValueError, match="templates must not be empty"):
+        ContextExplorationPlanner(templates=())
+    with pytest.raises(ValueError, match="specialist_ref"):
+        ContextAxisTemplate(
+            axis_id="bad",
+            label="Bad",
+            question="Bad?",
+            specialist_ref="bad:ref",
+        )
