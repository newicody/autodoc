+def _command() -> subject.GitHubOperatorLaboratoryAdvisoryProjectionCommand:
+    smoke = GitHubDualArtifactLaboratorySmokeCommand(
+        decision=Decision(),
+        laboratory=Laboratory(),
+        policy_decision_id="policy:test:0287-r7-r4",
