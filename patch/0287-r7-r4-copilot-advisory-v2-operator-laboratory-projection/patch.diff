+
+@dataclass(frozen=True, slots=True)
+class LaboratoryResult:
+    valid: bool = True
+    issues: tuple[str, ...] = ()
+    mapping: dict[str, Any] = field(
+        default_factory=lambda: {
+            "valid": True,
+            "github_mutation_performed": False,
+            "scheduler_created": False,
+            "parallel_orchestrator_created": False,
+            "publication_preview": {
