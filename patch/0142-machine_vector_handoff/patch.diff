+def _qdrant_command_argv(
+    *,
+    root: Path,
+    qdrant_url: str,
+    collection: str,
+    dimension: int,
+    sql_ref: str,
+    vector_json: Path | None,
+) -> tuple[str, ...]:
+    argv = [
+        sys.executable,
+        str(root / "tools" / "run_qdrant_projection_live_smoke.py"),
+        str(root),
+        "--qdrant-url",
+        qdrant_url,
+        "--collection",
+        collection,
+        "--dimension",
+        str(dimension),
+        "--sql-ref",
+        sql_ref,
+    ]
+    if vector_json is not None:
+        argv.extend(("--vector-json", str(vector_json)))
+    argv.append("--execute")
+    return tuple(argv)
