+from src.context.passive_bus_supervisor_cellular_snapshot import (
+    PassiveSupervisorSink,
+    scheduler_supervision_event,
+)
+
+
+def test_scheduler_supervision_event_keeps_scheduler_upstream_only() -> None:
+    event = scheduler_supervision_event(
+        event_id="scheduler-evt-1",
+        event_kind="scheduler_tick",
+        state="running",
+        observed_at="2026-07-08T00:00:00Z",
+        scheduler_ref="scheduler:main",
+        route_ref="route-1",
+        policy_decision_id="policy-1",
+        payload={"handler": "dry-run"},
+    )
+
+    assert event.cell_kind == "SCHEDULER"
+    assert event.cell_id == "scheduler:main"
+    assert event.source_ref == "scheduler:main"
+    assert event.route_ref == "route-1"
+    assert event.policy_decision_id == "policy-1"
+    assert event.payload["scheduler_ref"] == "scheduler:main"
+    assert event.payload["upstream_authority"] == "scheduler"
+    assert event.payload["supervisor_role"] == "downstream_observer"
+
+
+def test_passive_supervisor_sink_accepts_scheduler_event_without_scheduler_run() -> None:
+    sink = PassiveSupervisorSink(metadata={"test": "0231"})
+    accepted = sink.accept_scheduler_event(
+        event_id="scheduler-evt-2",
+        event_kind="scheduler_handler_planned",
+        state="queued",
+        observed_at="2026-07-08T00:00:01Z",
+        scheduler_ref="scheduler:main",
+        artifact_ref="artifact-1",
+    )
+
+    payload = sink.snapshot_payload(generated_at="2026-07-08T00:00:02Z")
+    cells = {cell["cell_id"]: cell for cell in payload["cells"]}
+
+    assert accepted.cell_kind == "SCHEDULER"
+    assert sink.event_count() == 1
+    assert payload["event_count"] == 1
+    assert payload["cell_count"] == 1
+    assert payload["metadata"]["scheduler_role"] == "upstream_orchestration_authority"
+    assert payload["supervision_authority_violation"] is False
+    assert cells["scheduler:main"]["refs"]["artifact_ref"] == "artifact-1"
