+import json
+from pathlib import Path
+import subprocess
+import sys
+
+
+def test_run_scheduler_eventbus_supervisor_smoke_writes_snapshot_and_audit(tmp_path: Path) -> None:
+    snapshot = tmp_path / "snapshot.json"
+    audit = tmp_path / "audit.jsonl"
+    result = subprocess.run(
+        [
+            sys.executable,
+            "tools/run_scheduler_eventbus_supervisor_smoke_0231.py",
+            "--event-id",
+            "scheduler-evt-cli",
+            "--event-kind",
+            "scheduler_tick",
+            "--state",
+            "running",
+            "--observed-at",
+            "2026-07-08T00:00:00Z",
+            "--scheduler-ref",
+            "scheduler:main",
+            "--route-ref",
+            "route-1",
+            "--snapshot-output",
+            str(snapshot),
+            "--audit-jsonl",
+            str(audit),
+            "--format",
+            "json",
+        ],
+        cwd=Path(__file__).resolve().parents[2],
+        check=True,
+        text=True,
+        capture_output=True,
+    )
+
+    payload = json.loads(result.stdout)
+    written = json.loads(snapshot.read_text(encoding="utf-8"))
+    audit_lines = audit.read_text(encoding="utf-8").strip().splitlines()
+
+    assert payload["scheduler_eventbus_supervisor_source_ready"] is True
+    assert payload["cellular_snapshot_written"] is True
+    assert payload["accepted_event"]["cell_kind"] == "SCHEDULER"
+    assert payload["accepted_event"]["route_ref"] == "route-1"
+    assert written["metadata"]["scheduler_role"] == "upstream_orchestration_authority"
+    assert len(audit_lines) == 1
+    assert json.loads(audit_lines[0])["event_id"] == "scheduler-evt-cli"
+
+
+def test_run_scheduler_eventbus_supervisor_smoke_summary(tmp_path: Path) -> None:
+    result = subprocess.run(
+        [
+            sys.executable,
+            "tools/run_scheduler_eventbus_supervisor_smoke_0231.py",
+            "--format",
+            "summary",
+        ],
+        cwd=Path(__file__).resolve().parents[2],
+        check=True,
+        text=True,
+        capture_output=True,
+    )
+
+    assert "scheduler_source_ready=True" in result.stdout
+    assert "event_count=1" in result.stdout
+    assert "scheduler_ref=scheduler:main" in result.stdout
