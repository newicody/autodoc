@@ -0,0 +1,106 @@
+#!/usr/bin/env python3
+"""Smoke Scheduler upstream EventBus events into the passive supervisor sink."""
+
+from __future__ import annotations
+
+import argparse
+import json
+from pathlib import Path
+import sys
+from typing import Any
+
+ROOT = Path(__file__).resolve().parents[1]
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from src.context.passive_bus_supervisor_cellular_snapshot import PassiveSupervisorSink
+
+
+def _load_payload(path: Path | None) -> dict[str, Any]:
+    if path is None:
+        return {}
+    value = json.loads(path.read_text(encoding="utf-8"))
+    if not isinstance(value, dict):
+        raise SystemExit("--payload-json must contain a JSON object")
+    return value
+
+
+def parse_args(argv: tuple[str, ...]) -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--event-id", default="scheduler-event-0231")
+    parser.add_argument("--event-kind", default="scheduler_tick")
+    parser.add_argument("--state", default="running")
+    parser.add_argument("--observed-at", default="2026-07-08T00:00:00Z")
+    parser.add_argument("--scheduler-ref", default="scheduler:main")
+    parser.add_argument("--route-ref", default="")
+    parser.add_argument("--policy-decision-id", default="")
+    parser.add_argument("--artifact-ref", default="")
+    parser.add_argument("--sql-ref", default="")
+    parser.add_argument("--qdrant-ref", default="")
+    parser.add_argument("--shm-ref", default="")
+    parser.add_argument("--error", default="")
+    parser.add_argument("--payload-json", type=Path)
+    parser.add_argument("--snapshot-output", type=Path)
+    parser.add_argument("--audit-jsonl", type=Path)
+    parser.add_argument("--generated-at", default="2026-07-08T00:00:01Z")
+    parser.add_argument("--format", choices=("json", "summary"), default="json")
+    return parser.parse_args(argv)
+
+
+def run(options: argparse.Namespace) -> dict[str, Any]:
+    sink = PassiveSupervisorSink(
+        metadata={
+            "patch_id": "0231-r1-scheduler_eventbus_supervisor_upstream_source",
+            "source": "scheduler_eventbus_supervisor_smoke",
+            "scheduler_role": "upstream_orchestration_authority",
+            "supervisor_role": "downstream_observer",
+        },
+        audit_jsonl=options.audit_jsonl,
+    )
+    event = sink.accept_scheduler_event(
+        event_id=options.event_id,
+        event_kind=options.event_kind,
+        state=options.state,
+        observed_at=options.observed_at,
+        scheduler_ref=options.scheduler_ref,
+        route_ref=options.route_ref,
+        policy_decision_id=options.policy_decision_id,
+        artifact_ref=options.artifact_ref,
+        sql_ref=options.sql_ref,
+        qdrant_ref=options.qdrant_ref,
+        shm_ref=options.shm_ref,
+        error=options.error,
+        payload=_load_payload(options.payload_json),
+    )
+    if options.snapshot_output is not None:
+        payload = sink.write_snapshot(
+            options.snapshot_output,
+            generated_at=options.generated_at,
+        )
+    else:
+        payload = sink.snapshot_payload(generated_at=options.generated_at)
+    payload["accepted_event"] = event.to_dict()
+    payload["scheduler_eventbus_supervisor_source_ready"] = True
+    return payload
+
+
+def main(argv: tuple[str, ...] | None = None) -> int:
+    options = parse_args(tuple(sys.argv[1:] if argv is None else argv))
+    payload = run(options)
+    if options.format == "summary":
+        print(
+            "scheduler_source_ready={ready} event_count={event_count} cell_count={cell_count} "
+            "scheduler_ref={scheduler_ref}".format(
+                ready=payload["scheduler_eventbus_supervisor_source_ready"],
+                event_count=payload["event_count"],
+                cell_count=payload["cell_count"],
+                scheduler_ref=payload["accepted_event"]["source_ref"],
+            )
+        )
+    else:
+        print(json.dumps(payload, indent=2, sort_keys=True))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
