+        project_url=str(getattr(project, "project_url")),
+        fetch_project_url=str(getattr(fetch, "project_url")),
+        workflow_name=str(getattr(project, "workflow_name")),
+        fetch_workflow_name=str(getattr(fetch, "workflow_name")),
