+#!/usr/bin/env python3
+from pathlib import Path
+import argparse,json,os,sys
+from context.github_controlled_publication_contract_0276 import GitHubControlledPublicationCommand,build_github_controlled_publication_plan
+from context.github_controlled_publication_adapter_0276 import GitHubControlledPublicationAdapter,UrllibGitHubTransport
+from context.github_publication_collision_guard_0276 import run_github_publication_collision_guard,apply_guarded_github_publication
+from context.source_candidate_remote_mutation_gate import SourceCandidateRemoteMutationGatePolicy
+
+def load(path):
+ p=json.loads(Path(path).read_text());
+ if not isinstance(p,dict): raise ValueError("JSON must be an object")
+ return p
+def command_from(p): return GitHubControlledPublicationCommand(**p)
+def main(argv=None):
+ ap=argparse.ArgumentParser(); ap.add_argument("--command-json",required=True); ap.add_argument("--review-json",required=True); ap.add_argument("--mode",choices=("plan","preflight","apply"),default="plan"); ap.add_argument("--base-url",default="https://api.github.com"); ns=ap.parse_args(argv)
+ command=command_from(load(ns.command_json)); review=load(ns.review_json); adapter=GitHubControlledPublicationAdapter()
+ if ns.mode=="plan": payload={"mode":"plan","plan":build_github_controlled_publication_plan(command,review).to_mapping()}
+ else:
+  token=os.environ.get("AUTODOC_GITHUB_TOKEN",""); transport=UrllibGitHubTransport(base_url=ns.base_url)
+  if ns.mode=="preflight": payload={"mode":"preflight","guard":run_github_publication_collision_guard(command,review,transport=transport,token=token).to_mapping()}
+  else:
+   policy=SourceCandidateRemoteMutationGatePolicy(remote_mutation_enabled=command.remote_mutation_enabled,operator_confirmed=command.operator_confirmed,allowed_repositories=(command.repository,))
+   guard,result=apply_guarded_github_publication(adapter,command,review,policy,transport=transport,token=token); payload={"mode":"apply","guard":guard.to_mapping(),"result":result.to_mapping()}
+ text=json.dumps(payload,ensure_ascii=False,indent=2,sort_keys=True); assert token not in text if ns.mode!="plan" and token else True; print(text)
+ return 0
+if __name__=="__main__": raise SystemExit(main())
