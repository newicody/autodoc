@@ -0,0 +1,47 @@
+"""Remote preflight, revision and idempotency guard for 0276."""
+from __future__ import annotations
+from dataclasses import dataclass,field
+from collections.abc import Mapping
+from typing import Any
+import hashlib,json
+from context.github_controlled_publication_contract_0276 import GitHubControlledPublicationCommand,build_github_controlled_publication_plan
+from context.github_controlled_publication_adapter_0276 import GitHubControlledPublicationAdapter,GitHubControlledPublicationApplyResult,GitHubHttpTransport
+from context.source_candidate_remote_mutation_gate import SourceCandidateRemoteMutationGatePolicy
+GUARD_SCHEMA="missipy.github.publication_collision_guard.v1"
+@dataclass(frozen=True,slots=True)
+class GitHubPublicationCollisionGuardPolicy:
+ allow_closed_issue:bool=False; require_remote_revision:bool=True; scan_recent_comments:int=100
+@dataclass(frozen=True,slots=True)
+class GitHubPublicationCollisionGuardResult:
+ status:str; issues:tuple[str,...]; repository:str; issue_number:int; expected_revision:str; current_revision:str; etag:str; state:str; publication_marker:str; marker_found:bool; snapshot_digest:str; preflight_paths:tuple[str,...]; schema:str=GUARD_SCHEMA
+ @property
+ def clear(self): return self.status=="clear"
+ @property
+ def idempotent_replay(self): return self.status=="idempotent_replay"
+ def to_mapping(self): return {"schema":self.schema,"status":self.status,"issues":list(self.issues),"repository":self.repository,"issue_number":self.issue_number,"expected_revision":self.expected_revision,"current_revision":self.current_revision,"etag":self.etag,"state":self.state,"publication_marker":self.publication_marker,"marker_found":self.marker_found,"snapshot_digest":self.snapshot_digest,"preflight_paths":list(self.preflight_paths),"remote_mutation_performed":False}
+def _headers(token): return {"Authorization":"Bearer "+token,"Accept":"application/vnd.github+json","X-GitHub-Api-Version":"2022-11-28","User-Agent":"autodoc-publication-guard/0276"}
+def _digest(value): return "sha256:"+hashlib.sha256(json.dumps(value,sort_keys=True,separators=(",",":"),ensure_ascii=False).encode()).hexdigest()
+def _revision_matches(expected,updated,etag,digest): return expected in {updated,etag,digest,etag.strip('W/\"')}
+def run_github_publication_collision_guard(command,review,*,transport:GitHubHttpTransport,token:str,policy=None):
+ p=policy or GitHubPublicationCollisionGuardPolicy(); plan=build_github_controlled_publication_plan(command,review); issues=[]; paths=[]
+ if not token.strip(): return GitHubPublicationCollisionGuardResult("blocked",("token_missing",),command.repository,command.issue_number,command.expected_remote_revision,"","","",plan.publication_marker,False,"",())
+ issue_path=f"/repos/{command.repository}/issues/{command.issue_number}"; paths.append(issue_path); response=transport.request("GET",issue_path,headers=_headers(token),body=None)
+ if response.status!=200: return GitHubPublicationCollisionGuardResult("blocked",(f"issue_get_http_{response.status}",),command.repository,command.issue_number,command.expected_remote_revision,"",str(response.headers.get("ETag","")),"",plan.publication_marker,False,"",tuple(paths))
+ issue=response.json_mapping(); updated=str(issue.get("updated_at", "")); etag=str(response.headers.get("ETag",response.headers.get("etag",""))); digest=_digest(issue); state=str(issue.get("state","")); marker_found=plan.publication_marker in str(issue.get("body") or "")
+ if p.require_remote_revision and not _revision_matches(command.expected_remote_revision,updated,etag,digest): issues.append("remote_revision_conflict")
+ if state=="closed" and not p.allow_closed_issue: issues.append("issue_closed")
+ if command.mutation_kind=="issue_comment":
+  path=issue_path+f"/comments?per_page={p.scan_recent_comments}"; paths.append(path); comments=transport.request("GET",path,headers=_headers(token),body=None)
+  if comments.status!=200: issues.append(f"comments_get_http_{comments.status}")
+  else:
+   data=json.loads(comments.body or b"[]")
+   marker_found=any(plan.publication_marker in str(x.get("body") or "") for x in data if isinstance(x,dict))
+ elif command.mutation_kind=="issue_labels_replace":
+  current=tuple(sorted(str(x.get("name")) for x in issue.get("labels",[]) if isinstance(x,dict) and x.get("name"))); desired=tuple(sorted(command.labels)); marker_found=current==desired
+ status="conflict" if "remote_revision_conflict" in issues else "blocked" if issues else "idempotent_replay" if marker_found else "clear"
+ return GitHubPublicationCollisionGuardResult(status,tuple(dict.fromkeys(issues)),command.repository,command.issue_number,command.expected_remote_revision,updated,etag,state,plan.publication_marker,marker_found,digest,tuple(paths))
+def apply_guarded_github_publication(adapter,command,review,gate_policy,*,transport,token,guard_policy=None):
+ guard=run_github_publication_collision_guard(command,review,transport=transport,token=token,policy=guard_policy)
+ if guard.idempotent_replay: return guard,GitHubControlledPublicationApplyResult(False,True,"idempotent_replay",None)
+ if not guard.clear: return guard,GitHubControlledPublicationApplyResult(False,False,"blocked",None,blocked_reasons=guard.issues)
+ return guard,adapter.apply(command,review,gate_policy,transport=transport,token=token,guard_receipt=guard.to_mapping())
