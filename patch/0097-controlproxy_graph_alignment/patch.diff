+  rankdir=LR;
+  graph [
+    label="Runtime ControlFS / SHM / ControlProxy / Cluster Fabric graph — 0097 integrated root",
+    labelloc=t
+  ];
+  node [shape=box];
+
+  subgraph cluster_policy_zone {
+    label="SecurityFS / Scheduler policy / zones";
+    style=rounded;
+
+    securityfs [
+      label="SecurityFS\nsubsystem rules / zones / scopes"
+    ];
+    policy_engine [
+      label="PolicyEngine\ncompiles rules and zone decisions"
+    ];
+    scheduler [
+      label="Scheduler\ndecision authority\nNo Scheduler.run() modification"
+    ];
+    priority_queue [
+      label="PriorityQueue\ndeterministic command ordering"
+    ];
+    dispatcher [
+      label="Dispatcher\nselects handler boundary"
+    ];
+
+    securityfs -> policy_engine [label="read rules"];
+    policy_engine -> scheduler [label="authorized decision + zone + policy_decision_id"];
+    scheduler -> priority_queue [label="enqueue approved work"];
+    priority_queue -> scheduler [label="Scheduler.run() drains ready work"];
+    scheduler -> dispatcher [label="dispatch"];
+  }
+
+  subgraph cluster_controlproxy_controlfs {
+    label="ControlProxy / ControlFS bounded subsystem";
+    style=rounded;
+
+    controlproxy_handler [
+      label="ControlProxy route handler\ncalled by Dispatcher\nvalidates authorized envelope"
+    ];
+    controlfs_surface [
+      shape=folder,
+      label="ControlFS surface\n/run/autodoc/controlfs\nactive/routes, leases, revoked, status"
+    ];
+    generation_table [
+      shape=cylinder,
+      label="generation_state.json\nroute_id -> current_generation\nincremented only when materialized"
+    ];
+    generation_lock [
+      label="route generation lock\ninter-process file lock"
+    ];
+    runtime_placement [
+      label="runtime placement policy\nfile | /dev/shm\nNot /dev/shm-only"
+    ];
+    locked_materializer [
+      label="locked generation materializer\nload -> verify -> materialize -> persist"
+    ];
+    lifecycle [
+      label="lifecycle\ncandidate -> active -> draining -> closed"
+    ];
+
+    controlproxy_handler -> controlfs_surface [label="writes route-control state"];
+    controlfs_surface -> generation_lock [label="per route lock"];
+    generation_lock -> generation_table [label="load/verify/persist"];
+    generation_table -> runtime_placement [label="next g2/g3 generation"];
+    runtime_placement -> locked_materializer [label="resolved runtime root"];
+    locked_materializer -> lifecycle [label="candidate state"];
+  }
+
+  subgraph cluster_runtime_surfaces {
+    label="Existing runtime surfaces";
+    style=rounded;
+
+    shm_runtime [
+      shape=folder,
+      label="SHM/file runtime root\nroutes/<route_id>@gN/ring.bin\nNo live mmap resize"
+    ];
+    event_bus [
+      shape=folder,
+      label="existing event.bus\nfacts, not commands"
+    ];
+    context_bus [
+      shape=folder,
+      label="existing context.bus\ncompact context facts"
+    ];
+    workers [
+      label="Workers / experts\nuse materialized routes only"
+    ];
+    recorder [
+      label="Recorder\njournal writer"
+    ];
+    zfs_store [
+      shape=cylinder,
+      label="ZFS Store\njournal / contracts / replay / snapshots"
+    ];
+
+    shm_runtime -> workers [label="route access"];
+    workers -> event_bus [label="facts"];
+    workers -> context_bus [label="context patches/facts"];
+    event_bus -> recorder [label="drain facts"];
+    context_bus -> recorder [label="drain context facts"];
+    recorder -> zfs_store [label="durable write"];
+  }
+
+  subgraph cluster_future_extensions {
+    label="Future extensions, not implemented now";
+    style=dashed;
+
+    network_bridge [
+      label="NetworkBridge future\ncompact facts / remote handles only"
+    ];
+    hardware_bridge [
+      label="HardwareBridge future\nDMA-backed route buffers\nnot direct /dev/shm sharing"
+    ];
+    cluster_fabric [
+      label="Hardware Cluster Fabric future lointain\nFPGA/ASIC passive observer/accelerator"
+    ];
+
+    network_bridge -> hardware_bridge [style=dashed, label="future compatibility"];
+    hardware_bridge -> cluster_fabric [style=dashed, label="future PCIe/LVDS path"];
+  }
+
+  dispatcher -> controlproxy_handler [label="handler call"];
+  lifecycle -> shm_runtime [label="materialized route generation"];
+  lifecycle -> event_bus [label="status fact"];
+  lifecycle -> context_bus [label="route/context visibility fact"];
+  shm_runtime -> network_bridge [style=dashed, label="future selected replication"];
+}
