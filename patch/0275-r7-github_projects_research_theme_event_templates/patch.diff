+name: Autodoc controlled research request
+
+on:
+  workflow_dispatch:
+    inputs:
+      issue_number:
+        description: Numéro de l'issue à traiter
+        required: true
+        type: string
+      requested_status:
+        description: Intention correspondant à la colonne Status
+        required: true
+        type: choice
+        options:
+          - Recherche
+          - Développement
+          - Production
+      request_mode:
+        description: Nature du cycle
+        required: true
+        type: choice
+        options:
+          - initial
+          - continuation
+          - transversal
+      parent_event_ref:
+        description: Événement parent ou précédent, si applicable
+        required: false
+        type: string
+
+permissions:
+  contents: read
+  issues: read
+  actions: read
+
+jobs:
+  build-dual-artifacts:
+    runs-on: ubuntu-latest
+
+    steps:
+      - name: Checkout Autodoc runtime
+        uses: actions/checkout@v6
+        with:
+          repository: newicody/autodoc
+          path: autodoc-runtime
+
+      - name: Set up Python
+        uses: actions/setup-python@v6
+        with:
+          python-version: "3.13"
+
+      - name: Prepare output directory
+        run: mkdir -p out
+
+      - name: Read selected issue
+        env:
+          GH_TOKEN: ${{ github.token }}
+          ISSUE_NUMBER: ${{ inputs.issue_number }}
+        run: >
+          gh api
+          "repos/${GITHUB_REPOSITORY}/issues/${ISSUE_NUMBER}"
+          > out/issue.json
+
+      - name: Build controlled issue event
+        env:
+          AUTODOC_ISSUE_JSON: out/issue.json
+          AUTODOC_EVENT_OUTPUT: out/autodoc_issue_event.json
+          AUTODOC_REQUESTED_STATUS: ${{ inputs.requested_status }}
+          AUTODOC_REQUEST_MODE: ${{ inputs.request_mode }}
+          AUTODOC_PARENT_EVENT_REF: ${{ inputs.parent_event_ref }}
+        run: >
+          python
+          autodoc-runtime/templates/github/projects-repository/scripts/build_workflow_dispatch_issue_event.py
+
+      - name: Build authoritative request
+        env:
+          GITHUB_EVENT_PATH: ${{ github.workspace }}/out/autodoc_issue_event.json
+          AUTODOC_OUTPUT: out/authoritative_request.json
+        run: >
+          python
+          autodoc-runtime/templates/github/scripts/build_autodoc_authoritative_request.py
+
+      - name: Install Copilot CLI
+        if: ${{ vars.AUTODOC_COPILOT_ADVISORY_ENABLED == 'true' }}
+        run: npm install --global @github/copilot
+
+      - name: Build optional Copilot advisory
+        if: ${{ vars.AUTODOC_COPILOT_ADVISORY_ENABLED == 'true' }}
+        env:
+          COPILOT_GITHUB_TOKEN: ${{ secrets.AUTODOC_COPILOT_TOKEN }}
+          AUTODOC_REQUEST: out/authoritative_request.json
+          AUTODOC_ADVISORY: out/copilot_advisory.json
+        run: >
+          python
+          autodoc-runtime/templates/github/scripts/run_autodoc_copilot_advisory.py
+
+      - name: Build linking manifest
+        env:
+          AUTODOC_REQUEST: out/authoritative_request.json
+          AUTODOC_ADVISORY: out/copilot_advisory.json
+          AUTODOC_MANIFEST: out/dual_artifact_manifest.json
+        run: >
+          python
+          autodoc-runtime/templates/github/scripts/build_autodoc_dual_manifest.py
+
+      - name: Upload authoritative request
+        uses: actions/upload-artifact@v7
+        with:
+          name: autodoc-authoritative-request
+          path: out/authoritative_request.json
+          if-no-files-found: error
+
+      - name: Upload optional Copilot advisory
+        if: ${{ hashFiles('out/copilot_advisory.json') != '' }}
+        uses: actions/upload-artifact@v7
+        with:
+          name: autodoc-copilot-advisory
+          path: out/copilot_advisory.json
+          if-no-files-found: error
+
+      - name: Upload manifest
+        uses: actions/upload-artifact@v7
+        with:
+          name: autodoc-dual-artifact-manifest
+          path: out/dual_artifact_manifest.json
+          if-no-files-found: error
diff --git a/templates/github/projects-repository/scripts/build_workflow_dispatch_issue_event.py b/templates/github/projects-repository/scripts/build_workflow_dispatch_issue_event.py
new file mode 100644
index 0000000..20a1623
--- /dev/null
+++ b/templates/github/projects-repository/scripts/build_workflow_dispatch_issue_event.py
@@ -0,0 +1,71 @@
+#!/usr/bin/env python3
+"""Build a synthetic GitHub issue event for a controlled workflow_dispatch run."""
+
+from __future__ import annotations
+
+from pathlib import Path
+import json
+import os
+from typing import Any, Mapping
+
+
+def _load_mapping(path: Path) -> Mapping[str, Any]:
+    payload = json.loads(path.read_text(encoding="utf-8"))
+    if not isinstance(payload, dict):
+        raise ValueError("issue payload must be a JSON object")
+    return payload
+
+
+def build_event(
+    issue: Mapping[str, Any],
+    *,
+    repository: str,
+    actor: str,
+    requested_status: str,
+    request_mode: str,
+    parent_event_ref: str,
+) -> dict[str, Any]:
+    number = int(issue.get("number") or 0)
+    if number <= 0:
+        raise ValueError("issue number must be positive")
+    if requested_status not in {"Recherche", "Développement", "Production"}:
+        raise ValueError("unsupported requested_status")
+    if request_mode not in {"initial", "continuation", "transversal"}:
+        raise ValueError("unsupported request_mode")
+    return {
+        "action": "workflow_dispatch",
+        "issue": dict(issue),
+        "repository": {"full_name": repository},
+        "sender": {"login": actor},
+        "autodoc_dispatch": {
+            "issue_number": number,
+            "requested_status": requested_status,
+            "request_mode": request_mode,
+            "parent_event_ref": parent_event_ref,
+        },
+    }
+
+
+def main() -> int:
+    issue_path = Path(os.environ["AUTODOC_ISSUE_JSON"])
+    output_path = Path(
+        os.environ.get("AUTODOC_EVENT_OUTPUT", "out/autodoc_issue_event.json")
+    )
+    event = build_event(
+        _load_mapping(issue_path),
+        repository=os.environ["GITHUB_REPOSITORY"],
+        actor=os.environ.get("GITHUB_ACTOR", ""),
+        requested_status=os.environ["AUTODOC_REQUESTED_STATUS"],
+        request_mode=os.environ["AUTODOC_REQUEST_MODE"],
+        parent_event_ref=os.environ.get("AUTODOC_PARENT_EVENT_REF", ""),
+    )
+    output_path.parent.mkdir(parents=True, exist_ok=True)
+    output_path.write_text(
+        json.dumps(event, ensure_ascii=False, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
