+name: Nouvelle recherche
+description: Créer une recherche durable, relançable sur le même ticket.
+title: "[Recherche] "
+labels: []
+body:
+  - type: markdown
+    attributes:
+      value: |
+        Ce ticket conserve la question d'origine et l'historique de ses cycles.
+        Les références peuvent être ajoutées une par ligne. Les documents et
+        médias peuvent être déposés dans les zones de texte compatibles.
+
+  - type: textarea
+    id: original_question
+    attributes:
+      label: Question d'origine
+      description: Question stable à laquelle les cycles successifs restent rattachés.
+      placeholder: Quelle question doit être étudiée ?
+    validations:
+      required: true
+
+  - type: textarea
+    id: expected_delivery
+    attributes:
+      label: Résultat ou livrable recherché
+      description: Forme, profondeur et critères attendus.
+      placeholder: Synthèse, comparaison, dossier, proposition, code, plan...
+    validations:
+      required: true
+
+  - type: textarea
+    id: initial_parameters
+    attributes:
+      label: Contexte et paramètres actuels
+      description: Contraintes, hypothèses, limites, format et paramètres modifiables.
+      placeholder: |
+        Niveau de détail :
+        Contraintes :
+        Hypothèses :
+        Format attendu :
+
+  - type: textarea
+    id: cycle_refinement
+    attributes:
+      label: Affinage pour le prochain cycle
+      description: Précisions nouvelles, corrections ou changement de paramètres.
+      placeholder: Ce qui doit être approfondi ou modifié lors du prochain cycle.
+
+  - type: textarea
+    id: search_tickets
+    attributes:
+      label: "Chercher sur : tickets et recherches"
+      description: Ajouter une référence GitHub par ligne, par exemple #12 ou une URL.
+      placeholder: |
+        #12
+        https://github.com/newicody/projects/issues/24
+
+  - type: textarea
+    id: search_repositories
+    attributes:
+      label: "Chercher sur : dépôts"
+      description: Ajouter un dépôt ou une URL par ligne.
+      placeholder: |
+        newicody/autodoc
+        https://github.com/example/project
+
+  - type: textarea
+    id: search_documents
+    attributes:
+      label: "Chercher sur : documents, médias et liens"
+      description: Déposer des fichiers ou ajouter une URL par ligne.
+      placeholder: |
+        Déposer ici des documents ou médias.
+        https://example.org/source.pdf
+
+  - type: textarea
+    id: search_themes
+    attributes:
+      label: "Chercher sur : thèmes"
+      description: Ajouter un thème, un ticket de thème ou une référence par ligne.
+      placeholder: |
+        Chalouf
+        #30
+        Architecture réseau
+
+  - type: dropdown
+    id: search_scope
+    attributes:
+      label: Portée de la recherche
+      options:
+        - Cette recherche seulement
+        - Thème principal
+        - Plusieurs thèmes sélectionnés
+        - Sélection explicite uniquement
+    validations:
+      required: true
+
+  - type: dropdown
+    id: context_mode
+    attributes:
+      label: Niveau de contexte du prochain cycle
+      options:
+        - Complet
+        - Condensé
+        - Minimal
+    validations:
+      required: true
+
+  - type: checkboxes
+    id: next_cycle_exclusions
+    attributes:
+      label: Éléments à exclure du prochain cycle
+      description: Ces choix ne suppriment rien de l'historique.
+      options:
+        - label: Exclure le résultat du cycle précédent
+        - label: Exclure les anciens commentaires
+        - label: Exclure les anciennes pièces jointes
+        - label: Exclure les recherches liées
+        - label: Exclure les dépôts liés
+        - label: Exclure les documents et médias liés
+        - label: Exclure les résultats d'inférence externe
+
+  - type: textarea
+    id: precise_exclusions
+    attributes:
+      label: Exclusions précises
+      description: Références exactes de cycles, tickets, commentaires ou fichiers à écarter.
+      placeholder: Une référence par ligne.
+
+  - type: checkboxes
+    id: external_inference
+    attributes:
+      label: Inférence externe
+      options:
+        - label: Lancer également une inférence sur un moteur externe
+
+  - type: textarea
+    id: external_inference_details
+    attributes:
+      label: Précisions pour l'inférence externe
+      description: Objectif, contraintes ou préférence de moteur, sans secret.
+      placeholder: Ne jamais placer de token ou de secret dans ce champ.
+
+  - type: textarea
+    id: hierarchy_links
+    attributes:
+      label: Origine et liens hiérarchiques
+      description: Événement, recherche ou thème parent à conserver comme provenance.
+      placeholder: |
+        Recherche d'origine :
+        Événement précédent :
+        Thème principal :
