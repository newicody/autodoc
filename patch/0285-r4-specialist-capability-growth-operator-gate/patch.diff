+    assert "operator must be distinct from proposal proposer" in issues
+
+
+def test_candidate_must_extend_current_lineage_head() -> None:
+    proposal = _proposal()
+    candidate = PortableSpecialistRevision(
+        schema=PORTABLE_SPECIALIST_REVISION_SCHEMA,
