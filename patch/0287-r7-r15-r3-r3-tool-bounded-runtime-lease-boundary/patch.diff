+    )
+    return ImportedActionsRuntimePorts(
+        schema=IMPORTED_ACTIONS_RUNTIME_PORTS_SCHEMA,
+        runtime_ref=attestation.runtime_ref,
+        scheduler=_Scheduler(),
+        dispatcher=_Dispatcher(),
