+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[2]
+CURRENT = ROOT / "doc/README_CURRENT.md"
+REPORT = ROOT / (
+    "PHASE0287_R7_R5_PRODUCT_FINAL_SPECIALIST_EXCHANGE_SYNTHESIS_"
+    "REUSE_AUDIT_REPORT.md"
+)
