+
+def test_plan_is_deterministic_across_input_order():
+    options = _options()
+    first = plan_github_project_v2_theme_grouping_deployment(
+        _command(desired_options=options)
+    )
+    second = plan_github_project_v2_theme_grouping_deployment(
