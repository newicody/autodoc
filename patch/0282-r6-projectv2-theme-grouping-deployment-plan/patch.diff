+                GitHubProjectV2ViewGroupingSnapshot(
+                    view_number=2,
+                    view_name="Board",
+                    grouped_field_id="PVTF_other",
+                ),
+            ),
+        )
+    )
+
+    assert result.valid is False
+    assert result.view_grouping_action == "view_collision"
