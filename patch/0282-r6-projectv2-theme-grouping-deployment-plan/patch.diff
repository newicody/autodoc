+    )
+    assert result.operations == ()
+
+
+def test_wrong_field_type_is_collision():
+    result = plan_github_project_v2_theme_grouping_deployment(
+        _command(
+            existing_fields=(
+                GitHubProjectV2ThemeFieldSnapshot(
+                    field_id="PVTF_theme",
+                    name="Thème",
+                    data_type="text",
+                ),
+            ),
+        )
+    )
+
