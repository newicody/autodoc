+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[2]
+ADAPTER = ROOT / "src/context/love_qdrant_hybrid_query_adapter_0287.py"
+EXECUTOR = ROOT / "src/inference/qdrant_client_projection_executor.py"
