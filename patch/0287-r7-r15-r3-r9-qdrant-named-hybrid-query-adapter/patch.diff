+def test_effect_gate_denies_search() -> None:
+    client = _Client(())
+    executor = QdrantClientProjectionExecutor(
+        client=client,
+        models_module=_Models,
+        config=QdrantClientConnectionConfig(),
+        gate=QdrantClientEffectGate(
