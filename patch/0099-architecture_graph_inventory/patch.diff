+
+def test_0099_manifest_stays_doc_and_rule_only() -> None:
+    text = _read(MANIFEST)
+    assert "src/kernel/scheduler.py" not in text
+    assert "src/kernel/queue.py" not in text
+    assert "src/kernel/dispatcher.py" not in text
