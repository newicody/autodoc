+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[2]
+OPTIONAL = ROOT / "tests/tools/test_github_copilot_advisory_optional_0277.py"
+EXTRACTION = ROOT / "tests/tools/test_github_copilot_advisory_response_extraction_0279.py"
+WORKFLOW = ROOT / "tests/tools/test_github_dual_artifact_actions_workflow_0275.py"
+RUNNER = ROOT / "templates/github/scripts/run_autodoc_copilot_advisory.py"
+REPORT = ROOT / "PHASE0287_R7_R2_R3_COPILOT_V2_PRODUCER_TEST_MIGRATION_REPORT.md"
+
+
+def test_active_producer_fixtures_use_v2_first_opinion() -> None:
+    combined = OPTIONAL.read_text() + EXTRACTION.read_text() + WORKFLOW.read_text()
+    for field in (
+        "concrete_objective",
+        "expected_result",
+        "provided_constraints",
+        "success_criteria",
+    ):
+        assert field in combined
+    assert "missipy.github.copilot_advisory.v2" in combined
+
+
+def test_historical_v1_reader_contract_remains_explicit() -> None:
+    extraction = EXTRACTION.read_text()
+    runner = RUNNER.read_text()
+    assert "def _advisory()" in extraction
+    assert '"summary": "Advisory summary"' in extraction
+    assert "def extract_advisory" in runner
+
+
+def test_no_semantic_v1_to_v2_conversion_is_added() -> None:
+    runner = RUNNER.read_text()
+    assert "def extract_advisory" in runner
+    assert "def extract_first_opinion" in runner
+    assert 'parsed = extract_first_opinion(process.stdout)' in runner
+    assert 'parsed["summary"]' not in runner.split("payload = {", 1)[1]
+
+
+def test_phase_is_test_only_and_installation_neutral() -> None:
+    report = REPORT.read_text()
+    assert "alters tests only" in report
+    assert "code_rule_review: done" in report
+    assert "live_path_status: transition" in report
