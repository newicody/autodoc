+            "title": "idea",
+            "url": "https://github.com/users/newicody/projects/2",
+        },
+        "items": {
+            "added": [
+                {
+                    "item_id": "PVTI_chalouf",
+                    "item_type": "DRAFT_ISSUE",
+                    "content_id": "DI_chalouf",
