+            "unchanged_ids": [],
+        },
+        "counts": {
+            "added_count": 1,
+            "changed_count": 0,
+            "removed_count": 0,
+            "unchanged_count": 0,
+        },
+        "boundaries": {
+            "external_call_performed": False,
+            "remote_mutation_allowed": False,
+            "sql_write_allowed": False,
