+# Copy to .var/config/love_installed_runtime.ini and keep it out of Git.
+# This file identifies the existing installed server composition. It does not
+# authorize construction of a second Scheduler or a fake SQL/OpenVINO/Qdrant
+# path. The provider must return the already-composed ports required by r14/r15.
+
+[provider]
+# One installation-owned composition function using module:function syntax.
+# It receives repository, run_id, request_payload, runtime_context, created_at
+# and the immutable InstalledRuntimeFactorySettings object when supported.
+factory =
+
+[runtime]
+schema = missipy.love.installed_runtime_factory_configuration.v1
+runtime_ref = runtime:love-installed
+
+[scheduler]
+scheduler_ref = scheduler:main
+# externally-managed reuses the live server loop; tool-bounded is reserved for
+# a dedicated Scheduler whose lifecycle is owned by the import command.
+lifecycle = externally-managed
+
+[sql]
+authority_ref = sql-authority:context-revisions
+base_revision_ref = context-revision:love-base
+
+[projection]
+backend_ref = projection:context-revision-sql-authority
+
+[embedding]
+backend_ref = openvino:multilingual-e5-small
+model_ref = model:multilingual-e5-small
+model_revision = installed
+# Locked by the existing E5 runtime and Qdrant collection profile.
+dimension = 384
+
+[qdrant]
+backend_ref = qdrant:local
+collection = autodoc_context_e5_384
+
+[evidence]
+# Comma-separated or one reference per line. Use durable configuration, model,
+# collection and deployment evidence references from the installed server.
+refs =
