+Component.tick() -> yield Event / Request -> ComponentProxy -> Scheduler.emit() -> PolicyEngine.decide() -> PriorityQueue -> Scheduler.run() -> Dispatcher.dispatch() -> Handler -> Request.reply -> ComponentProxy -> tick().asend(result)
