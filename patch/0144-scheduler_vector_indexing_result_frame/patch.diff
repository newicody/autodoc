+values_preview: [0.1, 0.2]
+point_id: `qdrant-point:abc123`
+qdrant_rest_id: `uuid-123`
+machine_vector_handoff: `true`
+strict_vector_handoff: `true`
+vector_json: `/tmp/e5_vector.json`
