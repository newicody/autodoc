+++ b/src/context/passive_bus_supervisor_cellular_snapshot.py
@@ -9,6 +9,8 @@ SQL, Qdrant, GitHub, SHM, or proxy control planes.
 from __future__ import annotations
 
 from dataclasses import dataclass, field
+import json
+from pathlib import Path
 from typing import Any, Iterable, Mapping
 
 
@@ -305,3 +307,111 @@ def build_cellular_snapshot(
         stale_count=sum(1 for cell in cells if cell.state == "stale"),
         metadata=_as_string_mapping(metadata),
     )
