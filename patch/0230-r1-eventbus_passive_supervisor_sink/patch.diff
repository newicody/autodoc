+#!/usr/bin/env python3
+"""Smoke the EventBus -> PassiveSupervisorSink -> CellularState path.
+
+This tool is a file-based smoke harness for canonical EventBus events. It does
+not implement an EventBus, call Scheduler.run, control proxies, mutate SHM,
+decide policy, or write SQL/Qdrant/GitHub.
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import sys
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any
+
+ROOT = Path(__file__).resolve().parents[1]
+if str(ROOT) not in sys.path:
+    sys.path.insert(0, str(ROOT))
+
+from src.context.passive_bus_supervisor_cellular_snapshot import PassiveSupervisorSink
+
+
+def _utc_now() -> str:
+    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
+
+
+def _load_json_object(raw_json: str, *, label: str) -> dict[str, Any]:
+    try:
+        value = json.loads(raw_json)
+    except json.JSONDecodeError as exc:
+        raise ValueError(f"invalid {label}: {exc}") from exc
+    if not isinstance(value, dict):
+        raise ValueError(f"{label} must be a JSON object")
+    return value
+
+
+def _load_jsonl_events(path: Path) -> list[dict[str, Any]]:
+    events: list[dict[str, Any]] = []
+    with path.open("r", encoding="utf-8") as handle:
+        for line_number, line in enumerate(handle, start=1):
+            stripped = line.strip()
+            if not stripped:
+                continue
+            event = _load_json_object(stripped, label=f"line {line_number}")
+            events.append(event)
+    return events
+
+
+def build_payload(
+    *,
+    event_json: list[str],
+    events_jsonl: Path | None,
+    generated_at: str,
+    output: Path | None,
+    audit_jsonl: Path | None,
+) -> dict[str, Any]:
+    sink = PassiveSupervisorSink(
+        metadata={
+            "patch_id": "0230-r1-eventbus_passive_supervisor_sink",
+            "source": "eventbus_passive_supervisor_sink_smoke",
+            "runtime_path": "eventbus_direct_sink",
+        },
+        audit_jsonl=audit_jsonl,
+    )
+
+    accepted = 0
+    if events_jsonl is not None:
+        accepted += len(sink.accept_many(_load_jsonl_events(events_jsonl)))
+    for raw_event in event_json:
+        sink.accept(_load_json_object(raw_event, label="--event-json"))
+        accepted += 1
+    if accepted == 0:
+        raise ValueError("at least one canonical EventBus event is required")
+
+    if output is not None:
+        return sink.write_snapshot(output, generated_at=generated_at)
+    return sink.snapshot_payload(generated_at=generated_at)
+
+
+def _build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        "--event-json",
+        action="append",
+        default=[],
+        help="Canonical EventBus event as a JSON object. May be repeated.",
+    )
+    parser.add_argument(
+        "--events-jsonl",
+        type=Path,
+        help="Optional replay/test input containing canonical EventBus event objects.",
+    )
+    parser.add_argument(
+        "--audit-jsonl",
+        type=Path,
+        help="Optional audit/replay output. Not part of the runtime hot path.",
+    )
+    parser.add_argument(
+        "--output",
+        type=Path,
+        help="Optional snapshot JSON output.",
+    )
+    parser.add_argument(
+        "--generated-at",
+        default="",
+        help="Optional deterministic snapshot timestamp.",
+    )
+    parser.add_argument(
+        "--format",
+        choices=("json",),
+        default="json",
+        help="Output format. JSON is the only supported format.",
+    )
+    return parser
+
+
+def main() -> int:
+    args = _build_parser().parse_args()
+    payload = build_payload(
+        event_json=args.event_json,
+        events_jsonl=args.events_jsonl,
+        generated_at=args.generated_at or _utc_now(),
+        output=args.output,
+        audit_jsonl=args.audit_jsonl,
+    )
+    print(json.dumps(payload, sort_keys=True))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
