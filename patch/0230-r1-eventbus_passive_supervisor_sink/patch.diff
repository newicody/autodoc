+from pathlib import Path
+
+from src.context.passive_bus_supervisor_cellular_snapshot import PassiveSupervisorSink
+
+
+def _event(event_id: str, cell_id: str, cell_kind: str, state: str, **refs: str) -> dict[str, str]:
+    event = {
+        "event_id": event_id,
+        "event_kind": f"{cell_kind.lower()}_observed",
+        "cell_id": cell_id,
+        "cell_kind": cell_kind,
+        "state": state,
+        "observed_at": "2026-07-08T00:00:00Z",
+    }
+    event.update(refs)
+    return event
+
+
+def test_eventbus_passive_supervisor_sink_covers_scheduler_runtime_and_data_surfaces() -> None:
+    sink = PassiveSupervisorSink(metadata={"test": "0230"})
+    sink.accept_many(
+        [
+            _event("evt-scheduler", "scheduler:main", "SCHEDULER", "running"),
+            _event("evt-route", "routeproxy:main", "ROUTEPROXY", "running", route_ref="route-1"),
+            _event("evt-control", "controlproxy:main", "CONTROLPROXY", "draining", route_ref="route-1"),
+            _event("evt-shm", "shm:ring", "SHM_RING", "queued", shm_ref="shm-1"),
+            _event("evt-policy", "policy:gate", "POLICY_GATE", "blocked", policy_decision_id="policy-1"),
+            _event("evt-github", "github:artifact", "GITHUB_ARTIFACT", "success", artifact_ref="artifact-1"),
+            _event("evt-candidate", "source:candidate", "SOURCE_CANDIDATE", "queued", artifact_ref="artifact-1"),
+            _event("evt-sql", "sql:authority", "SQL_AUTHORITY", "success", sql_ref="sql-1"),
+            _event("evt-qdrant", "qdrant:projection", "QDRANT_PROJECTION", "success", qdrant_ref="qdrant-1"),
+            _event("evt-rehydrate", "rehydrate:main", "REHYDRATE", "success", sql_ref="sql-1", qdrant_ref="qdrant-1"),
+            _event("evt-pushback", "pushback:github", "PUSHBACK", "queued", artifact_ref="artifact-1"),
+        ]
+    )
+
+    payload = sink.snapshot_payload(generated_at="2026-07-08T00:00:01Z")
+    cells = {cell["cell_id"]: cell for cell in payload["cells"]}
+
+    assert sink.event_count() == 11
+    assert payload["event_count"] == 11
+    assert payload["cell_count"] == 11
+    assert payload["blocked_count"] == 1
+    assert payload["metadata"]["runtime_path"] == "eventbus_direct_sink"
+    assert payload["metadata"]["scheduler_role"] == "upstream_orchestration_authority"
+    assert payload["metadata"]["eventbus_role"] == "canonical_runtime_event_transport"
+    assert payload["audit_journal_enabled"] is False
+    assert payload["supervision_authority_violation"] is False
+    assert cells["routeproxy:main"]["refs"]["route_ref"] == "route-1"
+    assert cells["shm:ring"]["refs"]["shm_ref"] == "shm-1"
+    assert cells["policy:gate"]["refs"]["policy_decision_id"] == "policy-1"
+    assert cells["sql:authority"]["refs"]["sql_ref"] == "sql-1"
+    assert cells["qdrant:projection"]["refs"]["qdrant_ref"] == "qdrant-1"
+
+
+def test_eventbus_passive_supervisor_sink_audit_and_snapshot_are_optional(tmp_path: Path) -> None:
+    audit_jsonl = tmp_path / "audit" / "events.jsonl"
+    snapshot_json = tmp_path / "snapshot" / "state.json"
+    sink = PassiveSupervisorSink(audit_jsonl=audit_jsonl)
+    sink.accept(_event("evt-1", "scheduler:main", "SCHEDULER", "success"))
+
+    payload = sink.write_snapshot(snapshot_json, generated_at="2026-07-08T00:00:01Z")
+
+    assert audit_jsonl.exists()
+    assert snapshot_json.exists()
+    assert payload["cellular_snapshot_written"] is True
+    assert payload["audit_journal_enabled"] is True
+    assert "evt-1" in audit_jsonl.read_text(encoding="utf-8")
