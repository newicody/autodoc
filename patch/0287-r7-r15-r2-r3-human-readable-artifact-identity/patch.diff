+        "advisory_artifact_ref": None,
+    }
+    bundle = build_human_readable_artifact_identity_bundle(
+        repository="newicody/projects",
+        workflow_run_id="2",
+        issue=issue,
+        request=request,
+        advisory=None,
+        manifest=manifest,
