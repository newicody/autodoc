+    }
+    decision = {
+        "decision_ref": "decision:0286-r2:approve",
+        "decision_digest": HASHES["decision"],
+        "outcome": "approve",
+        "operator_ref": "operator:eric",
+        "reason": "Approved for controlled Projects review.",
+        "proposal_ref": proposal["proposal_ref"],
