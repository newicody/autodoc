+        "candidate_revision_digest_sha256": HASHES["revision"],
+        "specialist_ref": proposal["specialist_ref"],
+        "revision_authorized": True,
+    }
+    entry = {
+        "history_ref": "history:technical",
+        "entry_ref": "history-entry:technical:1",
