-# Canonical Autodoc provider. The operator configures backends, not Python code.
-factory = context.love_manual_installed_runtime_provider_0287:build_installed_runtime_ports
+# Leave this empty to select the canonical provider automatically.
+# Canonical default: context.love_manual_installed_runtime_provider_0287:build_installed_runtime_ports
