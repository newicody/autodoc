+def test_existing_identical_linked_issue_is_replay() -> None:
+    first = plan_github_project_v2_parent_sub_ticket_mutation(
+        _command((_root_snapshot(),))
+    )
+    child = GitHubProjectV2IssueSnapshot(
+        issue_ref=CHILD_REF,
