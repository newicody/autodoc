+        "repository": "newicody/projects",
+        "issue_number": 42,
+        "source_title": "Validation chaîne GitHub vers Autodoc",
+        "source_ref": "github-frame:newicody/projects/issues/42",
+        "workflow_run_id": "29255262261",
+        "bundle_digest": "sha256:" + "a" * 64,
