+from pathlib import Path
+import re
+
+ROOT = Path(__file__).resolve().parents[2]
+INSTALLATION = (
+    ROOT / "templates/github/projects-repository/INSTALLATION.md"
+)
+RECONCILE = (
+    ROOT
+    / "templates/github/projects-repository/scripts/"
+    "reconcile_projectv2_configuration.py"
+)
+
+
+def test_user_owned_view_endpoint_uses_owner_login() -> None:
+    source = RECONCILE.read_text(encoding="utf-8")
+
+    assert (
+        'views_endpoint = '
+        'f"users/{plan.owner}/projectsV2/{plan.number}/views"'
+        in source
+    )
+    assert (
+        'views_endpoint = '
+        'f"users/{plan.user_id}/projectsV2/{plan.number}/views"'
+        not in source
+    )
+
+    # Numeric user_id remains report metadata only.
+    assert '"user_id": self.user_id' in source
+
+
+def test_simplified_installation_keeps_all_cumulative_markers() -> None:
+    text = INSTALLATION.read_text(encoding="utf-8")
+
+    current = re.search(
+        r"^Version du guide : `(?P<version>[^`]+)`\.$",
+        text,
+        flags=re.MULTILINE,
+    )
+    assert current is not None
+    assert current.group("version") == "0287-r5-r2"
+
+    for marker in (
+        "Installation cumulative de `newicody/projects`",
+        "mode opÃĐratoire cumulatif",
+        "Version actuelle du guide : `0287-r5`.",
+        "AUTODOC_COPILOT_ADVISORY_ENABLED=false",
+        "AUTODOC_COPILOT_ADVISORY_ENABLED=true",
+        "Cette valeur est le dÃĐfaut d'installation",
+        "AprÃĻs un premier dispatch validÃĐ sans Copilot",
+        "Ne pas crÃĐer de secret `AUTODOC_COPILOT_TOKEN`",
+        "Le workflow ne publie pas lui-mÃŠme son avis",
+        "ne dÃĐclenche aucun dispatch",
+        "| `0284-r9` |",
+        "Ne pas utiliser `--delete`",
+    ):
+        assert marker in text
+
+    assert len(text.splitlines()) < 380
