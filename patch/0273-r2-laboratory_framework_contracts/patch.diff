+            self,
+            "requested_specialist_refs",
+            _normalize_refs(
+                "requested_specialist_refs",
+                self.requested_specialist_refs,
+                allow_empty=True,
+                required_prefixes=_SPECIALIST_PREFIXES,
+            ),
+        )
+        object.__setattr__(
+            self,
+            "requested_laboratory_refs",
+            _normalize_refs(
+                "requested_laboratory_refs",
