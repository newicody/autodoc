@@ -0,0 +1,53 @@
+"""Pure controlled GitHub publication command and plan."""
+from __future__ import annotations
+from dataclasses import dataclass
+from collections.abc import Mapping
+from typing import Any
+import hashlib,json,re
+COMMAND_SCHEMA="missipy.github.controlled_publication_command.v1"; PLAN_SCHEMA="missipy.github.controlled_publication_plan.v1"; REVIEW_SCHEMA="missipy.github_project.publication_review.v1"
+_ALLOWED={"issue_comment","issue_body_update","issue_labels_replace"}; _REPO=re.compile(r"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$")
+class GitHubControlledPublicationError(ValueError): pass
+@dataclass(frozen=True,slots=True)
+class GitHubControlledPublicationCommand:
+ publication_ref:str; repository:str; issue_number:int; mutation_kind:str; target_ref:str; source_final_ref:str; source_sql_ref:str; source_review_ref:str; review_decision_id:str; policy_decision_id:str; expected_remote_revision:str
+ body:str=""; labels:tuple[str,...]=(); provenance_refs:tuple[str,...]=(); execute:bool=False; operator_confirmed:bool=False; remote_mutation_enabled:bool=False; schema:str=COMMAND_SCHEMA
+ def __post_init__(self):
+  if self.schema!=COMMAND_SCHEMA: raise GitHubControlledPublicationError("unsupported command schema")
+  for n in ("publication_ref","repository","target_ref","source_final_ref","source_sql_ref","source_review_ref","review_decision_id","policy_decision_id","expected_remote_revision"):
+   if not isinstance(getattr(self,n),str) or not getattr(self,n).strip(): raise GitHubControlledPublicationError(f"{n} is required")
+  if not _REPO.fullmatch(self.repository) or self.issue_number<=0: raise GitHubControlledPublicationError("repository or issue_number invalid")
+  expected_target=f"github:issue:{self.repository}#{self.issue_number}"
+  if self.target_ref!=expected_target: raise GitHubControlledPublicationError("target_ref must match repository and issue_number")
+  if not self.publication_ref.startswith("github-publication:"): raise GitHubControlledPublicationError("publication_ref must be typed")
+  if not self.source_final_ref.startswith("artifact-final:"): raise GitHubControlledPublicationError("source_final_ref must be typed")
+  if not self.source_sql_ref.startswith("sql:"): raise GitHubControlledPublicationError("source_sql_ref must be typed")
+  if not self.source_review_ref.startswith("github-review:"): raise GitHubControlledPublicationError("source_review_ref must be typed")
+  object.__setattr__(self,"labels",tuple(dict.fromkeys(str(x).strip() for x in self.labels if str(x).strip())))
+  object.__setattr__(self,"provenance_refs",tuple(dict.fromkeys(str(x).strip() for x in self.provenance_refs if str(x).strip())))
+  if self.mutation_kind not in _ALLOWED: raise GitHubControlledPublicationError("unsupported mutation_kind")
+  if self.mutation_kind in {"issue_comment","issue_body_update"} and not self.body.strip(): raise GitHubControlledPublicationError("body is required")
+  if self.mutation_kind=="issue_labels_replace" and not self.labels: raise GitHubControlledPublicationError("labels are required")
+  if self.execute and not (self.operator_confirmed and self.remote_mutation_enabled): raise GitHubControlledPublicationError("execute requires operator confirmation and remote enablement")
+ def to_mapping(self): return {"schema":self.schema,"publication_ref":self.publication_ref,"repository":self.repository,"issue_number":self.issue_number,"mutation_kind":self.mutation_kind,"target_ref":self.target_ref,"source_final_ref":self.source_final_ref,"source_sql_ref":self.source_sql_ref,"source_review_ref":self.source_review_ref,"review_decision_id":self.review_decision_id,"policy_decision_id":self.policy_decision_id,"expected_remote_revision":self.expected_remote_revision,"body":self.body,"labels":list(self.labels),"provenance_refs":list(self.provenance_refs),"execute":self.execute,"operator_confirmed":self.operator_confirmed,"remote_mutation_enabled":self.remote_mutation_enabled}
+@dataclass(frozen=True,slots=True)
+class GitHubControlledPublicationPlan:
+ command:GitHubControlledPublicationCommand; endpoint:str; method:str; payload:Mapping[str,Any]; publication_marker:str; remote_gate_payload:Mapping[str,Any]; schema:str=PLAN_SCHEMA
+ def to_mapping(self): return {"schema":self.schema,"command":self.command.to_mapping(),"endpoint":self.endpoint,"method":self.method,"payload":dict(self.payload),"publication_marker":self.publication_marker,"remote_gate_payload":dict(self.remote_gate_payload),"requires_collision_guard":True,"http_call_performed":False}
+def validate_approved_review(review,command):
+ issues=[]
+ if review.get("schema")!=REVIEW_SCHEMA: issues.append("review schema mismatch")
+ if review.get("status")!="approve": issues.append("review must be approved")
+ if review.get("review_ref")!=command.source_review_ref: issues.append("source_review_ref mismatch")
+ if review.get("sql_context_ref")!=command.source_sql_ref: issues.append("source_sql_ref mismatch")
+ return tuple(issues)
+def build_github_controlled_publication_plan(command,review):
+ issues=validate_approved_review(review,command)
+ if issues: raise GitHubControlledPublicationError("; ".join(issues))
+ marker="<!-- autodoc-publication:"+hashlib.sha256((command.publication_ref+"\0"+command.source_sql_ref).encode()).hexdigest()[:20]+" -->"
+ base=f"/repos/{command.repository}/issues/{command.issue_number}"
+ if command.mutation_kind=="issue_comment": method,endpoint,payload="POST",base+"/comments",{"body":command.body.rstrip()+"\n\n"+marker}
+ elif command.mutation_kind=="issue_body_update": method,endpoint,payload="PATCH",base,{"body":command.body.rstrip()+"\n\n"+marker}
+ else: method,endpoint,payload="PUT",base+"/labels",{"labels":list(command.labels)}
+ operation={"action":command.mutation_kind,"candidate_id":command.source_final_ref,"title":command.publication_ref,"labels":list(command.labels),"safety_flags":[],"endpoint":endpoint,"method":method}
+ gate={"schema":"missipy.source_candidate.github_projection_payload.v1","repository":command.repository,"project_key":None,"dry_run":True,"remote_mutation":False,"projection_allowed":True,"operations":[operation]}
+ return GitHubControlledPublicationPlan(command,endpoint,method,payload,marker,gate)
