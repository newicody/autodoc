@@ -0,0 +1,16 @@
+import pytest
+from context.github_controlled_publication_contract_0276 import *
+def command(**kw):
+ d=dict(publication_ref="github-publication:test",repository="newicody/autodoc",issue_number=42,mutation_kind="issue_comment",target_ref="github:issue:newicody/autodoc#42",source_final_ref="artifact-final:test",source_sql_ref="sql:specialist_output:test",source_review_ref="github-review:test",review_decision_id="decision:review:1",policy_decision_id="policy:1",expected_remote_revision="2026-07-11T00:00:00Z",body="Result") ; d.update(kw); return GitHubControlledPublicationCommand(**d)
+def review(status="approve"): return {"schema":"missipy.github_project.publication_review.v1","review_ref":"github-review:test","sql_context_ref":"sql:specialist_output:test","status":status}
+def test_plan_contains_marker_and_existing_gate_payload():
+ p=build_github_controlled_publication_plan(command(),review()); assert p.method=="POST" and p.publication_marker in p.payload["body"]
+ assert p.remote_gate_payload["dry_run"] is True and p.remote_gate_payload["remote_mutation"] is False
+def test_unapproved_review_blocks_plan():
+ with pytest.raises(GitHubControlledPublicationError): build_github_controlled_publication_plan(command(),review("pending"))
+def test_execute_needs_both_explicit_flags():
+ with pytest.raises(GitHubControlledPublicationError): command(execute=True)
+
+def test_list_labels_are_normalized_to_tuple():
+ c=command(mutation_kind="issue_labels_replace",body="",labels=["one","one","two"])
+ assert c.labels==("one","two")
