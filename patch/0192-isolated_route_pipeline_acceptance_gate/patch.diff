+digraph isolated_route_pipeline_acceptance_gate_0192 {
+  rankdir=LR;
+  label="0192 Isolated route pipeline acceptance gate";
+  labelloc=t;
+
+  audit [label="isolated_route_pipeline_artifact_audit.json"];
+  gate [label="acceptance gate"];
+  verdict [label="isolated_route_pipeline_acceptance.json"];
+  baseline [label="isolated-route-pipeline-write-read-v1"];
+
