+#!/usr/bin/env python3
+"""Check phase 0248 projection path readiness."""
+
+from __future__ import annotations
+
+import argparse
+import json
+import sys
+from pathlib import Path
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+SRC_ROOT = REPO_ROOT / "src"
+for _path in (str(SRC_ROOT), str(REPO_ROOT)):
+    if _path not in sys.path:
+        sys.path.insert(0, _path)
+
+from context.prod_server_projection_path_readiness_0248 import (  # noqa: E402
+    PROJECTION_PATH_READINESS_BOUNDARY,
+    build_projection_path_readiness,
+    projection_path_readiness_to_dict,
+    write_projection_path_readiness_report,
+)
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--server-config", default="doc/examples/autodoc_prod_server_initial_0241.ini")
+    parser.add_argument("--openvino-config", default="doc/examples/autodoc_openvino_embedding_e5_small_0246.ini")
+    parser.add_argument(
+        "--output",
+        default=".var/reports/prod_server_projection_path_readiness_0248.json",
+    )
+    parser.add_argument("--check-only", action="store_true")
+    parser.add_argument("--format", choices=("json", "summary"), default="json")
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+    server_config_path = Path(args.server_config)
+    openvino_config_path = Path(args.openvino_config)
+    output_path = Path(args.output)
+
+    if args.check_only:
+        report = build_projection_path_readiness(
+            server_config_path=server_config_path,
+            openvino_config_path=openvino_config_path,
+        )
+        payload = {
+            "production_server_projection_path_ready": report.ready,
+            "projection_path_readiness": projection_path_readiness_to_dict(report),
+            "boundary": dict(PROJECTION_PATH_READINESS_BOUNDARY),
+        }
+    else:
+        payload = write_projection_path_readiness_report(
+            server_config_path=server_config_path,
+            openvino_config_path=openvino_config_path,
+            output_path=output_path,
+        )
+        report = build_projection_path_readiness(
+            server_config_path=server_config_path,
+            openvino_config_path=openvino_config_path,
+        )
+
+    if args.format == "summary":
+        issue_count = len(report.issues)
+        if report.point_shape is None:
+            details = "collection=missing dimension=0 source=missing"
+        else:
+            details = (
+                f"source={report.point_shape.source_table} "
+                f"collection={report.point_shape.collection} "
