+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parents[2]
+
+
+def test_0235_commit_step_filters_var_runtime_artifacts() -> None:
+    source = (ROOT / "apply_patch_queue.py").read_text(encoding="utf-8")
+
+    assert 'file != ".var"' in source
+    assert 'file.startswith(".var/")' in source
+    assert 'run_git(("add", "--", *files)' in source
+
+
+def test_0235_manifest_does_not_list_var_runtime_report() -> None:
+    manifest = (
+        ROOT
+        / "doc/manifests/MANIFEST_0235_PATCH_QUEUE_IGNORED_RUNTIME_ARTIFACTS_GUARD_CHANGED_FILES.md"
+    ).read_text(encoding="utf-8")
+
+    assert ".var/reports" not in manifest
+
+
+def test_0235_rule_keeps_runtime_boundary() -> None:
+    rule = (ROOT / "doc/code-rules/0235_patch_queue_ignored_runtime_artifacts_guard_rule.md").read_text(encoding="utf-8")
+
+    assert "Scheduler execution" in rule
+    assert "SQL/Qdrant writes" in rule
+    assert "new EventBus" in rule
+    assert "VisPy runtime integration" in rule
