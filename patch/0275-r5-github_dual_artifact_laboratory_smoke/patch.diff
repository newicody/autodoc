+from context.github_dual_artifact_laboratory_smoke_0275 import *
+from context.source_candidate import SourceCandidateDecision
+from context.fake_laboratory_existing_scheduler_closed_loop_smoke_0274 import FakeLaboratoryClosedLoopSmokeCommand
+class Scheduler: pass
+def artifacts():
+ r=GitHubAuthoritativeRequestArtifact("f","r","github-request:x","newicody/autodoc",1,"T","B","https://x"); rb=canonical_json_bytes(r.to_mapping()); m=build_dual_artifact_manifest(r,rb); return rb,canonical_json_bytes(m.to_mapping())
+def test_smoke_requires_operator_promotion_and_keeps_preview_local():
+ rb,mb=artifacts(); cmd=GitHubDualArtifactLaboratorySmokeCommand(SourceCandidateDecision("promote","ok"),FakeLaboratoryClosedLoopSmokeCommand("sc:x"),"policy:1")
+ result=asyncio.run(run_github_dual_artifact_laboratory_smoke(Scheduler(),rb,mb,None,cmd))
+ assert result.valid and result.approved_candidate["status"]=="promoted"
+ assert result.publication_preview["status"]=="pending" and result.github_mutation_performed is False
