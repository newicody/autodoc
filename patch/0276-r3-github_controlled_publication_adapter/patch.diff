@@ -0,0 +1,18 @@
+from context.github_controlled_publication_adapter_0276 import *
+from context.github_controlled_publication_contract_0276 import *
+from context.source_candidate_remote_mutation_gate import SourceCandidateRemoteMutationGatePolicy
+class Transport:
+ def __init__(self): self.calls=[]
+ def request(self,m,p,*,headers,body=None): self.calls.append((m,p,headers,body)); return GitHubHttpResponse(201,{},b'{"id":1,"body":"ok"}')
+def command(): return GitHubControlledPublicationCommand("github-publication:x","newicody/autodoc",1,"issue_comment","github:issue:newicody/autodoc#1","artifact-final:x","sql:specialist_output:x","github-review:x","decision:1","policy:1","rev:1","body",execute=True,operator_confirmed=True,remote_mutation_enabled=True)
+def review(): return {"schema":"missipy.github_project.publication_review.v1","status":"approve","review_ref":"github-review:x","sql_context_ref":"sql:specialist_output:x"}
+def policy(): return SourceCandidateRemoteMutationGatePolicy(True,True,("newicody/autodoc",))
+def test_apply_refuses_without_r4_guard():
+ t=Transport(); r=GitHubControlledPublicationAdapter().apply(command(),review(),policy(),transport=t,token="secret",guard_receipt={})
+ assert not r.applied and not t.calls and "collision_guard_missing" in r.blocked_reasons
+def test_clear_guard_calls_injected_transport_and_never_serializes_token():
+ t=Transport(); guard={"schema":"missipy.github.publication_collision_guard.v1","status":"clear"}; r=GitHubControlledPublicationAdapter().apply(command(),review(),policy(),transport=t,token="secret",guard_receipt=guard)
+ assert r.applied and len(t.calls)==1 and "secret" not in str(r.to_mapping())
+def test_replay_guard_performs_no_http():
+ t=Transport(); guard={"schema":"missipy.github.publication_collision_guard.v1","status":"idempotent_replay"}; r=GitHubControlledPublicationAdapter().apply(command(),review(),policy(),transport=t,token="secret",guard_receipt=guard)
+ assert r.idempotent_replay and not t.calls
