@@ -0,0 +1,53 @@
+"""Narrow injected GitHub REST transport membrane; apply needs r4 guard."""
+from __future__ import annotations
+from dataclasses import dataclass,field
+from collections.abc import Mapping
+from typing import Any,Protocol
+import json,urllib.request,urllib.error
+from context.github_controlled_publication_contract_0276 import GitHubControlledPublicationCommand,GitHubControlledPublicationPlan,build_github_controlled_publication_plan
+from context.source_candidate_remote_mutation_gate import SourceCandidateRemoteMutationGatePolicy,run_source_candidate_remote_mutation_gate
+
+@dataclass(frozen=True,slots=True)
+class GitHubHttpResponse:
+ status:int; headers:Mapping[str,str]=field(default_factory=dict); body:bytes=b""
+ def json_mapping(self):
+  if not self.body: return {}
+  p=json.loads(self.body); return p if isinstance(p,dict) else {"value":p}
+class GitHubHttpTransport(Protocol):
+ def request(self,method:str,path:str,*,headers:Mapping[str,str],body:bytes|None=None)->GitHubHttpResponse: ...
+@dataclass(frozen=True,slots=True)
+class UrllibGitHubTransport:
+ base_url:str="https://api.github.com"; timeout:float=30.0
+ def request(self,method,path,*,headers,body=None):
+  req=urllib.request.Request(self.base_url.rstrip("/")+path,data=body,headers=dict(headers),method=method)
+  try:
+   with urllib.request.urlopen(req,timeout=self.timeout) as r: return GitHubHttpResponse(r.status,dict(r.headers.items()),r.read())
+  except urllib.error.HTTPError as e: return GitHubHttpResponse(e.code,dict(e.headers.items()) if e.headers else {},e.read())
+@dataclass(frozen=True,slots=True)
+class GitHubControlledPublicationDryRun:
+ plan:GitHubControlledPublicationPlan; gate:Mapping[str,Any]
+ def to_mapping(self): return {"schema":"missipy.github.controlled_publication_dry_run.v1","plan":self.plan.to_mapping(),"gate":dict(self.gate),"http_call_performed":False}
+@dataclass(frozen=True,slots=True)
+class GitHubControlledPublicationApplyResult:
+ applied:bool; idempotent_replay:bool; status:str; http_status:int|None; response:Mapping[str,Any]=field(default_factory=dict); blocked_reasons:tuple[str,...]=(); token_serialized:bool=False
+ def to_mapping(self): return {"schema":"missipy.github.controlled_publication_apply.v1","applied":self.applied,"idempotent_replay":self.idempotent_replay,"status":self.status,"http_status":self.http_status,"response":dict(self.response),"blocked_reasons":list(self.blocked_reasons),"token_serialized":False}
+class GitHubControlledPublicationAdapter:
+ def plan(self,command,review): return build_github_controlled_publication_plan(command,review)
+ def dry_run(self,command,review,policy):
+  plan=self.plan(command,review); gate=run_source_candidate_remote_mutation_gate(plan.remote_gate_payload,policy); return GitHubControlledPublicationDryRun(plan,gate.to_json_dict())
+ def apply(self,command,review,policy,*,transport,token,guard_receipt):
+  dry=self.dry_run(command,review,policy); reasons=[]
+  if not command.execute: reasons.append("execute_false")
+  if not dry.gate.get("mutation_allowed"): reasons.extend(x.get("code","") for x in dry.gate.get("issues",[]))
+  if guard_receipt.get("schema")!="missipy.github.publication_collision_guard.v1": reasons.append("collision_guard_missing")
+  guard_status=guard_receipt.get("status")
+  if guard_status=="idempotent_replay": return GitHubControlledPublicationApplyResult(False,True,"idempotent_replay",None)
+  if guard_status!="clear": reasons.append("collision_guard_not_clear")
+  if not token.strip(): reasons.append("token_missing")
+  if reasons: return GitHubControlledPublicationApplyResult(False,False,"blocked",None,blocked_reasons=tuple(dict.fromkeys(reasons)))
+  headers={"Authorization":"Bearer "+token,"Accept":"application/vnd.github+json","X-GitHub-Api-Version":"2022-11-28","User-Agent":"autodoc-controlled-publication/0276"}
+  body=(json.dumps(dict(dry.plan.payload),ensure_ascii=False,separators=(",",":"))+"\n").encode()
+  response=transport.request(dry.plan.method,dry.plan.endpoint,headers=headers,body=body)
+  safe={k:v for k,v in response.json_mapping().items() if k not in {"token","authorization"}}
+  ok=200<=response.status<300
+  return GitHubControlledPublicationApplyResult(ok,False,"applied" if ok else "remote_error",response.status,safe,() if ok else ("http_status",))
