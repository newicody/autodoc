+                vector_execute=True,
+            ),
+            store=store,
+            profile=passage_profile(),
+            embedder=embedder,
+            qdrant_executor=DemoQdrantProjectionExecutor(),
+        )
+        return handoff, store
+    finally:
+        await scheduler.shutdown()
+        await asyncio.wait_for(run_task, timeout=1.0)
