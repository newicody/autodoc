+name: autodoc-attachment-manifest
+
+on:
+  issues:
+    types:
+      - opened
+      - edited
+      - reopened
+  workflow_dispatch:
+
+permissions:
+  contents: read
+  issues: read
+  actions: read
+
+jobs:
+  build-autodoc-attachment-manifest:
+    runs-on: ubuntu-latest
+
+    steps:
+      - name: Checkout external idea repository
+        uses: actions/checkout@v4
+
+      - name: Build Autodoc attachment manifest
+        run: |
+          python scripts/build_autodoc_issue_attachment_manifest.py \
+            --event-path "$GITHUB_EVENT_PATH" \
+            --output-dir out/autodoc-artifacts
+
+      - name: Upload attachment manifest artifact
+        uses: actions/upload-artifact@v4
+        with:
+          name: autodoc-attachment-manifest-${{ github.run_id }}
+          path: out/autodoc-artifacts/attachment_manifest.json
diff --git a/tools/build_github_idea_repo_attachment_bootstrap_bundle.py b/tools/build_github_idea_repo_attachment_bootstrap_bundle.py
